    // Step 5: Instalando
    public class InstallingStep : InstallStep
    {
        public InstallingStep(MainWindow window) : base(window) { }

        public override void LoadContent(System.Windows.Controls.Panel container)
        {
            var stackPanel = new StackPanel
            {
                VerticalAlignment = VerticalAlignment.Center,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                MaxWidth = 600,
                ClipToBounds = false
            };
            
            var title = CreateGradientTitle("Instalando Voltris Optimizer", "Voltris Optimizer");
            stackPanel.Children.Add(title);
            
            var statusText = new TextBlock
            {
                Text = "Preparando instalação...",
                Foreground = (SolidColorBrush)System.Windows.Application.Current.Resources["TextSecondaryBrush"],
                FontFamily = new WinMedia.FontFamily("Segoe UI"),
                FontSize = 14,
                TextAlignment = TextAlignment.Center,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                TextWrapping = TextWrapping.Wrap,
                TextTrimming = TextTrimming.None,
                Margin = new Thickness(0, 16, 0, 16),
                ClipToBounds = false
            };
            stackPanel.Children.Add(statusText);
            
            Window.ProgressBarControl.Visibility = Visibility.Visible;
            Window.ProgressBarControl.Value = 0;
            
            container.Children.Add(stackPanel);
            
            // Iniciar instalação em background
            _ = InstallAsync(statusText);
        }

        private async Task InstallAsync(TextBlock statusText)
        {
            try
            {
                await Task.Delay(500);
                
                statusText.Text = "Criando diretórios...";
                Window.ProgressBarControl.Value = 10;
                await Task.Delay(300);
                
                try
                {
                    Directory.CreateDirectory(Window.InstallPath);
                }
                catch (UnauthorizedAccessException)
                {
                    var appDataPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "Voltris Optimizer");
                    Window.InstallPath = appDataPath;
                    Directory.CreateDirectory(Window.InstallPath);
                }
                Directory.CreateDirectory(Path.Combine(Window.InstallPath, "Images"));
                
                statusText.Text = "Copiando arquivos...";
                Window.ProgressBarControl.Value = 30;
                await Task.Delay(300);
                
                var sourcePath = Window.SourcePath;
                var expectedExe = Path.Combine(sourcePath, "VoltrisOptimizer.exe");
                
                if (HasEmbeddedZip("x64"))
                {
                    await ExtractEmbeddedZipTo("x64", Window.InstallPath);
                }
                else if (HasEmbeddedZip("x86"))
                {
                    await ExtractEmbeddedZipTo("x86", Window.InstallPath);
                }
                else if (Directory.Exists(sourcePath) && File.Exists(expectedExe))
                {
                    CopyDirectory(sourcePath, Window.InstallPath);
                }
                
                Window.ProgressBarControl.Value = 60;
                await Task.Delay(300);
                
                statusText.Text = "Instalando desinstalador...";
                Window.ProgressBarControl.Value = 55;
                await CopyUninstallerAsync();
                
                statusText.Text = "Registrando no Painel de Controle...";
                Window.ProgressBarControl.Value = 65;
                await RegisterUninstallerInARPAsync();
                
                Window.ProgressBarControl.Value = 70;
                await Task.Delay(300);
                
                statusText.Text = "Criando atalhos...";
                await CreateShortcuts();
                
                Window.ProgressBarControl.Value = 80;
                await Task.Delay(300);
                
                statusText.Text = "Configurando registro...";
                await ConfigureRegistry();
                
                Window.ProgressBarControl.Value = 100;
                statusText.Text = "Instalação concluída!";
                
                await Task.Delay(500);
                Window.LoadStep(5); // Ir para tela de conclusão
            }
            catch (Exception ex)
            {
                try { RollbackInstall(); } catch { }
                System.Windows.MessageBox.Show($"Erro durante a instalação:\n{ex.Message}", "Erro", System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Error);
            }
        }

        private void CopyDirectory(string sourceDir, string destDir)
        {
            foreach (var dir in Directory.GetDirectories(sourceDir, "*", SearchOption.AllDirectories))
            {
                var targetSubDir = dir.Replace(sourceDir, destDir);
                Directory.CreateDirectory(targetSubDir);
            }
            foreach (var file in Directory.GetFiles(sourceDir, "*", SearchOption.AllDirectories))
            {
                var targetFile = file.Replace(sourceDir, destDir);
                try
                {
                    Directory.CreateDirectory(Path.GetDirectoryName(targetFile) ?? destDir);
                    File.Copy(file, targetFile, true);
                }
                catch
                {
                }
            }
        }

        /// <summary>
        /// Copia o desinstalador (uninstall.exe) para o diretório de instalação.
        /// Suporta dois métodos: recurso embutido OU arquivo de build.
        /// </summary>
        private async Task CopyUninstallerAsync()
        {
            await Task.Run(() =>
            {
                try
                {
                    var uninstallerDestPath = Path.Combine(Window.InstallPath, "uninstall.exe");
                    
                    // MÉTODO 1: Tentar extrair de recurso embutido (mais profissional)
                    if (TryExtractEmbeddedUninstaller(uninstallerDestPath))
                    {
                        System.Diagnostics.Debug.WriteLine($"Desinstalador extraído de recurso embutido: {uninstallerDestPath}");
                        return;
                    }
                    
                    // MÉTODO 2: Tentar copiar de pasta de build do projeto Uninstaller
                    if (TryCopyUninstallerFromBuild(uninstallerDestPath))
                    {
                        System.Diagnostics.Debug.WriteLine($"Desinstalador copiado de pasta de build: {uninstallerDestPath}");
                        return;
                    }
                    
                    // Se nenhum método funcionou, lançar exceção
                    throw new FileNotFoundException(
                        "Não foi possível encontrar o desinstalador (uninstall.exe).\n\n" +
                        "Certifique-se de que:\n" +
                        "1. O projeto VoltrisUninstaller foi compilado antes\n" +
                        "2. O arquivo existe em: ..\\VoltrisUninstaller\\bin\\Release\\net8.0-windows\\win-x86\\publish\\uninstall.exe\n" +
                        "3. Ou o uninstall.exe está embutido como recurso no instalador");
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"ERRO CRÍTICO ao copiar desinstalador: {ex.Message}");
                    throw;
                }
            });
        }

        /// <summary>
        /// Tenta extrair o uninstall.exe de um recurso embutido no assembly.
        /// </summary>
        private bool TryExtractEmbeddedUninstaller(string destPath)
        {
            try
            {
                var ns = typeof(MainWindow).Namespace ?? "VoltrisOptimizerInstaller";
                var resourceName = $"{ns}.Resources.uninstall.exe";
                
                using var stream = Assembly.GetExecutingAssembly().GetManifestResourceStream(resourceName);
                if (stream == null)
                {
                    // Tentar nome alternativo
                    resourceName = $"{ns}.Uninstaller.uninstall.exe";
                    var altStream = Assembly.GetExecutingAssembly().GetManifestResourceStream(resourceName);
                    if (altStream == null)
                    {
                        return false;
                    }
                    using (altStream)
                    {
                        // Garantir que o diretório existe
                        var destDir = Path.GetDirectoryName(destPath);
                        if (!string.IsNullOrEmpty(destDir) && !Directory.Exists(destDir))
                        {
                            Directory.CreateDirectory(destDir);
                        }
                        
                        // Extrair arquivo
                        using var fileStream = new FileStream(destPath, FileMode.Create, FileAccess.Write, FileShare.None);
                        altStream.CopyTo(fileStream);
                    }
                }
                else
                {
                    // Garantir que o diretório existe
                    var destDir = Path.GetDirectoryName(destPath);
                    if (!string.IsNullOrEmpty(destDir) && !Directory.Exists(destDir))
                    {
                        Directory.CreateDirectory(destDir);
                    }
                    
                    // Extrair arquivo
                    using var fileStream = new FileStream(destPath, FileMode.Create, FileAccess.Write, FileShare.None);
                    stream.CopyTo(fileStream);
                }
                
                // Verificar se o arquivo foi criado corretamente
                if (!File.Exists(destPath))
                {
                    return false;
                }
                
                var fileInfo = new FileInfo(destPath);
                if (fileInfo.Length == 0)
                {
                    File.Delete(destPath);
                    return false;
                }
                
                // Garantir que não está somente leitura
                File.SetAttributes(destPath, FileAttributes.Normal);
                
                System.Diagnostics.Debug.WriteLine($"Desinstalador extraído de recurso: {resourceName}, Tamanho: {fileInfo.Length} bytes");
                return true;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Erro ao extrair desinstalador de recurso: {ex.Message}");
                return false;
            }
        }

        /// <summary>
        /// Tenta copiar o uninstall.exe da pasta de build do projeto VoltrisUninstaller.
        /// </summary>
        private bool TryCopyUninstallerFromBuild(string destPath)
        {
            try
            {
                // Caminhos possíveis para o uninstall.exe
                var possiblePaths = new List<string>();
                
                // 1. Caminho relativo ao instalador (projeto irmão)
                var installerDir = Path.GetDirectoryName(Assembly.GetExecutingAssembly().Location);
                if (!string.IsNullOrEmpty(installerDir))
                {
                    var projectRoot = Path.GetDirectoryName(Path.GetDirectoryName(installerDir));
                    if (!string.IsNullOrEmpty(projectRoot))
                    {
                        possiblePaths.Add(Path.Combine(projectRoot, "VoltrisUninstaller", "bin", "Release", "net8.0-windows", "win-x86", "publish", "uninstall.exe"));
                        possiblePaths.Add(Path.Combine(projectRoot, "VoltrisUninstaller", "bin", "Release", "net8.0-windows", "win-x86", "uninstall.exe"));
                        possiblePaths.Add(Path.Combine(projectRoot, "VoltrisUninstaller", "bin", "x86", "Release", "uninstall.exe"));
                    }
                }
                
                // 2. Caminho relativo ao diretório de trabalho atual
                var currentDir = Environment.CurrentDirectory;
                possiblePaths.Add(Path.Combine(currentDir, "..", "VoltrisUninstaller", "bin", "Release", "net8.0-windows", "win-x86", "publish", "uninstall.exe"));
                possiblePaths.Add(Path.Combine(currentDir, "..", "..", "VoltrisUninstaller", "bin", "Release", "net8.0-windows", "win-x86", "publish", "uninstall.exe"));
                
                // 3. Caminho absoluto comum
                var programFiles = Environment.GetFolderPath(Environment.SpecialFolder.ProgramFilesX86);
                if (!string.IsNullOrEmpty(programFiles))
                {
                    possiblePaths.Add(Path.Combine(programFiles, "Voltris Corporation", "VoltrisOptimizer", "uninstall.exe"));
                }
                
                // Procurar o arquivo
                foreach (var sourcePath in possiblePaths)
                {
                    try
                    {
                        var normalizedPath = Path.GetFullPath(sourcePath);
                        if (File.Exists(normalizedPath))
                        {
                            var destDir = Path.GetDirectoryName(destPath);
                            if (!string.IsNullOrEmpty(destDir) && !Directory.Exists(destDir))
                            {
                                Directory.CreateDirectory(destDir);
                            }
                            
                            // Copiar arquivo
                            File.Copy(normalizedPath, destPath, true);
                            
                            // Verificar se foi copiado corretamente
                            if (File.Exists(destPath))
                            {
                                var fileInfo = new FileInfo(destPath);
                                if (fileInfo.Length > 0)
                                {
                                    File.SetAttributes(destPath, FileAttributes.Normal);
                                    System.Diagnostics.Debug.WriteLine($"Desinstalador copiado de: {normalizedPath}, Tamanho: {fileInfo.Length} bytes");
                                    return true;
                                }
                            }
                        }
                    }
                    catch
                    {
                        // Continuar tentando outros caminhos
                        continue;
                    }
                }
                
                return false;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Erro ao copiar desinstalador de build: {ex.Message}");
                return false;
            }
        }

        /// <summary>
        /// Registra o desinstalador no Add/Remove Programs (ARP) do Windows.
        /// </summary>
        private async Task RegisterUninstallerInARPAsync()
        {
            await Task.Run(() =>
            {
                try
                {
                    var uninstallerPath = Path.Combine(Window.InstallPath, "uninstall.exe");
                    
                    // Verificar se o desinstalador existe
                    if (!File.Exists(uninstallerPath))
                    {
                        throw new FileNotFoundException($"Desinstalador não encontrado: {uninstallerPath}");
                    }
                    
                    // Obter informações da versão do aplicativo principal
                    var mainExePath = Path.Combine(Window.InstallPath, "VoltrisOptimizer.exe");
                    var mainDllPath = Path.Combine(Window.InstallPath, "VoltrisOptimizer.dll");
                    
                    string displayVersion = "";
                    try
                    {
                        if (File.Exists(mainDllPath))
                        {
                            var an = AssemblyName.GetAssemblyName(mainDllPath);
                            displayVersion = an.Version?.ToString() ?? "";
                        }
                        else if (File.Exists(mainExePath))
                        {
                            var fvi = FileVersionInfo.GetVersionInfo(mainExePath);
                            displayVersion = fvi.ProductVersion ?? fvi.FileVersion ?? "";
                        }
                    }
                    catch
                    {
                        displayVersion = "1.0.0.0";
                    }
                    
                    // Obter ícone
                    var iconPath = Path.Combine(Window.InstallPath, "Images", "voltris.ico");
                    var faviconPath = Path.Combine(Window.InstallPath, "Images", "favicon.ico");
                    string displayIcon = mainExePath;
                    if (File.Exists(iconPath))
                        displayIcon = iconPath;
                    else if (File.Exists(faviconPath))
                        displayIcon = faviconPath;
                    
                    // Calcular tamanho estimado
                    long sizeBytes = 0;
                    try
                    {
                        if (Directory.Exists(Window.InstallPath))
                        {
                            sizeBytes = Directory.GetFiles(Window.InstallPath, "*", SearchOption.AllDirectories)
                                .Sum(f => new FileInfo(f).Length);
                        }
                    }
                    catch { }
                    var estimatedKb = (int)Math.Max(1, sizeBytes / 1024);
                    
                    // Criar UninstallString com caminho completo entre aspas
                    var uninstallString = $"\"{uninstallerPath}\"";
                    var quietUninstallString = $"\"{uninstallerPath}\" /SILENT";
                    
                    // Registrar no ARP (Add/Remove Programs)
                    // Usar a view correta baseada na arquitetura do processo (x64 -> Registry64, x86 -> Registry32)
                    var view = Environment.Is64BitProcess ? RegistryView.Registry64 : RegistryView.Registry32;
                    using var baseKey = RegistryKey.OpenBaseKey(RegistryHive.LocalMachine, view);
                    using var key = baseKey.CreateSubKey(@"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\VoltrisOptimizer");
                    
                    if (key == null)
                    {
                        throw new InvalidOperationException("Falha ao criar chave de registro para desinstalação");
                    }
                    
                    // Definir valores obrigatórios
                    key.SetValue("DisplayName", "Voltris Optimizer", RegistryValueKind.String);
                    key.SetValue("Publisher", "Voltris Corporation", RegistryValueKind.String);
                    key.SetValue("InstallLocation", Window.InstallPath, RegistryValueKind.String);
                    key.SetValue("UninstallString", uninstallString, RegistryValueKind.String);
                    key.SetValue("QuietUninstallString", quietUninstallString, RegistryValueKind.String);
                    key.SetValue("DisplayIcon", displayIcon, RegistryValueKind.String);
                    key.SetValue("EstimatedSize", estimatedKb, RegistryValueKind.DWord);
                    key.SetValue("NoModify", 1, RegistryValueKind.DWord);
                    key.SetValue("NoRepair", 1, RegistryValueKind.DWord);
                    
                    // Valores opcionais mas recomendados
                    if (!string.IsNullOrWhiteSpace(displayVersion))
                    {
                        key.SetValue("DisplayVersion", displayVersion, RegistryValueKind.String);
                    }
                    
                    var installDate = DateTime.Now.ToString("yyyyMMdd");
                    key.SetValue("InstallDate", installDate, RegistryValueKind.String);
                    
                    // Verificar se o registro foi criado corretamente
                    var verifyUninstallString = key.GetValue("UninstallString") as string;
                    if (string.IsNullOrEmpty(verifyUninstallString) || !verifyUninstallString.Equals(uninstallString, StringComparison.OrdinalIgnoreCase))
                    {
                        throw new InvalidOperationException("Falha ao verificar registro de desinstalação");
                    }
                    
                    System.Diagnostics.Debug.WriteLine($"Desinstalador registrado no ARP:");
                    System.Diagnostics.Debug.WriteLine($"  DisplayName: Voltris Optimizer");
                    System.Diagnostics.Debug.WriteLine($"  UninstallString: {uninstallString}");
                    System.Diagnostics.Debug.WriteLine($"  InstallLocation: {Window.InstallPath}");
                    System.Diagnostics.Debug.WriteLine($"  DisplayVersion: {displayVersion}");
                }
                catch (UnauthorizedAccessException ex)
                {
                    var errorMsg = "Falha ao registrar desinstalador: Permissões insuficientes.\n\n" +
                                  "O instalador precisa ser executado como Administrador.";
                    System.Diagnostics.Debug.WriteLine($"ERRO: {errorMsg}");
                    throw new UnauthorizedAccessException(errorMsg, ex);
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"ERRO ao registrar desinstalador no ARP: {ex.Message}");
                    throw;
                }
            });
        }

        private void RollbackInstall()
        {
            try
            {
                try
                {
                    using var baseKey = RegistryKey.OpenBaseKey(RegistryHive.LocalMachine, RegistryView.Registry32);
                    baseKey.DeleteSubKeyTree(@"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\VoltrisOptimizer", false);
                }
                catch { }
                try
                {
                    var desktop = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.Desktop), "Voltris Optimizer.lnk");
                    var startMenu = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.StartMenu), "Programs", "Voltris Optimizer.lnk");
                    if (File.Exists(desktop)) File.Delete(desktop);
                    if (File.Exists(startMenu)) File.Delete(startMenu);
                }
                catch { }
                try
                {
                    // Remover desinstalador também
                    var uninstallerPath = Path.Combine(Window.InstallPath, "uninstall.exe");
                    if (File.Exists(uninstallerPath))
                    {
                        File.Delete(uninstallerPath);
                    }
                }
                catch { }
                try
                {
                    if (Directory.Exists(Window.InstallPath)) Directory.Delete(Window.InstallPath, true);
                }
                catch { }
            }
            catch { }
        }

        private bool HasEmbeddedZip(string arch)
        {
            var ns = typeof(MainWindow).Namespace ?? "VoltrisOptimizerInstaller";
            var resourceName = $"{ns}.Payload.{arch}.zip";
            return Assembly.GetExecutingAssembly().GetManifestResourceNames().Any(n => string.Equals(n, resourceName, StringComparison.OrdinalIgnoreCase));
        }

        private async Task ExtractEmbeddedZipTo(string arch, string destDir)
        {
            await Task.Run(() =>
            {
                try
                {
                    var ns = typeof(MainWindow).Namespace ?? "VoltrisOptimizerInstaller";
                    var resourceName = $"{ns}.Payload.{arch}.zip";
                    System.Diagnostics.Debug.WriteLine($"Extracting embedded resource: {resourceName} to {destDir}");
                    
                    using var stream = Assembly.GetExecutingAssembly().GetManifestResourceStream(resourceName);
                    if (stream == null)
                    {
                        System.Diagnostics.Debug.WriteLine($"Embedded resource not found: {resourceName}");
                        var availableResources = Assembly.GetExecutingAssembly().GetManifestResourceNames();
                        System.Diagnostics.Debug.WriteLine($"Available resources: {string.Join(", ", availableResources)}");
                        throw new FileNotFoundException($"Recurso incorporado não encontrado: {resourceName}");
                    }
                    
                    // Garantir que o diretório de destino exista
                    if (!Directory.Exists(destDir))
                    {
                        Directory.CreateDirectory(destDir);
                    }
                    
                    using var zip = new ZipArchive(stream);
                    System.Diagnostics.Debug.WriteLine($"ZIP entries count: {zip.Entries.Count}");
                    
                    foreach (var entry in zip.Entries)
                    {
                        try
                        {
                            var fullPath = Path.Combine(destDir, entry.FullName);
                            var directory = Path.GetDirectoryName(fullPath);
                            if (!string.IsNullOrEmpty(directory))
                            {
                                if (!Directory.Exists(directory))
                                {
                                    Directory.CreateDirectory(directory);
                                }
                            }
                            
                            if (string.IsNullOrEmpty(entry.Name))
                                continue; // diretório
                                
                            System.Diagnostics.Debug.WriteLine($"Extracting entry: {entry.FullName} to {fullPath}");
                            
                            using var entryStream = entry.Open();
                            using var fileStream = new FileStream(fullPath, FileMode.Create, FileAccess.Write, FileShare.None);
                            entryStream.CopyTo(fileStream);
                            
                            // Definir data de modificação
                            if (entry.LastWriteTime.DateTime != DateTime.MinValue)
                            {
                                File.SetLastWriteTime(fullPath, entry.LastWriteTime.DateTime);
                            }
                        }
                        catch (Exception entryEx)
                        {
                            System.Diagnostics.Debug.WriteLine($"Error extracting entry {entry.FullName}: {entryEx.Message}");
                        }
                    }
                    
                    System.Diagnostics.Debug.WriteLine($"Extraction completed to {destDir}");
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"Error in ExtractEmbeddedZipTo: {ex.Message}");
                    throw;
                }
            });
        }

        private async Task CreateShortcuts()
        {
            await Task.Run(() =>
            {
                var exePath = Path.Combine(Window.InstallPath, "VoltrisOptimizer.exe");
                
                if (Window.CreateDesktopShortcut)
                {
                    CreateShortcut(Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.Desktop), "Voltris Optimizer.lnk"), exePath);
                    System.Diagnostics.Debug.WriteLine("Desktop shortcut created");
                }
                
                // Criar atalho no Menu Iniciar apenas se a opção estiver marcada
                if (Window.CreateStartMenuShortcut)
                {
                    // Criar atalho no Menu Iniciar do usuário atual (Windows 10 e 11)
                    var startMenuUserPath = Path.Combine(
                        Environment.GetFolderPath(Environment.SpecialFolder.StartMenu), 
                        "Programs", 
                        "Voltris Corporation", 
                        "Voltris Optimizer.lnk");
                    CreateShortcut(startMenuUserPath, exePath);
                    System.Diagnostics.Debug.WriteLine($"Start Menu shortcut created (user): {startMenuUserPath}");
                    
                    // Tentar criar também para todos os usuários se tiver privilégios de admin
                    if (IsAdministrator())
                    {
                        try
                        {
                            var commonStartMenu = Environment.GetFolderPath(Environment.SpecialFolder.CommonStartMenu);
                            if (!string.IsNullOrEmpty(commonStartMenu))
                            {
                                var startMenuAllUsersPath = Path.Combine(
                                    commonStartMenu, 
                                    "Programs", 
                                    "Voltris Corporation", 
                                    "Voltris Optimizer.lnk");
                                CreateShortcut(startMenuAllUsersPath, exePath);
                                System.Diagnostics.Debug.WriteLine($"Start Menu shortcut created (all users): {startMenuAllUsersPath}");
                            }
                        }
                        catch (Exception ex)
                        {
                            System.Diagnostics.Debug.WriteLine($"Não foi possível criar atalho para todos os usuários: {ex.Message}");
                        }
                    }
                }
                
                if (Window.CreateQuickAccessShortcut)
                {
                    try
                    {
                        PinToQuickAccess(exePath);
                        System.Diagnostics.Debug.WriteLine("Pinned to Quick Access");
                    }
                    catch (Exception ex)
                    {
                        System.Diagnostics.Debug.WriteLine($"Failed to pin to Quick Access: {ex.Message}");
                    }
                }
            });
        }

        private void PinToQuickAccess(string targetPath)
        {
            try
            {
                // Usar PowerShell para fixar no Acesso Rápido
                // O verbo "pintohome" é o padrão para fixar no Acesso Rápido no Windows 10/11
                var psScript = $@"
try {{
    $shell = New-Object -ComObject Shell.Application
    $folder = $shell.Namespace((Split-Path '{targetPath.Replace("'", "''")}'))
    $item = $folder.ParseName((Split-Path '{targetPath.Replace("'", "''")}' -Leaf))
    $item.InvokeVerb('pintohome')
    Write-Host 'Fixado no Acesso Rápido com sucesso'
}} catch {{
    Write-Host 'Erro ao fixar: ' + $_.Exception.Message
    exit 1
}}
";
                Process.Start(new ProcessStartInfo
                {
                    FileName = "powershell",
                    Arguments = $"-NoProfile -ExecutionPolicy Bypass -Command \"{psScript}\"",
                    UseShellExecute = false,
                    CreateNoWindow = true,
                    WindowStyle = ProcessWindowStyle.Hidden
                })?.WaitForExit(5000);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Erro ao fixar no Acesso Rápido: {ex.Message}");
            }
        }
        
        private bool IsAdministrator()
        {
            try
            {
                var identity = WindowsIdentity.GetCurrent();
                var principal = new WindowsPrincipal(identity);
                return principal.IsInRole(WindowsBuiltInRole.Administrator);
            }
            catch
            {
                return false;
            }
        }

        private void CreateShortcut(string shortcutPath, string targetPath)
        {
            try
            {
                // Criar diretório se não existir
                var dir = Path.GetDirectoryName(shortcutPath);
                if (!string.IsNullOrEmpty(dir) && !Directory.Exists(dir))
                {
                    Directory.CreateDirectory(dir);
                }
                
                // Caminho do ícone
                var iconPath = Path.Combine(Window.InstallPath, "Images", "voltris.png");
                var iconIcoPath = Path.Combine(Window.InstallPath, "Images", "voltris.ico");
                
                // Sempre criar/atualizar ICO a partir do PNG para garantir qualidade
                // Se PNG existir, converter para ICO com alta qualidade
                if (File.Exists(iconPath))
                {
                    try
                    {
                        // Sempre recriar o ICO a partir do PNG para garantir qualidade
                        ConvertPngToIcoDirect(iconPath, iconIcoPath);
                    }
                    catch (Exception ex)
                    {
                        System.Diagnostics.Debug.WriteLine($"Erro ao converter PNG para ICO: {ex.Message}");
                    }
                }
                
                // Usar ICO (sempre preferir ICO para compatibilidade)
                // Se ICO não existir, usar executável como fallback
                string iconLocation;
                if (File.Exists(iconIcoPath))
                {
                    iconLocation = iconIcoPath;
                }
                else if (File.Exists(iconPath))
                {
                    // Se não conseguir criar ICO, tentar PNG (pode não funcionar em todas as versões)
                    iconLocation = iconPath;
                }
                else if (File.Exists(Path.Combine(Window.InstallPath, "Images", "favicon.ico")))
                {
                    iconLocation = Path.Combine(Window.InstallPath, "Images", "favicon.ico");
                }
                else
                {
                    // Fallback para executável
                    iconLocation = targetPath;
                }
                
                // Usar PowerShell para criar atalho (compatível com .NET Core)
                // Garantir que o caminho do ícone está correto e usar formato completo
                // Especificar índice 0 para usar o maior tamanho do ICO (melhor qualidade)
                var iconLocationFull = Path.GetFullPath(iconLocation);
                var psScript = $@"
try {{
    $WshShell = New-Object -ComObject WScript.Shell
    $Shortcut = $WshShell.CreateShortcut('{shortcutPath.Replace("'", "''")}')
    $Shortcut.TargetPath = '{targetPath.Replace("'", "''")}'
    $Shortcut.WorkingDirectory = '{Window.InstallPath.Replace("'", "''")}'
    $iconPath = '{iconLocationFull.Replace("'", "''")}'
    if (Test-Path $iconPath) {{
        $Shortcut.IconLocation = $iconPath + ',0'
    }} else {{
        $Shortcut.IconLocation = '{targetPath.Replace("'", "''")},0'
    }}
    $Shortcut.Save()
    Write-Host 'Atalho criado com sucesso'
}} catch {{
    Write-Host 'Erro: ' + $_.Exception.Message
    exit 1
}}
";
                var process = Process.Start(new ProcessStartInfo
                {
                    FileName = "powershell",
                    Arguments = $"-NoProfile -ExecutionPolicy Bypass -Command \"{psScript}\"",
                    UseShellExecute = false,
                    CreateNoWindow = true,
                    WindowStyle = ProcessWindowStyle.Hidden,
                    RedirectStandardOutput = true,
                    RedirectStandardError = true
                });
                
                if (process != null)
                {
                    var output = process.StandardOutput.ReadToEnd();
                    var error = process.StandardError.ReadToEnd();
                    process.WaitForExit(10000);
                    
                    if (process.ExitCode != 0)
                    {
                        System.Diagnostics.Debug.WriteLine($"Erro ao criar atalho: {error}");
                    }
                    else
                    {
                        System.Diagnostics.Debug.WriteLine($"Atalho criado: {output}");
                    }
                }
            }
            catch (Exception ex)
            {
                // Log do erro mas continua
                System.Diagnostics.Debug.WriteLine($"Erro ao criar atalho: {ex.Message}");
            }
        }
        
        private void ConvertPngToIcoDirect(string pngPath, string icoPath)
        {
            try
            {
                using (var originalBitmap = new System.Drawing.Bitmap(pngPath))
                {
                    // Usar interpolação de alta qualidade para redimensionamento
                    // Ordem: maior primeiro (256x256) para melhor qualidade quando Windows escolher
                    var iconSizes = new[] { 256, 128, 64, 48, 32, 16 };
                    var iconData = new List<(System.Drawing.Bitmap bitmap, byte[] data)>();
                    
                    foreach (var size in iconSizes)
                    {
                        // Criar bitmap com alta qualidade
                        var resized = new System.Drawing.Bitmap(size, size);
                        using (var graphics = System.Drawing.Graphics.FromImage(resized))
                        {
                            // Configurar interpolação de alta qualidade
                            graphics.InterpolationMode = System.Drawing.Drawing2D.InterpolationMode.HighQualityBicubic;
                            graphics.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.HighQuality;
                            graphics.PixelOffsetMode = System.Drawing.Drawing2D.PixelOffsetMode.HighQuality;
                            graphics.CompositingQuality = System.Drawing.Drawing2D.CompositingQuality.HighQuality;
                            
                            // Desenhar imagem redimensionada
                            graphics.DrawImage(originalBitmap, 0, 0, size, size);
                        }
                        
                        // Converter bitmap para array de bytes no formato ICO
                        var iconBytes = BitmapToIconBytes(resized);
                        iconData.Add((resized, iconBytes));
                    }
                    
                    // Escrever arquivo ICO com múltiplos tamanhos
                    using (var fileStream = new FileStream(icoPath, FileMode.Create))
                    {
                        // Cabeçalho ICO
                        fileStream.WriteByte(0); // Reserved
                        fileStream.WriteByte(0); // Reserved
                        fileStream.WriteByte(1); // Type (1 = ICO)
                        fileStream.WriteByte(0); // Type
                        fileStream.WriteByte((byte)iconData.Count); // Number of images
                        fileStream.WriteByte(0);
                        
                        // Calcular offset inicial
                        int offset = 6 + (iconData.Count * 16); // Header + directory entries
                        
                        // Escrever entradas do diretório
                        foreach (var (bitmap, data) in iconData)
                        {
                            var width = bitmap.Width == 256 ? (byte)0 : (byte)bitmap.Width;
                            var height = bitmap.Height == 256 ? (byte)0 : (byte)bitmap.Height;
                            
                            fileStream.WriteByte(width);
                            fileStream.WriteByte(height);
                            fileStream.WriteByte(0); // Color palette
                            fileStream.WriteByte(0); // Reserved
                            fileStream.WriteByte(1); // Color planes
                            fileStream.WriteByte(0);
                            fileStream.WriteByte(32); // Bits per pixel
                            fileStream.WriteByte(0);
                            
                            var sizeBytes = BitConverter.GetBytes(data.Length);
                            fileStream.Write(sizeBytes, 0, 4);
                            
                            var offsetBytes = BitConverter.GetBytes(offset);
                            fileStream.Write(offsetBytes, 0, 4);
                            
                            offset += data.Length;
                        }
                        
                        // Escrever dados das imagens
                        foreach (var (bitmap, data) in iconData)
                        {
                            fileStream.Write(data, 0, data.Length);
                        }
                    }
                    
                    // Liberar recursos
                    foreach (var (bitmap, _) in iconData)
                    {
                        bitmap.Dispose();
                    }
                }
            }
            catch (Exception ex)
            {
                // Usar Debug.WriteLine em vez de Log para evitar problemas de contexto
                System.Diagnostics.Debug.WriteLine($"Erro ao converter PNG para ICO: {ex.Message}");
                throw;
            }
        }
        
        private byte[] BitmapToIconBytes(System.Drawing.Bitmap bitmap)
        {
            var rect = new System.Drawing.Rectangle(0, 0, bitmap.Width, bitmap.Height);
            var bitmapData = bitmap.LockBits(rect, System.Drawing.Imaging.ImageLockMode.ReadOnly, 
                System.Drawing.Imaging.PixelFormat.Format32bppArgb);
            
            try
            {
                var length = bitmapData.Stride * bitmapData.Height;
                var bytes = new byte[length];
                System.Runtime.InteropServices.Marshal.Copy(bitmapData.Scan0, bytes, 0, length);
                
                var result = new List<byte>();
                
                // BITMAPINFOHEADER (40 bytes)
                result.AddRange(BitConverter.GetBytes(40)); // biSize
                result.AddRange(BitConverter.GetBytes(bitmap.Width)); // biWidth
                result.AddRange(BitConverter.GetBytes(bitmap.Height * 2)); // biHeight (dobro para incluir máscara)
                result.AddRange(BitConverter.GetBytes((short)1)); // biPlanes
                result.AddRange(BitConverter.GetBytes((short)32)); // biBitCount
                result.AddRange(BitConverter.GetBytes(0)); // biCompression
                result.AddRange(BitConverter.GetBytes(length)); // biSizeImage
                result.AddRange(BitConverter.GetBytes(0)); // biXPelsPerMeter
                result.AddRange(BitConverter.GetBytes(0)); // biYPelsPerMeter
                result.AddRange(BitConverter.GetBytes(0)); // biClrUsed
                result.AddRange(BitConverter.GetBytes(0)); // biClrImportant
                
                // Dados do bitmap (inverter linhas - formato bottom-up)
                var rowSize = bitmap.Width * 4;
                for (int y = bitmap.Height - 1; y >= 0; y--)
                {
                    var offset = y * bitmapData.Stride;
                    result.AddRange(bytes.Skip(offset).Take(rowSize));
                }
                
                // Máscara (todos zeros para transparência)
                var maskSize = ((bitmap.Width + 31) / 32) * 4 * bitmap.Height;
                result.AddRange(new byte[maskSize]);
                
                return result.ToArray();
            }
            finally
            {
                bitmap.UnlockBits(bitmapData);
            }
        }
        
        private static class Win32
        {
            [System.Runtime.InteropServices.DllImport("user32.dll", CharSet = System.Runtime.InteropServices.CharSet.Auto)]
            public static extern bool DestroyIcon(IntPtr handle);
        }
        

        private async Task ConfigureRegistry()
        {
            await Task.Run(() =>
            {
                if (Window.StartWithWindows)
                {
                    try
                    {
                        // Configurar startup automático usando o padrão do Windows
                        // Chave Run - comando de inicialização
                        using (var runKey = Registry.CurrentUser.OpenSubKey(@"Software\Microsoft\Windows\CurrentVersion\Run", true))
                        {
                            if (runKey != null)
                            {
                                var exePath = Path.Combine(Window.InstallPath, "VoltrisOptimizer.exe");
                                var arguments = Window.StartMinimized ? "/minimized" : "";
                                var command = $"\"{exePath}\" {arguments}".Trim();
                                runKey.SetValue("Voltris Optimizer", command);
                                runKey.Flush();
                            }
                        }
                        
                        // Chave StartupApproved - habilitar o item (estado = 2 = enabled)
                        using (var approvedKey = Registry.CurrentUser.OpenSubKey(@"Software\Microsoft\Windows\CurrentVersion\Explorer\StartupApproved\Run", true))
                        {
                            if (approvedKey != null)
                            {
                                // Valor binário que indica estado "habilitado"
                                var enabledValue = new byte[] { 0x02, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 };
                                approvedKey.SetValue("Voltris Optimizer", enabledValue, RegistryValueKind.Binary);
                                approvedKey.Flush();
                            }
                        }
                        
                        Log("Startup automático configurado com sucesso");
                    }
                    catch (Exception ex)
                    {
                        Window.Log($"Erro ao configurar startup: {ex.Message}");
                    }
                }
                else
                {
                    Log("Startup automático desativado pelo usuário");
                }
            });
        }

        public override bool CanProceed() => false; // Não pode avançar durante instalação
        public override void OnNext() { }
        public override string GetNextButtonText() => "Instalando...";
    }

    // Step: Desinstalando
    // UninstallingStep removido - usar VoltrisUninstaller separado

    // Step 6: Concluído
    public class CompleteStep : InstallStep
    {
        public CompleteStep(MainWindow window) : base(window) { }

        public override void LoadContent(System.Windows.Controls.Panel container)
        {
            var stackPanel = new StackPanel
            {
                VerticalAlignment = VerticalAlignment.Center,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                MaxWidth = 600,
                ClipToBounds = false
            };
            
            var title = CreateGradientTitle("Instalação Concluída!");
            title.Margin = new Thickness(0, 0, 0, 16);
            stackPanel.Children.Add(title);
            
            var description = new TextBlock
            {
                Text = $"O Voltris Optimizer foi instalado com sucesso em:\n{Window.InstallPath}\n\n" +
                       "Clique em 'Fechar' para sair do instalador.",
                Style = (Style)System.Windows.Application.Current.Resources["DescriptionTextStyle"],
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                TextAlignment = TextAlignment.Center,
                TextWrapping = TextWrapping.Wrap,
                TextTrimming = TextTrimming.None,
                Margin = new Thickness(0, 0, 0, 0),
                Padding = new Thickness(0, 0, 0, 8),
                ClipToBounds = false
            };
            stackPanel.Children.Add(description);
            
            var launchCheck = new System.Windows.Controls.CheckBox
            {
                Content = "Executar Voltris Optimizer agora",
                Style = (Style)System.Windows.Application.Current.Resources["ModernCheckBoxStyle"],
                IsChecked = Window.LaunchAfterInstall,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                Margin = new Thickness(0, 24, 0, 0)
            };
            launchCheck.Checked += (s, e) => Window.LaunchAfterInstall = true;
            launchCheck.Unchecked += (s, e) => Window.LaunchAfterInstall = false;
            stackPanel.Children.Add(launchCheck);
            
            container.Children.Add(stackPanel);
        }

        public override bool CanProceed() => true;
        public override void OnNext()
        {
            // Verificar se deve executar o programa
            var checkBox = FindCheckBox(Window.ContentPanel);
            if (checkBox?.IsChecked == true)
            {
                try
                {
                    var exePath = Path.Combine(Window.InstallPath, "VoltrisOptimizer.exe");
                    if (File.Exists(exePath))
                    {
                        Process.Start(new ProcessStartInfo
                        {
                            FileName = exePath,
                            WorkingDirectory = Window.InstallPath,
                            UseShellExecute = true
                        });
                    }
                }
                catch { }
            }
        }

        private System.Windows.Controls.CheckBox? FindCheckBox(System.Windows.Controls.Panel panel)
        {
            foreach (var child in panel.Children)
            {
                if (child is System.Windows.Controls.CheckBox cb) return cb;
                if (child is System.Windows.Controls.Panel p)
                {
                    var found = FindCheckBox(p);
                    if (found != null) return found;
                }
            }
            return null;
        }

        public override string GetNextButtonText() => "Fechar";
    }
}
