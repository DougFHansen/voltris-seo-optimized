            checkBox.Unchecked += (s, e) => { };
            stackPanel.Children.Add(checkBox);
            
            container.Children.Add(stackPanel);
        }

        public override bool CanProceed()
        {
            // Verificar se o checkbox está marcado
            var checkBox = FindCheckBox(Window.ContentPanel);
            return checkBox?.IsChecked == true;
        }

        private System.Windows.Controls.CheckBox? FindCheckBox(System.Windows.Controls.Panel panel)
        {
            foreach (var child in panel.Children)
            {
                if (child is System.Windows.Controls.CheckBox cb) return cb;
                if (child is System.Windows.Controls.Panel p)
                {
                    var found = FindCheckBox(p);
                    if (found != null) return found;
                }
            }
            return null;
        }

        public override void OnNext() { }
    }

    // Step 3: Destino
    public class DestinationStep : InstallStep
    {
        public DestinationStep(MainWindow window) : base(window) { }

        public override void LoadContent(System.Windows.Controls.Panel container)
        {
            var stackPanel = new StackPanel
            {
                VerticalAlignment = VerticalAlignment.Center,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                MaxWidth = 600,
                ClipToBounds = false
            };
            
            var title = new TextBlock
            {
                Text = "Escolha o Local de Instalação",
                Style = (Style)System.Windows.Application.Current.Resources["TitleTextStyle"],
                TextAlignment = TextAlignment.Center,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center
            };
            stackPanel.Children.Add(title);
            
            var description = new TextBlock
            {
                Text = "Selecione a pasta onde o Voltris Optimizer será instalado.",
                Style = (Style)System.Windows.Application.Current.Resources["DescriptionTextStyle"],
                TextAlignment = TextAlignment.Center,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                TextWrapping = TextWrapping.Wrap,
                TextTrimming = TextTrimming.None,
                Margin = new Thickness(0, 16, 0, 16),
                ClipToBounds = false
            };
            stackPanel.Children.Add(description);
            
            var grid = new Grid();
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) });
            grid.ColumnDefinitions.Add(new ColumnDefinition { Width = GridLength.Auto });
            
            var textBox = new System.Windows.Controls.TextBox
            {
                Text = Window.InstallPath,
                Margin = new Thickness(0, 0, 12, 0),
                Padding = new Thickness(12, 8, 12, 8),
                Background = (SolidColorBrush)System.Windows.Application.Current.Resources["DarkPanelBrush"],
                Foreground = (SolidColorBrush)System.Windows.Application.Current.Resources["TextPrimaryBrush"],
                BorderBrush = (SolidColorBrush)System.Windows.Application.Current.Resources["DarkBorderBrush"],
                BorderThickness = new Thickness(1),
                FontFamily = new WinMedia.FontFamily("Segoe UI"),
                FontSize = 13
            };
            textBox.TextChanged += (s, e) => Window.InstallPath = textBox.Text;
            Grid.SetColumn(textBox, 0);
            grid.Children.Add(textBox);
            
            var browseButton = new System.Windows.Controls.Button
            {
                Content = "Procurar...",
                Style = (Style)System.Windows.Application.Current.Resources["SecondaryButtonStyle"],
                Padding = new Thickness(16, 8, 16, 8),
                MinWidth = 100,
                Margin = new Thickness(0, 0, 24, 0)
            };
            browseButton.Click += (s, e) =>
            {
                using (var dialog = new System.Windows.Forms.FolderBrowserDialog())
                {
                    var installDir = Path.GetDirectoryName(Window.InstallPath);
                    // Sempre usar ProgramFilesX86 para x86
                    var defaultBase = Environment.GetFolderPath(Environment.SpecialFolder.ProgramFilesX86);
                    if (string.IsNullOrEmpty(defaultBase))
                    {
                        defaultBase = @"C:\Program Files (x86)";
                    }
                    dialog.SelectedPath = !string.IsNullOrEmpty(installDir) ? installDir : defaultBase;
                    dialog.Description = "Selecione a pasta de instalação";
                    if (dialog.ShowDialog() == System.Windows.Forms.DialogResult.OK && !string.IsNullOrEmpty(dialog.SelectedPath))
                    {
                        textBox.Text = Path.Combine(dialog.SelectedPath, "Voltris Optimizer");
                        Window.InstallPath = textBox.Text;
                    }
                }
            };
            Grid.SetColumn(browseButton, 1);
            grid.Children.Add(browseButton);
            
            stackPanel.Children.Add(grid);
            
            // Espaço necessário
            var spaceInfo = new TextBlock
            {
                Text = $"Espaço necessário: ~160 MB\nEspaço disponível: {GetAvailableSpace(Window.InstallPath):N0} MB",
                Foreground = (SolidColorBrush)System.Windows.Application.Current.Resources["TextSecondaryBrush"],
                FontFamily = new WinMedia.FontFamily("Segoe UI"),
                FontSize = 12,
                TextWrapping = TextWrapping.Wrap,
                TextTrimming = TextTrimming.None,
                TextAlignment = TextAlignment.Center,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                Margin = new Thickness(0, 16, 0, 0),
                ClipToBounds = false
            };
            stackPanel.Children.Add(spaceInfo);
            
            container.Children.Add(stackPanel);
        }

        private long GetAvailableSpace(string path)
        {
            try
            {
                var root = Path.GetPathRoot(path);
                if (!string.IsNullOrEmpty(root))
                {
                    var drive = new DriveInfo(root);
                    return drive.AvailableFreeSpace / (1024 * 1024);
                }
            }
            catch
            {
            }
            return 0;
        }

        public override bool CanProceed() => !string.IsNullOrWhiteSpace(Window.InstallPath);
        public override void OnNext() { }
    }

