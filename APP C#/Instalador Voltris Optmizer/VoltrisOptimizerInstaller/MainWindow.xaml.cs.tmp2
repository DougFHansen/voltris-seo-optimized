namespace VoltrisOptimizerInstaller
{
    public partial class MainWindow : Window
    {
        private int _currentStep = 0;
        private readonly List<InstallStep> _steps = new List<InstallStep>();
        private string _installPath = @"";
        private bool _isSilent = false;
        private bool _createDesktopShortcut = true;
        private bool _createStartMenuShortcut = true;
        private bool _createQuickAccessShortcut = true;
        private bool _startWithWindows = true;  // STARTUP AUTOMÁTICO ATIVADO POR PADRÃO
        private bool _startMinimized = true;    // INICIAR MINIMIZADO POR PADRÃO
        private bool _launchAfterInstall = true;
        private string _sourcePath = "";
        private string _logFile = "";

        public MainWindow()
        {
                // Log inicial imediato para debug (antes de qualquer coisa)
                try
                {
                    var debugLog = Path.Combine(Path.GetTempPath(), "voltris_uninstall_debug.log");
                    var args = Environment.GetCommandLineArgs();
                    var exe = Assembly.GetExecutingAssembly().Location ?? Process.GetCurrentProcess().MainModule?.FileName ?? "UNKNOWN";
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] MainWindow START\n");
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Exe: {exe}\n");
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Args: {string.Join(" | ", args)}\n");
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] FileName: {Path.GetFileName(exe)}\n");
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Args[0]: {(args.Length > 0 ? args[0] : "EMPTY")}\n");
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Args[0] FileName: {(args.Length > 0 ? Path.GetFileName(args[0]) : "EMPTY")}\n");
                    
                    // DETECÇÃO IMEDIATA DE DESINSTALAÇÃO (ANTES DE InitializeComponent)
                    var hasUninstallArg = args.Any(a => string.Equals(a, "--uninstall", StringComparison.OrdinalIgnoreCase) || 
                                                     string.Equals(a, "/uninstall", StringComparison.OrdinalIgnoreCase));
                    var args0ContainsUninstall = args.Length > 0 && args[0].Contains("uninstall.exe", StringComparison.OrdinalIgnoreCase);
                    var args0FileNameIsUninstall = args.Length > 0 && string.Equals(Path.GetFileName(args[0]), "uninstall.exe", StringComparison.OrdinalIgnoreCase);
                    
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Has --uninstall arg: {hasUninstallArg}\n");
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Args[0] contains uninstall.exe: {args0ContainsUninstall}\n");
                    File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Args[0] filename is uninstall.exe: {args0FileNameIsUninstall}\n");
                    
                    // Verificar registry IMEDIATAMENTE (tentar múltiplas views)
                    string? installPath = null;
                    try
                    {
                        // Tentar Registry32 primeiro
                        using var baseKey32 = RegistryKey.OpenBaseKey(RegistryHive.LocalMachine, RegistryView.Registry32);
                        using var key32 = baseKey32.OpenSubKey(@"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\VoltrisOptimizer");
                        if (key32 != null)
                        {
                            installPath = key32.GetValue("InstallLocation") as string;
                            File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Registry32 InstallLocation: {installPath ?? "NULL"}\n");
                        }
                        else
                        {
                            File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Registry32 key not found\n");
                        }
                    }
                    catch (Exception ex)
                    {
                        File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Registry32 error: {ex.Message}\n");
                    }
                    
                    // Se não encontrou, tentar Registry64
                    if (string.IsNullOrEmpty(installPath))
                    {
                        try
                        {
                            using var baseKey64 = RegistryKey.OpenBaseKey(RegistryHive.LocalMachine, RegistryView.Registry64);
                            using var key64 = baseKey64.OpenSubKey(@"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\VoltrisOptimizer");
                            if (key64 != null)
                            {
                                installPath = key64.GetValue("InstallLocation") as string;
                                File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Registry64 InstallLocation: {installPath ?? "NULL"}\n");
                            }
                        }
                        catch (Exception ex)
                        {
                            File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Registry64 error: {ex.Message}\n");
                        }
                    }
                    
                    // Verificar arquivo de marcação
                    if (!string.IsNullOrEmpty(installPath) && Directory.Exists(installPath))
                    {
                        var markerFile = Path.Combine(installPath, ".uninstaller");
                        var markerExists = File.Exists(markerFile);
                        File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Marker file: {markerFile}, Exists: {markerExists}\n");
                        
                        if (markerExists || hasUninstallArg || args0ContainsUninstall || args0FileNameIsUninstall)
                        {
                            File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] ✓✓✓ UNINSTALL MODE DETECTED!\n");
                            File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] Reason: marker={markerExists}, arg={hasUninstallArg}, args0Contains={args0ContainsUninstall}, args0FileName={args0FileNameIsUninstall}\n");
                        }
                    }
                    else
                    {
                        // Mesmo sem registry, verificar se Args[0] é uninstall.exe
                        if (args0ContainsUninstall || args0FileNameIsUninstall || hasUninstallArg)
                        {
                            File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] ✓✓✓ UNINSTALL MODE DETECTED by Args[0]!\n");
                        }
                    }
                }
                catch (Exception ex)
                {
                    try
                    {
                        var debugLog = Path.Combine(Path.GetTempPath(), "voltris_uninstall_debug.log");
                        File.AppendAllText(debugLog, $"[{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff}] ERROR in debug log: {ex.Message}\n{ex.StackTrace}\n");
                    }
                    catch { }
                }
            
            try
            {
                InitializeComponent();
                
                // Aplicar cantos arredondados perfeitos (Windows 10/11)
                WindowRoundedCornersHelper.ApplyRoundedCorners(this, cornerRadius: 12);
                
                // Aplicar estilo do ScrollViewer após Loaded
                this.Loaded += (s, e) =>
                {
                    try
                    {
                        if (System.Windows.Application.Current.Resources.Contains("ModernScrollViewerStyle"))
                        {
                            ContentScroll.Style = (System.Windows.Style)System.Windows.Application.Current.Resources["ModernScrollViewerStyle"];
                        }
                    }
                    catch { }
                };
                
                // Obter caminho do executável de forma mais robusta (suporta single-file)
                var args = Environment.GetCommandLineArgs();
                
                _isSilent = args.Any(a => string.Equals(a, "--silent", StringComparison.OrdinalIgnoreCase))
                            || args.Any(a => string.Equals(a, "/silent", StringComparison.OrdinalIgnoreCase));
                _logFile = ResolveLogPath();
                Log($"Init mode=install, silent={_isSilent}");

                var logOnly = args.Any(a => string.Equals(a, "--log-only", StringComparison.OrdinalIgnoreCase));
                if (logOnly)
                {
                    try
                    {
                        var exeLocation = Assembly.GetExecutingAssembly().Location ?? Process.GetCurrentProcess().MainModule?.FileName ?? "UNKNOWN";
                        Log($"LogOnly: exe={exeLocation}");
                        Log($"LogOnly: os64={Environment.Is64BitOperatingSystem}, proc64={Environment.Is64BitProcess}");
                        Log($"LogOnly: user={Environment.UserName}, machine={Environment.MachineName}");
                        Log("LogOnly: finished");
                    }
                    catch { }
                    try { System.Windows.Application.Current.Shutdown(); } catch { }
                    try { Environment.Exit(0); } catch { }
                    return;
                }
                
                // Detectar caminho dos arquivos (mesma pasta do instalador ou relativo)
                _sourcePath = DetectSourcePath();
                Log($"SourcePath={_sourcePath}");

                // Definir caminho padrão de instalação baseado na arquitetura
                try
                {
                    // Detectar arquitetura baseada no payload embutido ou no próprio processo
                    bool isPayloadX64 = HasEmbeddedZip("x64");
                    bool isProcessX64 = Environment.Is64BitProcess;
                    
                    // Se tivermos payload x64 ou formos um processo x64 sem payload específico definido ainda, assumimos x64
                    // A prioridade é: payload embutido > arquitetura do processo
                    bool use64BitPath = isPayloadX64 || (isProcessX64 && !HasEmbeddedZip("x86"));
                    
                    string baseProgramFiles;
                    
                    if (use64BitPath && Environment.Is64BitOperatingSystem)
                    {
                        // Para instalação x64 em OS x64
                        baseProgramFiles = Environment.GetFolderPath(Environment.SpecialFolder.ProgramFiles);
                        Log("Architecture detected: x64 -> Using Program Files");
                    }
                    else
                    {
                        // Para instalação x86 ou OS x86
                        baseProgramFiles = Environment.GetFolderPath(Environment.SpecialFolder.ProgramFilesX86);
                        if (string.IsNullOrEmpty(baseProgramFiles)) // Fallback para 32-bit OS onde só existe um Program Files
                        {
                             baseProgramFiles = Environment.GetFolderPath(Environment.SpecialFolder.ProgramFiles);
                        }
                         Log("Architecture detected: x86 -> Using Program Files (x86)");
                    }

                    _installPath = System.IO.Path.Combine(baseProgramFiles, "Voltris Corporation", "VoltrisOptimizer");
                    Log($"DefaultInstallPath={_installPath}");
                }
                catch (Exception ex)
                {
                    // Fallback de segurança extremo
                    _installPath = @"C:\Program Files\Voltris Corporation\VoltrisOptimizer"; 
                    Log($"DefaultInstallPathFallback={_installPath} (Error: {ex.Message})");
                }

                // Verificar se há arquivos na pasta ou recursos embutidos (x64 ou x86)
                var hasFolderExe = !string.IsNullOrEmpty(_sourcePath) && File.Exists(Path.Combine(_sourcePath, "VoltrisOptimizer.exe"));
                var hasEmbedded = HasEmbeddedZip("x64") || HasEmbeddedZip("x86");
                Log($"HasFolderExe={hasFolderExe}, HasEmbedded={hasEmbedded}");
                if (!hasFolderExe && !hasEmbedded)
                {
                    System.Windows.MessageBox.Show(
                        "Não foi possível encontrar os arquivos do Voltris Optimizer.\n\n" +
                        "Certifique-se de que a pasta 'publish' está na mesma pasta do instalador ou que os pacotes estejam embutidos.",
                        "Arquivos não encontrados",
                        MessageBoxButton.OK,
                        MessageBoxImage.Warning
                    );
                }
                
                _steps.Clear();
                    Log("Install mode steps initialized");
                    _steps.AddRange(new InstallStep[]
                    {
                        new WelcomeStep(this),
                        new LicenseStep(this),
                        new DestinationStep(this),
                        new OptionsStep(this),
                        new InstallingStep(this),
                        new CompleteStep(this)
                    });
                
                LoadStep(0);
                if (_isSilent)
                {
                    // Avançar automaticamente por todos os passos
                    while (_currentStep < _steps.Count - 1 && _steps[_currentStep].CanProceed())
                    {
                        _steps[_currentStep].OnNext();
                        LoadStep(_currentStep + 1);
                    }
                }
            }
            catch (Exception ex)
            {
                System.Windows.MessageBox.Show(
                    $"Erro ao inicializar o instalador:\n{ex.Message}\n\n{ex.StackTrace}",
                    "Erro",
                    MessageBoxButton.OK,
                    MessageBoxImage.Error
                );
                Close();
            }
        }

        private bool HasEmbeddedZip(string arch)
        {
            try
            {
                var assembly = Assembly.GetExecutingAssembly();
                var resourceNames = assembly.GetManifestResourceNames();
                var ns = typeof(MainWindow).Namespace ?? "VoltrisOptimizerInstaller";
                var resourceName = $"{ns}.Payload.{arch}.zip";
                
                // Log para depuração
                System.Diagnostics.Debug.WriteLine($"Checking for embedded resource: {resourceName}");
                System.Diagnostics.Debug.WriteLine($"Available resources: {string.Join(", ", resourceNames)}");
                
                var result = resourceNames.Any(n => string.Equals(n, resourceName, StringComparison.OrdinalIgnoreCase));
                System.Diagnostics.Debug.WriteLine($"Embedded resource {resourceName} found: {result}");
                return result;
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error in HasEmbeddedZip: {ex.Message}");
                return false;
            }
        }

        private string DetectSourcePath()
        {
            var location = Assembly.GetExecutingAssembly().Location;
            var installerDir = string.IsNullOrEmpty(location) ? AppContext.BaseDirectory : (Path.GetDirectoryName(location) ?? AppContext.BaseDirectory);
            
            // Verificar primeiro se temos recursos embutidos (qualquer arquitetura)
            if (HasEmbeddedZip("x64") || HasEmbeddedZip("x86"))
            {
                Log("Using embedded ZIP for installation");
                return installerDir; // Usar recursos embutidos
            }
            
            var possiblePaths = new[]
            {
                Path.Combine(installerDir, "Payload", "x86"),
                Path.Combine(installerDir, "win-x86", "publish"),
                Path.Combine(installerDir, "publish"),
                Path.Combine(installerDir, "..", "publish"),
                Path.Combine(Environment.CurrentDirectory, "publish"),
                Path.Combine(Environment.CurrentDirectory, "..", "bin", "Release", "net8.0-windows", "win-x86", "publish")
            };
            
            foreach (var path in possiblePaths)
            {
                try
                {
                    var fullPath = Path.GetFullPath(path);
                    if (Directory.Exists(fullPath) && File.Exists(Path.Combine(fullPath, "VoltrisOptimizer.exe")))
                    {
                        Log($"Found source files at: {fullPath}");
                        return fullPath;
                    }
                }
                catch (Exception ex)
                {
                    Log($"Error checking path {path}: {ex.Message}");
                }
            }
            
            Log($"No source files found, using installer directory: {installerDir}");
            return installerDir;
        }

        public void LoadStep(int stepIndex)
        {
            if (stepIndex < 0 || stepIndex >= _steps.Count)
                return;
                
            _currentStep = stepIndex;
            var step = _steps[stepIndex];
            
            ContentPanel.Children.Clear();
            step.LoadContent(ContentPanel);
            ContentPanel.UpdateLayout();
            try { ContentScroll.ScrollToTop(); ContentScroll.ScrollToLeftEnd(); } catch { }
            
            UpdateButtons();
        }

        private void UpdateButtons()
        {
            var step = _steps[_currentStep];
            
            CancelButton.Content = _currentStep == 0 ? "Cancelar" : "Voltar";
            NextButton.Content = step.GetNextButtonText();
            
            if (_currentStep == _steps.Count - 1)
            {
                NextButton.Visibility = Visibility.Collapsed;
                CancelButton.Content = "Fechar";
            }
            else
            {
                NextButton.Visibility = Visibility.Visible;
            }
        }

        private void NextButton_Click(object sender, RoutedEventArgs e)
        {
            var step = _steps[_currentStep];
            if (step.CanProceed())
            {
                step.OnNext();
                LoadStep(_currentStep + 1);
            }
            else
            {
                if (step is LicenseStep)
                {
                    try { ContentScroll.ScrollToBottom(); } catch { }
                    ShowModernModal(
                        "Aceite os termos",
                        "Por favor, role o texto da licença até o fim e marque a opção 'Eu aceito os termos do acordo de licença' para continuar."
                    );
                }
            }
        }

        private void ShowModernModal(string title, string message)
        {
            try
            {
                var dialog = new Window
                {
                    Owner = this,
                    WindowStyle = WindowStyle.None,
                    AllowsTransparency = true,
                    Background = WinMedia.Brushes.Transparent,
                    ResizeMode = ResizeMode.NoResize,
                    ShowInTaskbar = false,
                    SizeToContent = SizeToContent.WidthAndHeight,
                    WindowStartupLocation = WindowStartupLocation.CenterOwner
                };

                var ownerWidth = this.ActualWidth > 0 ? this.ActualWidth : this.Width;
                var maxContentWidth = Math.Max(420, ownerWidth - 120);
                dialog.MaxWidth = Math.Max(480, ownerWidth - 40);

                var root = new Border
                {
                    Background = (SolidColorBrush)System.Windows.Application.Current.Resources["DarkPanelBrush"],
                    BorderBrush = (SolidColorBrush)System.Windows.Application.Current.Resources["DarkBorderBrush"],
                    BorderThickness = new Thickness(1),
                    CornerRadius = new CornerRadius(12),
                    Padding = new Thickness(24)
                };
                root.MaxWidth = maxContentWidth;

                root.Effect = new System.Windows.Media.Effects.DropShadowEffect
                {
                    BlurRadius = 24,
                    ShadowDepth = 0,
                    Opacity = 0.5,
                    Color = Colors.Black
                };

                var stack = new StackPanel { MinWidth = 420, MaxWidth = maxContentWidth };

                var titleBlock = new TextBlock
                {
                    Text = title,
                    FontFamily = new WinMedia.FontFamily("Segoe UI"),
                    FontWeight = FontWeights.SemiBold,
                    FontSize = 18,
                    Margin = new Thickness(0, 0, 0, 8)
                };
                titleBlock.Foreground = new WinMedia.LinearGradientBrush
                {
                    StartPoint = new System.Windows.Point(0, 0),
                    EndPoint = new System.Windows.Point(1, 0),
                    GradientStops = new WinMedia.GradientStopCollection
                    {
                        new WinMedia.GradientStop(((SolidColorBrush)System.Windows.Application.Current.Resources["AccentBrush"]).Color, 0),
                        new WinMedia.GradientStop(((SolidColorBrush)System.Windows.Application.Current.Resources["SecondaryBrush"]).Color, 0.5),
                        new WinMedia.GradientStop(((SolidColorBrush)System.Windows.Application.Current.Resources["PrimaryBrush"]).Color, 1)
                    }
                };

                var messageBlock = new TextBlock
                {
                    Text = message,
                    Foreground = (SolidColorBrush)System.Windows.Application.Current.Resources["TextSecondaryBrush"],
                    FontFamily = new WinMedia.FontFamily("Segoe UI"),
                    FontSize = 14,
                    TextWrapping = TextWrapping.Wrap,
                    LineHeight = 22,
                    Margin = new Thickness(0, 4, 0, 18)
                };

                var buttonsGrid = new Grid();
                buttonsGrid.ColumnDefinitions.Add(new ColumnDefinition { Width = new GridLength(1, GridUnitType.Star) });
                buttonsGrid.ColumnDefinitions.Add(new ColumnDefinition { Width = GridLength.Auto });

                var okButton = new System.Windows.Controls.Button
                {
                    Content = "OK",
                    Style = (Style)System.Windows.Application.Current.Resources["ModernButtonStyle"],
                    MinWidth = 100
                };
                okButton.Click += (s, e) => dialog.Close();
                Grid.SetColumn(okButton, 1);

                buttonsGrid.Children.Add(okButton);

                stack.Children.Add(titleBlock);
                stack.Children.Add(messageBlock);
                stack.Children.Add(buttonsGrid);
                root.Child = stack;
                dialog.Content = root;

                dialog.KeyDown += (s, e) => { if (e.Key == System.Windows.Input.Key.Escape) dialog.Close(); };
                dialog.ShowDialog();
            }
            catch
            {
                System.Windows.MessageBox.Show(message, title, System.Windows.MessageBoxButton.OK, System.Windows.MessageBoxImage.Information);
            }
        }

        private void CancelButton_Click(object sender, RoutedEventArgs e)
        {
            if (_currentStep == 0 || _currentStep == _steps.Count - 1)
            {
                try
                {
                    if (_currentStep == _steps.Count - 1 && _launchAfterInstall)
                    {
                        var exePath = Path.Combine(InstallPath, "VoltrisOptimizer.exe");
                        if (File.Exists(exePath))
                        {
                            var args = StartMinimized ? "/minimized" : string.Empty;
                            Process.Start(new ProcessStartInfo
                            {
                                FileName = exePath,
                                Arguments = args,
                                UseShellExecute = true,
                                WorkingDirectory = InstallPath
                            });
                        }
                    }
                }
                catch { }
                Close();
            }
            else
            {
                LoadStep(_currentStep - 1);
            }
        }

        private void Header_MouseLeftButtonDown(object sender, System.Windows.Input.MouseButtonEventArgs e)
        {
            if (e.ChangedButton == System.Windows.Input.MouseButton.Left)
            {
                DragMove();
            }
        }
        
        private void MinimizeButton_Click(object sender, RoutedEventArgs e)
        {
            WindowState = WindowState.Minimized;
        }
        
        private void CloseButton_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                if (_launchAfterInstall)
                {
                    var exePath = Path.Combine(InstallPath, "VoltrisOptimizer.exe");
                    if (File.Exists(exePath))
                    {
                        var args = StartMinimized ? "/minimized" : string.Empty;
                        Process.Start(new ProcessStartInfo
                        {
                            FileName = exePath,
                            Arguments = args,
                            UseShellExecute = true,
                            WorkingDirectory = InstallPath
                        });
                    }
                }
            }
            catch { }
            Close();
        }

