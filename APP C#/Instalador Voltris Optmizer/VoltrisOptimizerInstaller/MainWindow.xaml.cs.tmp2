        private void Log(string message)
        {
            try
            {
                var logMessage = $"{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff} [{Environment.UserName}] {message}";
                
                // Log para arquivo
                if (string.IsNullOrEmpty(_logFile))
                    _logFile = ResolveLogPath();
                
                var logDir = Path.GetDirectoryName(_logFile);
                if (!string.IsNullOrEmpty(logDir))
                {
                    Directory.CreateDirectory(logDir);
                }
                File.AppendAllText(_logFile, logMessage + Environment.NewLine);
                
                // Log para debug (opcional)
                System.Diagnostics.Debug.WriteLine(logMessage);
            }
            catch { }
        }

        private string ResolveLogPath()
        {
            var paths = new List<string>();
            try
            {
                var common = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.CommonApplicationData), "Voltris", "Uninstall");
                paths.Add(Path.Combine(common, "uninstall.log"));
            }
            catch { }
            try
            {
                var local = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "Voltris", "Uninstall");
                paths.Add(Path.Combine(local, "uninstall.log"));
            }
            catch { }
            try
            {
                var temp = Path.Combine(Path.GetTempPath(), "Voltris", "Uninstall");
                paths.Add(Path.Combine(temp, "uninstall.log"));
            }
            catch { }
            foreach (var p in paths)
            {
                try
                {
                    var d = Path.GetDirectoryName(p);
                    if (!string.IsNullOrEmpty(d) && !Directory.Exists(d)) Directory.CreateDirectory(d);
                    return p;
                }
                catch { }
            }
            return Path.Combine(Path.GetTempPath(), "uninstall.log");
        }

        private bool IsAdministrator()
        {
            try
            {
                var wi = WindowsIdentity.GetCurrent();
                var wp = new WindowsPrincipal(wi);
                return wp.IsInRole(WindowsBuiltInRole.Administrator);
            }
            catch { return false; }
        }

        private string DetectInstallPathFromRegistry()
        {
            var views = new[] { RegistryView.Registry64, RegistryView.Registry32 };
            foreach (var view in views)
            {
                try
                {
                    using (var baseKey = RegistryKey.OpenBaseKey(RegistryHive.LocalMachine, view))
                    using (var key = baseKey.OpenSubKey(@"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\VoltrisOptimizer"))
                    {
                        if (key != null)
                        {
                            var path = key.GetValue("InstallLocation") as string;
                            if (!string.IsNullOrEmpty(path) && Directory.Exists(path))
                            {
                                return path;
                            }

                            var uninstallStr = key.GetValue("UninstallString") as string;
                            if (!string.IsNullOrEmpty(uninstallStr))
                            {
                                string? exeCandidate = null;
                                var s = uninstallStr.Trim();
                                if (s.StartsWith("\""))
                                {
                                    var end = s.IndexOf('"', 1);
                                    if (end > 1)
                                    {
                                        exeCandidate = s.Substring(1, end - 1);
                                    }
                                }
                                else
                                {
                                    var idx = s.IndexOf(' ');
                                    exeCandidate = idx > 0 ? s.Substring(0, idx) : s;
                                }

                                if (!string.IsNullOrEmpty(exeCandidate) && File.Exists(exeCandidate))
                                {
                                    var dir = Path.GetDirectoryName(exeCandidate);
                                    if (!string.IsNullOrEmpty(dir) && Directory.Exists(dir))
                                    {
                                        return dir;
                                    }
                                }
                            }
                        }
                    }
                }
                catch { }
            }
            return string.Empty;
            return string.Empty;
        }

        // Métodos de desinstalação antigos removidos - usar VoltrisUninstaller separado
    }

    // Classe base para os steps
    public abstract class InstallStep
    {
        protected MainWindow Window { get; }

        protected InstallStep(MainWindow window)
        {
            Window = window;
        }

        public abstract void LoadContent(System.Windows.Controls.Panel container);
        public abstract bool CanProceed();
        public abstract void OnNext();
        public virtual string GetNextButtonText() => "Avançar";
        
        // Helper para criar título com gradiente em "Voltris Optimizer"
        protected TextBlock CreateGradientTitle(string fullText, string highlightText = "Voltris Optimizer")
        {
            var title = new TextBlock
            {
                TextAlignment = TextAlignment.Center,
                HorizontalAlignment = System.Windows.HorizontalAlignment.Center,
                FontFamily = new WinMedia.FontFamily("Segoe UI"),
                FontSize = 24,
                FontWeight = FontWeights.Bold,
                LineHeight = 32,
                TextWrapping = TextWrapping.Wrap // CORREÇÃO: Permite que o título quebre linha se for muito longo
            };
            
            var parts = fullText.Split(new[] { highlightText }, StringSplitOptions.None);
            
            if (parts.Length == 2)
            {
                // Texto antes do highlight
                if (!string.IsNullOrEmpty(parts[0]))
                {
                    title.Inlines.Add(new Run(parts[0]) { Foreground = (SolidColorBrush)System.Windows.Application.Current.Resources["TextPrimaryBrush"] });
                }
                
                // Texto com gradiente
                var gradientRun = new Run(highlightText);
                gradientRun.Foreground = new WinMedia.LinearGradientBrush
                {
                    StartPoint = new System.Windows.Point(0, 0),
                    EndPoint = new System.Windows.Point(1, 0),
                    GradientStops = new WinMedia.GradientStopCollection
                    {
                        new WinMedia.GradientStop((System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#FF4B6B"), 0),
                        new WinMedia.GradientStop((System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#8B31FF"), 0.5),
                        new WinMedia.GradientStop((System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#31A8FF"), 1)
                    }
                };
                title.Inlines.Add(gradientRun);
                
                // Texto depois do highlight
                if (!string.IsNullOrEmpty(parts[1]))
                {
                    title.Inlines.Add(new Run(parts[1]) { Foreground = (SolidColorBrush)System.Windows.Application.Current.Resources["TextPrimaryBrush"] });
                }
            }
            else
            {
                // Se não encontrar o texto, usar gradiente em todo o título
                title.Text = fullText;
                title.Foreground = new WinMedia.LinearGradientBrush
                {
                    StartPoint = new System.Windows.Point(0, 0),
                    EndPoint = new System.Windows.Point(1, 0),
                    GradientStops = new WinMedia.GradientStopCollection
                    {
                        new WinMedia.GradientStop((System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#FF4B6B"), 0),
                        new WinMedia.GradientStop((System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#8B31FF"), 0.5),
                        new WinMedia.GradientStop((System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#31A8FF"), 1)
                    }
                };
            }
            
            return title;
        }
    }

