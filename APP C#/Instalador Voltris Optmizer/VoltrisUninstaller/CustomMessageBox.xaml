<Window x:Class="VoltrisUninstaller.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltris Optimizer"
        Width="500" MinWidth="450"
        MinHeight="180"
        SizeToContent="Height"
        MaxHeight="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    
    <Border Background="#171313"
            BorderBrush="#3a3a3e"
            BorderThickness="1"
            CornerRadius="12"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" 
                            ShadowDepth="0" 
                            Opacity="0.5" 
                            Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#1c1c1e"
                    BorderBrush="#3a3a3e"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="24,20">
                <TextBlock x:Name="TitleText"
                          Text="InformaÃ§Ã£o"
                          Foreground="#FFFFFF"
                          FontFamily="Segoe UI"
                          FontSize="20"
                          FontWeight="Bold"/>
            </Border>
            
            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Icon -->
                <Border x:Name="IconBorder"
                       Grid.Column="0"
                       Width="56"
                       Height="56"
                       CornerRadius="28"
                       Margin="0,0,20,0"
                       VerticalAlignment="Top">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF4B6B" Offset="0"/>
                            <GradientStop Color="#8B31FF" Offset="0.5"/>
                            <GradientStop Color="#31A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="IconText"
                              Text="â„¹"
                              Foreground="White"
                              FontSize="36"
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,-2,0,0"/>
                </Border>
                
                <!-- Message -->
                <TextBlock x:Name="MessageText"
                          Grid.Column="1"
                          Text="Mensagem"
                          Foreground="#E0E0E0"
                          FontFamily="Segoe UI"
                          FontSize="14"
                          TextWrapping="Wrap"
                          LineHeight="22"
                          VerticalAlignment="Center"
                          Margin="0,0,0,0"/>
            </Grid>
            
            <!-- Footer -->
            <Border Grid.Row="2"
                   Background="#1c1c1e"
                   BorderBrush="#3a3a3e"
                   BorderThickness="0,1,0,0"
                   CornerRadius="0,0,12,12"
                   Padding="24,20">
                <Grid>
                    <Button x:Name="OkButton"
                           Content="OK"
                           HorizontalAlignment="Right"
                           MinWidth="120"
                           Click="OkButton_Click"
                           Foreground="White"
                           BorderThickness="0"
                           Padding="24,12"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Cursor="Hand"
                           MinHeight="44">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                       Background="{TemplateBinding Background}"
                                       CornerRadius="8"
                                       Padding="{TemplateBinding Padding}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" 
                                                        ShadowDepth="0" 
                                                        Opacity="0.5" 
                                                        Color="#31A8FF"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

