<Window x:Class="VoltrisUninstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltris Optimizer - Desinstalador"
        Width="700" Height="550"
        MinWidth="600" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    
    <Border Background="{StaticResource DarkBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" 
                            ShadowDepth="0" 
                            Opacity="0.5" 
                            Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Content -->
                <RowDefinition Height="*"/>
                <!-- Footer/Buttons -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Efeitos de Fundo -->
            <Ellipse Width="300" Height="300" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top"
                    Margin="50,30,0,0"
                    Fill="{StaticResource AccentBlurBrush}">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <Ellipse Width="250" Height="250" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom"
                    Margin="0,0,80,50"
                    Fill="{StaticResource SecondaryBlurBrush}">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <Border Background="{StaticResource DarkBrush}" Opacity="0.7"/>
            
            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource DarkPanelBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="24,20,8,20"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Column="0" 
                               Grid.Row="0"
                               Orientation="Horizontal" 
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left">
                        <Image Source="pack://application:,,,/Images/voltris.png"
                               Width="52"
                               Height="52"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Voltris Optimizer"
                                      FontFamily="Segoe UI"
                                      FontSize="20"
                                      FontWeight="Bold"
                                      VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="Desinstalador v1.0.0.0"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI"
                                      FontSize="12"
                                      Margin="0,4,0,0"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Botões de Controle -->
                    <StackPanel Grid.Column="2"
                               Grid.Row="0"
                               Orientation="Horizontal"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Margin="0,-20,-8,-20">
                        <!-- Botão Minimizar -->
                        <Button x:Name="MinimizeButton"
                               Content="−"
                               Width="46"
                               Height="40"
                               Background="Transparent"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               BorderThickness="0"
                               FontSize="18"
                               FontWeight="Bold"
                               Click="MinimizeButton_Click"
                               Cursor="Hand"
                               ToolTip="Minimizar"
                               VerticalAlignment="Top">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#2a2a2e"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <!-- Botão Fechar -->
                        <Button x:Name="CloseButton"
                               Content="✕"
                               Width="46"
                               Height="40"
                               Background="Transparent"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               BorderThickness="0"
                               FontSize="16"
                               FontWeight="Bold"
                               Click="CloseButton_Click"
                               Cursor="Hand"
                               ToolTip="Fechar"
                               VerticalAlignment="Top">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                       CornerRadius="0,12,0,0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#FF4B6B"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Content Area -->
            <ScrollViewer x:Name="ContentScroll" Grid.Row="1"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Padding="32,24">
                <StackPanel x:Name="ContentStackPanel">
                    <!-- Título -->
                    <TextBlock x:Name="TitleTextBlock"
                              Text="Desinstalar Voltris Optimizer"
                              Style="{StaticResource TitleTextStyle}">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    
                    <!-- Descrição -->
                    <TextBlock x:Name="DescriptionTextBlock"
                              Text="Este assistente removerá o Voltris Optimizer do seu computador."
                              Style="{StaticResource DescriptionTextStyle}"/>
                    
                    <!-- Opções -->
                    <CheckBox x:Name="KeepUserDataCheckBox" 
                             Content="Manter dados do usuário (configurações, logs, etc.)"
                             IsChecked="False"
                             Style="{StaticResource ModernCheckBoxStyle}"/>
                    
                    <!-- Barra de progresso -->
                    <ProgressBar x:Name="ProgressBar"
                               Height="6"
                               Margin="0,24,0,16"
                               Minimum="0"
                               Maximum="100"
                               Value="0"
                               Visibility="Collapsed"
                               Background="{StaticResource DarkBorderBrush}">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                    
                    <!-- Status -->
                    <TextBlock x:Name="StatusText"
                             Text="Pronto para desinstalar..."
                             Foreground="{StaticResource TextSecondaryBrush}"
                             FontFamily="Segoe UI"
                             FontSize="14"
                             TextWrapping="Wrap"
                             Margin="0,0,0,24"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer com BotÃµes -->
            <Border Grid.Row="2"
                   Background="{StaticResource DarkPanelBrush}"
                   BorderBrush="{StaticResource DarkBorderBrush}"
                   BorderThickness="0,1,0,0"
                   CornerRadius="0,0,12,12"
                   Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Botão Cancelar -->
                    <Button x:Name="CancelButton"
                           Grid.Column="1"
                           Content="Cancelar"
                           Style="{StaticResource SecondaryButtonStyle}"
                           Click="CancelButton_Click"
                           Margin="0,0,12,0"
                           MinWidth="100"/>
                    
                    <!-- Botão Desinstalar -->
                    <Button x:Name="UninstallButton"
                           Grid.Column="2"
                           Content="Desinstalar"
                           Style="{StaticResource ModernButtonStyle}"
                           Click="UninstallButton_Click"
                           MinWidth="120"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
