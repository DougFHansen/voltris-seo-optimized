<Window x:Class="VoltrisOptimizer.Core.Updater.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltris Optimizer - Atualização Inteligente"
        Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="False"
        MouseDown="Window_MouseDown">
    
    <Window.Resources>
        <!-- Gradiente principal SaaS -->
        <LinearGradientBrush x:Key="SaaSGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8E2DE2" Offset="0"/>
            <GradientStop Color="#4A00E0" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- Estilo do botão principal SaaS -->
        <Style x:Key="SaaSUpdateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SaaSGradientBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Color="#4A00E0" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#9D50BB" Offset="0"/>
                                            <GradientStop Color="#6E48AA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="130" CenterY="22"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- Container principal Glassmorphism -->
    <Border CornerRadius="20" Background="#0F0F15" BorderThickness="1" BorderBrush="#252535">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.7"/>
        </Border.Effect>
        
        <Grid>
            <!-- Background Decoration (Soft Glows) -->
            <Ellipse Width="350" Height="350" Fill="#1A8E2DE2" Margin="-150,-150,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="250" Height="250" Fill="#1A4A00E0" Margin="0,0,-80,-80" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Icon/Header -->
                    <RowDefinition Height="*"/>    <!-- Changes -->
                    <RowDefinition Height="Auto"/> <!-- Progress -->
                    <RowDefinition Height="Auto"/> <!-- Action -->
                </Grid.RowDefinitions>
                
                <!-- Modern SaaS Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,28">
                    <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border CornerRadius="20" Background="#1AFFFFFF">
                            <TextBlock Text="✨" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border CornerRadius="20" BorderThickness="1" BorderBrush="#3FFFFFFF" Opacity="0.5"/>
                    </Grid>
                    
                    <TextBlock Text="Atualização Necessária" 
                               FontSize="22" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    
                    <Border Background="#1A8E2DE2" CornerRadius="8" Padding="12,4" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock x:Name="VersionText"
                                   Text="v1.0.1.5 → v1.0.2.0"
                                   FontSize="11" Foreground="#9D50BB" FontWeight="Bold"
                                   FontFamily="Consolas, Monospace"/>
                    </Border>
                </StackPanel>
                
                <!-- Changelog Professional (With Scroll) -->
                <Border Grid.Row="1" Background="#0A0A0F" CornerRadius="16" BorderThickness="1" BorderBrush="#1AFFFFFF" Margin="0,0,0,24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="20">
                        <StackPanel>
                            <TextBlock Text="NOVAS MELHORIAS" 
                                       FontSize="10" FontWeight="Black" Foreground="#66FFFFFF" 
                                       Margin="0,0,0,12"/>
                            
                            <TextBlock x:Name="ChangelogText"
                                       Text="• Otimização do núcleo de rede Intel/Killer&#x0a;• Estabilidade de FPS nas zonas Alpha&#x0a;• Novos drivers virtuais de baixa latência&#x0a;• Correções de segurança críticas"
                                       FontSize="13" Foreground="#D0D0D5"
                                       TextWrapping="Wrap" 
                                       LineHeight="22"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       Margin="0,0,10,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- Modern Progress Indicator -->
                <StackPanel x:Name="ProgressPanel" Grid.Row="2" Margin="0,0,0,24" Visibility="Collapsed">
                    <Grid Margin="0,0,0,10">
                        <TextBlock x:Name="ProgressStatusText" 
                                   Text="Baixando pacote criptografado..."
                                   FontSize="12" Foreground="#80808F"/>
                        <TextBlock x:Name="ProgressPercentText" 
                                   HorizontalAlignment="Right"
                                   Text="0%"
                                   FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                    </Grid>
                    
                    <Border Background="#151520" CornerRadius="6" Height="6">
                        <Border x:Name="ProgressBar" 
                                HorizontalAlignment="Left" 
                                Width="0"
                                CornerRadius="6"
                                Background="{StaticResource SaaSGradientBrush}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#8E2DE2" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                </StackPanel>
                
                <!-- Action Button -->
                <Button x:Name="UpdateButton"
                        Grid.Row="3"
                        Content="Atualizar Agora"
                        Style="{StaticResource SaaSUpdateButtonStyle}"
                        Height="56"
                        Click="UpdateButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
