<UserControl x:Class="VoltrisOptimizer.Core.PreparePc.UI.Views.PreparePcConfirmationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource BgPrimary}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <Style x:Key="LevelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0AFFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="28,24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#12FFFFFF"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BrandBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Storyboard x:Key="EntryAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Background Glow (GPU-friendly) -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="700" Height="700" 
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-300,-300,0" Opacity="0.07">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B31FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <!-- Main Container — responsive, no Viewbox -->
        <Border Margin="32,24" Style="{StaticResource PremiumCard}" Padding="36,28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="28"/>    <!-- Spacer -->
                    <RowDefinition Height="*"/>     <!-- Cards -->
                    <RowDefinition Height="20"/>    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource BorderHover}" Margin="0,0,10,0"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource BorderHover}" Margin="0,0,10,0"/>
                        <Border Width="28" Height="8" CornerRadius="4" Background="{StaticResource VoltrisGradient}"/>
                    </StackPanel>
                    <TextBlock Text="Nível de Refatoração" 
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Selecione o nível de profundidade para a otimização de baixo nível" 
                               FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                </StackPanel>

                <!-- CARDS -->
                <Grid Grid.Row="2" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Correção Segura -->
                    <Border Grid.Column="0" Style="{StaticResource LevelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Width="48" Height="48" CornerRadius="12" Background="#1531A8FF" 
                                    HorizontalAlignment="Left" Margin="0,0,0,16">
                                <Viewbox Margin="12">
                                    <Path Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M11,16.5L6.5,12L7.9,10.6L11,13.7L16.6,8.1L18,9.5L11,16.5Z" 
                                          Fill="{StaticResource BrandBlue}"/>
                                </Viewbox>
                            </Border>

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="CORREÇÃO SEGURA" FontSize="18" FontWeight="Bold" 
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="Restauração de arquitetura DISM e SFC Scan completo. Foco em estabilidade absoluta do Windows." 
                                           FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" 
                                           TextWrapping="Wrap" LineHeight="19" Opacity="0.8"/>
                            </StackPanel>

                            <Button Grid.Row="2" Content="Selecionar Seguro" Style="{StaticResource SecondaryButton}" 
                                    Height="44" Click="StandardMode_Click" Margin="0,20,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Latência Máxima -->
                    <Border Grid.Column="2" Style="{StaticResource LevelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Width="48" Height="48" CornerRadius="12" Background="#158B31FF" 
                                    HorizontalAlignment="Left" Margin="0,0,0,16">
                                <Viewbox Margin="12">
                                    <Path Data="M11,21L12,13L8.5,13L13,3L12,11L15.5,11L11,21Z" 
                                          Fill="{StaticResource BrandPurple}"/>
                                </Viewbox>
                            </Border>

                            <StackPanel Grid.Row="1">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="LATÊNCIA MÁXIMA" FontSize="18" FontWeight="Bold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Border Background="{StaticResource BrandPurple}" CornerRadius="5" Padding="8,2" 
                                            Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="PRO" Foreground="White" FontSize="9" FontWeight="Black"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Calibração de timers e reset de stack de rede para resposta instantânea em jogos. Recomendado para e-Sports." 
                                           FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" 
                                           TextWrapping="Wrap" LineHeight="19" Opacity="0.8"/>
                            </StackPanel>

                            <Button Grid.Row="2" Content="Selecionar Latência" Style="{StaticResource PrimaryButton}" 
                                    Height="44" Click="AdvancedMode_Click" Margin="0,20,0,0"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- FOOTER -->
                <Grid Grid.Row="4">
                    <Button Content="VOLTAR" HorizontalAlignment="Left" Click="BackButton_Click"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" 
                                           Foreground="{DynamicResource TextSecondaryBrush}" 
                                           TextDecorations="Underline" FontSize="12" Opacity="0.7"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="As alterações exigem privilégios de administrador." 
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" 
                               HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.5"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
