<UserControl x:Class="VoltrisOptimizer.Core.PreparePc.UI.Views.PreparePcIntroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="780" d:DesignWidth="1100"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <!-- Estilo de tag de recurso seguindo paleta global -->
        <Style x:Key="FeatureTagStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DarkHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
        </Style>
        
        <!-- Link Button Style (Missing Resource) -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="text" 
                                   Text="{TemplateBinding Content}" 
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="text" Property="Foreground" Value="{DynamicResource PrimaryLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeonSecondaryButtonStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#0A0A0F" ClipToBounds="True">
        <!-- Background decorations -->
        <Grid>
            <!-- Efeitos de Blur Decorativos -->
            <Viewbox HorizontalAlignment="Left" 
                     VerticalAlignment="Top"
                     Margin="-50,-50,0,0"
                     Stretch="Uniform"
                     Width="400" Height="400"
                     IsHitTestVisible="False">
                <Ellipse Width="400" Height="400" 
                         Fill="{StaticResource AccentBlurBrush}">
                    <Ellipse.Effect>
                        <BlurEffect Radius="120"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Viewbox>
            
            <Viewbox HorizontalAlignment="Right" 
                     VerticalAlignment="Bottom"
                     Margin="0,0,-50,-50"
                     Stretch="Uniform"
                     Width="350" Height="350"
                     IsHitTestVisible="False">
                <Ellipse Width="350" Height="350" 
                         Fill="{StaticResource SecondaryBlurBrush}">
                    <Ellipse.Effect>
                        <BlurEffect Radius="120"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Viewbox>
            
            <!-- Main Content Container - Fit to Screen -->
            <Viewbox Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10" StretchDirection="DownOnly" MaxWidth="1920" MaxHeight="1080">
                <Grid Width="1100" Height="760">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header Step -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20">
                        <Ellipse Width="12" Height="12" Fill="{StaticResource DarkBorderBrush}" Margin="0,0,8,0"/>
                        <Ellipse Width="12" Height="12" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                        <Ellipse Width="12" Height="12" Fill="{StaticResource DarkBorderBrush}"/>
                    </StackPanel>

                    <!-- Main Card -->
                    <Border Grid.Row="1" 
                            HorizontalAlignment="Stretch"
                            Margin="80,0"
                            VerticalAlignment="Center"
                            CornerRadius="24" 
                            Padding="2">
                        <!-- Gradient border -->
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.4" Color="#8B31FF"/>
                        </Border.Effect>
                        
                        <Border Background="#0D0D14" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="22" Padding="30,25">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Title Section -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <Border Width="64" Height="64" CornerRadius="16" Margin="0,0,24,0" Background="#1A1A24">
                                            <Path Data="M22.7,19L13.6,9.9C14.5,7.1 17.2,5 20.4,5C23.6,5 26.3,7.1 27.2,9.9L22.7,19M20.4,3C16.7,3 13.5,5.1 12,8.3L2,18.3L3.6,19.9L5.1,18.4L7.1,20.4L8.6,18.9L6.6,16.9L8.1,15.4L10.1,17.4L11.6,15.9L9.6,13.9L12,11.5C13.5,8.3 16.7,6.2 20.4,6.2C24.1,6.2 27.3,8.3 28.8,11.5L30.2,10.1L31.7,11.6L30.3,13C31.8,16.2 31.8,20 30.3,23.2L28.9,24.6L27.4,23.1L28.8,21.7C29.9,19.1 29.9,16.1 28.8,13.5L22.7,19.6C22.5,19.8 22.2,19.9 22,19.9C21.8,19.9 21.5,19.8 21.3,19.6L20.4,18.7L19.5,19.6C19.1,20 18.5,20 18.1,19.6C17.7,19.2 17.7,18.6 18.1,18.2L19,17.3L18.1,16.4C17.7,16 17.7,15.4 18.1,15C18.5,14.6 19.1,14.6 19.5,15L20.4,15.9L21.3,15C21.7,14.6 22.3,14.6 22.7,15C23.1,15.4 23.1,16 22.7,16.4L21.8,17.3L22.7,18.2C23.1,18.6 23.1,19.2 22.7,19.6M13.1,22.6L11.6,21.1L13.6,19.1L15.1,20.6L13.1,22.6Z" 
                                                  Fill="{StaticResource VoltrisGradientBrush}"
                                                  Width="32" Height="32" 
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Refatoração de Integridade" 
                                                           FontFamily="Segoe UI Variable Display, Segoe UI"
                                                           FontSize="34" 
                                                           FontWeight="Bold" 
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <Border Background="{StaticResource SuccessGradientBrush}" 
                                                        CornerRadius="6" 
                                                        Padding="10,3" 
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="VITAL" 
                                                               Foreground="White" 
                                                               FontSize="11" 
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Restauração de Componentes e Otimização Profunda do Windows" 
                                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                                       FontSize="18" 
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <TextBlock Text="Esta operação realiza uma varredura completa por arquivos corrompidos e falhas de arquitetura, restaurando a saúde do Windows e eliminando erros que degradam o desempenho."
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               FontSize="16"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="700"
                                               HorizontalAlignment="Center"
                                               LineHeight="22"/>
                                </StackPanel>
                                
                                <!-- Divider -->
                                <Rectangle Grid.Row="1" Height="1" Fill="#2A2A35" Margin="40,0,40,30"/>
                                
                                <!-- Features Grid -->
                                <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,30" MaxWidth="700">
                                    <Border Style="{StaticResource FeatureTagStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" 
                                                  Fill="{StaticResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="SFC Scan (System File Checker)" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Style="{StaticResource FeatureTagStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" 
                                                  Fill="{StaticResource SecondaryBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="DISM Image Repair" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Style="{StaticResource FeatureTagStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M19.36,2.72L20.78,4.14L15.06,9.85C16.13,11.39 16.28,13.24 15.38,14.44L9.06,8.12C10.26,7.22 12.11,7.37 13.65,8.44L19.36,2.72M5.93,17.57C3.92,15.56 2.69,13.16 2.35,10.92L7.23,8.83L14.67,16.27L12.58,21.15C10.34,20.81 7.94,19.58 5.93,17.57Z" 
                                                  Fill="{StaticResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="Limpeza Profunda de Disco" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Style="{StaticResource FeatureTagStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,21L15.6,16.2C14.6,15.45 13.35,15 12,15C10.65,15 9.4,15.45 8.4,16.2L12,21M12,3C7.95,3 4.21,4.34 1.2,6.6L3,9C5.5,7.12 8.62,6 12,6C15.38,6 18.5,7.12 21,9L22.8,6.6C19.79,4.34 16.05,3 12,3M12,9C9.3,9 6.81,9.89 4.8,11.4L6.6,13.8C8.1,12.67 9.97,12 12,12C14.03,12 15.9,12.67 17.4,13.8L19.2,11.4C17.19,9.89 14.7,9 12,9Z" 
                                                  Fill="{StaticResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="Reset de Adaptadores de Rede" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Style="{StaticResource FeatureTagStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M11,21H10L11,14H7.5C7.16,14 7,13.76 7,13.5C7,13.35 7.04,13.23 7.12,13.13L13,3H14L13,10H16.5C16.82,10 17,10.25 17,10.5C17,10.66 16.95,10.78 16.88,10.88L11,21Z" 
                                                  Fill="{StaticResource AccentBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="Otimização do Plano de Energia" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Style="{StaticResource FeatureTagStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M21,6H3A2,2 0 0,0 1,8V16A2,2 0 0,0 3,18H21A2,2 0 0,0 23,16V8A2,2 0 0,0 21,6M11,13H8V16H6V13H3V11H6V8H8V11H11V13M15.5,15A1.5,1.5 0 0,1 14,13.5A1.5,1.5 0 0,1 15.5,12A1.5,1.5 0 0,1 17,13.5A1.5,1.5 0 0,1 15.5,15M19.5,12A1.5,1.5 0 0,1 18,10.5A1.5,1.5 0 0,1 19.5,9A1.5,1.5 0 0,1 21,10.5A1.5,1.5 0 0,1 19.5,12Z" 
                                                  Fill="{StaticResource SecondaryBrush}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="Limpeza de Shader Cache (DirectX/OpenGL)" FontFamily="Segoe UI Variable, Segoe UI" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                                
                                <!-- CTA Button -->
                                <StackPanel Grid.Row="3" HorizontalAlignment="Center">
                                    <Button x:Name="StartButton" 
                                            Style="{StaticResource NeonButtonStyle}"
                                            Padding="50,16"
                                            Margin="0,0,0,12"
                                            Click="StartButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Iniciar Refatoração de Sistema" FontFamily="Segoe UI Variable Display, Segoe UI" FontSize="19" FontWeight="bold"/>
                                            <Path Data="M4,12 L20,12 M20,12 L14,6 M20,12 L14,18" 
                                                  Stroke="White" 
                                                  StrokeThickness="3" 
                                                  Width="24" Height="24" 
                                                  Stretch="Uniform"
                                                  Margin="16,0,0,0"
                                                  VerticalAlignment="Center"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                                              Fill="{StaticResource TextMutedBrush}"
                                              Width="14" Height="14" 
                                              Stretch="Uniform"
                                              Margin="0,0,8,0" 
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="Estimativa de Calibragem: 10-30 minutos" Foreground="{StaticResource TextSecondaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>
                    
                    <!-- Footer Actions -->
                    <Grid Grid.Row="2" Margin="40,20,40,20">
                        <Button x:Name="SkipButton" 
                                Content="Pular e ir para Dashboard" 
                                Style="{StaticResource LinkButtonStyle}"
                                FontSize="18"
                                FontWeight="Bold"
                                HorizontalAlignment="Left"
                                Click="SkipButton_Click"/>
                                
                        <Button x:Name="ScheduleButton" 
                                Content="Agendar para depois" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="18"
                                FontWeight="Bold"
                                Padding="28,14"
                                HorizontalAlignment="Right"
                                Click="ScheduleButton_Click"/>
                    </Grid>
                </Grid>
            </Viewbox>
        </Grid>
    </Border>    
</UserControl>
