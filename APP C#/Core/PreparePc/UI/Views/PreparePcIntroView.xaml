<UserControl x:Class="VoltrisOptimizer.Core.PreparePc.UI.Views.PreparePcIntroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource BgPrimary}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <Style x:Key="FeatureItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#0AFFFFFF"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#12FFFFFF"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BrandPurple}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PremiumActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource VoltrisGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="MaxWidth" Value="480"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="EntryAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="LayoutRoot">
        <!-- Background Glow (GPU-friendly, sem BlurEffect) -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" 
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-250,-250,0,0" Opacity="0.08">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF4B6B" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="500" Height="500" 
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-200,-200" Opacity="0.06">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#31A8FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <!-- Main Container — responsive, no Viewbox -->
        <Border Margin="32,24" Style="{StaticResource PremiumCard}" Padding="36,28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="20"/>    <!-- Spacer -->
                    <RowDefinition Height="*"/>     <!-- Content -->
                    <RowDefinition Height="24"/>    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>  <!-- Action -->
                    <RowDefinition Height="16"/>    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>  <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- 1. HEADER -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="60" Height="60" CornerRadius="16" Margin="0,0,20,0"
                            Background="{StaticResource VoltrisGradientVertical}">
                        <Viewbox Margin="14">
                            <Path Data="M22.7,19L13.6,9.9C14.5,7.1 17.2,5 20.4,5C23.6,5 26.3,7.1 27.2,9.9L22.7,19M20.4,3C16.7,3 13.5,5.1 12,8.3L2,18.3L3.6,19.9L5.1,18.4L7.1,20.4L8.6,18.9L6.6,16.9L8.1,15.4L10.1,17.4L11.6,15.9L9.6,13.9L12,11.5C13.5,8.3 16.7,6.2 20.4,6.2C24.1,6.2 27.3,8.3 28.8,11.5L30.2,10.1L31.7,11.6L30.3,13C31.8,16.2 31.8,20 30.3,23.2L28.9,24.6L27.4,23.1L28.8,21.7C29.9,19.1 29.9,16.1 28.8,13.5L22.7,19.6C22.5,19.8 22.2,19.9 22,19.9C21.8,19.9 21.5,19.8 21.3,19.6L20.4,18.7L19.5,19.6C19.1,20 18.5,20 18.1,19.6C17.7,19.2 17.7,18.6 18.1,18.2L19,17.3L18.1,16.4C17.7,16 17.7,15.4 18.1,15C18.5,14.6 19.1,14.6 19.5,15L20.4,15.9L21.3,15C21.7,14.6 22.3,14.6 22.7,15C23.1,15.4 23.1,16 22.7,16.4L21.8,17.3L22.7,18.2C23.1,18.6 23.1,19.2 22.7,19.6M13.1,22.6L11.6,21.1L13.6,19.1L15.1,20.6L13.1,22.6Z" 
                                  Fill="White" Stretch="Uniform"/>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Refatoração de Integridade" 
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Border Background="#1510B981" CornerRadius="6" Padding="10,4" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="SISTEMA RECOMENDADO" Foreground="#10B981" FontSize="10" FontWeight="Black"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Reparo profundo de arquitetura e calibração de performance de baixo nível." 
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                    </StackPanel>
                </Grid>

                <!-- 2. CONTENT AREA -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Features List -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Esta operação essencial elimina picos de latência (stuttering) corrigindo a integridade dos registros e arquivos de sistema do Windows." 
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.8"
                                   TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,18"/>
                        
                        <UniformGrid Columns="2">
                            <Border Style="{StaticResource FeatureItemStyle}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="9" Background="#1510B981" Margin="0,0,12,0">
                                        <Viewbox Margin="7" Stretch="Uniform">
                                            <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9L10,17Z" Fill="#10B981"/>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="SFC Scan &amp; Repair" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource FeatureItemStyle}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="9" Background="#1531A8FF" Margin="0,0,12,0">
                                        <Viewbox Margin="7" Stretch="Uniform">
                                            <Path Data="M12,2L2,7L12,12L22,7L12,2M2,17L12,22L22,17M2,12L12,17L22,12" Fill="#31A8FF"/>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="DISM Components" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource FeatureItemStyle}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="9" Background="#15FF4B6B" Margin="0,0,12,0">
                                        <Viewbox Margin="7" Stretch="Uniform">
                                            <Path Data="M12,3C7.58,3 4,5.24 4,8C4,10.76 7.58,13 12,13C16.42,13 20,10.76 20,8C20,5.24 16.42,3 12,3M4,10V13C4,15.76 7.58,18 12,18C16.42,18 20,15.76 20,13V10C20,12.76 16.42,15 12,15C7.58,15 4,12.76 4,10M4,15V18C4,20.76 7.58,23 12,23C16.42,23 20,20.76 20,18V15C20,17.76 16.42,20 12,20C7.58,20 4,17.76 4,15Z" Fill="#FF4B6B"/>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="Disk Optimization" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource FeatureItemStyle}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="9" Background="#158B31FF" Margin="0,0,12,0">
                                        <Viewbox Margin="7" Stretch="Uniform">
                                            <Path Data="M5,12.55A11,11 0 0,1 16.55,5L18,3.5A13,13 0 0,0 3.5,18L5,12.55M1.39,9.17A17,17 0 0,1 22.61,9.17L21.1,10.68A15,15 0 0,0 2.9,10.68L1.39,9.17M9.1,14.1A5,5 0 0,1 14.9,14.1L13.4,15.6A3,3 0 0,0 10.6,15.6L9.1,14.1M12,17A1,1 0 0,0 13,16A1,1 0 0,0 12,15A1,1 0 0,0 11,16A1,1 0 0,0 12,17Z" Fill="#8B31FF"/>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Text="Network Stack Reset" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Sidebar Insight -->
                    <Border Grid.Column="2" Style="{StaticResource ElevatedCard}" Padding="20" VerticalAlignment="Center">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="30" Height="30" CornerRadius="8" Background="#208B31FF" Margin="0,0,10,0">
                                    <Viewbox Margin="6" Stretch="Uniform">
                                        <Path Data="M13,9H11V7H13M13,17H11V11H13M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2Z" Fill="#8B31FF"/>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="ANÁLISE DO SISTEMA" FontSize="10" FontWeight="Black"
                                           Foreground="{StaticResource BrandPurple}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Essencial para máquinas competitivas que utilizam kernels de alta frequência. Evita picos de DPC Latency e instabilidade de timers."
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" 
                                       TextWrapping="Wrap" LineHeight="18" Opacity="0.85"/>

                            <Border Height="1" Background="{StaticResource BorderSubtle}" Margin="0,14"/>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="7" Background="#15FFFFFF" Margin="0,0,8,0">
                                    <Viewbox Margin="5" Stretch="Uniform">
                                        <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                                              Fill="{DynamicResource TextMutedBrush}"/>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="~15 min estimados" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 3. ACTION -->
                <StackPanel Grid.Row="4" HorizontalAlignment="Center">
                    <Button x:Name="StartButton" Style="{StaticResource PremiumActionButton}" 
                            Click="StartButton_Click" Width="460">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="EXECUTAR REFATORAÇÃO DE INTEGRIDADE" FontSize="13" FontWeight="Black"/>
                            <Path Data="M12,4L10.59,5.41L16.17,11H4V13H16.17L10.59,18.59L12,20L20,12L12,4Z" 
                                  Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 4. FOOTER -->
                <Grid Grid.Row="6">
                    <Button x:Name="SkipButton" HorizontalAlignment="Left" VerticalAlignment="Center" 
                            Click="SkipButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="Ignorar e ir ao Dashboard" Foreground="{DynamicResource TextSecondaryBrush}" 
                                           TextDecorations="Underline" FontSize="12" Opacity="0.7"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="ScheduleButton" Content="Agendar para o Próximo Boot" 
                            Style="{StaticResource SecondaryButton}" 
                            Padding="20,10" HorizontalAlignment="Right"
                            Click="ScheduleButton_Click" FontSize="12"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
