<UserControl x:Class="VoltrisOptimizer.Core.PreparePc.UI.Views.PreparePcProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="780" d:DesignWidth="1100"
             FontFamily="Segoe UI Variable, Segoe UI, Sans-Serif"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    
    <UserControl.Resources>
        <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="#0A0A0F"/>
            <Setter Property="Foreground" Value="{StaticResource VoltrisGradientHorizontalBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" BorderBrush="#1E1E2E" BorderThickness="1">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" 
                                        Background="{TemplateBinding Foreground}" 
                                        CornerRadius="5" HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A1515"/>
            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#60FF4466" Offset="0"/>
                                    <GradientStop Color="#40FF4466" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A1A1A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A1010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource NeonButtonStyle}"/>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeonSecondaryButtonStyle}"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgPrimary}">
        <!-- Background Glow (GPU-friendly, sem BlurEffect) -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" 
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-200,0" Opacity="0.06">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B31FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400" 
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100" Opacity="0.05">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#31A8FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <!-- Main Container — responsive, no Viewbox -->
        <Border Margin="32,24" Background="{DynamicResource BgCardGlass}" 
                BorderBrush="{DynamicResource BorderLight}" BorderThickness="1" CornerRadius="24">
            <Grid Margin="32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="16"/>    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>  <!-- Progress Card -->
                    <RowDefinition Height="12"/>    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>  <!-- Steps Tracking -->
                    <RowDefinition Height="12"/>    <!-- Spacer -->
                    <RowDefinition Height="*"/>     <!-- Terminal Console -->
                    <RowDefinition Height="16"/>    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>  <!-- Actions Footer -->
                </Grid.RowDefinitions>
                    
                <!-- Header Section -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="52" Height="52" CornerRadius="14" Margin="0,0,18,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Margin="12">
                            <Path x:Name="HeaderIconPath" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderText" Text="Otimização Profunda &amp; Reparo" 
                                   FontSize="24" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="SubHeaderText" 
                                   Text="Aguarde enquanto o Voltris restaura a integridade do seu sistema." 
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.8"/>
                    </StackPanel>
                    
                    <Border Grid.Column="2" Background="#15FFFFFF" CornerRadius="10" Padding="14,7" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock x:Name="StatusText" Text="EXECUTANDO" FontSize="11" FontWeight="Bold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ElapsedTimeText" Text="00:00" FontSize="11" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RemainingTimeText" Text="" FontSize="11" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Progress Card -->
                <Border Grid.Row="2" Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" 
                        CornerRadius="16" Padding="24,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="CurrentStepText" Text="Etapa 1 de 12: Inicializando Motor" 
                                       FontSize="16" FontWeight="Bold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="CurrentActionText" 
                                       Text="Verificando permissões administrativas e componentes do sistema..." 
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ProgressBar x:Name="OverallProgress" Style="{StaticResource ProgressBarStyle}" 
                                         Value="0" Height="8" Margin="0,16,0,0"/>
                        </StackPanel>
                        
                        <TextBlock x:Name="PercentText" Grid.Column="1" Text="0%" FontSize="42" FontWeight="Bold" 
                                   VerticalAlignment="Center" Margin="30,0,0,0">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#8B31FF" Offset="0"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Grid>
                </Border>
                
                <!-- Steps Tracking -->
                <Border Grid.Row="4" Background="#08FFFFFF" CornerRadius="12" Padding="16,12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="120">
                        <StackPanel x:Name="StepsStatusPanel"/>
                    </ScrollViewer>
                </Border>
                
                <!-- Terminal Console -->
                <Border Grid.Row="6" Background="#05050A" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="16" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#0AFFFFFF" Padding="16,10">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M20,19V7H4V19H20M20,5A2,2 0 0,1 22,7V19A2,2 0 0,1 20,21H4A2,2 0 0,1 2,19V7A2,2 0 0,1 4,5H20M13,17H17V19H13V17M10,14.5L7,17.5L5.5,16L8.5,13L5.5,10L7,8.5L11,12.5V13.5L10,14.5Z" 
                                          Fill="{DynamicResource TextSecondaryBrush}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,10,0"/>
                                    <TextBlock Text="CONSOLE DE SAÍDA" FontSize="10" FontWeight="Bold" 
                                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="ExportLogsBtn" Content="Exportar Logs" HorizontalAlignment="Right" 
                                        Background="Transparent" BorderThickness="0" 
                                        Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="Bold" 
                                        Cursor="Hand" Click="ExportLogsBtn_Click"/>
                            </Grid>
                        </Border>
                        
                        <ScrollViewer x:Name="LogsScrollViewer" Grid.Row="1" Padding="16,12">
                            <TextBlock x:Name="LogsTextBlock" FontFamily="Cascadia Code, Consolas, monospace" 
                                       FontSize="12" Foreground="#D1D5DB" LineHeight="18"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
                
                <!-- Actions Footer -->
                <Grid Grid.Row="8">
                    <Button x:Name="CancelBtn" Content="Cancelar Operação" Style="{StaticResource CancelButtonStyle}" 
                            HorizontalAlignment="Left" Click="CancelBtn_Click"/>
                    
                    <StackPanel x:Name="CompletedActions" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                        <Button x:Name="RollbackBtn" Content="Desfazer" Style="{StaticResource SecondaryButtonStyle}" 
                                Margin="0,0,10,0" Click="RollbackBtn_Click"/>
                        <Button x:Name="ViewReportBtn" Content="Relatório" Style="{StaticResource SecondaryButtonStyle}" 
                                Margin="0,0,10,0" Click="ViewReportBtn_Click"/>
                        <Button x:Name="ContinueBtn" Content="Concluir" Style="{StaticResource SuccessButtonStyle}" 
                                Width="160" Click="ContinueBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
