<Window x:Class="VoltrisOptimizer.UI.Windows.UninstallSuccessModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desinstalação Concluída"
        Width="560"
        MinWidth="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <LinearGradientBrush x:Key="VoltrisGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF4B6B" Offset="0"/>
            <GradientStop Color="#8B31FF" Offset="0.5"/>
            <GradientStop Color="#31A8FF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ModalOkButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource VoltrisGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer glass border -->
    <Border CornerRadius="20"
            BorderBrush="#2A2A3A"
            BorderThickness="1.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="48" ShadowDepth="0" Opacity="0.65" Color="#000000"/>
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F0F18" Offset="0"/>
                <GradientStop Color="#1A1A28" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid ClipToBounds="True">

            <!-- Atmospheric glow — top-left blue -->
            <Ellipse Width="380" Height="380"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-160,-160,0,0" Opacity="0.13" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#31A8FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Atmospheric glow — bottom-right pink -->
            <Ellipse Width="340" Height="340"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-140,-140" Opacity="0.11" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF4B6B" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Gradient top accent bar -->
            <Border Height="4" VerticalAlignment="Top" CornerRadius="20,20,0,0"
                    Background="{StaticResource VoltrisGradient}" IsHitTestVisible="False"/>

            <!-- Main content -->
            <Grid Margin="36,20,36,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- close btn row -->
                    <RowDefinition Height="Auto"/>  <!-- center content -->
                    <RowDefinition Height="Auto"/>  <!-- button row -->
                </Grid.RowDefinitions>

                <!-- Close button top-right -->
                <Button Grid.Row="0"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="OkButton_Click"
                        Width="28" Height="28">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#25FF3B3B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="✕" Foreground="#5A5A70" FontSize="14" FontWeight="Bold"/>
                </Button>

                <!-- Center content -->
                <StackPanel Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center">

                    <!-- Success icon ring -->
                    <Grid HorizontalAlignment="Center" Margin="0,8,0,20">
                        <!-- Outer glow ring -->
                        <Ellipse Width="96" Height="96" Opacity="0.18">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Icon container -->
                        <Border Width="72" Height="72" CornerRadius="36"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0D3B2A" Offset="0"/>
                                    <GradientStop Color="#0A2E20" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1.5</Border.BorderThickness>
                            <!-- Checkmark -->
                            <Path Data="M9,20.42L2.79,14.21L5.62,11.38L9,14.77L18.88,4.88L21.71,7.71L9,20.42Z"
                                  Fill="#10B981" Width="28" Height="28"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path.Effect>
                                    <DropShadowEffect BlurRadius="10" Color="#10B981" ShadowDepth="0" Opacity="0.6"/>
                                </Path.Effect>
                            </Path>
                        </Border>
                    </Grid>

                    <!-- Label -->
                    <TextBlock Text="DESINSTALAÇÃO CONCLUÍDA"
                               FontSize="11" FontWeight="Black"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"
                               FontFamily="Segoe UI Variable Display, Segoe UI">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>

                    <!-- Title -->
                    <TextBlock x:Name="TitleText"
                               Text="Programas removidos com sucesso"
                               FontSize="24" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="420"
                               Margin="0,0,0,16"
                               FontFamily="Segoe UI Variable Display, Segoe UI"/>

                    <!-- Stats row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">

                        <!-- Total desinstalados -->
                        <Border CornerRadius="10" Padding="16,10" Margin="0,0,12,0"
                                BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0D2A1E" Offset="0"/>
                                    <GradientStop Color="#0A2018" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#10B981" Opacity="0.35"/>
                            </Border.BorderBrush>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="SuccessCountText"
                                           Text="0"
                                           FontSize="28" FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           Foreground="#10B981"/>
                                <TextBlock Text="Desinstalados"
                                           FontSize="11" Foreground="#6B9E8A"
                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Falhas (só aparece se houver) -->
                        <Border x:Name="FailureBadge"
                                CornerRadius="10" Padding="16,10"
                                BorderThickness="1" Visibility="Collapsed">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2A0D0D" Offset="0"/>
                                    <GradientStop Color="#200A0A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FF4B6B" Opacity="0.35"/>
                            </Border.BorderBrush>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="FailureCountText"
                                           Text="0"
                                           FontSize="28" FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           Foreground="#FF4B6B"/>
                                <TextBlock Text="Com falha"
                                           FontSize="11" Foreground="#9E6B6B"
                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Subtitle message -->
                    <TextBlock x:Name="SubtitleText"
                               Text="O sistema foi atualizado e a lista de aplicativos foi reconstruída."
                               FontSize="13" Foreground="#7A7A90"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               Margin="0,0,0,4"
                               LineHeight="20"/>
                </StackPanel>

                <!-- OK Button -->
                <Button Grid.Row="2"
                        x:Name="OkBtn"
                        Content="OK"
                        Style="{StaticResource ModalOkButton}"
                        HorizontalAlignment="Center"
                        Width="200" Height="48"
                        Padding="0"
                        Margin="0,16,0,0"
                        Click="OkButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
