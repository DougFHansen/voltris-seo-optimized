<Window x:Class="VoltrisOptimizer.UI.Windows.RestartConfirmationModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reinício Necessário" Height="480" Width="620" MinWidth="520" MinHeight="440"
        WindowStartupLocation="CenterScreen" 
        AllowsTransparency="True" 
        WindowStyle="None"
        Background="Transparent"
        Topmost="False"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Cores literais do sistema Voltris -->
        <Color x:Key="DarkBgColor">#0A0A0F</Color>
        <Color x:Key="PanelColor">#12121A</Color>
        <Color x:Key="BorderColor">#2A2A3A</Color>
        <Color x:Key="AccentColor">#FF4B6B</Color>
        <Color x:Key="SecondaryColor">#8B31FF</Color>
        <Color x:Key="PrimaryColor">#31A8FF</Color>

        <SolidColorBrush x:Key="DarkBgBrush" Color="#0A0A0F"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#12121A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2A2A3A"/>
        
        <LinearGradientBrush x:Key="VoltrisGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FF4B6B" Offset="0"/>
            <GradientStop Color="#8B31FF" Offset="0.5"/>
            <GradientStop Color="#31A8FF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ModalButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A24"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A3A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252535"/>
                    <Setter Property="BorderBrush" Value="#3A3A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryModalButton" TargetType="Button" BasedOn="{StaticResource ModalButton}">
            <Setter Property="Background" Value="{StaticResource VoltrisGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#0D0D14" CornerRadius="16" BorderBrush="#2A2A3A" BorderThickness="1.5">
        <Grid>
            <!-- Solid Background to prevent transparency issues -->
            <Border Background="#0A0A0F" CornerRadius="15" Margin="1"/>
            
            <!-- Atmospheric Glow (SaaS Style) -->
            <Ellipse Fill="#31A8FF" Width="450" Height="450" Margin="-225,-225,0,0" Opacity="0.12" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#FF4B6B" Width="400" Height="400" Margin="0,0,-200,-200" Opacity="0.12" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>

            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="REINÍCIO NECESSÁRIO" 
                                 FontSize="11" 
                                 FontWeight="Bold" 
                                 Foreground="#31A8FF" 
                                 FontFamily="Segoe UI Variable Display, Segoe UI"/>
                        <Border Width="6" Height="6" CornerRadius="3" Background="#FF4B6B" Margin="10,0,0,0" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#FF4B6B" ShadowDepth="0" Opacity="0.8"/>
                            </Border.Effect>
                        </Border>
                    </StackPanel>
                    
                    <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CancelButton_Click">
                        <TextBlock Text="✕" Foreground="#6B6B80" FontSize="16"/>
                    </Button>
                </Grid>

                <!-- Content -->
                <Grid Grid.Row="1" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">
                        <!-- Icon Container with Voltris Branding -->
                        <Grid Margin="0,0,0,24" HorizontalAlignment="Center">
                            <Border Width="90" Height="90" CornerRadius="45" Background="#151520" BorderBrush="#2A2A3A" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="25" Color="#000000" Opacity="0.4" ShadowDepth="0"/>
                                </Border.Effect>
                            </Border>
                            <Path Fill="{StaticResource VoltrisGradient}" 
                                   Width="36" Height="36"
                                   Stretch="Uniform"
                                   Data="M12,4V1L8,5L12,9V6C15.31,6 18,8.69 18,12C18,13.01 17.75,13.97 17.3,14.8L18.76,16.26C19.54,15.03 20,13.57 20,12C20,7.58 16.42,4 12,4M12,18C8.69,18 6,15.31 6,12C6,10.99 6.25,10.03 6.7,9.2L5.24,7.74C4.46,8.97 4,10.43 4,12C4,16.42 7.58,20 12,20V23L16,19L12,15V18Z">
                                <Path.Effect>
                                    <DropShadowEffect BlurRadius="15" Color="#8B31FF" Opacity="0.4" ShadowDepth="0"/>
                                </Path.Effect>
                            </Path>
                        </Grid>

                        <!-- Título: TextWrapping + FontSize adaptável via ViewBox para nunca cortar -->
                        <Viewbox Stretch="Uniform" MaxHeight="72" Margin="0,0,0,12">
                            <TextBlock x:Name="ModalTitleText"
                                     Text="Finalizar Otimização"
                                     FontSize="26"
                                     FontWeight="Bold"
                                     HorizontalAlignment="Center"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap"
                                     Width="500"
                                     FontFamily="Segoe UI Variable Display, Segoe UI">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="White" Offset="0"/>
                                        <GradientStop Color="#B4B4C0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Viewbox>

                        <TextBlock x:Name="ModalDescriptionText"
                                   Text="Para aplicar as configurações de performance avançadas, seu computador precisa ser reiniciado. Deseja fazer isso agora?" 
                                   Foreground="#9494A0" 
                                   FontSize="14" 
                                   TextWrapping="Wrap" 
                                   TextAlignment="Center" 
                                   HorizontalAlignment="Center"
                                   MaxWidth="460"
                                   LineHeight="22"
                                   FontFamily="Segoe UI Variable, Segoe UI"/>
                    </StackPanel>
                </Grid>

                <!-- Footer / Buttons -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="CANCELAR" Style="{StaticResource ModalButton}" Margin="0,0,8,0" Height="48" Click="CancelButton_Click"/>
                    <Button Grid.Column="1" Content="DEPOIS" Style="{StaticResource ModalButton}" Margin="4,0,4,0" Height="48" Click="RestartLaterButton_Click"/>
                    <Button Grid.Column="2" Content="REINICIAR AGORA" Style="{StaticResource PrimaryModalButton}" Margin="8,0,0,0" Height="48" Click="RestartNowButton_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
