<Window x:Class="VoltrisOptimizer.UI.Windows.OperationQueueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Operação em Andamento" Height="Auto" Width="580" MinHeight="420" MaxHeight="700"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" SizeToContent="Height"
        Topmost="True" ShowInTaskbar="False"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    
    <Border CornerRadius="20" 
            Margin="0"
            ClipToBounds="True"
            Background="#0A0A0F">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" 
                            ShadowDepth="0" 
                            Opacity="0.7" 
                            Color="Black"/>
        </Border.Effect>
        <Border.BorderBrush>
            <SolidColorBrush Color="#1E1E2E"/>
        </Border.BorderBrush>
        <Border.BorderThickness>
            <Thickness>1</Thickness>
        </Border.BorderThickness>
        
        <Grid>
            <!-- Borda sutil com gradiente -->
            <Border CornerRadius="20" 
                   BorderThickness="1"
                   IsHitTestVisible="False">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#25FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#05FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
            </Border>
            
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Ícone de Fila Moderno -->
                <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <!-- Círculo de fundo com gradiente -->
                    <Ellipse Width="80" Height="80" Opacity="0.15">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    
                    <!-- Círculo principal com gradiente Voltris -->
                    <Ellipse Width="64" Height="64">
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    
                    <!-- Ícone de Fila (⏱) -->
                    <Viewbox Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                              Fill="White"/>
                    </Viewbox>
                </Grid>

                <!-- Título -->
                <TextBlock Grid.Row="1" Text="Operação em Andamento" 
                           FontSize="26" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <!-- Progresso da operação atual -->
                <Border Grid.Row="2" Background="#12121A" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="CurrentOperationText" 
                                   Text="Instalando componentes essenciais do Windows..." 
                                   FontSize="14" Foreground="#E0E0E8" TextWrapping="Wrap" 
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        
                        <!-- Barra de progresso -->
                        <Grid Height="8" Margin="0,0,0,8">
                            <Border Background="#1E1E2E" CornerRadius="4"/>
                            <Border x:Name="ProgressBar" HorizontalAlignment="Left" Width="0" 
                                    CornerRadius="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        
                        <Grid>
                            <TextBlock x:Name="ProgressText" Text="75%" 
                                       FontSize="12" Foreground="#B8B8C8" 
                                       HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TimeRemainingText" Text="~1 minuto restante" 
                                       FontSize="12" Foreground="#B8B8C8" 
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Opções -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <StackPanel>
                        <TextBlock Text="O que você deseja fazer?" 
                                   FontSize="15" Foreground="#E0E0E8" FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>

                        <!-- Opção 1: Adicionar à Fila (RECOMENDADO) -->
                        <Border x:Name="Option1Border" Background="#1E1E2E" BorderBrush="#8B31FF" 
                                BorderThickness="2" CornerRadius="14" Padding="20,16" 
                                Margin="0,0,0,12" Cursor="Hand" MouseDown="Option1_Click">
                            <Border.Effect>
                                <DropShadowEffect Color="#8B31FF" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Ícone -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" 
                                        VerticalAlignment="Top" Margin="0,0,16,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF4B6B" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Viewbox Width="20" Height="20">
                                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White"/>
                                    </Viewbox>
                                </Border>

                                <!-- Texto -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Adicionar à Fila" FontSize="16" FontWeight="SemiBold" 
                                               Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Executará automaticamente após a instalação terminar. Você pode explorar o programa enquanto aguarda." 
                                               FontSize="12" Foreground="#B8B8C8" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>

                                <!-- Badge Recomendado -->
                                <Border Grid.Column="2" Background="#00B894" CornerRadius="8" 
                                        Padding="10,4" VerticalAlignment="Top" Margin="8,0,0,0">
                                    <TextBlock Text="RECOMENDADO" FontSize="10" FontWeight="Bold" 
                                               Foreground="White"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Opção 2: Executar Agora (Avançado) -->
                        <Border x:Name="Option2Border" Background="#12121A" BorderBrush="#1E1E2E" 
                                BorderThickness="1" CornerRadius="14" Padding="20,16" 
                                Margin="0,0,0,12" Cursor="Hand" MouseDown="Option2_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Ícone -->
                                <Border Grid.Column="0" Width="40" Height="40" Background="#2E2E3E" 
                                        CornerRadius="10" VerticalAlignment="Top" Margin="0,0,16,0">
                                    <Viewbox Width="20" Height="20">
                                        <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="#FF6B6B"/>
                                    </Viewbox>
                                </Border>

                                <!-- Texto -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Executar Agora" FontSize="16" FontWeight="SemiBold" 
                                                   Foreground="White" Margin="0,0,8,0"/>
                                        <TextBlock Text="(Avançado)" FontSize="12" Foreground="#FF6B6B" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="#B8B8C8" TextWrapping="Wrap" LineHeight="18">
                                        <Run Text="Cancela a instalação e executa imediatamente."/>
                                        <LineBreak/>
                                        <Run Text="⚠️ Alguns jogos podem não funcionar corretamente." Foreground="#FF6B6B"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Opção 3: Agendar para Depois -->
                        <Border x:Name="Option3Border" Background="#12121A" BorderBrush="#1E1E2E" 
                                BorderThickness="1" CornerRadius="14" Padding="20,16" 
                                Cursor="Hand" MouseDown="Option3_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Ícone -->
                                <Border Grid.Column="0" Width="40" Height="40" Background="#2E2E3E" 
                                        CornerRadius="10" VerticalAlignment="Top" Margin="0,0,16,0">
                                    <Viewbox Width="20" Height="20">
                                        <Path Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z" 
                                              Fill="#31A8FF"/>
                                    </Viewbox>
                                </Border>

                                <!-- Texto -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Agendar para Depois" FontSize="16" FontWeight="SemiBold" 
                                               Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock Text="Pula ambas as operações e permite agendar para executar quando você quiser." 
                                               FontSize="12" Foreground="#B8B8C8" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
