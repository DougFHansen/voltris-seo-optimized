<Window x:Class="VoltrisOptimizer.UI.Windows.PurchasePlansWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Escolha seu Plano - Voltris Optimizer"
        Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#A0A0B0"/>
        
        <Style x:Key="PlanButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="1" BorderBrush="#3E3E5E">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#35354F"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#7F30FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="#121216" BorderBrush="#2A2A3C" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Plans -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="24">
                <TextBlock Text="Escolha o Plano Ideal" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="32" Height="32">
                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="#808090" Stretch="Uniform" Margin="8"/>
                </Button>
            </Grid>

            <!-- Plans Container -->
            <Grid Grid.Row="1" Margin="24,0,24,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Standard Plan -->
                <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="12" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="STANDARD" FontSize="14" FontWeight="Bold" Foreground="#31A8FF"/>
                            <TextBlock Text="R$ 99,00" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,8,0,4"/>
                            <TextBlock Text="/ ano" FontSize="14" Foreground="#808090"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Margin="0,24,0,0">
                            <TextBlock Text="✓ 1 Dispositivo" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ Otimização Básica" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ Suporte por Email" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                        </StackPanel>
                        
                        <Button Grid.Row="2" Content="Escolher Standard" Click="BuyStandard_Click" Style="{StaticResource PlanButtonStyle}"/>
                    </Grid>
                </Border>

                <!-- Pro Plan (Highlight) -->
                <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="12" Padding="24" BorderBrush="#7F30FF" BorderThickness="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Background="#7F30FF" CornerRadius="4" Padding="8,2" Margin="0,-36,-12,0">
                            <TextBlock Text="MAIS VENDIDO" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <StackPanel>
                            <TextBlock Text="PRO" FontSize="14" FontWeight="Bold" Foreground="#7F30FF"/>
                            <TextBlock Text="R$ 199,00" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,8,0,4"/>
                            <TextBlock Text="/ ano" FontSize="14" Foreground="#808090"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,24,0,0">
                            <TextBlock Text="✓ 3 Dispositivos" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ Otimização Gamer" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ Suporte Prioritário" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ Limpeza Profunda" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                        </StackPanel>

                        <Button Grid.Row="2" Content="Escolher Pro" Click="BuyPro_Click" Background="#7F30FF" Style="{StaticResource PlanButtonStyle}"/>
                    </Grid>
                </Border>

                <!-- Enterprise Plan -->
                <Border Grid.Column="4" Background="{StaticResource CardBackground}" CornerRadius="12" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="ENTERPRISE" FontSize="14" FontWeight="Bold" Foreground="#FF4B6B"/>
                            <TextBlock Text="R$ 499,00" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,8,0,4"/>
                            <TextBlock Text="/ vitalício" FontSize="14" Foreground="#808090"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,24,0,0">
                            <TextBlock Text="✓ Dispositivos Ilimitados" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ Todas as Otimizações" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ Suporte VIP WhatsApp" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ API de Integração" Foreground="#C0C0D0" Margin="0,0,0,8"/>
                        </StackPanel>

                        <Button Grid.Row="2" Content="Escolher Enterprise" Click="BuyEnterprise_Click" Style="{StaticResource PlanButtonStyle}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
