<Window x:Class="VoltrisOptimizer.UI.Windows.WelcomeLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bem-vindo ao Voltris Optimizer" 
        Height="550" Width="850"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Storyboard x:Key="OnLoaded">
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8"/>
            <ThicknessAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Margin" From="0,40,0,-40" To="0" Duration="0:0:0.6">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoaded}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="MainBorder" CornerRadius="24" BorderThickness="1" Opacity="0">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#40FFFFFF" Offset="0"/>
                <GradientStop Color="#10FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A1A24" Offset="0"/>
                <GradientStop Color="#0D0D14" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid x:Name="MainContent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lado Esquerdo: Visual/Logo -->
            <Border Grid.Column="0" CornerRadius="24,0,0,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#158B31FF" Offset="0"/>
                        <GradientStop Color="#1031A8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                
                <Grid>
                    <!-- Background Pattern -->
                    <Canvas Opacity="0.1">
                        <Ellipse Width="300" Height="300" Fill="#8B31FF" Canvas.Left="-100" Canvas.Top="-100">
                            <Ellipse.Effect>
                                <BlurEffect Radius="100"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Ellipse Width="300" Height="300" Fill="#31A8FF" Canvas.Right="-100" Canvas.Bottom="-100">
                            <Ellipse.Effect>
                                <BlurEffect Radius="100"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Logo Real -->
                        <Grid Width="120" Height="120" Margin="0,0,0,24">
                            <Image Source="pack://application:,,,/Images/voltris.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                        
                        <!-- Título com Branding do Site -->
                        <TextBlock Text="VOLTRIS" FontSize="36" FontWeight="Black" HorizontalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#31A8FF" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#FF4B6B" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="OPTIMIZER" FontSize="14" FontWeight="Bold" Foreground="#80FFFFFF" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                        
                        <!-- Enterprise Box Centralizada e Traduzida -->
                        <Border Background="#10FFFFFF" CornerRadius="16" Padding="15" Margin="0,48,0,0" MaxWidth="360" HorizontalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="PARA EMPRESAS, GAMERS E STREAMERS" Foreground="#31A8FF" FontSize="10" FontWeight="Bold" Margin="0,0,0,8" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                <TextBlock Text="Sincronize suas configurações e gerencie sua licença em tempo real através do nosso Dashboard oficial." 
                                           Foreground="{DynamicResource TextSecondaryBrush}" 
                                           FontSize="13" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lado Direito: Ações -->
            <Grid Grid.Column="1" Margin="48">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Potencialize sua Experiência" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                    <TextBlock Text="Vincule este dispositivo à sua conta Voltris para desbloquear telemetria real e controle centralizado." 
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,32" LineHeight="22"/>

                    <!-- Benefícios -->
                    <StackPanel Margin="0,0,0,40">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#1031A8FF" CornerRadius="8">
                                <Path Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z" 
                                      Fill="#31A8FF" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Sincronização na Nuvem" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text="Suas otimizações salvas em qualquer lugar." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#108B31FF" CornerRadius="8">
                                <Path Data="M3,5A2,2 0 0,1 5,3H19A2,2 0 0,1 21,5V19A2,2 0 0,1 19,21H5C3.89,21 3,20.1 3,19V5M7,7V9H17V7H7M7,11V13H17V11H7M7,15V17H14V15H7Z" 
                                      Fill="#8B31FF" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Dashboard Enterprise" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text="Acompanhe o status do seu PC via Web." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#10FF4B6B" CornerRadius="8">
                                <Path Data="M12,2A2,2 0 0,1 14,4C14,4.74 13.6,5.39 13,5.73V7H14A7,7 0 0,1 21,14H22A1,1 0 0,1 23,15V18A1,1 0 0,1 22,19H21V20A2,2 0 0,1 19,22H5A2,2 0 0,1 3,20V19H2A1,1 0 0,1 1,18V15A1,1 0 0,1 2,14H3A7,7 0 0,1 10,7H11V5.73C10.4,5.39 10,4.74 10,4A2,2 0 0,1 12,2M7.5,13A2.5,2.5 0 0,0 5,15.5A2.5,2.5 0 0,0 7.5,18A2.5,2.5 0 0,0 10,15.5A2.5,2.5 0 0,0 7.5,13M16.5,13A2.5,2.5 0 0,0 14,15.5A2.5,2.5 0 0,0 16.5,18A2.5,2.5 0 0,0 19,15.5A2.5,2.5 0 0,0 16.5,13Z" 
                                      Fill="#FF4B6B" Stretch="Uniform" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Controle Remoto" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text="Otimize, reinicie, desligue e corrija seu PC remotamente." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Botões -->
                    <StackPanel>
                        <Button x:Name="LinkButton" 
                                Content="Vincular Conta Agora" 
                                Style="{StaticResource NeonButtonStyle}" 
                                Height="54" Click="LinkButton_Click"/>
                        
                        <Button x:Name="SkipButton" 
                                Content="Agora Não, continuar sem vincular" 
                                Style="{StaticResource NeonSecondaryButtonStyle}" 
                                Margin="0,16,0,0" Height="48" Click="SkipButton_Click"
                                BorderThickness="0" Background="Transparent"/>
                    </StackPanel>
                </StackPanel>

                <!-- Footer -->
                <TextBlock Text="Você pode vincular sua conta a qualquer momento nas configurações." 
                           VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" Opacity="0.5"/>
                
                <!-- Close Button -->
                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" 
                        Background="Transparent" Foreground="White" 
                        BorderThickness="0" HorizontalAlignment="Right" 
                        VerticalAlignment="Top" Margin="0,-24,-24,0"
                        Width="32" Height="32" Click="SkipButton_Click"
                        Opacity="0.5" Cursor="Hand"/>
            </Grid>
        </Grid>
    </Border>
</Window>
