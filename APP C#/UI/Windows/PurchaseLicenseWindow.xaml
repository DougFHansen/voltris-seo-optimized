<Window x:Class="VoltrisOptimizer.UI.Windows.PurchaseLicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltris Optimizer - Adquirir Licença Pro"
        Height="680"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Window.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                            From="0.95" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                            From="0.95" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
    <Window.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1"/>
    </Window.RenderTransform>
    
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="24"
            MouseDown="TitleBar_MouseDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0D12" Offset="0"/>
                <GradientStop Color="#12121A" Offset="0.5"/>
                <GradientStop Color="#0D0D12" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#25FFFFFF" Offset="0"/>
                <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                <GradientStop Color="#15FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect BlurRadius="60" ShadowDepth="0" Opacity="0.8" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <!-- Background Effects -->
            <Grid IsHitTestVisible="False" ClipToBounds="True">
                <!-- Glow superior -->
                <Ellipse Width="400" Height="400" 
                         HorizontalAlignment="Center" VerticalAlignment="Top"
                         Margin="0,-200,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#30FF4B6B" Offset="0"/>
                            <GradientStop Color="#00FF4B6B" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Glow inferior esquerdo -->
                <Ellipse Width="300" Height="300" 
                         HorizontalAlignment="Left" VerticalAlignment="Bottom"
                         Margin="-100,0,0,-100">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#208B31FF" Offset="0"/>
                            <GradientStop Color="#008B31FF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>
            
            <Grid Margin="32,24,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header com X -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Button HorizontalAlignment="Right"
                            Width="40" Height="40"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CloseButton_Click"
                            ToolTip="Fechar aplicativo">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="CloseBorder" 
                                        Background="#10FFFFFF" 
                                        CornerRadius="10">
                                    <Path Data="M18,6L6,18 M6,6L18,18" 
                                          Stroke="#80FFFFFF"
                                          StrokeThickness="2"
                                          Width="14" Height="14"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBorder" Property="Background" Value="#30EF4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                
                <!-- Ícone e Título -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,28">
                    <!-- Ícone animado -->
                    <Border Width="100" Height="100" CornerRadius="28" 
                            HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#D93654" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#FF4B6B" Opacity="0.5"/>
                        </Border.Effect>
                        <Grid>
                            <!-- Lock icon -->
                            <Path Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"
                                  Fill="White"
                                  Width="48" Height="48"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <!-- Badge Trial Expirado -->
                    <Border Background="#20EF4444" 
                            CornerRadius="20" 
                            Padding="16,6" 
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                        <TextBlock Text="⚠️ TRIAL EXPIRADO"
                                   FontSize="11"
                                   FontWeight="Bold"
                               Foreground="#EF4444"/>
                    </Border>
                    
                    <!-- Título -->
                    <TextBlock Text="Período de Teste Encerrado"
                              FontSize="26"
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Foreground="White"
                              Margin="0,0,0,8"/>
                    
                    <!-- Subtítulo -->
                    <TextBlock Text="Seu período de teste foi encerrado.&#x0a;Para continuar utilizando o Voltris Optimizer, adquira uma licença&#x0a;através do nosso site oficial."
                              FontSize="14"
                              Foreground="#A0A0B0"
                              HorizontalAlignment="Center"
                              TextAlignment="Center"
                              LineHeight="20"/>
                </StackPanel>
                
                <!-- Card de Benefícios -->
                <Border Grid.Row="2" 
                        CornerRadius="16"
                        Margin="0,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#15FFFFFF" Offset="0"/>
                            <GradientStop Color="#08FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#20FFFFFF"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    
                    <StackPanel Margin="24,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="28" Height="28" CornerRadius="8" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="✦" FontSize="14" Foreground="White"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Benefícios da Licença Pro"
                                      FontSize="15"
                                      FontWeight="SemiBold"
                                      Foreground="White"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Lista de benefícios -->
                        <StackPanel Margin="0,0,0,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Otimizações ilimitadas do sistema" FontSize="13" Foreground="#C0C0D0"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Modo Gamer com boost de FPS" FontSize="13" Foreground="#C0C0D0"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Agendamento automático de tarefas" FontSize="13" Foreground="#C0C0D0"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Suporte técnico prioritário 24/7" FontSize="13" Foreground="#C0C0D0"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Atualizações vitalícias incluídas" FontSize="13" Foreground="#C0C0D0"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Botões -->
                <StackPanel Grid.Row="3">
                    <!-- Botão Comprar -->
                    <Button x:Name="BuyButton"
                            Height="56"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Margin="0,0,0,12"
                            Cursor="Hand"
                            Click="BuyButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" 
                                        CornerRadius="14"
                                        Cursor="Hand">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#059669" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#10B981" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal" 
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center">
                                        <!-- Icon: Shopping Cart / External Link -->
                                        <Path Data="M19,4H15.62C15.16,2.83 14,2 12.71,2C11.41,2 10.27,2.83 9.81,4H6.42C5.08,4 4,5.08 4,6.42V17.58C4,18.92 5.08,20 6.42,20H19C20.34,20 21.42,18.92 21.42,17.58V6.42C21.42,5.08 20.34,4 19,4M12.71,4C13.12,4 13.5,4.38 13.5,4.79C13.5,5.21 13.12,5.58 12.71,5.58C12.3,5.58 11.92,5.21 11.92,4.79C11.92,4.38 12.3,4 12.71,4M19,17.58C19,17.79 18.79,18 18.58,18H6.84C6.63,18 6.42,17.79 6.42,17.58V6.42C6.42,6.21 6.63,6 6.84,6H19C19.21,6 19.42,6.21 19.42,6.42V17.58H19Z"
                                              Fill="White"
                                              Width="22" Height="22"
                                              Stretch="Uniform"
                                              Margin="0,0,12,0"/>
                                        <TextBlock Text="Adquirir Licença pelo Site" 
                                                   Foreground="White" 
                                                   FontWeight="SemiBold"
                                                   FontSize="15"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#10B981" Opacity="0.6"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- Botão Já tenho licença -->
                    <Button x:Name="HaveLicenseButton"
                            Height="48"
                            FontSize="14"
                            Margin="0,0,0,12"
                            Cursor="Hand"
                            Click="HaveLicenseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" 
                                        Background="#15FFFFFF"
                                        BorderBrush="#25FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel Orientation="Horizontal" 
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center">
                                        <Path Data="M7,14A2,2 0 0,1 5,12A2,2 0 0,1 7,10A2,2 0 0,1 9,12A2,2 0 0,1 7,14M12.65,10C11.83,7.67 9.61,6 7,6A6,6 0 0,0 1,12A6,6 0 0,0 7,18C9.61,18 11.83,16.33 12.65,14H17V18H21V14H23V10H12.65Z"
                                              Fill="#A0A0B0"
                                              Width="18" Height="18"
                                              Stretch="Uniform"
                                              Margin="0,0,10,0"/>
                                        <TextBlock Text="Já tenho uma licença" 
                                                   Foreground="#D0D0E0" 
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#25FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- Texto de aviso -->
                    <TextBlock Text="O aplicativo será fechado se você não ativar uma licença."
                              FontSize="11"
                              Foreground="#606070"
                              HorizontalAlignment="Center"
                              Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
