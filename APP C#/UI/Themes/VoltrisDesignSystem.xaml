<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- 🎨 VOLTRIS DESIGN SYSTEM - WPF -->
    <!-- Baseado 100% no branding do site voltris.com.br -->
    <!-- Padrão: Enterprise SaaS B2B (Vale do Silício) -->
    <!-- ============================================ -->
    
    <!-- QUALIDADE DE TEXTO GLOBAL -->
    <Style TargetType="TextBlock">
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <!-- ============================================ -->
    <!-- CORES PRIMÁRIAS (GRADIENTE SIGNATURE) -->
    <!-- ============================================ -->
    
    <Color x:Key="BrandBlueColor">#31A8FF</Color>
    <Color x:Key="BrandPurpleColor">#8B31FF</Color>
    <Color x:Key="BrandPinkColor">#FF4B6B</Color>
    <Color x:Key="BrandGreenColor">#00FF94</Color>
    
    <SolidColorBrush x:Key="BrandBlue" Color="{StaticResource BrandBlueColor}"/>
    <SolidColorBrush x:Key="BrandPurple" Color="{StaticResource BrandPurpleColor}"/>
    <SolidColorBrush x:Key="BrandPink" Color="{StaticResource BrandPinkColor}"/>
    <SolidColorBrush x:Key="BrandGreen" Color="{StaticResource BrandGreenColor}"/>

    <!-- ============================================ -->
    <!-- CORES DE FUNDO -->
    <!-- ============================================ -->
    
    <Color x:Key="BgPrimaryColor">#050510</Color>
    <Color x:Key="BgSecondaryColor">#0A0A0F</Color>
    <Color x:Key="BgCardColor">#121218</Color>
    <Color x:Key="BgElevatedColor">#1A1A22</Color>
    <Color x:Key="BgInputColor">#171313</Color>
    
    <SolidColorBrush x:Key="BgPrimary" Color="{StaticResource BgPrimaryColor}"/>
    <SolidColorBrush x:Key="BgSecondary" Color="{StaticResource BgSecondaryColor}"/>
    <SolidColorBrush x:Key="BgCard" Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgElevated" Color="{StaticResource BgElevatedColor}"/>
    <SolidColorBrush x:Key="BgInput" Color="{StaticResource BgInputColor}"/>

    <!-- ============================================ -->
    <!-- CORES DE TEXTO -->
    <!-- ============================================ -->
    
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="TextTertiaryColor">#64748B</Color>
    <Color x:Key="TextMutedColor">#475569</Color>
    
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiary" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}"/>

    <!-- ============================================ -->
    <!-- CORES DE BORDA -->
    <!-- ============================================ -->
    
    <SolidColorBrush x:Key="BorderSubtle" Color="#0DFFFFFF"/>
    <SolidColorBrush x:Key="BorderDefault" Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="BorderHover" Color="#33FFFFFF"/>

    <!-- ============================================ -->
    <!-- CORES DE ESTADO -->
    <!-- ============================================ -->
    
    <SolidColorBrush x:Key="StatusSuccess" Color="#00FF94"/>
    <SolidColorBrush x:Key="StatusWarning" Color="#EAB308"/>
    <SolidColorBrush x:Key="StatusError" Color="#FF4B6B"/>
    <SolidColorBrush x:Key="StatusInfo" Color="#31A8FF"/>

    <!-- ============================================ -->
    <!-- GRADIENTES (SIGNATURE VOLTRIS) -->
    <!-- ============================================ -->
    
    <!-- Gradiente Principal (Horizontal) -->
    <LinearGradientBrush x:Key="VoltrisGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF4B6B" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#31A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradiente Reverso -->
    <LinearGradientBrush x:Key="VoltrisGradientReverse" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#31A8FF" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#FF4B6B" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradiente Vertical -->
    <LinearGradientBrush x:Key="VoltrisGradientVertical" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF4B6B" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#31A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradientes de Fundo (Sutis) -->
    <LinearGradientBrush x:Key="BgGlowBlue" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A31A8FF" Offset="0"/>
        <GradientStop Color="#0A31A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="BgGlowPurple" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A8B31FF" Offset="0"/>
        <GradientStop Color="#0A8B31FF" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="BgGlowPink" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1AFF4B6B" Offset="0"/>
        <GradientStop Color="#0AFF4B6B" Offset="1"/>
    </LinearGradientBrush>

    <!-- ============================================ -->
    <!-- ESTILOS DE BOTÃO ENTERPRISE -->
    <!-- ============================================ -->
    
    <!-- Botão Primário (Gradiente) -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource VoltrisGradient}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Botão Secundário (Outline) -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0DFFFFFF"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#1AFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 👻 BOTÃO GHOST LINK (Underline) -->
    <Style x:Key="GhostLinkButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="Padding" Value="0,2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <TextBlock x:Name="BtnText" 
                               Text="{TemplateBinding Content}"
                               Foreground="{TemplateBinding Foreground}"
                               TextDecorations="Underline"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Adicionando recursos de compatibilidade para o Prepare PC -->
    <SolidColorBrush x:Key="BgCardGlass" Color="#15FFFFFF"/>
    <SolidColorBrush x:Key="BorderLight" Color="#30FFFFFF"/>

    <!-- ============================================ -->
    <!-- ESTILOS DE CARD PREMIUM -->
    <!-- ============================================ -->
    
    <!-- Card com Glassmorphism -->
    <Style x:Key="PremiumCard" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0DFFFFFF" Offset="0"/>
                    <GradientStop Color="#05FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="Padding" Value="24"/>
    </Style>
    
    <!-- Card Elevado -->
    <Style x:Key="ElevatedCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BgCard}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="10" Opacity="0.2" Color="Black" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- ESTILOS DE INPUT -->
    <!-- ============================================ -->
    
    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource BgInput}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrandBlue}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- PROGRESS BAR PREMIUM -->
    <!-- ============================================ -->
    
    <Style x:Key="VoltrisProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="8"/>
        <Setter Property="Background" Value="#1AFFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource VoltrisGradient}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border Name="PART_Track" 
                                CornerRadius="4" 
                                Background="{TemplateBinding Background}"/>
                        <Border Name="PART_Indicator" 
                                CornerRadius="4" 
                                HorizontalAlignment="Left" 
                                Background="{TemplateBinding Foreground}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" 
                                                  ShadowDepth="0" 
                                                  Opacity="0.6" 
                                                  Color="#8B31FF"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- TIPOGRAFIA -->
    <!-- ============================================ -->
    
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="48"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="LineHeight" Value="56"/>
    </Style>
    
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="LineHeight" Value="44"/>
    </Style>
    
    <Style x:Key="H3" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="LineHeight" Value="32"/>
    </Style>
    
    <Style x:Key="Body" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="LineHeight" Value="21"/>
    </Style>
    
    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        <Setter Property="LineHeight" Value="18"/>
    </Style>

    <!-- ============================================ -->
    <!-- ESTILOS PADRONIZADOS DE TEXTO (ENTERPRISE)   -->
    <!-- ============================================ -->
    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource H2}">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource H3}">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock" BasedOn="{StaticResource Body}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ============================================ -->
    <!-- CHECKBOX PREMIUM (TOGGLE MODERNO) -->
    <!-- ============================================ -->
    <Style x:Key="PremiumCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <!-- Toggle Background -->
                        <Border x:Name="ToggleBackground"
                                Width="56"
                                Height="32"
                                CornerRadius="16"
                                Background="#1AFFFFFF"
                                BorderBrush="#1CFFFFFF"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.2" Color="Black"/>
                            </Border.Effect>
                        </Border>
                        
                        <!-- Toggle Circle -->
                        <Border x:Name="ToggleCircle"
                                Width="24"
                                Height="24"
                                CornerRadius="12"
                                Background="White"
                                HorizontalAlignment="Left"
                                Margin="4,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ToggleTransform" X="0"/>
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- Estado Checked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ToggleTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="24"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ToggleBackground"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#00FF94"
                                                        Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ToggleTransform"
                                                         Storyboard.TargetProperty="X"
                                                         To="0"
                                                         Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ToggleBackground"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#1AFFFFFF"
                                                        Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        
                        <!-- Estado Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleBackground" Property="BorderBrush" Value="#33FFFFFF"/>
                        </Trigger>
                        
                        <!-- Estado Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- ESTILOS DE BOTÃO ADICIONAIS -->
    <!-- ============================================ -->
    
    <!-- Alias para PrimaryButton -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>
    
    <!-- Alias para SecondaryButton -->
    <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButton}"/>
    
    <!-- Botão Hyperlink -->
    <Style x:Key="HyperlinkButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostLinkButton}"/>

    <!-- ============================================ -->
    <!-- ESTILOS DE CARD ADICIONAIS -->
    <!-- ============================================ -->
    
    <!-- Alias para PremiumCard -->
    <Style x:Key="CardBorderStyle" TargetType="Border" BasedOn="{StaticResource PremiumCard}"/>
    
    <!-- Card Header Text -->
    <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <!-- ============================================ -->
    <!-- ÍCONE DE HEADER DE PÁGINA -->
    <!-- ============================================ -->
    <Style x:Key="ModernPageHeaderIconStyle" TargetType="ContentControl">
        <Setter Property="Width" Value="64"/>
        <Setter Property="Height" Value="64"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <!-- Círculo de fundo com gradiente -->
                        <Ellipse Width="64" Height="64">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1AFF4B6B" Offset="0"/>
                                    <GradientStop Color="#1A8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#1A31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.4" Color="#8B31FF"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        
                        <!-- Conteúdo (ícone) -->
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- CONVERTERS INLINE -->
    <!-- ============================================ -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    
</ResourceDictionary>
