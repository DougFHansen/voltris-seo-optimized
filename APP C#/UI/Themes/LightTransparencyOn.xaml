<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- LIGHT THEME + TRANSPARÊNCIA ATIVA           -->
    <!-- Sobrescreve brushes light com versões       -->
    <!-- semi-transparentes para efeito acrylic      -->
    <!-- ============================================ -->

    <!-- Fundos semi-transparentes claros -->
    <SolidColorBrush x:Key="DarkBrush"          Color="#B0F8FAFC"/>
    <SolidColorBrush x:Key="DarkPanelBrush"      Color="#C0FFFFFF"/>
    <SolidColorBrush x:Key="DarkPanelAltBrush"   Color="#B8F1F5F9"/>
    <SolidColorBrush x:Key="DarkBorderBrush"      Color="#40E2E8F0"/>
    <Color x:Key="DarkColor">#B0F8FAFC</Color>
    <Color x:Key="DarkPanelColor">#C0FFFFFF</Color>
    <Color x:Key="DarkPanelAltColor">#B8F1F5F9</Color>
    <Color x:Key="DarkBorderColor">#40E2E8F0</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush"  Color="#90F8FAFC"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#D0FFFFFF"/>

    <!-- Cards do Dashboard semi-transparentes no light -->
    <SolidColorBrush x:Key="BgCardGlass"  Color="#C8FFFFFF"/>
    <SolidColorBrush x:Key="BgDark"       Color="#B0F8FAFC"/>
    <SolidColorBrush x:Key="BgCard"       Color="#C8FFFFFF"/>
    <SolidColorBrush x:Key="BgElevated"   Color="#C0F1F5F9"/>
    <SolidColorBrush x:Key="BgInput"      Color="#D0FFFFFF"/>
    <SolidColorBrush x:Key="BgPrimary"    Color="#B0F8FAFC"/>
    <SolidColorBrush x:Key="BgSecondary"  Color="#B8F1F5F9"/>

    <LinearGradientBrush x:Key="DarkGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#B0F8FAFC" Offset="0"/>
        <GradientStop Color="#C0F1F5F9" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
