<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Recursos Locais para Garantir SincronizaÃ§Ã£o de Cor -->
    <LinearGradientBrush x:Key="SidebarBrandGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF4B6B" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#31A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ============================================ -->
    <!-- VOLTRIS PREMIUM SIDEBAR - DESIGN MODERNO    -->
    <!-- Glassmorphism + Neon + AnimaÃ§Ãµes Suaves     -->
    <!-- ============================================ -->
    
    <!-- ============================================ -->
    <!-- ESTILO DO SIDEBAR CONTAINER                 -->
    <!-- ============================================ -->
    <Style x:Key="PremiumSidebarContainerStyle" TargetType="Border">
        <Setter Property="Width" Value="240"/>
        <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="40" 
                                  ShadowDepth="0" 
                                  Color="#000000" 
                                  Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DO HEADER (LOGO SECTION)             -->
    <!-- ============================================ -->
    <Style x:Key="PremiumSidebarHeaderStyle" TargetType="Border">
        <Setter Property="Padding" Value="0,32,0,24"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#20A855F7" Offset="0.3"/>
                    <GradientStop Color="#30A855F7" Offset="0.5"/>
                    <GradientStop Color="#20A855F7" Offset="0.7"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="VersionBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#12FFFFFF"/>
        <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Triggers>
            <!-- OTIMIZAÇÃO PERFORMANCE: Removida animação Forever Bloom/Opacity -->
        </Style.Triggers>
    </Style>

    <Style x:Key="StatusDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Height" Value="6"/>
        <Setter Property="Fill" Value="#10B981"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#10B981" Opacity="0.8"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- OTIMIZAÇÃO PERFORMANCE: Removida animação de BlurRadius no DropShadow (caro d+) -->
        </Style.Triggers>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DO FOOTER (STATUS SECTION)           -->
    <!-- ============================================ -->
    <Style x:Key="PremiumSidebarFooterStyle" TargetType="Border">
        <Setter Property="Padding" Value="20,16,20,16"/>
        <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#20FF007A" Offset="0"/>
                    <GradientStop Color="#308B31FF" Offset="0.5"/>
                    <GradientStop Color="#4000D4FF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DOS RÃ“TULOS DE GRUPO (SAAS STYLE)    -->
    <!-- ============================================ -->
    <Style x:Key="SidebarGroupLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Opacity" Value="0.7"/>
        <Setter Property="Margin" Value="24,24,16,8"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
    </Style>

    <!-- ============================================ -->
    <!-- BOTÃƒO DE NAVEGAÃ‡ÃƒO PREMIUM MODERNO          -->
    <!-- CORREÃ‡ÃƒO: Height="Auto" + MinHeight + Padding adequado para evitar corte de texto -->
    <!-- ============================================ -->
    <Style x:Key="PremiumNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,12,16,12"/>
        <Setter Property="Margin" Value="12,3,12,3"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ControlTemplate.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextWrapping" Value="NoWrap"/>
                            <Setter Property="TextTrimming" Value="None"/>
                            <Setter Property="UseLayoutRounding" Value="True"/>
                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0" Color="Black" BlurRadius="0" Opacity="0"/>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ControlTemplate.Resources>
                    <Grid Background="Transparent">
                        <!-- Background Elevation -->
                        <Border x:Name="BackgroundBorder"
                                Background="Transparent"
                                CornerRadius="12"
                                Margin="0,0,0,0"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="Presenter" 
                                              HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="14,0,14,0">
                                <ContentPresenter.Tag>
                                    <Binding Path="Tag" RelativeSource="{RelativeSource TemplatedParent}"/>
                                </ContentPresenter.Tag>
                            </ContentPresenter>
                        </Border>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BackgroundBorder" Property="Background" Value="#12FFFFFF"/>
                            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
                        </Trigger>
                        
                        <!-- Categorized Icon Colors -->
                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Dashboard">
                             <!-- This trigger is inside Template, so 'Self' is the Button -->
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="Path">
                <Setter Property="Width" Value="20"/>
                <Setter Property="Height" Value="20"/>
                <Setter Property="Stretch" Value="Uniform"/>
                <Setter Property="Margin" Value="0,0,14,0"/>
                <Setter Property="Fill" Value="#707085"/>
                <Setter Property="Stroke" Value="Transparent"/>
                <Setter Property="StrokeThickness" Value="0"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Ãcones Coloridos Baseados no Tag do BotÃ£o -->
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Dashboard">
                        <Setter Property="Fill" Value="#31A8FF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Performance">
                        <Setter Property="Fill" Value="#8B31FF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Cleanup">
                        <Setter Property="Fill" Value="#10B981"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Network">
                        <Setter Property="Fill" Value="#00D4FF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Gamer">
                        <Setter Property="Fill" Value="#FF4B6B"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Diagnostics">
                        <Setter Property="Fill" Value="#F59E0B"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="History">
                        <Setter Property="Fill" Value="#6366F1"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Logs">
                        <Setter Property="Fill" Value="#94A3B8"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="ProfessionalServices">
                        <Setter Property="Fill" Value="#A855F7"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Scheduler">
                        <Setter Property="Fill" Value="#EC4899"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="System">
                        <Setter Property="Fill" Value="#3B82F6"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Repair">
                        <Setter Property="Fill" Value="#F97316"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Security">
                        <Setter Property="Fill" Value="#EF4444"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Privacy">
                        <Setter Property="Fill" Value="#06B6D4"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Debloat">
                        <Setter Property="Fill" Value="#84CC16"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="DeviceInfo">
                        <Setter Property="Fill" Value="#F59E0B"/>
                    </DataTrigger>

                    <!-- Glow no Hover -->
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.4" Color="{Binding Fill.Color, RelativeSource={RelativeSource Self}}"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Style.Resources>
        <Style.Triggers>
             <Trigger Property="IsMouseOver" Value="True">
                 <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
             </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- ============================================ -->
    <!-- BOTÃƒO DE NAVEGAÃ‡ÃƒO ATIVO (PREMIUM)          -->
    <!-- CORREÃ‡ÃƒO: Height="Auto" + MinHeight + Padding adequado -->
    <!-- ============================================ -->
    <Style x:Key="PremiumNavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource PremiumNavButtonStyle}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="Padding" Value="16,12,16,12"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Background="Transparent">
                        <!-- Background Ativo com Gradiente Voltris -->
                        <Border x:Name="BackgroundBorder"
                                CornerRadius="12"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0" Opacity="0.15">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderThickness>0</Border.BorderThickness>
                            
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="14,0,14,0"/>
                        </Border>
                        
                        <!-- Indicador Ativo (Melhorado estilo SaaS) -->
                        <Border x:Name="LeftIndicator"
                                Width="4"
                                Opacity="1"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Height="22"
                                Margin="0,0,0,0"
                                CornerRadius="0,3,3,0"
                                Background="{StaticResource SidebarBrandGradient}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <!-- Sobrescrever o Estilo de Path para o estado ATIVO -->
            <Style TargetType="Path">
                <Setter Property="Width" Value="20"/>
                <Setter Property="Height" Value="20"/>
                <Setter Property="Stretch" Value="Uniform"/>
                <Setter Property="Margin" Value="0,0,14,0"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <!-- No estado ativo, o Ã­cone brilha com sua cor temÃ¡tica -->
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.5" Color="{Binding Fill.Color, RelativeSource={RelativeSource Self}}"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Dashboard">
                        <Setter Property="Fill" Value="#31A8FF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Performance">
                        <Setter Property="Fill" Value="#8B31FF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Cleanup">
                        <Setter Property="Fill" Value="#10B981"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Network">
                        <Setter Property="Fill" Value="#00D4FF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Gamer">
                        <Setter Property="Fill" Value="#FF4B6B"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Diagnostics">
                        <Setter Property="Fill" Value="#F59E0B"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="History">
                        <Setter Property="Fill" Value="#6366F1"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Logs">
                        <Setter Property="Fill" Value="#94A3B8"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="ProfessionalServices">
                        <Setter Property="Fill" Value="#A855F7"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Scheduler">
                        <Setter Property="Fill" Value="#EC4899"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="System">
                        <Setter Property="Fill" Value="#3B82F6"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Repair">
                        <Setter Property="Fill" Value="#F97316"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Security">
                        <Setter Property="Fill" Value="#EF4444"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Privacy">
                        <Setter Property="Fill" Value="#06B6D4"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Debloat">
                        <Setter Property="Fill" Value="#84CC16"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="DeviceInfo">
                        <Setter Property="Fill" Value="#14B8A6"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Shield">
                        <Setter Property="Fill" Value="#8B31FF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Benchmark">
                        <Setter Property="Fill" Value="#F97316"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Personalize">
                        <Setter Property="Fill" Value="#F59E0B"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Display">
                        <Setter Property="Fill" Value="#06B6D4"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Energy">
                        <Setter Property="Fill" Value="#FFAA00"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Style.Resources>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DA SCROLLBAR PREMIUM (SAAS GRADE)    -->
    <!-- ============================================ -->
    <Style x:Key="SidebarScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="IsTabStop" Value="false"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="rectangle"
                            CornerRadius="3"
                            Background="{StaticResource SidebarBrandGradient}"
                            Opacity="0.6"
                            SnapsToDevicePixels="True"
                            Width="5"
                            Margin="0,0,3,0"
                            HorizontalAlignment="Right"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="rectangle" Property="Opacity" Value="0.9"/>
                            <Setter TargetName="rectangle" Property="Width" Value="6"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#8B31FF" Opacity="0.4"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="true">
                            <Setter TargetName="rectangle" Property="Opacity" Value="0.95"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="true"
                               IsEnabled="{TemplateBinding IsMouseOver}">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SidebarScrollBarThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- ESTILO DO SCROLLVIEWER PREMIUM              -->
    <!-- ============================================ -->
    <Style x:Key="PremiumSidebarScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="CanContentScroll" Value="True"/>
        <Setter Property="PanningMode" Value="VerticalOnly"/>
        <Setter Property="Padding" Value="0,0,0,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid x:Name="Grid" Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/> <!-- Gutter reduzido para visual mais limpo -->
                        </Grid.ColumnDefinitions>
                        
                        <!-- ConteÃºdo com Opacity Mask (Efeito SaaS de fade suave nas bordas) -->
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                CanHorizontallyScroll="False"
                                                CanVerticallyScroll="False"
                                                Content="{TemplateBinding Content}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                Grid.Column="0"
                                                Margin="0,0,4,16"
                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            
                        </ScrollContentPresenter>

                        <!-- ScrollBar Ghost: InvisÃ­vel por padrÃ£o, aparece ao interagir -->
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   AutomationProperties.AutomationId="VerticalScrollBar"
                                   Cursor="Arrow"
                                   Grid.Column="1"
                                   Width="6"
                                   Opacity="0"
                                   HorizontalAlignment="Right"
                                   Margin="0,10,2,10"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   Minimum="0"
                                   Orientation="Vertical"
                                   Style="{StaticResource SidebarScrollBarStyle}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"/>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- Trigger: Mostrar ScrollBar apenas quando o mouse estiver sobre o Sidebar -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_VerticalScrollBar"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_VerticalScrollBar"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        
                        <!-- Adicional: Mostrar se estiver arrastando o scroll -->
                        <Trigger SourceName="PART_VerticalScrollBar" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="0.9"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DO STATUS INDICATOR                  -->
    <!-- ============================================ -->
    <Style x:Key="PremiumStatusIndicatorStyle" TargetType="Border">
        <Setter Property="Height" Value="4"/>
        <Setter Property="Background" Value="#1A1A1F"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>
    
    <Style x:Key="PremiumStatusIndicatorFillStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF007A" Offset="0"/>
                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                    <GradientStop Color="#00D4FF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="10" 
                                  ShadowDepth="0" 
                                  Color="#8B31FF" 
                                  Opacity="0.8"/>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>

