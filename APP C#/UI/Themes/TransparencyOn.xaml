<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- TRANSPARÊNCIA ATIVA — DARK MODE             -->
    <!-- Carregado APÓS o tema — sobrescreve fundos  -->
    <!-- com versões semi-transparentes              -->
    <!-- ============================================ -->

    <!-- Fundos principais semi-transparentes (dark) -->
    <SolidColorBrush x:Key="DarkBrush"          Color="#800F0F14"/>
    <SolidColorBrush x:Key="DarkPanelBrush"     Color="#661A1A26"/>
    <SolidColorBrush x:Key="DarkPanelAltBrush"  Color="#73252535"/>
    <SolidColorBrush x:Key="DarkBorderBrush"    Color="#252A2A3A"/>
    <Color x:Key="DarkColor">#800F0F14</Color>
    <Color x:Key="DarkPanelColor">#661A1A26</Color>
    <Color x:Key="DarkPanelAltColor">#73252535</Color>
    <Color x:Key="DarkBorderColor">#252A2A3A</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush"  Color="#3D0A0A0F"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#550D0D15"/>

    <!-- Cards e painéis semi-transparentes (dark) -->
    <SolidColorBrush x:Key="BgCard"        Color="#66121218"/>
    <SolidColorBrush x:Key="BgCardGlass"   Color="#55121218"/>
    <SolidColorBrush x:Key="BgElevated"    Color="#661A1A22"/>
    <SolidColorBrush x:Key="BgInput"       Color="#73171313"/>
    <SolidColorBrush x:Key="BgPrimary"     Color="#66050510"/>
    <SolidColorBrush x:Key="BgSecondary"   Color="#660A0A0F"/>
    <SolidColorBrush x:Key="BgDark"        Color="#660A0A0A"/>
    <SolidColorBrush x:Key="BgHover"       Color="#1AFFFFFF"/>

    <LinearGradientBrush x:Key="DarkGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#660A0A0F" Offset="0"/>
        <GradientStop Color="#7312121A" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#55121218" Offset="0"/>
        <GradientStop Color="#661A1A22" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassCardBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#440D0D15" Offset="0"/>
        <GradientStop Color="#55121218" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassDarkBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#550A0A0F" Offset="0"/>
        <GradientStop Color="#6612121A" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SectionGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#55121218" Offset="0"/>
        <GradientStop Color="#661A1A22" Offset="1"/>
    </LinearGradientBrush>

    <!-- Menu de contexto: sempre sólido -->
    <SolidColorBrush x:Key="ContextMenuBackgroundBrush" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="ContextMenuBorderBrush"     Color="#302A2A3A"/>

</ResourceDictionary>
