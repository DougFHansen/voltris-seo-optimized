<Window x:Class="VoltrisOptimizer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:VoltrisOptimizer.UI.Views"
        xmlns:controls="clr-namespace:VoltrisOptimizer.UI.Controls"
        mc:Ignorable="d"
        Title="Voltris Optimizer - Sistema Profissional de Otimização para Windows 10/11"
        MinHeight="600" MinWidth="850"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderThickness="0"
        BorderBrush="Transparent"
        Icon="pack://application:,,,/Images/favicon.ico"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    
    <Window.Resources>
    </Window.Resources>
    
    <!-- Container principal com bordas arredondadas perfeitas -->
    <Grid x:Name="RootContainer">
        <Grid.Clip>
            <RectangleGeometry x:Name="ClipGeometry" RadiusX="16" RadiusY="16"/>
        </Grid.Clip>
        
        <!-- Fundo base dinâmico — transparente quando acrylic ativo, sólido caso contrário -->
        <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="16"/>
        
        <!-- Borda decorativa com sombra sutil -->
        <Border x:Name="MainBorder"
                BorderThickness="1" 
                BorderBrush="{DynamicResource DarkBorderBrush}"
                CornerRadius="16"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True"
                Background="Transparent">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" 
                                  ShadowDepth="0" 
                                  Opacity="0.4" 
                                  Color="Black"/>
            </Border.Effect>
        </Border>
        
        <!-- Container de conteúdo com clipping perfeito -->
        <Border CornerRadius="16" ClipToBounds="True" Background="Transparent">
        <Grid UseLayoutRounding="True" 
              SnapsToDevicePixels="True" 
              ClipToBounds="True"
              TextOptions.TextFormattingMode="Display"
              TextOptions.TextRenderingMode="ClearType"
              TextOptions.TextHintingMode="Fixed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Efeitos de Blur Decorativos -->
            <Viewbox HorizontalAlignment="Left" 
                     VerticalAlignment="Top"
                     Margin="30,20,0,0"
                     Stretch="Uniform"
                     MaxWidth="350" MaxHeight="350"
                     Grid.RowSpan="2"
                     IsHitTestVisible="False">
                <Ellipse Width="350" Height="350" Opacity="0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="{DynamicResource AccentBlurColor}" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Viewbox>
            
            <Viewbox HorizontalAlignment="Right" 
                     VerticalAlignment="Bottom"
                     Margin="0,0,60,40"
                     Stretch="Uniform"
                     MaxWidth="300" MaxHeight="300"
                     Grid.RowSpan="2"
                     IsHitTestVisible="False">
                <Ellipse Width="300" Height="300" Opacity="0.4">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="{DynamicResource SecondaryBlurColor}" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Viewbox>
            
            <Viewbox HorizontalAlignment="Center" 
                     VerticalAlignment="Center"
                     Stretch="Uniform"
                     MaxWidth="200" MaxHeight="200"
                     Grid.RowSpan="2"
                     IsHitTestVisible="False">
                <Ellipse Width="200" Height="200" Opacity="0.3">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="{DynamicResource PrimaryBlurColor}" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Viewbox>
            
            <!-- Overlay para legibilidade — semi-transparente quando acrylic ativo -->
            <Border Opacity="0.45" CornerRadius="0" Grid.RowSpan="2" IsHitTestVisible="False"
                    Background="{DynamicResource WindowBackgroundBrush}"/>
            
            <!-- ============================================ -->
            <!-- BARRA DE TÍTULO MODERNA -->
            <!-- ============================================ -->
            <Border Grid.Row="0"
                    VerticalAlignment="Top"
                    CornerRadius="15,15,0,0"
                    Background="Transparent">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{DynamicResource DarkBorderColor}"/>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness>0,0,0,1</Thickness>
                </Border.BorderThickness>
                <Grid MinHeight="44" MaxHeight="56">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Logo e Título -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="16,0,12,0">
                        <!-- Ícone da Logo -->
                        <Image Source="pack://application:,,,/Images/voltris.png"
                               MaxWidth="120" MaxHeight="34" 
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Voltris Optimizer"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       TextOptions.TextFormattingMode="Display"
                                       TextOptions.TextRenderingMode="ClearType">
                                <TextBlock.Foreground>
                                    <StaticResource ResourceKey="VoltrisGradientHorizontalBrush"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock x:Name="VersionText"
                                       Text="v1.0.0.9"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="10"
                                       Margin="0,1,0,0"
                                       TextWrapping="NoWrap"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Área arrastável -->
                    <Border Grid.Column="1" 
                            MouseDown="TitleBar_MouseDown"
                            Background="Transparent"
                            Cursor="SizeAll"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
                    
                    <!-- Botões da Barra de Título -->
                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch">
                        <!-- Botão Vincular Conta (Login) -->
                        <Button x:Name="LoginWebButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="LoginWebButton_Click"
                                MinWidth="46"
                                MinHeight="32"
                                ToolTip="Voltris Cloud - Sincronizar Conta">
                            <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z"
                                  Fill="#31A8FF"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Botão Shield -->
                        <Button x:Name="ShieldHeaderButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="ShieldHeaderButton_Click"
                                MinWidth="46"
                                MinHeight="32"
                                ToolTip="Voltris Shield - Proteção do Sistema">
                            <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,3.27L18.53,6.31C18.4,11.23 15.68,15.7 12,17.29C8.32,15.7 5.6,11.23 5.47,6.31L12,3.27Z"
                                  Fill="#8B31FF"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Botão Ativar Licença -->
                        <Button x:Name="ActivateLicenseHeaderButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="ActivateLicenseHeaderButton_Click"
                                MinWidth="46"
                                MinHeight="32"
                                ToolTip="Ativar Licença">
                            <Path Data="M7,14A2,2 0 0,1 5,12A2,2 0 0,1 7,10A2,2 0 0,1 9,12A2,2 0 0,1 7,14M12.65,10C11.83,7.67 9.61,6 7,6A6,6 0 0,0 1,12A6,6 0 0,0 7,18C9.61,18 11.83,16.33 12.65,14H17V18H21V14H23V10H12.65Z"
                                  Fill="#10B981"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </Button>
                        
                        <!-- Botão Tema (Dark/Light) -->
                        <Button x:Name="ThemeToggleButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="ThemeToggleButton_Click"
                                MinWidth="46"
                                MinHeight="32"
                                ToolTip="Alternar Tema">
                            <Path x:Name="ThemeToggleIcon"
                                  Data="M17.75,4.09L15.22,6.03L16.13,9.09L13.5,7.28L10.87,9.09L11.78,6.03L9.25,4.09L12.44,4L13.5,1L14.56,4L17.75,4.09M21.25,11L19.61,12.25L20.2,14.23L18.5,13.06L16.8,14.23L17.39,12.25L15.75,11L17.81,10.95L18.5,9L19.19,10.95L21.25,11M18.97,15.95C19.8,15.87 20.69,17.05 20.16,17.8C19.84,18.25 19.5,18.67 19.08,19.07C15.17,23 8.84,23 4.94,19.07C1.03,15.17 1.03,8.83 4.94,4.93C5.34,4.53 5.76,4.17 6.21,3.85C6.96,3.32 8.14,4.21 8.06,5.04C7.79,7.9 8.75,10.87 10.95,13.06C13.14,15.26 16.1,16.22 18.97,15.95Z"
                                  Fill="#94A3B8"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </Button>

                        <!-- Botão Transparência -->
                        <Button x:Name="TransparencyToggleButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="TransparencyToggleButton_Click"
                                MinWidth="46"
                                MinHeight="32"
                                ToolTip="Alternar Transparência">
                            <Path x:Name="TransparencyToggleIcon"
                                  Data="M12,3C7.05,3 3,7.05 3,12C3,16.95 7.05,21 12,21C16.95,21 21,16.95 21,12C21,7.05 16.95,3 12,3M12,5C15.87,5 19,8.13 19,12C19,15.87 15.87,19 12,19V5Z"
                                  Fill="#94A3B8"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </Button>

                        <Button x:Name="SettingsButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="SettingsButton_Click"
                                MinWidth="46"
                                MinHeight="32"
                                ToolTip="Configurações">
                            <Path Data="{StaticResource SettingsIcon}"
                                  Fill="#94A3B8"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="MinimizeButton_Click"
                                Width="46"
                                Height="32"
                                ToolTip="Minimizar">
                            <Path Data="M4,12 L20,12" 
                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"
                                  Width="12" Height="12"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="MaximizeButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="MaximizeButton_Click"
                                Width="46"
                                Height="32"
                                ToolTip="Maximizar/Restaurar">
                            <Path x:Name="MaximizeIcon"
                                  Data="M4,4 L20,4 L20,20 L4,20 Z" 
                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Width="11" Height="11"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="CloseButton"
                                Style="{StaticResource TitleBarCloseButtonStyle}"
                                Click="CloseButton_Click"
                                Width="46"
                                Height="32"
                                ToolTip="Fechar">
                            <Path Data="M4,4 L20,20 M20,4 L4,20" 
                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"
                                  Width="11" Height="11"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- ============================================ -->
            <!-- CONTEÚDO PRINCIPAL -->
            <!-- ============================================ -->
            <!-- ============================================ -->
            <!-- CONTEÚDO PRINCIPAL (COM SCROLLVIEWER GLOBAL) -->
            <!-- ============================================ -->
            <!-- ============================================ -->
            <!-- CONTEÚDO PRINCIPAL (LAYOUT GRID DIRETO) -->
            <!-- ============================================ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" MinWidth="200"/> <!-- Sidebar: encolhe até 200px -->
                    <ColumnDefinition Width="*" MinWidth="500"/>   <!-- Conteúdo: mínimo 500px -->
                </Grid.ColumnDefinitions>
                
                <!-- ============================================ -->
                <!-- SIDEBAR MODERNA COM TRANSPARÊNCIA PROFISSIONAL -->
                <!-- ============================================ -->
                <Border Grid.Column="0" 
                        VerticalAlignment="Stretch"
                        Style="{StaticResource PremiumSidebarContainerStyle}">
                    
                    <Grid VerticalAlignment="Stretch">
                        <!-- Atmospheric Glow (SaaS Style) -->
                        <Ellipse Width="300" Height="300" 
                                 HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                 Margin="0,0,0,-150" Opacity="0.15"
                                 IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{DynamicResource AccentBlurColor}" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        
                        <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <!-- Header fixo -->
                            <RowDefinition Height="Auto"/>
                            <!-- Scroll area flexível — ocupa todo espaço restante -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Logo e Branding (Modern SaaS Header) -->
                        <Border Grid.Row="0" Style="{StaticResource PremiumSidebarHeaderStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <!-- Logo Container with Enhanced Quality and Size -->
                                <Grid Margin="0,0,0,8">
                                    <Image x:Name="SidebarLogo"
                                           Source="pack://application:,,,/Images/logo.png"
                                           Width="140"
                                           Height="46"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           SnapsToDevicePixels="True"
                                           UseLayoutRounding="True"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Effect>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                                        </Image.Effect>
                                    </Image>
                                </Grid>
                                           
                                <!-- Version Badge (Professional SaaS Style) -->
                                <Border Style="{StaticResource VersionBadgeStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Green Pulse Status Dot -->
                                        <Ellipse Style="{StaticResource StatusDotStyle}"/>
                                        
                                        <TextBlock x:Name="SidebarVersionText"
                                                   Text="ENGINE V1.0.0.9"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Typography.Capitals="AllSmallCaps"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Menu de Navegação Premium com altura controlada e DPI-aware -->
                        <ScrollViewer Grid.Row="1" 
                                      x:Name="SidebarScrollViewer"
                                      Style="{DynamicResource PremiumSidebarScrollViewerStyle}"
                                      VerticalScrollBarVisibility="Auto"
                                      VerticalAlignment="Stretch"
                                      UseLayoutRounding="True"
                                      SnapsToDevicePixels="True">
                            <StackPanel Margin="0,8,0,24"
                                        UseLayoutRounding="True"
                                        SnapsToDevicePixels="True">
                                <!-- SEÇÃO PRINCIPAL -->
                                <TextBlock Text="PRINCIPAL" Style="{StaticResource SidebarGroupLabelStyle}" Margin="24,8,16,6"/>
                                
                                <Button x:Name="NavDashboard" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Dashboard">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource HomeIcon}" Fill="#31A8FF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Dashboard"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavPerformance" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Performance">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource PerformanceIcon}" Fill="#FF4B6B" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Desempenho"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavCleanup" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Cleanup">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource CleanupIcon}" Fill="#10B981" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Limpeza"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavNetwork" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Network">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource NetworkIcon}" Fill="#00D4FF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Rede"/>
                                    </StackPanel>
                                </Button>

                                <!-- SEÇÃO MÓDULOS -->
                                <TextBlock Text="MÓDULOS" Style="{StaticResource SidebarGroupLabelStyle}"/>
                                
                                <Button x:Name="NavGamer" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Gamer">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource GamerIcon}" Fill="#FF6B35" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Gamer"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavShield" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Shield">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource ShieldIcon}" Fill="#8B31FF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Voltris Shield"/>
                                    </StackPanel>
                                </Button>

                                <!-- SEÇÃO STREAMING -->
                                <TextBlock Text="STREAMING" Style="{StaticResource SidebarGroupLabelStyle}"/>

                                <Button x:Name="NavStreamHub" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="StreamHub">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource StreamHubIcon}" Fill="#9146FF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Stream Hub"/>
                                    </StackPanel>
                                </Button>

                                <!-- SEÇÃO FERRAMENTAS -->
                                <TextBlock Text="FERRAMENTAS" Style="{StaticResource SidebarGroupLabelStyle}"/>
                                
                                <Button x:Name="NavPersonalize" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Personalize">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource PersonalizeIcon}" Fill="#F59E0B" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Personalizar" VerticalAlignment="Center" FontWeight="Medium"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavDisplay" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Display">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource DisplayIcon}" Fill="#06B6D4" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Tela" VerticalAlignment="Center" FontWeight="Medium"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavEnergy" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Energy">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M7,2v11h3v9l7-12h-4l4-8H7z"
                                              Fill="#FFAA00" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Energia"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavSecurity" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Security">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource SecurityIcon}" Fill="#EF4444" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Segurança"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavPrivacy" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Privacy">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource PrivacyIcon}" Fill="#A855F7" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Privacidade"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavDebloat" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Debloat">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource DebloatIcon}" Fill="#EC4899" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Debloat"/>
                                    </StackPanel>
                                </Button>

                                <!-- SEÇÃO MONITORAMENTO -->
                                <TextBlock Text="MONITORAMENTO" Style="{StaticResource SidebarGroupLabelStyle}"/>
                                
                                <Button x:Name="NavDeviceInfo" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="DeviceInfo">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource DeviceInfoIcon}" Fill="#14B8A6" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Dispositivo"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavBenchmark" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Benchmark">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource BenchmarkIcon}" Fill="#F97316" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Benchmark"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavDiagnostics" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Diagnostics">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource DiagnosticsIcon}" Fill="#6366F1" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Diagnóstico"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavHistory" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="History">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource HistoryIcon}" Fill="#84CC16" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Histórico"/>
                                    </StackPanel>
                                </Button>

                                <!-- SEÇÃO SERVIÇOS -->
                                <TextBlock Text="SERVIÇOS" Style="{StaticResource SidebarGroupLabelStyle}"/>
                                
                                <Button x:Name="NavScheduler" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Scheduler">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource SchedulerIcon}" Fill="#0EA5E9" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Agendador"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavLogs" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Logs">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource LogsIcon}" Fill="#94A3B8" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Logs"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavProfessionalServices" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="ProfessionalServices">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource ServicesIcon}" Fill="#D946EF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Serviços Pro"/>
                                    </StackPanel>
                                </Button>

                                <!-- SEÇÃO SISTEMA -->
                                <TextBlock Text="SISTEMA" Style="{StaticResource SidebarGroupLabelStyle}"/>
                                
                                <Button x:Name="NavRepair" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="Repair">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource RepairIcon}" Fill="#FB923C" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Reparo"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="NavSystem" Style="{StaticResource PremiumNavButtonStyle}" Click="NavButton_Click" Tag="System">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource SystemIcon}" Fill="#64748B" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                        <TextBlock Text="Sistema"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- ============================================ -->
                <!-- ÁREA DE CONTEÚDO -->
                <!-- ============================================ -->
                <!-- ============================================ -->
                <!-- ÁREA DE CONTEÚDO (COM SCROLLVIEWER INDEPENDENTE) -->
                <!-- ============================================ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Frame de Conteúdo SEM Scroll (Fit-to-Screen) -->
                    <ContentControl x:Name="ContentFrame"
                                    Grid.Row="0"
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    ClipToBounds="True"
                                    MinWidth="400"
                                    Margin="0"
                                    Padding="0"/>
                    
                    <!-- Barra de Progresso Inferior (Seamless) -->
                    <Border Grid.Row="1"
                           Padding="24,8,24,12"
                           CornerRadius="0,0,15,0"
                           Background="Transparent"
                           BorderBrush="#1AFFFFFF"
                           BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Progress Bar Row -->
                                <RowDefinition Height="Auto" MinHeight="18"/> <!-- Status Text Row -->
                            </Grid.RowDefinitions>
                            
                            <!-- Progress Bar com Glow -->
                            <Border Grid.Row="0"
                                    MinHeight="6"
                                    Height="6"
                                    Background="{DynamicResource DarkBorderBrush}"
                                    CornerRadius="3"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center">
                                <Border x:Name="ProgressBarFill"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource VoltrisGradientHorizontalBrush}"
                                        CornerRadius="3"
                                        Width="0"
                                        VerticalAlignment="Stretch"
                                        Height="6">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                                    </Border.Effect>
                                </Border>
                            </Border>
                            
                            <TextBlock x:Name="StatusLabel"
                                       Grid.Row="1"
                                       Text=""
                                       Visibility="Collapsed"
                                       FontSize="12"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       FontWeight="Medium"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        </Border>

        <!-- Modal de Bloqueio Onboarding -->
        <controls:OnboardingLockModal x:Name="LockModal" Grid.RowSpan="2" Panel.ZIndex="9999"/>
    </Grid>
</Window>
