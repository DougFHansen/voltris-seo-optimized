<Window x:Class="VoltrisOptimizer.UI.Views.DlsTutorialPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DLS — Guia Completo"
        Width="780" Height="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="600" MinHeight="500"
        Background="{DynamicResource DarkBrush}">

    <Window.Resources>
        <Style x:Key="TutorialCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="350" Height="350"
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-100,-120,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="90"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,36">

                <!-- ======== HEADER ======== -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B31FF" Offset="0"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="M7,2V13H10V22L17,10H13L17,2H7Z" Fill="White" Width="18" Height="18" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Dynamic Load Stabilizer — Guia Completo"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Entenda como o DLS otimiza seu sistema em tempo real para máxima performance."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Separator Background="#15FFFFFF" Margin="0,14,0,18"/>

                <!-- ======== 1. O QUE É O DLS ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#258B31FF" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M7,2V13H10V22L17,10H13L17,2H7Z" Fill="#8B31FF" Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="O que é o DLS?" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            O Dynamic Load Stabilizer (DLS) é o motor de estabilização inteligente do Voltris Optimizer. Ele monitora continuamente todos os processos do sistema e ajusta prioridades de CPU e I/O em tempo real.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0">
                            Diferente de otimizadores tradicionais que aplicam regras fixas, o DLS usa um conjunto de engines especializados que trabalham em conjunto para garantir que o processo em foco (seu jogo ou aplicativo principal) sempre tenha os recursos necessários.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== 2. COMO FUNCIONA ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#2531A8FF" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"
                                      Fill="#31A8FF" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Como funciona?" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            O DLS opera em ciclos contínuos (a cada 5 segundos por padrão) e executa as seguintes etapas:
                        </TextBlock>
                        <StackPanel Margin="0,10,0,0">
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#1510B981" Margin="0,0,10,0">
                                        <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Coleta telemetria do kernel (CPU, I/O, latência de interrupções)" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#1531A8FF" Margin="0,0,10,0">
                                        <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="#31A8FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Analisa comportamento de cada processo (CPU%, I/O, prioridade)" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#158B31FF" Margin="0,0,10,0">
                                        <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="#8B31FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Aplica decisões inteligentes: throttle, boost, afinidade de cores" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" CornerRadius="6" Background="#15F59E0B" Margin="0,0,10,0">
                                        <TextBlock Text="4" FontSize="11" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Monitora estabilidade e reverte ações se necessário" Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ======== 3. ENGINES ESPECIALIZADOS ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#2510B981" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M17,17H7V7H17M21,11V9H19V7C19,5.89 18.1,5 17,5H15V3H13V5H11V3H9V5H7C5.89,5 5,5.89 5,7V9H3V11H5V13H3V15H5V17A2,2 0 0,0 7,19H9V21H11V19H13V21H15V19H17A2,2 0 0,0 19,17V15H21V13H19V11M9,9H15V15H9V9Z"
                                      Fill="#10B981" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Engines Especializados (DLS 5.0)" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,10">
                            O DLS 5.0 integra múltiplos engines que trabalham em conjunto:
                        </TextBlock>
                        <UniformGrid Columns="2" Margin="0,0,0,0">
                            <Border Background="#0A8B31FF" CornerRadius="8" Padding="12,10" Margin="0,0,6,6">
                                <StackPanel>
                                    <TextBlock Text="🧠 CPU Governor" FontSize="12" FontWeight="Bold" Foreground="#A78BFA"/>
                                    <TextBlock Text="Gerencia prioridades e afinidade de CPU" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0A31A8FF" CornerRadius="8" Padding="12,10" Margin="6,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="💾 I/O Scheduler" FontSize="12" FontWeight="Bold" Foreground="#60A5FA"/>
                                    <TextBlock Text="Otimiza prioridades de leitura/escrita em disco" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0A10B981" CornerRadius="8" Padding="12,10" Margin="0,0,6,6">
                                <StackPanel>
                                    <TextBlock Text="⚡ Input Latency" FontSize="12" FontWeight="Bold" Foreground="#10B981"/>
                                    <TextBlock Text="Reduz latência de input para jogos competitivos" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0AF59E0B" CornerRadius="8" Padding="12,10" Margin="6,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="🌡️ Thermal Power" FontSize="12" FontWeight="Bold" Foreground="#F59E0B"/>
                                    <TextBlock Text="Monitora temperatura e ajusta carga automaticamente" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0AEF4444" CornerRadius="8" Padding="12,10" Margin="0,0,6,6">
                                <StackPanel>
                                    <TextBlock Text="🛡️ Stability Guard" FontSize="12" FontWeight="Bold" Foreground="#EF4444"/>
                                    <TextBlock Text="Protege contra instabilidade e reverte ações perigosas" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0AEC4899" CornerRadius="8" Padding="12,10" Margin="6,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="🚀 Launch Accelerator" FontSize="12" FontWeight="Bold" Foreground="#EC4899"/>
                                    <TextBlock Text="Acelera abertura de programas e jogos" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ======== 4. JOGO EM FOCO ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#25A78BFA" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M21.58,16.09L13.13,7.64C13.02,7.39 12.83,7.18 12.58,7.06L2.05,2.05L7.06,12.58C7.18,12.83 7.39,13.02 7.64,13.13L16.09,21.58L18.83,18.83L21.58,16.09Z"
                                      Fill="#A78BFA" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Jogo em Foco" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            A funcionalidade "Jogo em Foco" permite que você selecione manualmente qual processo deve receber prioridade máxima. Quando definido, o DLS garante que esse processo tenha:
                        </TextBlock>
                        <StackPanel Margin="12,10,0,0">
                            <TextBlock Style="{StaticResource BodyText}">• Prioridade de CPU elevada (AboveNormal ou High)</TextBlock>
                            <TextBlock Style="{StaticResource BodyText}">• Afinidade de cores otimizada para máximo throughput</TextBlock>
                            <TextBlock Style="{StaticResource BodyText}">• Prioridade de I/O elevada para carregamento rápido</TextBlock>
                            <TextBlock Style="{StaticResource BodyText}">• Processos concorrentes automaticamente limitados</TextBlock>
                        </StackPanel>
                        <Border Background="#0A8B31FF" CornerRadius="8" Padding="12,10" Margin="0,12,0,0">
                            <TextBlock Style="{StaticResource BodyText}" Foreground="#A78BFA">
                                💡 Dica: O DLS também detecta jogos automaticamente quando o Modo Gamer está ativo. O "Jogo em Foco" manual é útil para aplicativos que não são detectados automaticamente.
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ======== 5. PERFIS INTELIGENTES ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#25F59E0B" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                      Fill="#F59E0B" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Integração com Perfis Inteligentes" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            O DLS se adapta automaticamente ao perfil inteligente selecionado nas configurações. Cada perfil ajusta os parâmetros do DLS de forma diferente:
                        </TextBlock>
                        <StackPanel Margin="0,10,0,0">
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                                <TextBlock Style="{StaticResource BodyText}">🎮 Gamer Competitivo — Prioridade máxima para jogos, latência mínima</TextBlock>
                            </Border>
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                                <TextBlock Style="{StaticResource BodyText}">🎮 Gamer Single Player — Balanceamento entre FPS e estabilidade</TextBlock>
                            </Border>
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                                <TextBlock Style="{StaticResource BodyText}">💼 Trabalho/Office — Foco em responsividade de aplicativos</TextBlock>
                            </Border>
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                                <TextBlock Style="{StaticResource BodyText}">🎨 Criativo — Otimização para renderização e multithreading</TextBlock>
                            </Border>
                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                                <TextBlock Style="{StaticResource BodyText}">⚖ Balanceado — Otimizações gerais baseadas no hardware</TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ======== 6. DICAS E BOAS PRÁTICAS ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#25EC4899" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z"
                                      Fill="#EC4899" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Dicas e Boas Práticas" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,0">
                            <Border Background="#0A10B981" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                <TextBlock Style="{StaticResource BodyText}" Foreground="#10B981">
                                    ✅ Mantenha o DLS sempre ativo — ele consome menos de 0.1% de CPU e garante estabilidade contínua.
                                </TextBlock>
                            </Border>
                            <Border Background="#0A31A8FF" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                <TextBlock Style="{StaticResource BodyText}" Foreground="#60A5FA">
                                    ✅ Use "Jogo em Foco" quando notar stuttering em um jogo específico que não está sendo detectado automaticamente.
                                </TextBlock>
                            </Border>
                            <Border Background="#0AF59E0B" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                <TextBlock Style="{StaticResource BodyText}" Foreground="#F59E0B">
                                    ⚠️ O DLS protege processos críticos do sistema (svchost, csrss, dwm) e nunca os limita, garantindo estabilidade total.
                                </TextBlock>
                            </Border>
                            <Border Background="#0A8B31FF" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                <TextBlock Style="{StaticResource BodyText}" Foreground="#A78BFA">
                                    ✅ O monitor de "Distribuição de Carga" mostra em tempo real como os cores da CPU estão sendo utilizados.
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ======== BOTÃO FECHAR ======== -->
                <Button x:Name="BtnClose" 
                        Content="Fechar" 
                        Click="BtnClose_Click"
                        HorizontalAlignment="Center"
                        Padding="32,10"
                        Margin="0,8,0,0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#15FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
