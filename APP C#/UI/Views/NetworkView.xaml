<UserControl x:Class="VoltrisOptimizer.UI.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-100,-150,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300" Height="300" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-80,0,0,-80">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,24,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- HEADER SEPARADO E ELEGANTE -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32" HorizontalAlignment="Left">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-15" To="0" Duration="0:0:0.6">
                                        <DoubleAnimation.EasingFunction>
                                            <ExponentialEase EasingMode="EaseOut" Exponent="7"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <TextBlock Text="GERENCIAMENTO DE REDE"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Margin="2,0,0,6"/>
                    
                    <TextBlock Text="Otimização e DNS"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <Rectangle Width="40" Height="3" Fill="{DynamicResource VoltrisGradientBrush}" 
                               HorizontalAlignment="Left" Margin="2,10,0,0" RadiusX="1.5" RadiusY="1.5"/>
                </StackPanel>

                <!-- CARD 1: SELEÇÃO DE INTERFACE E STATUS -->
                <Border Grid.Row="1"
                        Style="{StaticResource PremiumCard}"
                        Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Mini Header do Card -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#2031A8FF" Margin="0,0,12,0">
                                <Path Data="M12,21L15.6,16.2C14.6,15.45 13.35,15 12,15C10.65,15 9.4,15.45 8.4,16.2L12,21M12,3C7.95,3 4.21,4.34 1.2,6.6L3,9C5.5,7.12 8.62,6 12,6C15.38,6 18.5,7.12 21,9L22.8,6.6C19.79,4.34 16.05,3 12,3M12,9C9.3,9 6.81,9.89 4.8,11.4L6.6,13.8C8.1,12.67 9.97,12 12,12C14.03,12 15.9,12.67 17.4,13.8L19.2,11.4C17.19,9.89 14.7,9 12,9Z" 
                                      Fill="{DynamicResource PrimaryBrush}"
                                      Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Status do Adaptador" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Coluna Esquerda: Seleção -->
                            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                <TextBlock Text="Adaptador Ativo" Style="{StaticResource Caption}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="2,0,0,8"/>
                                <ComboBox x:Name="cmbNetworkInterfaces" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="cmbNetworkInterfaces_SelectionChanged"
                                          HorizontalAlignment="Stretch"
                                          MinHeight="45"/>
                                <TextBlock Text="Certifique-se de selecionar a interface que está usando para internet." 
                                           FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5" TextWrapping="Wrap" Margin="2,8,0,0"/>
                            </StackPanel>

                            <!-- Coluna Direita: Detalhes DNS -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- IPv4 -->
                                <Border Grid.Row="0" Grid.Column="0" Background="#08FFFFFF" CornerRadius="10" Padding="12" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="DNS IPv4 Primário" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtIPv4DNSPrimary" Text="Carregando..." FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" Background="#08FFFFFF" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="DNS IPv4 Secundário" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtIPv4DNSSecondary" Text="Carregando..." FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- IPv6 -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#08FFFFFF" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="DNS IPv6 Primário" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtIPv6DNSPrimary" Text="Carregando..." FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Background="#08FFFFFF" CornerRadius="10" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="DNS IPv6 Secundário" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtIPv6DNSSecondary" Text="Carregando..." FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- CARD 2: CONFIGURAÇÃO DE DNS -->
                <Border Grid.Row="2"
                        Style="{StaticResource PremiumCard}"
                        Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#20FF4B6B" Margin="0,0,12,0">
                                <TextBlock Text="⚡" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Otimização de Servidores DNS" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                            <TextBlock Text="Servidor de DNS Recomendado" Style="{StaticResource Caption}" Margin="2,0,0,8"/>
                            <ComboBox x:Name="cmbDNSOptions" 
                                      Style="{StaticResource ModernComboBoxStyle}"
                                      HorizontalAlignment="Stretch"
                                      MinHeight="45"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="2" Columns="2">
                            <Button x:Name="ApplyDNSButton" 
                                    Content="Aplicar DNS" 
                                    Style="{StaticResource NeonButtonStyle}" 
                                    Margin="0,0,10,0"
                                    MinHeight="48"
                                    Click="ApplyDNS_Click"/>
                            <Button x:Name="ResetDNSButton" 
                                    Content="Restaurar Padrão" 
                                    Style="{StaticResource NeonSecondaryButtonStyle}" 
                                    Margin="10,0,0,0"
                                    MinHeight="48"
                                    Click="ResetDefaultDNS_Click"/>
                        </UniformGrid>
                    </Grid>
                </Border>
                
                <!-- CARD 3: OPÇÕES DE REPARO -->
                <Border Grid.Row="3"
                        Style="{StaticResource PremiumCard}"
                        Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#2010B981" Margin="0,0,12,0">
                                <TextBlock Text="⚙️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Ferramentas de Diagnóstico e Reparo" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <CheckBox Grid.Row="0" Grid.Column="0" x:Name="NetworkFlushDNS" Content="Limpar Cache DNS" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="True" Margin="0,0,10,12"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" x:Name="NetworkResetWinsock" Content="Resetar Winsock" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="True" Margin="10,0,0,12"/>
                            <CheckBox Grid.Row="1" Grid.Column="0" x:Name="NetworkResetTCP" Content="Resetar TCP/IP Stack" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="True" Margin="0,0,10,0"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" x:Name="NetworkRenewDHCP" Content="Renovar Concessão DHCP" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="False" Margin="10,0,0,0"/>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- CARD 4: AÇÕES GERAIS -->
                <Border Grid.Row="4"
                        Style="{StaticResource PremiumCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#208B31FF" Margin="0,0,12,0">
                                <TextBlock Text="🚀" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Executar Otimizações" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" x:Name="RunNetworkButton" Content="⚡ Otimizar Conexão" Style="{StaticResource NeonButtonStyle}" MinHeight="52" Click="RunNetworkButton_Click"/>
                            <Button Grid.Column="2" x:Name="OptimizeStackButton" Content="🛡️ Corrigir Erros de Rede" Style="{StaticResource NeonSecondaryButtonStyle}" MinHeight="52" Click="OptimizeStackButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
