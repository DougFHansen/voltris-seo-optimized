<UserControl x:Class="VoltrisOptimizer.UI.Views.DeviceInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="900" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            
            <Storyboard x:Key="EntryAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>

            <!-- Estilo padronizado para labels de cards -->
            <Style x:Key="CardValueHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>

            <!-- Estilo para o título da seção interna do card -->
            <Style x:Key="CardSectionHeaderStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="Margin" Value="0,0,0,16"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{DynamicResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Background Decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" Fill="#0D31A8FF" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-300,-200,0">
                <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,40,32,40">
                
                <!-- HEADER CENTRALIZADO PADRÃO VOLTRIS -->
                <StackPanel Margin="0,0,0,40" HorizontalAlignment="Center">
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                        <ContentControl Style="{StaticResource ModernPageHeaderIconStyle}">
                            <Path Data="{DynamicResource DeviceInfoIcon}" 
                                  Fill="White" 
                                  Width="20" Height="20" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </ContentControl>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="{DynamicResource DeviceInfoIcon}" Fill="{DynamicResource BrandBlue}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="INFORMAÇÕES DO DISPOSITIVO" 
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="12" FontWeight="Black"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrandBlue}"/>
                    </StackPanel>
                    
                    <TextBlock Text="Especificações de Hardware" 
                               Style="{DynamicResource PageTitleTextStyle}"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Monitoramento detalhado dos componentes físicos e do ambiente de execução." 
                               Style="{DynamicResource BodyTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" Opacity="0.7"/>
                </StackPanel>

                <!-- GRID PRINCIPAL - ORGANIZAÇÃO EM LINHAS E COLUNAS PARA ALINHAMENTO -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="20"/> <!-- Gap 1 -->
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="20"/> <!-- Gap 2 -->
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <!-- LINHA 1: Cards Iniciais (Sistema / RAM / Storage Start) -->
                    
                    <!-- SISTEMA -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{DynamicResource PremiumCard}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <StackPanel Style="{StaticResource CardSectionHeaderStyle}">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#1A31A8FF" Margin="0,0,12,0">
                                    <Path Data="{DynamicResource SystemIcon}" Fill="{DynamicResource BrandBlue}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="center" VerticalAlignment="center"/>
                                </Border>
                                <TextBlock Text="Sistema" VerticalAlignment="Center" Style="{DynamicResource SectionTitleTextStyle}" FontSize="13"/>
                            </StackPanel>
                            <TextBlock Text="{Binding OsName}" Style="{StaticResource CardValueHeaderStyle}"/>
                            <TextBlock Text="{Binding OsVersion}" Style="{DynamicResource Caption}" Opacity="0.6"/>
                        </StackPanel>
                    </Border>

                    <!-- MEMÓRIA RAM -->
                    <Border Grid.Row="0" Grid.Column="2" Style="{DynamicResource PremiumCard}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <StackPanel Style="{StaticResource CardSectionHeaderStyle}">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#1A8B31FF" Margin="0,0,12,0">
                                    <Path Data="{DynamicResource IconRam}" Fill="{DynamicResource BrandPurple}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Memória RAM" VerticalAlignment="Center" Style="{DynamicResource SectionTitleTextStyle}" FontSize="13"/>
                            </StackPanel>
                            <TextBlock Text="{Binding RamTotal}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding RamType}" Style="{DynamicResource BodyTextStyle}" Foreground="{DynamicResource BrandPurple}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- ARMAZENAMENTO (Ocupa várias linhas para alinhar com os outros cards menores) -->
                    <Border Grid.Row="0" Grid.RowSpan="5" Grid.Column="4" Style="{DynamicResource PremiumCard}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <StackPanel Style="{StaticResource CardSectionHeaderStyle}">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#1A31A8FF" Margin="0,0,12,0">
                                    <Path Data="{DynamicResource IconDisk}" Fill="{DynamicResource BrandBlue}" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Armazenamento" VerticalAlignment="Center" Style="{DynamicResource SectionTitleTextStyle}" FontSize="14"/>
                            </StackPanel>
                            
                            <ItemsControl ItemsSource="{Binding Drives}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,16" Background="#0AFFFFFF" CornerRadius="12" Padding="14,12">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Letter}" FontWeight="Black" Foreground="{DynamicResource BrandBlue}" FontSize="18" VerticalAlignment="Center" Width="35"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,8,0" MinWidth="0">
                                                        <TextBlock Text="{Binding Model}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="34"/>
                                                        <TextBlock Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource TextMuted}" FontWeight="Medium" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" Background="{DynamicResource BrandBlue}" CornerRadius="4" Padding="6,2" VerticalAlignment="Top" Opacity="0.9">
                                                        <TextBlock Text="{Binding Type}" FontSize="9" FontWeight="Black" Foreground="{DynamicResource TextPrimary}"/>
                                                    </Border>
                                                </Grid>
                                                
                                                <TextBlock Style="{DynamicResource Caption}" Margin="0,4,0,8">
                                                    <Run Text="{Binding FreeSpace}" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/> 
                                                    <Run Text="livres de"/> 
                                                    <Run Text="{Binding TotalSize}"/>
                                                </TextBlock>
                                                
                                                <ProgressBar Value="{Binding UsagePercent}" Style="{DynamicResource VoltrisProgressBar}" Height="4" HorizontalAlignment="Stretch"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- LINHA 2 (Espaçamento via Grid.RowDefinitions) -->

                    <!-- LINHA 3: CPU / Energia -->
                    
                    <!-- PROCESSADOR -->
                    <Border Grid.Row="2" Grid.Column="0" Style="{DynamicResource PremiumCard}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <StackPanel Style="{StaticResource CardSectionHeaderStyle}">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#1AFF4B6B" Margin="0,0,12,0">
                                    <Path Data="{DynamicResource IconCpu}" Fill="{DynamicResource BrandPink}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Processador" VerticalAlignment="Center" Style="{DynamicResource SectionTitleTextStyle}" FontSize="13"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CpuName}" Style="{StaticResource CardValueHeaderStyle}"/>
                            <TextBlock Text="{Binding CpuDetails}" FontSize="11" Foreground="{DynamicResource BrandPink}" FontWeight="Medium" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ENERGIA / BATERIA -->
                    <Border Grid.Row="2" Grid.Column="2" Style="{DynamicResource PremiumCard}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <StackPanel Style="{StaticResource CardSectionHeaderStyle}">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#1AFF4B6B" Opacity="0.8" Margin="0,0,12,0">
                                    <Path Data="{DynamicResource BoltIcon}" Fill="{DynamicResource BrandPink}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Energia" VerticalAlignment="Center" Style="{DynamicResource SectionTitleTextStyle}" FontSize="13"/>
                            </StackPanel>
                            <TextBlock Text="{Binding BatteryStatus}" Style="{StaticResource CardValueHeaderStyle}"/>
                            <TextBlock Text="Estado atual da fonte de alimentação" Style="{DynamicResource Caption}" Opacity="0.6"/>
                        </StackPanel>
                    </Border>

                    <!-- LINHA 5: GPU / Rede -->
                    
                    <!-- PLACA DE VÍDEO -->
                    <Border Grid.Row="4" Grid.Column="0" Style="{DynamicResource PremiumCard}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <StackPanel Style="{StaticResource CardSectionHeaderStyle}">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#1A00FF94" Margin="0,0,12,0">
                                    <Path Data="{DynamicResource GamerIcon}" Fill="{DynamicResource BrandGreen}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Placa de Vídeo" VerticalAlignment="Center" Style="{DynamicResource SectionTitleTextStyle}" FontSize="13"/>
                            </StackPanel>
                            <TextBlock Text="{Binding GpuName}" Style="{StaticResource CardValueHeaderStyle}"/>
                            <TextBlock Text="{Binding GpuDetails}" FontSize="11" Foreground="{DynamicResource BrandGreen}" FontWeight="Medium" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- REDE & CONEXÕES -->
                    <Border Grid.Row="4" Grid.Column="2" Style="{DynamicResource PremiumCard}" VerticalAlignment="Stretch">
                        <StackPanel>
                            <StackPanel Style="{StaticResource CardSectionHeaderStyle}">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#1A31A8FF" Margin="0,0,12,0">
                                    <Path Data="{DynamicResource NetworkIcon}" Fill="{DynamicResource BrandBlue}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Rede" VerticalAlignment="Center" Style="{DynamicResource SectionTitleTextStyle}" FontSize="13"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Networks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Speed}" FontSize="10" Foreground="{DynamicResource BrandBlue}" FontWeight="Black"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Sem conexões ativas" Style="{DynamicResource Caption}" Visibility="{Binding Networks.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}" Opacity="0.6"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- LOADING OVERLAY -->
        <Border Background="#CC000000" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" CornerRadius="0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Style="{DynamicResource VoltrisProgressBar}"/>
                <TextBlock Text="SINCRONIZANDO ESPECIFICAÇÕES..." Foreground="{DynamicResource TextPrimary}" FontWeight="Black" HorizontalAlignment="Center" Margin="0,24,0,0" FontSize="12"/>
                <TextBlock Text="Aguarde enquanto o Voltris perfila seu Hardware" Style="{DynamicResource Caption}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>


