<UserControl x:Class="VoltrisOptimizer.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextFormattingMode="Display"
             RenderOptions.BitmapScalingMode="HighQuality"
             RenderOptions.ClearTypeHint="Enabled">
    
    <UserControl.Resources>
        <!-- Estilo para cards de configuração - TAMANHO ADEQUADO -->
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <!-- Estilo para título de seção - TAMANHO ADEQUADO -->
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        
        <!-- Estilo para descrição - TAMANHO ADEQUADO -->
        <Style x:Key="SettingsSectionDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <!-- Estilo para ícone - TAMANHO ADEQUADO -->
        <Style x:Key="SettingsIconStyle" TargetType="Border">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- Toggle Switch Style Moderno -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Track" 
                                    Width="50" 
                                    Height="28" 
                                    CornerRadius="14" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#40FFFFFF"
                                    BorderThickness="1">
                                <Ellipse x:Name="Thumb" 
                                         Width="22" 
                                         Height="22" 
                                         Margin="3,0,0,0" 
                                         HorizontalAlignment="Left" 
                                         VerticalAlignment="Center" 
                                         Fill="White">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#059669" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#10B981"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-150,-150,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <!-- LAYOUT RESPONSIVO COM SCROLL -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0"
                      Margin="0"
                      UseLayoutRounding="True"
                      SnapsToDevicePixels="True">
            <Grid MaxWidth="1400" MinWidth="600" Margin="24,16,24,24" 
                  HorizontalAlignment="Center"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <!-- Ícone -->
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6B7280" Offset="0"/>
                                <GradientStop Color="#4B5563" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#6B7280" Opacity="0.45"/>
                        </Border.Effect>
                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                              Fill="White"
                              Width="24" Height="24"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Configurações"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold"
                                  HorizontalAlignment="Left">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Personalize o comportamento do Voltris Optimizer"
                                  FontSize="13"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,4,0,0"
                                  HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Conteúdo das Configurações -->
                <StackPanel Grid.Row="1" Margin="0,0,0,0">
                    
                    <!-- Seção de Conta Voltris -->
                    <Border x:Name="AccountSection" Style="{StaticResource SettingsCardStyle}" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EC4899" Offset="0"/>
                                        <GradientStop Color="#DB2777" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="👤" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Conta Enterprise" Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock x:Name="AccountEmailText" Text="Gerencie o vínculo com sua conta Voltris na nuvem" Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="UnlinkButton"
                                            Height="38" 
                                            Padding="18,0" 
                                            HorizontalAlignment="Left"
                                            Click="UnlinkDevice_Click"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#20EF4444" Offset="0"/>
                                                            <GradientStop Color="#30DC2626" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="#FFEF4444"/>
                                                <Setter Property="BorderBrush" Value="#60EF4444"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="8"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock Text="🚪" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background">
                                                                        <Setter.Value>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                <GradientStop Color="#40EF4444" Offset="0"/>
                                                                                <GradientStop Color="#50DC2626" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#80EF4444"/>
                                                                    <Setter Property="Foreground" Value="#FFFEF2F2"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background">
                                                                        <Setter.Value>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                <GradientStop Color="#60DC2626" Offset="0"/>
                                                                                <GradientStop Color="#70B91C1C" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#A0EF4444"/>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="Desvincular deste Computador" FontWeight="SemiBold"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Link Account Section (When not linked) -->
                    <Border x:Name="LinkAccountSection" Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#4338CA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="☁️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Voltris Cloud" Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Vincule seu dispositivo para gerenciar remotamente e sincronizar otimizações." Style="{StaticResource SettingsSectionDesc}"/>

                                <Button Content="Vincular agora ao Voltris Cloud" 
                                        Height="36" Padding="20,0" Margin="0,4,0,0" HorizontalAlignment="Left"
                                        Style="{StaticResource NeonButtonStyle}"
                                        Click="LinkAccount_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Seção de Idioma -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#1D4ED8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🌐" FontSize="16" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                                <!-- Idioma COMPACTO -->
                                <StackPanel Grid.Column="1" Margin="0,0,0,0">
                                    <TextBlock Text="Idioma do Aplicativo" 
                                             Style="{StaticResource SettingsSectionTitle}"/>
                                    <TextBlock Text="Selecione o idioma da interface." 
                                             Style="{StaticResource SettingsSectionDesc}"/>
                                    
                                    <WrapPanel Margin="0,4,0,0">
                                        <RadioButton x:Name="RadioPortuguese"
                                                   Content="Português"
                                                   IsChecked="True"
                                                   GroupName="Language"
                                                   Style="{StaticResource ModernRadioButtonStyle}"
                                                   Checked="RadioPortuguese_Checked"
                                                   Margin="0,0,12,4"/>
                                        
                                        <RadioButton x:Name="RadioSpanish"
                                                   Content="Español"
                                                   Style="{StaticResource ModernRadioButtonStyle}"
                                                   GroupName="Language"
                                                   Checked="RadioSpanish_Checked"
                                                   Margin="0,0,12,4"/>
                                        
                                        <RadioButton x:Name="RadioEnglish"
                                                   Content="English"
                                                   Style="{StaticResource ModernRadioButtonStyle}"
                                                   GroupName="Language"
                                                   Checked="RadioEnglish_Checked"
                                                   Margin="0,0,12,4"/>
                                    </WrapPanel>
                                </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Perfil Inteligente -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                        <GradientStop Color="#D97706" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🧠" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding IntelligentProfileTitle, FallbackValue='Perfil Inteligente'}" Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="{Binding IntelligentProfileDesc, FallbackValue='Define como o motor AI deve priorizar as otimizações do sistema'}" Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <ComboBox x:Name="ProfileCombo" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          HorizontalAlignment="Stretch"
                                          MaxWidth="400"
                                          SelectionChanged="ProfileCombo_SelectionChanged">
                                    <ComboBoxItem Content="{Binding ProfileGamerCompetitiveText, FallbackValue='🎮 Gamer Competitivo'}">
                                        <ComboBoxItem.ToolTip>
                                            <ToolTip MaxWidth="350">
                                                <StackPanel>
                                                    <TextBlock Text="🎮 Perfil Gamer Competitivo" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                                                        <Run Text="Otimizações aplicadas:" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Prioridade GPU = 8 (máxima)</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Prioridade de processos de jogos = 6</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Redução de latência de input</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">• Otimizações de memória e CPU</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Foreground="#10B981">
                                                        <Run Text="Ganho esperado:" FontWeight="SemiBold"/>
                                                        <Run Text=" 5-15% em latência"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </ComboBoxItem.ToolTip>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="{Binding ProfileGamerSinglePlayerText, FallbackValue='🎯 Gamer Single Player'}">
                                        <ComboBoxItem.ToolTip>
                                            <ToolTip MaxWidth="350">
                                                <StackPanel>
                                                    <TextBlock Text="🎯 Perfil Gamer Single Player" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                                                        <Run Text="Otimizações aplicadas:" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Prioridade GPU = 7 (alta)</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Prioridade de processos de jogos = 5</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Otimizações para mundo aberto</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">• Otimizações de memória e CPU</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Foreground="#10B981">
                                                        <Run Text="Ganho esperado:" FontWeight="SemiBold"/>
                                                        <Run Text=" 3-10% em performance"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </ComboBoxItem.ToolTip>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="{Binding ProfileWorkOfficeText, FallbackValue='💼 Trabalho / Office'}">
                                        <ComboBoxItem.ToolTip>
                                            <ToolTip MaxWidth="350">
                                                <StackPanel>
                                                    <TextBlock Text="💼 Perfil Trabalho / Office" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                                                        <Run Text="Otimizações aplicadas:" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• MaxCmds = 100 (mais conexões simultâneas)</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Estabilidade de rede SMB</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Foco em serviços essenciais</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">• Otimizações de memória e CPU</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Foreground="#10B981">
                                                        <Run Text="Ganho esperado:" FontWeight="SemiBold"/>
                                                        <Run Text=" 10-20% em performance de rede"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </ComboBoxItem.ToolTip>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="{Binding ProfileCreativeVideoEditingText, FallbackValue='🎬 Vídeo / Design'}">
                                        <ComboBoxItem.ToolTip>
                                            <ToolTip MaxWidth="350">
                                                <StackPanel>
                                                    <TextBlock Text="🎬 Perfil Vídeo / Design" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                                                        <Run Text="Otimizações aplicadas:" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Win32PrioritySeparation = 24</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Balanceamento foreground/background</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Otimização multithreading</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">• Otimizações de memória e CPU</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Foreground="#10B981">
                                                        <Run Text="Ganho esperado:" FontWeight="SemiBold"/>
                                                        <Run Text=" 8-12% em renderização"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </ComboBoxItem.ToolTip>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="{Binding ProfileDeveloperProgrammingText, FallbackValue='💻 Programação / Dev'}">
                                        <ComboBoxItem.ToolTip>
                                            <ToolTip MaxWidth="350">
                                                <StackPanel>
                                                    <TextBlock Text="💻 Perfil Programação / Dev" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                                                        <Run Text="Otimizações aplicadas:" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Otimizações para IDEs e compiladores</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Prioridade para processos de build</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,2">• Gestão avançada de memória</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">• Otimizações de disco e I/O</TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Foreground="#10B981">
                                                        <Run Text="Ganho esperado:" FontWeight="SemiBold"/>
                                                        <Run Text=" 5-15% em performance de build"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </ComboBoxItem.ToolTip>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="{Binding ProfileEnterpriseSecureText, FallbackValue='🏢 Enterprise Seguro'}">
                                        <ComboBoxItem.ToolTip>
                                            <ToolTip MaxWidth="350">
                                                <StackPanel>
