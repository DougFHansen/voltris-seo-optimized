                                                      Fill="#60A5FA" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="PROCESSOS OTIMIZADOS AGORA" 
                                                           FontSize="10" FontWeight="Bold" Foreground="#60A5FA" Opacity="0.9"/>
                                            </StackPanel>
                                            
                                            <Border CornerRadius="10" BorderThickness="1" MinHeight="90" Padding="4">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#08FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#04FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="White" Opacity="0.06"/>
                                                </Border.BorderBrush>
                                                <ListBox x:Name="DlsOptimizedList" 
                                                         Background="Transparent" 
                                                         BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         Padding="4">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#10FFFFFF" CornerRadius="8" Padding="10,7" Margin="0,2">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="22" Height="22" CornerRadius="6" Background="#1510B981" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                        <Path Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z"
                                                                              Fill="#10B981" Width="10" Height="10" Stretch="Uniform"
                                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{Binding ProcessName}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                                    <Border Grid.Column="2" CornerRadius="4" Background="#1510B981" Padding="6,2">
                                                                        <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                            
                                            <!-- Monitor de Cores -->
                                            <StackPanel Orientation="Horizontal" Margin="0,18,0,8">
                                                <Path Data="M17,17H7V7H17M21,11V9H19V7C19,5.89 18.1,5 17,5H15V3H13V5H11V3H9V5H7C5.89,5 5,5.89 5,7V9H3V11H5V13H3V15H5V17A2,2 0 0,0 7,19H9V21H11V19H13V21H15V19H17A2,2 0 0,0 19,17V15H21V13H19V11M9,9H15V15H9V9Z"
                                                      Fill="#F59E0B" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="DISTRIBUIÇÃO DE CARGA (CPU CORES)" 
                                                           FontSize="10" FontWeight="Bold" Foreground="#F59E0B" Opacity="0.9"/>
                                            </StackPanel>
                                            <ItemsControl x:Name="DlsCoreUsage">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>

                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Ajuda e Tutorial -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EC4899" Offset="0"/>
                                        <GradientStop Color="#DB2777" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📚" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ajuda e Tutorial"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Revise o tutorial interativo para aprender todas as funcionalidades"
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <Button x:Name="ShowOnboardingButton"
                                        Content="📖 Ver Tutorial Novamente"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Height="44"
                                        HorizontalAlignment="Left"
                                        Padding="24,0"
                                        Click="ShowOnboardingButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Atualizações -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8B31FF" Offset="0"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🚀" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Atualizações"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Verifique se há novas versões do Voltris Optimizer"
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <!-- Info de Versão -->
                                <Border Background="{DynamicResource DarkPanelAltBrush}"
                                        CornerRadius="10"
                                        Padding="14"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="📦" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="CurrentVersionText"
                                                       Text="Versão atual: Carregando..."
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✅" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="UpdateStatusText"
                                                       Text="Você está usando a versão mais recente"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource SuccessBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <WrapPanel>
                                    <Button x:Name="CheckUpdatesButton"
                                            Content="🔍 Verificar Atualizações"
                                            Style="{StaticResource NeonButtonStyle}"
                                            Height="44"
                                            Padding="20,0"
                                            Margin="0,0,10,10"
                                            Click="CheckUpdatesButton_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Suporte -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#25D366" Offset="0"/>
                                        <GradientStop Color="#128C7E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="💬" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Suporte Premium"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Precisa de ajuda dedicada ou quer sugerir melhorias? Fale diretamente com nossa equipe."
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <Button x:Name="SupportButton"
                                        Content="📱 Suporte Premium"
                                        Style="{StaticResource NeonButtonStyle}"
                                        Height="44"
                                        Padding="24,0"
                                        HorizontalAlignment="Left"
                                        Click="SupportButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                     From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
