<UserControl x:Class="VoltrisOptimizer.UI.Views.BenchmarkPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="900"
             Background="{DynamicResource DarkBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-150,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300" Height="300" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-80,0,0,-80">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,32">
            <Grid Margin="28,24,28,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Botões -->
                    <RowDefinition Height="Auto"/> <!-- Progresso -->
                    <RowDefinition Height="Auto"/> <!-- Score Global -->
                    <RowDefinition Height="Auto"/> <!-- Resultados Detalhados -->
                    <RowDefinition Height="Auto"/> <!-- Comparação -->
                    <RowDefinition Height="Auto"/> <!-- Throttling -->
                    <RowDefinition Height="Auto"/> <!-- Tutorial Inline -->
                </Grid.RowDefinitions>

                <!-- ============================================ -->
                <!-- HEADER -->
                <!-- ============================================ -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center" Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B31FF" Offset="0"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#8B31FF" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="{StaticResource BenchmarkIcon}" 
                              Fill="White" Width="20" Height="20" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Benchmark Profissional"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Análise avançada de desempenho com medições reais do sistema"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- ============================================ -->
                <!-- BOTÕES PRINCIPAIS -->
                <!-- ============================================ -->
                <Border Grid.Row="1" Background="{DynamicResource DarkPanelBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="16,14" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Benchmark Inicial -->
                        <Button Grid.Column="0" x:Name="BtnInitial" Click="BtnInitial_Click"
                                IsEnabled="{Binding IsNotRunning}" MinHeight="56" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="10" Padding="12,10"
                                                        Background="#1531A8FF" BorderBrush="#3031A8FF" BorderThickness="1">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border Width="28" Height="28" CornerRadius="7" Background="#2531A8FF" HorizontalAlignment="Center">
                                                            <Path Data="{StaticResource BenchmarkIcon}" Fill="#31A8FF" Width="14" Height="14" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Benchmark Inicial" FontSize="11.5" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#2531A8FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Benchmark Final -->
                        <Button Grid.Column="2" x:Name="BtnFinal" Click="BtnFinal_Click"
                                IsEnabled="{Binding IsNotRunning}" MinHeight="56" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="10" Padding="12,10"
                                                        Background="#158B31FF" BorderBrush="#308B31FF" BorderThickness="1">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border Width="28" Height="28" CornerRadius="7" Background="#258B31FF" HorizontalAlignment="Center">
                                                            <Path Data="{StaticResource PerformanceIcon}" Fill="#8B31FF" Width="14" Height="14" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Benchmark Final" FontSize="11.5" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#258B31FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Comparar Resultados -->
                        <Button Grid.Column="4" x:Name="BtnCompare" Click="BtnCompare_Click"
                                IsEnabled="{Binding CanCompare}" MinHeight="56" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="10" Padding="12,10"
                                                        Background="#15FF4B6B" BorderBrush="#30FF4B6B" BorderThickness="1">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border Width="28" Height="28" CornerRadius="7" Background="#25FF4B6B" HorizontalAlignment="Center">
                                                            <Path Data="M9,3L5,6.99H8V14H10V6.99H13L9,3M16,17.01V10H14V17.01H11L15,21L19,17.01H16Z" Fill="#FF4B6B" Width="14" Height="14" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Comparar" FontSize="11.5" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#25FF4B6B"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Benchmark Completo -->
                        <Button Grid.Column="6" x:Name="BtnComplete" Click="BtnComplete_Click"
                                IsEnabled="{Binding IsNotRunning}" MinHeight="56" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="10" Padding="12,10">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#208B31FF" Offset="0"/>
                                                            <GradientStop Color="#2031A8FF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#408B31FF" Offset="0"/>
                                                            <GradientStop Color="#4031A8FF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>1</Border.BorderThickness>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border Width="28" Height="28" CornerRadius="7" HorizontalAlignment="Center">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#308B31FF" Offset="0"/>
                                                                    <GradientStop Color="#3031A8FF" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <Path Data="{StaticResource BoltIcon}" Fill="White" Width="14" Height="14" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Benchmark Completo" FontSize="11.5" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Tutorial -->
                        <Button Grid.Column="8" x:Name="BtnTutorial" Click="BtnTutorial_Click"
                                MinHeight="56" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="10" Padding="12,10"
                                                        Background="#15EAB308" BorderBrush="#30EAB308" BorderThickness="1">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border Width="28" Height="28" CornerRadius="7" Background="#25EAB308" HorizontalAlignment="Center">
                                                            <Path Data="{StaticResource LogsIcon}" Fill="#EAB308" Width="14" Height="14" Stretch="Uniform"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="Tutorial" FontSize="11.5" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#25EAB308"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- ============================================ -->
                <!-- PROGRESSO EM TEMPO REAL -->
                <!-- ============================================ -->
                <Border Grid.Row="2" Background="{DynamicResource DarkPanelBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="20,14" Margin="0,0,0,16"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtStatus" Text="Aguardando..." FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                            <TextBlock x:Name="TxtPercent" Text="0%" Grid.Column="1"
                                       Foreground="{DynamicResource BrandBlue}" FontWeight="Bold" FontSize="13"/>
                        </Grid>
                        <ProgressBar x:Name="ProgressBenchmark" Height="6" Maximum="100" Value="0"
                                     Foreground="{DynamicResource BrandBlue}"
                                     Background="#15FFFFFF" BorderThickness="0"/>
                        <TextBlock Text="⚠️ Não utilize o computador durante o benchmark para garantir precisão."
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ============================================ -->
                <!-- SCORE GLOBAL -->
                <!-- ============================================ -->
                <Border Grid.Row="3" x:Name="PanelScore" Visibility="Collapsed"
                        Margin="0,0,0,16" CornerRadius="14" Padding="24,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#15FF4B6B" Offset="0"/>
                            <GradientStop Color="#158B31FF" Offset="0.5"/>
                            <GradientStop Color="#1531A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#40FF4B6B" Offset="0"/>
                            <GradientStop Color="#408B31FF" Offset="0.5"/>
                            <GradientStop Color="#4031A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                            <TextBlock Text="SCORE GLOBAL" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtOverallScore" Text="0.00" FontSize="42" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock x:Name="TxtScoreLabel" Text="" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <!-- CPU -->
                            <TextBlock Grid.Row="0" Text="CPU (35%)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Row="0" Grid.Column="1" x:Name="BarCpu" Height="8" Maximum="100" Value="0"
                                         Foreground="#FF4B6B" Background="#15FFFFFF" BorderThickness="0" Margin="8,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="TxtCpuScore" Text="--" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>

                            <!-- Memory -->
                            <TextBlock Grid.Row="1" Text="Memória (20%)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            <ProgressBar Grid.Row="1" Grid.Column="1" x:Name="BarMemory" Height="8" Maximum="100" Value="0"
                                         Foreground="#8B31FF" Background="#15FFFFFF" BorderThickness="0" Margin="8,6,8,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="TxtMemoryScore" Text="--" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right" Margin="0,6,0,0"/>

                            <!-- Disk -->
                            <TextBlock Grid.Row="2" Text="Disco (25%)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            <ProgressBar Grid.Row="2" Grid.Column="1" x:Name="BarDisk" Height="8" Maximum="100" Value="0"
                                         Foreground="#31A8FF" Background="#15FFFFFF" BorderThickness="0" Margin="8,6,8,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="TxtDiskScore" Text="--" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right" Margin="0,6,0,0"/>

                            <!-- Scheduler -->
                            <TextBlock Grid.Row="3" Text="Scheduler (10%)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            <ProgressBar Grid.Row="3" Grid.Column="1" x:Name="BarScheduler" Height="8" Maximum="100" Value="0"
                                         Foreground="#10B981" Background="#15FFFFFF" BorderThickness="0" Margin="8,6,8,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="TxtSchedulerScore" Text="--" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right" Margin="0,6,0,0"/>

                            <!-- UI -->
                            <TextBlock Grid.Row="4" Text="UI (10%)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,6,0,0"/>
                            <ProgressBar Grid.Row="4" Grid.Column="1" x:Name="BarUi" Height="8" Maximum="100" Value="0"
                                         Foreground="#EAB308" Background="#15FFFFFF" BorderThickness="0" Margin="8,6,8,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="TxtUiScore" Text="--" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right" Margin="0,6,0,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ============================================ -->
                <!-- PAINEL DE COMPARAÇÃO ANTES/DEPOIS -->
                <!-- ============================================ -->
                <Border Grid.Row="5" x:Name="PanelComparison" Visibility="Collapsed"
                        Background="{DynamicResource DarkPanelBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="20,16" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="26" Height="26" CornerRadius="6" Background="#25FF4B6B" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M9,3L5,6.99H8V14H10V6.99H13L9,3M16,17.01V10H14V17.01H11L15,21L19,17.01H16Z" Fill="#FF4B6B" Width="12" Height="12" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Comparação Antes / Depois" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <TextBlock Grid.Row="0" Text="MÉTRICA" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="ANTES" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="DEPOIS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="GANHO" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>

                            <Separator Grid.Row="1" Grid.ColumnSpan="5" Background="#15FFFFFF" Margin="0,6"/>

                            <!-- CPU -->
                            <TextBlock Grid.Row="2" Text="CPU" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="CmpCpuBefore" Text="--" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" x:Name="CmpCpuAfter" Text="--" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" x:Name="CmpCpuGain" Text="--" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>

                            <!-- Memory -->
                            <TextBlock Grid.Row="3" Text="Memória" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="CmpMemBefore" Text="--" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" x:Name="CmpMemAfter" Text="--" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="3" Grid.Column="4" x:Name="CmpMemGain" Text="--" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>

                            <!-- Disk -->
                            <TextBlock Grid.Row="4" Text="Disco" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,4"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="CmpDiskBefore" Text="--" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="4" Grid.Column="3" x:Name="CmpDiskAfter" Text="--" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="4" Grid.Column="4" x:Name="CmpDiskGain" Text="--" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>

                            <!-- Scheduler -->
                            <TextBlock Grid.Row="5" Text="Scheduler" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,4"/>
                            <TextBlock Grid.Row="5" Grid.Column="2" x:Name="CmpSchedBefore" Text="--" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="5" Grid.Column="3" x:Name="CmpSchedAfter" Text="--" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="5" Grid.Column="4" x:Name="CmpSchedGain" Text="--" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>

                            <!-- Overall -->
                            <TextBlock Grid.Row="6" Text="GLOBAL" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,4"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" x:Name="CmpOverallBefore" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,8,0,4"/>
                            <TextBlock Grid.Row="6" Grid.Column="3" x:Name="CmpOverallAfter" Text="--" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" Margin="0,8,0,4"/>
                            <TextBlock Grid.Row="6" Grid.Column="4" x:Name="CmpOverallGain" Text="--" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,8,0,4"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ============================================ -->
                <!-- THROTTLING ALERT -->
                <!-- ============================================ -->
                <Border Grid.Row="6" x:Name="PanelThrottling" Visibility="Collapsed"
                        Background="#20F59E0B" BorderBrush="#40F59E0B" BorderThickness="1"
