                                    <TextBlock Text="Aprenda a utilizar o sistema de benchmark para analisar e melhorar o desempenho do seu PC."
                                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="2" x:Name="BtnCloseTutorial" Click="BtnCloseTutorial_Click"
