                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <Separator Background="#15FFFFFF" Margin="0,10,0,16"/>

                        <!-- 1. O que é o Benchmark -->
                        <Border Background="{DynamicResource DarkBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="26" Height="26" CornerRadius="6" Background="#2531A8FF" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Path Data="M15.5,12C18,12 20,14 20,16.5C20,17.38 19.75,18.21 19.31,18.9L22.39,22L21,23.39L17.88,20.32C17.19,20.75 16.37,21 15.5,21C13,21 11,19 11,16.5C11,14 13,12 15.5,12M15.5,14A2.5,2.5 0 0,0 13,16.5A2.5,2.5 0 0,0 15.5,19A2.5,2.5 0 0,0 18,16.5A2.5,2.5 0 0,0 15.5,14M5,3H19C20.1,3 21,3.9 21,5V14.03C20.5,13.22 19.8,12.54 19,12.03V5H5V19H9.5C9.81,19.75 10.26,20.42 10.81,21H5C3.9,21 3,20.1 3,19V5C3,3.9 3.9,3 5,3M7,7H17V9H7V7M7,11H12.03C11.23,11.5 10.54,12.2 10.03,13H7V11M7,15H9.17C9.06,15.5 9,16 9,16.5V17H7V15Z" Fill="#31A8FF" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="O que é o Benchmark?" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                                    O Benchmark mede o desempenho real do seu computador em diversas áreas: processador (CPU), memória RAM, disco (SSD/HDD) e responsividade do sistema. Diferente de benchmarks genéricos, o Voltris mede métricas que impactam diretamente a sua experiência: velocidade de abertura de programas, fluidez da interface e latência do agendador de tarefas do Windows.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 2. Benchmark Inicial -->
                        <Border Background="{DynamicResource DarkBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="26" Height="26" CornerRadius="6" Background="#2531A8FF" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource BenchmarkIcon}" Fill="#31A8FF" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Como executar o Benchmark Inicial" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                                    O Benchmark Inicial captura uma "foto" do desempenho atual do seu sistema, antes de qualquer otimização. Ele serve como linha de base para comparação futura.
                                </TextBlock>
                                <TextBlock FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,4">Quando executar:</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,0,0" LineHeight="22">• Logo após instalar o Voltris, antes de aplicar otimizações&#x0a;• Após reinstalar o Windows ou atualizar drivers&#x0a;• Sempre que quiser ter um ponto de referência atualizado</TextBlock>
                                <TextBlock FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,4">O que acontece durante o teste:</TextBlock>
                                <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,0,0">
                                    O sistema executa testes automatizados que duram aproximadamente 30 a 60 segundos. O processador, memória e disco são testados com cargas controladas para medir a capacidade real de cada componente.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 3. Otimizações -->
                        <Border Background="{DynamicResource DarkBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="26" Height="26" CornerRadius="6" Background="#25EAB308" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource BoltIcon}" Fill="#EAB308" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Aplicação de Otimizações" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                                    Após o Benchmark Inicial, aplique as otimizações do Voltris através das páginas de Performance, Modo Gamer ou Benchmark Completo. As otimizações ajustam configurações do Windows como prioridades de CPU, gerenciamento de memória e configurações de energia. O Benchmark Final mede o impacto dessas otimizações com dados concretos.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 4. Benchmark Final -->
                        <Border Background="{DynamicResource DarkBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="26" Height="26" CornerRadius="6" Background="#258B31FF" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource PerformanceIcon}" Fill="#8B31FF" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Benchmark Final" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                                    Executa exatamente os mesmos testes do Benchmark Inicial, mas com as otimizações ativas. Execute-o após aplicar otimizações e aguardar pelo menos 15 segundos para o sistema estabilizar. O botão "Benchmark Completo" faz tudo isso automaticamente.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 5. Comparação -->
                        <Border Background="{DynamicResource DarkBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="26" Height="26" CornerRadius="6" Background="#25FF4B6B" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Path Data="M9,3L5,6.99H8V14H10V6.99H13L9,3M16,17.01V10H14V17.01H11L15,21L19,17.01H16Z" Fill="#FF4B6B" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Comparação de Resultados" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                                    Após executar ambos os benchmarks, clique em "Comparar" para ver uma tabela detalhada com os valores antes e depois.
                                </TextBlock>
                                <TextBlock FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,4">Como interpretar:</TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,0,0,0" LineHeight="22">• Valores em verde = melhoria de desempenho&#x0a;• Valores em vermelho = redução (raro, variação natural)&#x0a;• Acima de +5% = ganhos significativos&#x0a;• Variações de ±2% são normais entre execuções</TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 6. Score -->
                        <Border Background="{DynamicResource DarkBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#25FF4B6B" Offset="0"/>
                                                <GradientStop Color="#25EAB308" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Path Data="M5,16L3,5L8.5,10L12,4L15.5,10L21,5L19,16H5M19,19A1,1 0 0,1 18,20H6A1,1 0 0,1 5,19V18H19V19Z" Fill="#EAB308" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Score do Sistema" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                                    O Score Global é uma nota ponderada que combina todas as métricas em um único número de 0 a 100. Ele é calculado com os seguintes pesos:
                                </TextBlock>

                                <!-- Score weights visual grid -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="8" Padding="10,8" Background="#15FF4B6B">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="CPU" FontSize="11" FontWeight="SemiBold" Foreground="#FF4B6B" HorizontalAlignment="Center"/>
                                            <TextBlock Text="35%" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" CornerRadius="8" Padding="10,8" Background="#1531A8FF">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Disco" FontSize="11" FontWeight="SemiBold" Foreground="#31A8FF" HorizontalAlignment="Center"/>
                                            <TextBlock Text="25%" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="4" CornerRadius="8" Padding="10,8" Background="#158B31FF">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Memória" FontSize="11" FontWeight="SemiBold" Foreground="#8B31FF" HorizontalAlignment="Center"/>
                                            <TextBlock Text="20%" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="6" CornerRadius="8" Padding="10,8" Background="#1510B981">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Scheduler" FontSize="11" FontWeight="SemiBold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                            <TextBlock Text="10%" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="8" CornerRadius="8" Padding="10,8" Background="#15EAB308">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="UI" FontSize="11" FontWeight="SemiBold" Foreground="#EAB308" HorizontalAlignment="Center"/>
                                            <TextBlock Text="10%" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Score ranges -->
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="8" Padding="10,8" Background="#1510B981" BorderBrush="#2510B981" BorderThickness="1">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="85+" FontSize="16" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Excelente" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" CornerRadius="8" Padding="10,8" Background="#1531A8FF" BorderBrush="#2531A8FF" BorderThickness="1">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="75+" FontSize="16" FontWeight="Bold" Foreground="#31A8FF" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Bom" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="4" CornerRadius="8" Padding="10,8" Background="#15FF4B6B" BorderBrush="#25FF4B6B" BorderThickness="1">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="&lt;50" FontSize="16" FontWeight="Bold" Foreground="#FF4B6B" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Otimizar" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 7. Métricas -->
                        <Border Background="{DynamicResource DarkBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="26" Height="26" CornerRadius="6" Background="#2510B981" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource DiagnosticsIcon}" Fill="#10B981" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Métricas Analisadas" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <Border Background="#10FF4B6B" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="CPU Performance" FontSize="12" FontWeight="SemiBold" Foreground="#FF4B6B"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">Operações matemáticas intensivas (ponto flutuante, inteiros, SHA-256). Testa single-thread e multi-thread.</TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Background="#108B31FF" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="Memory Performance" FontSize="12" FontWeight="SemiBold" Foreground="#8B31FF"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">Velocidade de leitura/escrita da RAM, latência de acesso e throughput com padrões sequenciais e aleatórios.</TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1031A8FF" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="Disk Performance" FontSize="12" FontWeight="SemiBold" Foreground="#31A8FF"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">Leitura e escrita do disco com operações sequenciais e aleatórias de 4KB, simulando uso real do sistema.</TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1010B981" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="Scheduler Latency" FontSize="12" FontWeight="SemiBold" Foreground="#10B981"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">Latência do agendador de tarefas do Windows. Valores baixos significam maior fluidez.</TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Background="#10EAB308" CornerRadius="8" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="UI Responsiveness" FontSize="12" FontWeight="SemiBold" Foreground="#EAB308"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0">Responsividade da interface gráfica — tempo de resposta do Dispatcher do WPF e fluidez geral.</TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 8. Benchmark Completo -->
                        <Border Background="{DynamicResource DarkBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#258B31FF" Offset="0"/>
                                                <GradientStop Color="#2531A8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Path Data="{StaticResource BoltIcon}" Fill="White" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Benchmark Completo (Automático)" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}">
                                    Executa todo o fluxo automaticamente em 4 fases:
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="10,6,0,0" LineHeight="22">1. Executa o Benchmark Inicial (linha de base)&#x0a;2. Aplica as otimizações recomendadas&#x0a;3. Aguarda 15 segundos para estabilização&#x0a;4. Executa o Benchmark Final e gera a comparação</TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 9. Boas Práticas -->
                        <Border CornerRadius="12" Padding="18,14" Margin="0,0,0,4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#15EAB308" Offset="0"/>
                                    <GradientStop Color="#1531A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#30EAB308" Offset="0"/>
                                    <GradientStop Color="#3031A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="26" Height="26" CornerRadius="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#25EAB308" Offset="0"/>
                                                <GradientStop Color="#2531A8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Path Data="M12,2A7,7 0 0,1 19,9C19,11.38 17.81,13.47 16,14.74V17A1,1 0 0,1 15,18H9A1,1 0 0,1 8,17V14.74C6.19,13.47 5,11.38 5,9A7,7 0 0,1 12,2M9,21V20H15V21A1,1 0 0,1 14,22H10A1,1 0 0,1 9,21M12,4A5,5 0 0,0 7,9C7,11.05 8.23,12.81 10,13.58V16H14V13.58C15.77,12.81 17,11.05 17,9A5,5 0 0,0 12,4Z" Fill="#EAB308" Width="13" Height="13" Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Boas Práticas" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22">• Feche programas pesados antes de iniciar&#x0a;• Não utilize o computador durante o benchmark&#x0a;• Mantenha o notebook conectado à tomada&#x0a;• Execute 2 a 3 vezes e considere a média&#x0a;• Aguarde pelo menos 2 minutos após ligar o PC&#x0a;• Se detectar thermal throttling, aguarde o PC esfriar</TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
