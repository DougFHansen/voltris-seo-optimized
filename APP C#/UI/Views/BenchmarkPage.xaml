                    <StackPanel Orientation="Horizontal">
                        <Border Width="28" Height="28" CornerRadius="7" Background="#30F59E0B" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Path Data="M1,21H23L12,2L1,21M13,18H11V16H13V18M13,14H11V10H13V14Z" Fill="#F59E0B" Width="14" Height="14" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Throttling de CPU Detectado" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#F59E0B"/>
                            <TextBlock x:Name="TxtThrottlingInfo" Text="" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ============================================ -->
                <!-- TUTORIAL INLINE -->
                <!-- ============================================ -->
                <Border Grid.Row="7" x:Name="PanelTutorial" Visibility="Collapsed"
                        Background="{DynamicResource DarkPanelBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="24,20" Margin="0,0,0,16">
                    <StackPanel>
                        <!-- Tutorial Header with close button -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="36" Height="36" CornerRadius="9" Margin="0,0,10,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8B31FF" Offset="0"/>
                                            <GradientStop Color="#31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="{StaticResource LogsIcon}" Fill="White" Width="16" Height="16" Stretch="Uniform"
