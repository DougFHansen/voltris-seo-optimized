<UserControl x:Class="VoltrisOptimizer.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             Background="Transparent"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    
    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="DashboardVM" />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- ============================================ -->
        <!-- DESIGN SYSTEM VOLTRIS (ENTERPRISE PREMIUM) -->
        <!-- ============================================ -->
        
        <!-- Cores do Branding (Extraídas do Site) -->
        <Color x:Key="ColorPrimary">#3b82f6</Color>
        <Color x:Key="ColorAccent1">#FF4B6B</Color>
        <Color x:Key="ColorAccent2">#8B31FF</Color>
        <Color x:Key="ColorAccent3">#31A8FF</Color>
        
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
        <SolidColorBrush x:Key="BrushAccent1" Color="{StaticResource ColorAccent1}"/>
        <SolidColorBrush x:Key="BrushAccent2" Color="{StaticResource ColorAccent2}"/>
        <SolidColorBrush x:Key="BrushAccent3" Color="{StaticResource ColorAccent3}"/>
        
        <!-- Gradientes de Marca -->
        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF4B6B" Offset="0"/>
            <GradientStop Color="#8B31FF" Offset="0.5"/>
            <GradientStop Color="#31A8FF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4facfe" Offset="0"/>
            <GradientStop Color="#00f2fe" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- ============================================ -->
        <!-- ESTILOS DE COMPONENTES -->
        <!-- Usa DynamicResource para responder ao tema -->
        <!-- ============================================ -->
        
        <!-- Glass Card Style -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCardGlass}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderAccent}"/>
                    <!-- CORREÇÃO PERFORMANCE: Removido DropShadowEffect do hover.
                         DropShadowEffect força renderização por software e causa
                         re-composição de toda a card a cada frame durante hover.
                         Substituído por mudança de borda que é GPU-accelerated. -->
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Modern Action Button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10" 
                                SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" Focusable="False" 
                                              HorizontalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="{DynamicResource BgHover}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource BrushPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#2AFFFFFF"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent Button -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource MainGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <!-- CORREÇÃO PERFORMANCE: Removido DropShadowEffect do hover.
                 Efeitos de sombra forçam renderização por software no WPF. -->
        </Style>
        
        <!-- Status Badge -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Ícones (SVG Path Data) -->
        <Geometry x:Key="IconCpu">M17,6H7A2,2 0 0,0 5,8V16A2,2 0 0,0 7,18H17A2,2 0 0,0 19,16V8A2,2 0 0,0 17,6M11,2V4H13V2H11M7,2V4H9V2H7M15,2V4H17V2H15M2,7V9H4V7H2M2,11V13H4V11H2M2,15V17H4V15H2M20,7V9H22V7H20M20,11V13H22V11H20M20,15V17H22V15H20M11,20V22H13V20H11M7,20V22H9V20H7M15,20V22H17V20H15Z</Geometry>
        <Geometry x:Key="IconRam">M2,6H22V18H2M5,8V16H7V8H5M9,8V16H11V8H9M13,8V16H15V8H13M17,8V16H19V8H17Z</Geometry>
        <Geometry x:Key="IconDisk">M4,3H20A2,2 0 0,1 22,5V9A2,2 0 0,1 20,11H4A2,2 0 0,1 2,9V5A2,2 0 0,1 4,3M4,7H20V5H4V7M4,13H20A2,2 0 0,1 22,15V19A2,2 0 0,1 20,21H4A2,2 0 0,1 2,19V15A2,2 0 0,1 4,13M4,17H20V15H4V17M6,6H8V6H6M6,16H8V16H6Z</Geometry>
        <Geometry x:Key="IconShield">M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,7C13.4,7 14.8,8.6 14.8,11V11.5H16V17H8V11.5H9.2V11C9.2,8.6 10.6,7 12,7</Geometry>
        <Geometry x:Key="IconTemperature">M15,13V5A3,3 0 0,0 9,5V13A5,5 0 1,0 15,13M12,4A1,1 0 0,1 13,5V8H11V5A1,1 0 0,1 12,4Z</Geometry>

        <!-- Animations -->
        <Storyboard x:Key="EntryAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="30" To="0" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Background decorativo (Dashboard Style) -->
        <!-- CORREÇÃO PERFORMANCE: Removidos BlurEffect dos Ellipses decorativos.
             BlurEffect com Radius=150 força renderização por software (não GPU-accelerated no WPF)
             e causa re-composição a cada frame, degradando significativamente a responsividade.
             Substituído por gradientes radiais estáticos que são GPU-friendly. -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" 
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-200,-200,0,0"
                     Opacity="0.08">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3b82f6" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="500" Height="500" 
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-150,-150"
                     Opacity="0.06">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B31FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
            <Grid MinWidth="600">
            <Grid.RowDefinitions>
                <RowDefinition Height="75"/>    <!-- Row 0: Header -->
                <RowDefinition Height="12"/>    <!-- Row 1: Spacer -->
                <RowDefinition Height="*"/>     <!-- Row 2: Quick Actions (FLEXIBLE GROWTH) -->
                <RowDefinition Height="12"/>    <!-- Row 3: Spacer -->
                <RowDefinition Height="85"/>    <!-- Row 4: Performance Metrics -->
                <RowDefinition Height="12"/>    <!-- Row 5: Spacer -->
                <RowDefinition Height="220"/>   <!-- Row 6: Bottom Cards -->
            </Grid.RowDefinitions>

            <!-- HEADER PRINCIPAL -->
            <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="20,0" Height="75">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="20"/>
                        <ColumnDefinition Width="Auto" MaxWidth="340"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Logo + Branding -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M3,13h8V3H3V13z M3,21h8v-6H3V21z M13,21h8V11h-8V21z M13,3v6h8V3H13z" Fill="White" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Dashboard"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="20"
                                       FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <WrapPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Border Background="#1A10B981" Padding="5,2" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="5" Height="5" Fill="#10B981" Margin="0,0,4,0"/>
                                        <TextBlock Text="SISTEMA ATIVO" FontSize="12" FontWeight="Bold" Foreground="#10B981"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding CpuName}" FontSize="14" Foreground="{DynamicResource TextDim}" Margin="8,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- System Overall Status Summary — Enterprise Cards -->
                    <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <!-- SAÚDE Card -->
                        <Border Margin="0,0,10,0" MinWidth="120" MaxWidth="160" CornerRadius="12" BorderThickness="1" Padding="10,8"
                                Background="{DynamicResource BgCardGlass}" BorderBrush="{DynamicResource BorderLight}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1AFF4B6B" Offset="0"/>
                                            <GradientStop Color="#1A8B31FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.42,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.58,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z"
                                          Fill="#8B31FF" Width="16" Height="16" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="SAÚDE" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextTertiary}" 
                                               Typography.Capitals="AllSmallCaps" Margin="0,0,0,1"/>
                                    <TextBlock Text="{Binding HealthStatusText}" FontSize="15" FontWeight="Bold" Foreground="{Binding HealthStatusColor}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- LICENÇA Card -->
                        <Border MinWidth="120" MaxWidth="160" CornerRadius="12" BorderThickness="1" Padding="10,8"
                                Background="{DynamicResource BgCardGlass}" BorderBrush="{DynamicResource BorderLight}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A8B31FF" Offset="0"/>
                                            <GradientStop Color="#1A31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z"
                                          Fill="#31A8FF" Width="16" Height="16" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="LICENÇA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextTertiary}" 
                                               Typography.Capitals="AllSmallCaps" Margin="0,0,0,1"/>
                                    <TextBlock Text="{Binding LicenseStatusText}" FontSize="15" FontWeight="Bold" Foreground="{Binding LicenseStatusColor}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>


            <!-- ============================================ -->
            <!-- INDICADORES DE PERFORMANCE (CPU, RAM, DISK, TEMP) -->
            <!-- ============================================ -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}" Value="400">
                                <!-- Triggering layout based on width could be done with a converter or custom component, 
                                     but for now we'll stick to a responsive Grid -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- CPU Metric -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="12,0" MinWidth="120" Height="85">
                    <StackPanel VerticalAlignment="Center">
                        <Grid Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconCpu}" Fill="{StaticResource BrushPrimary}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="CPU" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}%}" HorizontalAlignment="Right" FontSize="26" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                        </Grid>
                        <ProgressBar Height="5" Value="{Binding CpuUsage}" Maximum="100" Foreground="{StaticResource BrushPrimary}" Background="#1AFFFFFF" BorderThickness="0"/>
                        <TextBlock Text="Uso do Processador" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                
                <!-- RAM Metric -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="12,0" MinWidth="120" Height="85">
                    <StackPanel VerticalAlignment="Center">
                        <Grid Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconRam}" Fill="{StaticResource BrushAccent2}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="MEMÓRIA" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding RamUsage, StringFormat={}{0:F0}%}" HorizontalAlignment="Right" FontSize="26" FontWeight="Bold" Foreground="{StaticResource BrushAccent2}"/>
                        </Grid>
                        <ProgressBar Height="5" Value="{Binding RamUsage}" Maximum="100" Foreground="{StaticResource BrushAccent2}" Background="#1AFFFFFF" BorderThickness="0"/>
                        <TextBlock Text="{Binding RamInfo}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                
                <!-- Disk Metric -->
                <Border Grid.Column="4" Style="{StaticResource GlassCard}" Padding="12,0" MinWidth="120" Height="85">
                    <StackPanel VerticalAlignment="Center">
                        <Grid Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconDisk}" Fill="{StaticResource BrushAccent1}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="ARMAZEM." FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding DiskUsage, StringFormat={}{0:F0}%}" HorizontalAlignment="Right" FontSize="26" FontWeight="Bold" Foreground="{StaticResource BrushAccent1}"/>
                        </Grid>
                        <ProgressBar Height="5" Value="{Binding DiskUsage}" Maximum="100" Foreground="{StaticResource BrushAccent1}" Background="#1AFFFFFF" BorderThickness="0"/>
                        <TextBlock Text="{Binding DiskInfo}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                
                <!-- Temperature Metric -->
                <Border Grid.Column="6" Style="{StaticResource GlassCard}" Padding="12,0" MinWidth="120" Height="85">
                    <StackPanel VerticalAlignment="Center">
                        <Grid Margin="0,0,0,6">
                            <!-- Esquerda: Ícone e Título -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconTemperature}" Fill="{Binding ThermalStatusColor}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="TEMP" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                                <!-- Indicador de temperatura estimada -->
                                <TextBlock Text="~" FontSize="14" FontWeight="Bold" Foreground="#F59E0B" Margin="4,0,0,0" VerticalAlignment="Center" ToolTip="Temperatura estimada (limitada por hardware)">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTemperatureEstimated}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                            <!-- Direita: Valores de CPU e GPU -->
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <!-- CPU Row -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,2">
                                    <TextBlock Text="CPU" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Bottom" Margin="0,0,6,1.5"/>
                                    <TextBlock Text="{Binding CpuTemperature, StringFormat={}{0:F1}°C}" FontSize="14" FontWeight="Bold" Foreground="{Binding ThermalStatusColor}"/>
                                </StackPanel>
                                <!-- GPU Row -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="GPU" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Bottom" Margin="0,0,6,1.5"/>
                                    <TextBlock Text="{Binding GpuTemperature, StringFormat={}{0:F1}°C}" FontSize="14" FontWeight="Bold" Foreground="{Binding ThermalStatusColor}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Height="4" Value="{Binding CpuTemperature}" Maximum="100" Foreground="{Binding ThermalStatusColor}" Background="#1AFFFFFF" BorderThickness="0"/>
                        <TextBlock Text="{Binding ThermalStatus}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- ============================================ -->
            <!-- AÇÕES RÁPIDAS (BOTÕES) - EXPANDED TO FILL GAIN SYMMETRY -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="20,0" VerticalAlignment="Stretch">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Textos à esquerda -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="OTIMIZAÇÃO INTELIGENTE" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource TextMain}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Execute as melhores otimizações baseadas no perfil do seu PC" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource TextDim}" 
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <!-- Botões à direita -->
                    <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="12,0,0,0">
                        <Button Command="{Binding QuickOptimizeCommand}" 
                                Style="{StaticResource AccentButton}" 
                                Padding="16,8" 
                                MinHeight="34"
                                Margin="0,4,8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" Margin="0,0,5,0" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="OTIMIZAR AGORA" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding QuickCleanupCommand}" 
                                Style="{StaticResource ModernButton}" 
                                Padding="16,8" 
                                MinHeight="34"
                                Margin="0,4,8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="扫" Margin="0,0,5,0" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="LIMPEZA RÁPIDA" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RefreshCommand}" 
                                Style="{StaticResource ModernButton}" 
                                Padding="10,8" 
                                MinHeight="34"
                                Margin="0,4,0,4">
                            <TextBlock Text="🔄" FontSize="13" VerticalAlignment="Center"/>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>


            <!-- ============================================ -->
            <!-- BOTTOM CARDS: SAÚDE, LICENÇA, ATIVIDADE -->
            <!-- ============================================ -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- System Health Card -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="16,8" Height="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="*"/>    <!-- Content (Boxed) -->
                            <RowDefinition Height="Auto"/> <!-- Footer Divider -->
                            <RowDefinition Height="Auto"/> <!-- Footer (Time) -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                             <Ellipse Width="6" Height="6" Fill="{Binding HealthStatusColor}" Margin="0,0,8,0" VerticalAlignment="Center">
                                <!-- CORREÇÃO PERFORMANCE: Removido DropShadowEffect com binding dinâmico.
                                     Sombra com cor dinâmica causa re-render a cada mudança de HealthStatusColor. -->
                             </Ellipse>
                             <TextBlock Text="SAÚDE DO SISTEMA" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextDim}"/>
                        </StackPanel>

                        <!-- Content (Flexible Grid to Fill Height) -->
                        <Grid Grid.Row="1" Margin="0,8,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Main Stats -->
                                <RowDefinition Height="*"/>    <!-- Flex Spacer -->
                                <RowDefinition Height="Auto"/> <!-- Metrics List -->
                            </Grid.RowDefinitions>

                            <!-- Top Part: Health Score -->
                            <StackPanel Grid.Row="0">
                                 <Grid Margin="0,0,0,8">
                                     <TextBlock Text="{Binding HealthStatusText}" FontSize="32" FontWeight="Bold" Foreground="{Binding HealthStatusColor}" VerticalAlignment="Center"/>
                                     <TextBlock Text="{Binding OverallScore, StringFormat={}SCORE {0}/100}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextMain}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                 </Grid>
                                 <Grid Height="8">
                                     <Border Background="#1AFFFFFF" CornerRadius="4"/>
                                     <ProgressBar Value="{Binding OverallScore}" Maximum="100" Foreground="{Binding HealthStatusColor}" Background="Transparent" BorderThickness="0"/>
                                 </Grid>
                            </StackPanel>

                            <!-- Bottom Part: Services Monitor (ENLARGED) -->
                            <StackPanel Grid.Row="2" Margin="0,5,0,0">
                                <Border Height="1" Background="#1AFFFFFF" Margin="0,0,0,12"/>
                                <UniformGrid Columns="3">
                                    <StackPanel>
                                        <TextBlock Text="BOOSTER" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Fill="#8B31FF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding GamerServiceStatus}" FontSize="12" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="REDE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Fill="#3b82f6" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding NetworkServiceStatus}" FontSize="12" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="LIMPEZA" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Fill="{Binding CleanupServiceColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding CleanupServiceStatus}" FontSize="12" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Footer Divider -->
                        <Border Grid.Row="2" Height="1" Background="#1AFFFFFF" Margin="-16,0,-16,0"/>

                        <!-- Footer: Last Action (Full Width) -->
                        <Border Grid.Row="3" Margin="-16,0,-16,-8" Background="#08FFFFFF" CornerRadius="0,0,16,16">
                            <Grid Margin="16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Path Grid.Column="0" Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" Fill="{DynamicResource TextMuted}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="ÚLTIMA AÇÃO REGISTRADA" FontSize="9" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,1"/>
                                    <TextBlock Text="{Binding LastOptimizationTime}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextMain}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- License Status Card -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="16,8" Height="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="*"/>    <!-- Content (Boxed) -->
                            <RowDefinition Height="Auto"/> <!-- Footer Divider -->
                            <RowDefinition Height="Auto"/> <!-- Footer (User) -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                             <Path Data="{StaticResource IconShield}" Fill="{StaticResource BrushAccent3}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                             <TextBlock Text="ASSINATURA &amp; CONTA" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextDim}"/>
                        </StackPanel>

                        <!-- Content (Flexible Grid to Fill Height) -->
                        <Grid Grid.Row="1" Margin="0,8,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Main Status -->
                                <RowDefinition Height="*"/>    <!-- Flex Spacer -->
                                <RowDefinition Height="Auto"/> <!-- Features List -->
                            </Grid.RowDefinitions>

                            <!-- Top Part: License Info -->
                            <StackPanel Grid.Row="0">
                                 <Grid Margin="0,0,0,8">
                                     <TextBlock Text="{Binding LicenseType}" FontSize="26" FontWeight="Bold" Foreground="{Binding LicenseStatusColor}" VerticalAlignment="Center"/>
                                     <Border Background="#1AFFFFFF" CornerRadius="4" Padding="8,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                         <TextBlock Text="{Binding LicenseStatusText}" FontSize="12" FontWeight="Bold" Foreground="{Binding LicenseStatusColor}"/>
                                     </Border>
                                 </Grid>
                                 <Grid Height="8">
                                     <Border Background="#1AFFFFFF" CornerRadius="4"/>
                                     <ProgressBar Value="100" Maximum="100" Foreground="{StaticResource BrushAccent3}" Background="Transparent" BorderThickness="0" Opacity="0.5"/>
                                 </Grid>
                            </StackPanel>

                            <!-- Bottom Part: Features Info (ENLARGED) -->
                            <StackPanel Grid.Row="2" Margin="0,2,0,0">
                                <Border Height="1" Background="#1AFFFFFF" Margin="0,0,0,12"/>
                                <UniformGrid Columns="3">
                                    <StackPanel>
                                        <TextBlock Text="MOTOR IA" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding ScoreStatus}" FontSize="12" Foreground="{Binding HealthStatusColor}" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="SUPORTE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,2A7,7 0 0,1 19,9C19,11.38 17.81,13.47 16,14.74V17A1,1 0 0,1 15,18H9A1,1 0 0,1 8,17V14.74C6.19,13.47 5,11.38 5,9A7,7 0 0,1 12,2M9,21V20H15V21A1,1 0 0,1 14,22H10A1,1 0 0,1 9,21M12,4A5,5 0 0,0 7,9C7,11.05 8.23,12.81 10,13.58V16H14V13.58C15.77,12.81 17,11.05 17,9A5,5 0 0,0 12,4Z" Fill="{DynamicResource TextMain}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding SupportLevel}" FontSize="12" Foreground="{DynamicResource TextDim}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="NUVEM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMain}" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M19.35,10.03C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.03C2.34,8.36 0,10.9 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.03Z" Fill="#3b82f6" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="ATIVO" FontSize="11" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>

                        <!-- Footer Divider -->
                        <Border Grid.Row="2" Height="1" Background="#1AFFFFFF" Margin="-16,0,-16,0"/>

                        <!-- Footer: User Email (Full Width) -->
                        <Border Grid.Row="3" Margin="-16,0,-16,-8" Background="#08FFFFFF" CornerRadius="0,0,16,16">
                            <Grid Margin="16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" Background="#1Affffff" Margin="0,0,10,0">
                                    <TextBlock Text="👤" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="CONTA VINCULADA" FontSize="9" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,1"/>
                                    <TextBlock Text="{Binding LinkedEmail}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextMain}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <Button Grid.Column="2" Command="{Binding NavigateToSystemCommand}" Style="{StaticResource ModernButton}" Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="GERENCIAR" FontSize="10" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Recent Activity Card -->
                <Border Grid.Column="4" Style="{StaticResource GlassCard}" Padding="16,10" Height="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="Auto"/> <!-- Divider Top -->
                            <RowDefinition Height="*"/>    <!-- Activity List (DYNAMIC FILL) -->
                            <RowDefinition Height="Auto"/> <!-- Divider Bottom -->
                            <RowDefinition Height="Auto"/> <!-- Footer (Action) -->
                        </Grid.RowDefinitions>

                        <!-- Header with Live Indicator -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                             <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                  <Path Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3A9,9 0 0,0 4,12H1L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3" Fill="{DynamicResource TextDim}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                  <TextBlock Text="ATIVIDADE RECENTE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                             </StackPanel>
                             
                             <Grid HorizontalAlignment="Right" VerticalAlignment="Center" ToolTip="Monitoramento em tempo real ativo">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="Auto"/>
                                     <ColumnDefinition Width="Auto"/>
                                 </Grid.ColumnDefinitions>
                                 <Ellipse Grid.Column="0" Width="6" Height="6" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.8">
                                     <!-- CORREÇÃO PERFORMANCE: Removida animação Forever de opacidade.
                                          Animações RepeatBehavior=Forever causam ticks contínuos do compositor
                                          mesmo quando a janela está em background, consumindo CPU desnecessariamente. -->
                                 </Ellipse>
                                 <TextBlock Grid.Column="1" Text="LIVE" FontSize="9" FontWeight="Black" Foreground="#10B981" Opacity="0.8" VerticalAlignment="Center" Margin="0,0.5,0,0"/>
                             </Grid>
                        </Grid>

                        <!-- Divider -->
                        <Border Grid.Row="1" Height="1" Background="#1AFFFFFF" Margin="0,0,0,10"/>

                        <!-- Content Area (List or Empty State) -->
                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <!-- Empty State -->
                            <TextBlock Text="Nenhuma atividade recente" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource TextMuted}" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"
                                       FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RecentEvents.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Activity List (Synchronized with History Page) -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid>
                                    <!-- Vertical Timeline Track (Centered under nodes) -->
                                    <Rectangle Fill="#1AFFFFFF" Width="1" HorizontalAlignment="Left" Margin="4,0,0,0" Grid.RowSpan="999"/>
                                    
                                    <ItemsControl ItemsSource="{Binding RecentEvents}"
                                                  VirtualizingStackPanel.IsVirtualizing="True"
                                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.CanContentScroll="True">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RecentEvents.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="10"/> <!-- Timeline Node Col -->
                                                        <ColumnDefinition Width="*"/>  <!-- Content Col -->
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Timeline Node (Circular style matching History) -->
                                                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" 
                                                            Background="{DynamicResource DarkBrush}" 
                                                            BorderBrush="{Binding TypeColor}" 
                                                            BorderThickness="1.5" 
                                                            VerticalAlignment="Top" 
                                                            Margin="0,4,0,0"
                                                            Panel.ZIndex="2">
                                                        <!-- CORREÇÃO PERFORMANCE: Removido DropShadowEffect.
                                                             Era aplicado a CADA item da lista, causando N renderizações por software. -->
                                                    </Border>
                                                    
                                                    <!-- Message and Meta Row -->
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                        <TextBlock Text="{Binding Message}" 
                                                                 Foreground="{StaticResource TextPrimary}" 
                                                                 FontSize="12" 
                                                                 FontWeight="SemiBold" 
                                                                 TextWrapping="Wrap"/>
                                                        
                                                        <StackPanel Orientation="Horizontal" Opacity="0.6" Margin="0,2,0,0">
                                                            <TextBlock Text="{Binding Timestamp}" FontSize="9" Foreground="#94A3B8" Margin="0,0,6,0"/>
                                                            <TextBlock Text="•" FontSize="9" Foreground="#94A3B8" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding Type}" FontSize="9" FontWeight="Bold" Foreground="{Binding TypeColor}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                        
                        <!-- Footer Divider -->
                        <Border Grid.Row="3" Height="1" Background="#1AFFFFFF" Margin="-16,0,-16,0"/>

                        <!-- Footer: View All Action (Full Width Button) -->
                        <Button Grid.Row="4" 
                                Command="{Binding NavigateToActivityHistoryCommand}"
                                Margin="-16,0,-16,-10"
                                Background="#08FFFFFF"
                                BorderThickness="0"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Padding="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#08FFFFFF"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="0,0,16,16">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#15FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            
                            <Grid Margin="16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="VER HISTÓRICO COMPLETO" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                <Path Grid.Column="1" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Fill="{DynamicResource TextMuted}" Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </ScrollViewer>
    
    <!-- ============================================ -->
    <!-- PREPARE PC OVERLAY (OOBE/Provisioning Style) -->
    <!-- ============================================ -->
    <Grid Visibility="{Binding IsPreparing, Converter={StaticResource BooleanToVisibilityConverter}}" 
          Background="#E6000000" 
          Panel.ZIndex="9999">
        <Border MaxWidth="600" 
                MinHeight="300" 
                Background="{DynamicResource DarkPanelBrush}" 
                BorderBrush="#2A2A3A" 
                BorderThickness="1" 
                CornerRadius="16" 
                Padding="32" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Margin="20">
            <!-- CORREÇÃO PERFORMANCE: Removido DropShadowEffect BlurRadius=40.
                 Sombras grandes forçam renderização por software. -->
            
            <StackPanel>
                <!-- Título -->
                <TextBlock Text="Preparando seu PC" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimary}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>
                
                <!-- Mensagem Estática -->
                <TextBlock Text="{Binding StaticMessage}" 
                           FontSize="13" 
                           Foreground="#94A3B8" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center" 
                           Margin="0,0,0,24" 
                           LineHeight="18"/>
                
                <!-- Mensagem Dinâmica -->
                <TextBlock Text="{Binding CurrentStatusMessage}" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="#3b82f6" 
                           TextAlignment="Center" 
                           Margin="0,0,0,20" 
                           MinHeight="20"
                           TextWrapping="Wrap"/>
                
                <!-- Progress Bar -->
                <Grid Margin="0,0,0,12">
                    <Border Height="8" 
                            Background="{DynamicResource DarkBorderBrush}" 
                            CornerRadius="4"/>
                    <Border x:Name="ProgressBarContainer" Height="8" CornerRadius="4" HorizontalAlignment="Left" Background="{StaticResource MainGradient}">
                        <Border.Width>
                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                  <Binding Path="PrepareProgress"/>
                                <Binding ElementName="ProgressBarContainer" Path="ActualWidth" /> <!-- This won't work as expected but let's see -->
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                    <!-- Improved Progress Bar usage should be here, but keeping user logic -->
                </Grid>
                
                <!-- Percentual -->
                <TextBlock Text="{Binding PrepareProgress, StringFormat={}{0:F0}%}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimary}" 
                           TextAlignment="Center" 
                           Margin="0,0,0,20"/>
                
                <!-- Botão Cancelar -->
                <Button Content="Cancelar" 
                        Command="{Binding CancelPreparationCommand}" 
                        Style="{StaticResource ModernButton}" 
                        HorizontalAlignment="Center" 
                        Padding="32,10" 
                        Opacity="0.7"/>
            </StackPanel>
        </Border>
    </Grid>
    </Grid>
</UserControl>