<Window x:Class="VoltrisOptimizer.UI.Views.LicenseActivationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoltrisOptimizer.UI.Views"
        mc:Ignorable="d"
        Title="Licenciamento - Voltris Optimizer"
        Height="720" Width="1100"
        MinHeight="600" MinWidth="800"
        MaxHeight="900" MaxWidth="1400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled"
        SizeToContent="Manual">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Estilo do botão de plano -->
        <Style x:Key="PlanCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#8B31FF"/>
                    <Setter Property="Background" Value="#1E1E38"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Estilo do botão de ação -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF4B6B" Offset="0"/>
                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                        <GradientStop Color="#31A8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="30,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#8B31FF" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#8B31FF" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Estilo do botão secundário -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#8B31FF"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Animação de fade in -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
        </EventTrigger>
    </Window.Triggers>
    
    <!-- Container principal - 100% arredondado sem transparência -->
    <Border CornerRadius="16" Background="{DynamicResource DarkBrush}" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <!-- Background com cores do sidebar -->
            <Grid Background="{DynamicResource DarkBrush}">
                <!-- Efeitos de Blur Decorativos -->
                <Viewbox HorizontalAlignment="Left" 
                         VerticalAlignment="Top"
                         Margin="30,20,0,0"
                         Stretch="Uniform"
                         MaxWidth="350" MaxHeight="350"
                         IsHitTestVisible="False">
                    <Ellipse Width="350" Height="350" 
                             Fill="{StaticResource AccentBlurBrush}">
                        <Ellipse.Effect>
                            <BlurEffect Radius="120"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Viewbox>
                
                <Viewbox HorizontalAlignment="Right" 
                         VerticalAlignment="Bottom"
                         Margin="0,0,60,40"
                         Stretch="Uniform"
                         MaxWidth="300" MaxHeight="300"
                         IsHitTestVisible="False">
                    <Ellipse Width="300" Height="300" 
                             Fill="{StaticResource SecondaryBlurBrush}">
                        <Ellipse.Effect>
                            <BlurEffect Radius="120"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Viewbox>
                
                <Viewbox HorizontalAlignment="Center" 
                         VerticalAlignment="Center"
                         Stretch="Uniform"
                         MaxWidth="200" MaxHeight="200"
                         IsHitTestVisible="False">
                    <Ellipse Width="200" Height="200" 
                             Fill="{StaticResource PrimaryBlurBrush}">
                        <Ellipse.Effect>
                            <BlurEffect Radius="100"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Viewbox>
                
                <!-- Overlay para legibilidade — transparente quando backdrop ativo -->
                <Border x:Name="LicenseOverlay" Opacity="0.92" CornerRadius="0" IsHitTestVisible="False">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource DarkColor}"/>
                    </Border.Background>
                </Border>
            </Grid>
            
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Title Bar -->
                <Border Grid.Row="0" Background="{DynamicResource DarkPanelBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="16,16,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Path Grid.Column="0" 
                                  Data="M12,1L8,5H11V14H13V5H16M18,23H6C4.89,23 4,22.1 4,21V9A2,2 0 0,1 6,7H9V9H6V21H18V9H15V7H18A2,2 0 0,1 20,9V21A2,2 0 0,1 18,23Z" 
                                  Fill="{DynamicResource PrimaryBrush}"
                                  Width="20" Height="20" 
                                  Stretch="Uniform"
                                  VerticalAlignment="Center" 
                                  Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="Ativação de Licença" 
                                      FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="─" Style="{StaticResource SecondaryButtonStyle}" 
                                   Padding="15,5" Click="MinimizeButton_Click"/>
                            <Button Content="✕" Style="{StaticResource SecondaryButtonStyle}" 
                                   Padding="15,5" Margin="5,0,0,0" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Conteúdo principal -->
                <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="30,20,30,30">
                    <StackPanel MaxWidth="1200">
                        <!-- Header -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock FontSize="28" FontWeight="Bold" 
                                      HorizontalAlignment="Center"
                                      TextWrapping="Wrap">
                                <TextBlock.Foreground>
                                    <StaticResource ResourceKey="VoltrisGradientHorizontalBrush"/>
                                </TextBlock.Foreground>
                                <Run Text="Escolha seu plano"/>
                            </TextBlock>
                            <TextBlock x:Name="TrialStatusText"
                                      Text="{Binding TrialStatusText}"
                                      FontSize="14" Foreground="#8B8BA0"
                                      HorizontalAlignment="Center" Margin="0,8,0,0"
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <!-- Alerta offline -->
                        <Border Visibility="{Binding OfflineWarningVisible, Converter={StaticResource BoolToVis}}"
                               Background="#30FF4B6B" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Modo offline - algumas funcionalidades podem estar limitadas"
                                          Foreground="#FFB4B4" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Cards de planos - DESIGN PROFISSIONAL RESPONSIVO -->
                        <!-- Grid responsivo que se adapta a qualquer resolução -->
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="180"/>
                                <ColumnDefinition Width="*" MinWidth="180"/>
                                <ColumnDefinition Width="*" MinWidth="180"/>
                                <ColumnDefinition Width="*" MinWidth="180"/>
                            </Grid.ColumnDefinitions>
                            <!-- Trial -->
                            <Border Grid.Column="0" Style="{StaticResource PlanCardStyle}" Margin="0,0,6,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Path Grid.Row="0" 
                                          Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                                          Fill="{DynamicResource TextSecondaryBrush}"
                                          Width="28" Height="28" 
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center" 
                                          Margin="0,0,0,10"/>
                                    
                                    <TextBlock Grid.Row="1" Text="Trial" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                                              HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    
                                    <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <TextBlock Text="Grátis" FontSize="22" FontWeight="Bold" Foreground="#6B6B80"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="7 dias" FontSize="11" Foreground="#6B6B80"
                                                  HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Row="3" Background="#2A2A4A" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                                        <TextBlock Text="1 dispositivo" FontSize="11" Foreground="#8B8BA0"
                                                  HorizontalAlignment="Center" FontWeight="Medium"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Row="4" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Funcionalidades básicas" FontSize="11" Foreground="#B4B4C0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Suporte por email" FontSize="11" Foreground="#B4B4C0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <Button Grid.Row="5" Content="Continuar Trial" 
                                           Style="{StaticResource SecondaryButtonStyle}"
                                           Command="{Binding ContinueTrialCommand}"
                                           HorizontalAlignment="Stretch"
                                           Padding="0,12" FontSize="12" FontWeight="SemiBold"
                                           Margin="0,12,0,0"/>
                                </Grid>
                            </Border>
                            
                            <!-- Standard -->
                            <Border Grid.Column="1" Style="{StaticResource PlanCardStyle}" Margin="6,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Path Grid.Row="0" 
                                          Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.63L2,9.24L7.46,13.97L5.82,21L12,17.27Z" 
                                          Fill="{DynamicResource PrimaryBrush}"
                                          Width="28" Height="28" 
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center" 
                                          Margin="0,0,0,10"/>
                                    
                                    <TextBlock Grid.Row="1" Text="Standard" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                                              HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    
                                    <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <TextBlock Text="R$ 49,90" FontSize="22" FontWeight="Bold" Foreground="#31A8FF"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="/mês" FontSize="11" Foreground="#6B6B80"
                                                  HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Row="3" Background="#2A2A4A" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                                        <TextBlock Text="1 dispositivo" FontSize="11" Foreground="#8B8BA0"
                                                  HorizontalAlignment="Center" FontWeight="Medium"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Row="4" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Todas as funcionalidades" FontSize="11" Foreground="#B4B4C0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Atualizações 1 ano" FontSize="11" Foreground="#B4B4C0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Modo Gamer básico" FontSize="11" Foreground="#B4B4C0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <Button Grid.Row="5" Content="Comprar Standard" 
                                           Style="{StaticResource SecondaryButtonStyle}"
                                           Command="{Binding BuyLicenseCommand}"
                                           CommandParameter="standard"
                                           HorizontalAlignment="Stretch"
                                           Padding="0,12" FontSize="12" FontWeight="SemiBold"
                                           Margin="0,12,0,0"/>
                                </Grid>
                            </Border>
                            
                            <!-- Pro (Popular) -->
                            <Border Grid.Column="2" Margin="6,0" CornerRadius="14">
                                <Border.Background>
                                    <SolidColorBrush Color="{DynamicResource DarkPanelColor}"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8B31FF" Offset="0"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>2</Border.BorderThickness>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#8B31FF" Opacity="0.4"/>
                                </Border.Effect>
                                
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Badge Popular -->
                                    <Border Grid.Row="0" Background="#8B31FF" CornerRadius="16" Padding="12,5" 
                                           HorizontalAlignment="Center" Margin="0,-24,0,12">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                                        </Border.Effect>
                                        <TextBlock Text="⚡ POPULAR" FontSize="10" FontWeight="Bold" 
                                                  Foreground="{DynamicResource TextPrimary}"/>
                                    </Border>
                                    
                                    <Path Grid.Row="1" 
                                          Data="M5,16L3,5L8.5,12L12,5L15.5,12L21,5L19,16H5M19,19H5V22H19V19Z" 
                                          Fill="{DynamicResource VoltrisGradientBrush}"
                                          Width="28" Height="28" 
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center" 
                                          Margin="0,0,0,10"/>
                                    
                                    <TextBlock Grid.Row="2" Text="Pro" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                                              HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    
                                    <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <TextBlock Text="R$ 499,00" FontSize="22" FontWeight="Bold" Foreground="#8B31FF"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="/mês" FontSize="11" Foreground="#6B6B80"
                                                  HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Row="4" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#308B31FF" Offset="0"/>
                                                <GradientStop Color="#3031A8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="3 dispositivos" FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                                  HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Row="5" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Todas as funcionalidades" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Suporte prioritário" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Modo Gamer avançado" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Otimizações de rede" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Perfis por jogo" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <Button Grid.Row="6" Content="Comprar Pro" 
                                           Style="{StaticResource ActionButtonStyle}"
                                           Command="{Binding BuyLicenseCommand}"
                                           CommandParameter="pro"
                                           HorizontalAlignment="Stretch"
                                           Padding="0,12" FontSize="12" FontWeight="Bold"
                                           Margin="0,12,0,0"/>
                                </Grid>
                            </Border>
                            
                            <!-- Enterprise - DESIGN EMPRESARIAL PREMIUM -->
                            <Border Grid.Column="3" Margin="6,0,0,0" CornerRadius="14">
                                <Border.Background>
                                    <SolidColorBrush Color="{DynamicResource DarkPanelColor}"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>2</Border.BorderThickness>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#8B31FF" Opacity="0.5"/>
                                </Border.Effect>
                                
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Badge Enterprise Premium -->
                                    <Border Grid.Row="0" CornerRadius="16" Padding="12,5" 
                                           HorizontalAlignment="Center" Margin="0,-24,0,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                                <GradientStop Color="#31A8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#8B31FF" Opacity="0.7"/>
                                        </Border.Effect>
                                        <TextBlock Text="👑 ENTERPRISE" FontSize="9" FontWeight="Bold" 
                                                  Foreground="{DynamicResource TextPrimary}"/>
                                    </Border>
                                    
                                    <!-- Ícone Premium com Gradiente Voltris -->
                                    <Path Grid.Row="1" 
                                          Data="M12,2L15.09,8.26L22,9.27L17,14.14L18.18,21.02L12,17.77L5.82,21.02L7,14.14L2,9.27L8.91,8.26L12,2Z" 
                                          Width="28" Height="28" 
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,10">
                                        <Path.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                                <GradientStop Color="#31A8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Fill>
                                        <Path.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                                        </Path.Effect>
                                    </Path>
                                    
                                    <TextBlock Grid.Row="2" Text="Enterprise" FontSize="18" FontWeight="Bold" 
                                              HorizontalAlignment="Center" Margin="0,0,0,6">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                                <GradientStop Color="#31A8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    
                                    <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <TextBlock Text="R$ 1.500,00" FontSize="22" FontWeight="Bold" 
                                                  HorizontalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock Text="/mês" FontSize="11" Foreground="#6B6B80"
                                                  HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Row="4" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#40FF4B6B" Offset="0"/>
                                                <GradientStop Color="#408B31FF" Offset="0.5"/>
                                                <GradientStop Color="#4031A8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="∞ Ilimitados" FontSize="11" Foreground="{DynamicResource TextPrimary}"
                                                  HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Row="5" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Tudo do Pro" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Atualizações vitalícias" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Suporte 24/7 Premium" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="API de integração" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="✓" FontSize="12" Foreground="#00FF88" Margin="0,0,6,0" FontWeight="Bold"/>
                                            <TextBlock Text="Gerenciamento centralizado" FontSize="11" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <Button Grid.Row="6" Content="Comprar Enterprise" 
                                           Command="{Binding BuyLicenseCommand}"
                                           CommandParameter="enterprise"
                                           HorizontalAlignment="Stretch"
                                           Padding="0,12" FontSize="12" FontWeight="Bold"
                                           Margin="0,12,0,0"
                                           Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#FF4B6B" Offset="0"/>
                                                            <GradientStop Color="#8B31FF" Offset="0.5"/>
                                                            <GradientStop Color="#31A8FF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border"
                                                                   Background="{TemplateBinding Background}"
                                                                   CornerRadius="8"
                                                                   Padding="{TemplateBinding Padding}">
                                                                <Border.Effect>
                                                                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" 
                                                                                    Color="#8B31FF" Opacity="0.6"/>
                                                                </Border.Effect>
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Effect">
                                                                        <Setter.Value>
                                                                            <DropShadowEffect BlurRadius="24" ShadowDepth="0" 
                                                                                            Color="#8B31FF" Opacity="0.9"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                        
                        <!-- Área de ativação - PROFISSIONAL E RESPONSIVO -->
                        <Border Background="{DynamicResource DarkPanelBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="30,24" Margin="0,10,0,0">
                            <StackPanel>
                                <Grid HorizontalAlignment="Center" Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Path Grid.Column="0" 
                                          Data="M12,1L8,5H11V14H13V5H16M18,23H6C4.89,23 4,22.1 4,21V9A2,2 0 0,1 6,7H9V9H6V21H18V9H15V7H18A2,2 0 0,1 20,9V21A2,2 0 0,1 18,23Z" 
                                          Fill="{DynamicResource PrimaryBrush}"
                                          Width="20" Height="20" 
                                          Stretch="Uniform"
                                          VerticalAlignment="Center" 
                                          Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1" Text="Ativar Licença" 
                                              FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                                
                                <TextBlock Text="Já possui uma chave de licença? Insira abaixo para ativar:" 
                                          FontSize="14" Foreground="#8B8BA0"
                                          HorizontalAlignment="Center" Margin="0,0,0,18"
                                          TextWrapping="Wrap"/>
                                
                                <StackPanel HorizontalAlignment="Center" MaxWidth="600">
                                    <!-- Campo de licença com botão integrado -->
                                    <Border Background="{DynamicResource DarkPanelAltBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="2" 
                                           CornerRadius="10" Padding="0" MinHeight="50">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Campo de entrada -->
                                            <TextBox x:Name="LicenseKeyInput"
                                                    Grid.Column="0"
                                                    Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    FontSize="15"
                                                    FontFamily="Consolas, Cascadia Code"
                                                    BorderThickness="0"
                                                    CaretBrush="#8B31FF"
                                                    VerticalContentAlignment="Center"
                                                    Padding="16,0"
                                                    MinWidth="300">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="TextBox">
                                                                    <Grid>
                                                                        <TextBlock x:Name="Placeholder"
                                                                                  Text="VOLTRIS-XXXX-XXXX-XXXX-XXXX"
                                                                                  Foreground="#4A4A5A"
                                                                                  FontFamily="Consolas"
                                                                                  FontSize="15"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="16,0"
                                                                                  IsHitTestVisible="False"
                                                                                  Visibility="Collapsed"/>
                                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                                     VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="Text" Value="">
                                                                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                                        </Trigger>
                                                                        <Trigger Property="Text" Value="{x:Null}">
                                                                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            
                                            <!-- Botão Ativar -->
                                            <Button x:Name="ActivateButton"
                                                   Grid.Column="1"
                                                   Command="{Binding ActivateCommand}"
                                                   Visibility="{Binding IsActivateButtonVisible, Converter={StaticResource BoolToVis}}"
                                                   Margin="4"
                                                   Padding="24,0"
                                                   Cursor="Hand"
                                                   IsEnabled="{Binding CanActivate}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#8B31FF" Offset="0"/>
                                                                    <GradientStop Color="#6D28D9" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="border"
                                                                           Background="{TemplateBinding Background}"
                                                                           CornerRadius="7"
                                                                           Padding="{TemplateBinding Padding}">
                                                                        <Border.Effect>
                                                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" 
                                                                                            Color="#8B31FF" Opacity="0.4"/>
                                                                        </Border.Effect>
                                                                        <Grid>
                                                                            <TextBlock x:Name="NormalText"
                                                                                      Text="Ativar"
                                                                                      FontSize="15"
                                                                                      FontWeight="SemiBold"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"
                                                                                      Foreground="{DynamicResource TextPrimary}"/>
                                                                            <StackPanel x:Name="LoadingPanel"
                                                                                       Orientation="Horizontal"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Visibility="Collapsed">
                                                                                <TextBlock Text="⏳" FontSize="13" Margin="0,0,5,0"/>
                                                                                <TextBlock Text="Ativando..."
                                                                                          FontSize="13"
                                                                                          FontWeight="SemiBold"
                                                                                          Foreground="{DynamicResource TextPrimary}"/>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActivating}" Value="True">
                                                                            <Setter TargetName="NormalText" Property="Visibility" Value="Collapsed"/>
                                                                            <Setter TargetName="LoadingPanel" Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="border" Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" 
                                                                                                    Color="#8B31FF" Opacity="0.7"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Trigger>
                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                            <Setter Property="Opacity" Value="0.5"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Mensagem de ajuda -->
                                    <TextBlock Text="Formato: VOLTRIS-XXXX-XXXX-XXXX-XXXX"
                                              FontSize="12"
                                              Foreground="#6B6B80"
                                              HorizontalAlignment="Center"
                                              Margin="0,10,0,0"/>

                                    <!-- Indicador de Licença Ativa -->
                                    <Border Background="#1A00FF88" BorderBrush="#3000FF88" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,16,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTrialMode}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="✓" Foreground="#00FF88" FontWeight="Bold" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding ActiveLicenseTitle}" Foreground="#E0FFEF" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Status/Erro -->
                                <TextBlock x:Name="StatusText"
                                          Text="{Binding StatusMessage}"
                                          FontSize="14" Foreground="#8B8BA0"
                                          HorizontalAlignment="Center" Margin="0,20,0,0"
                                          TextWrapping="Wrap"
                                          Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}}"/>
                                
                                <Border x:Name="ErrorBorder"
                                       Visibility="{Binding ShowError, Converter={StaticResource BoolToVis}}"
                                       Background="#30FF4B6B" CornerRadius="10" Padding="20" Margin="0,15,0,0"
                                       MaxWidth="600">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="❌" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding ErrorMessage}"
                                                  FontSize="14" Foreground="#FF8B9B"
                                                  TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <Border x:Name="SuccessBorder"
                                       Visibility="{Binding ShowSuccess, Converter={StaticResource BoolToVis}}"
                                       Background="#3031FF6B" CornerRadius="10" Padding="20" Margin="0,15,0,0"
                                       MaxWidth="600">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="✅" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding StatusMessage}"
                                                  FontSize="14" Foreground="#8BFF8B"
                                                  TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- Device ID -->
                        <Border Background="{DynamicResource DarkPanelBrush}" BorderBrush="{DynamicResource DarkBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,20,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="Device ID:" FontSize="12" Foreground="#6B6B80"
                                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" 
                                          Text="{Binding DeviceId}" 
                                          FontSize="12" FontFamily="Consolas" Foreground="#8B8BA0"
                                          VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="📋 Copiar" 
                                       Style="{StaticResource SecondaryButtonStyle}"
                                       Command="{Binding CopyDeviceIdCommand}"
                                       Padding="12,6" FontSize="11"/>
                            </Grid>
                        </Border>
                        
                        <!-- Footer -->
                        <TextBlock Text="Ao ativar, você concorda com os Termos de Uso e Política de Privacidade"
                                  FontSize="11" Foreground="#4A4A5A"
                                  HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
                

            </Grid>
        </Grid>
    </Border>
</Window>

