<UserControl x:Class="VoltrisOptimizer.UI.Views.PersonalizeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             xmlns:conv="clr-namespace:VoltrisOptimizer.UI.Converters"
             Background="Transparent"
             UseLayoutRounding="True" SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:HexStringToBrushConverter x:Key="HexBrush"/>
        <conv:EqualToIntConverter x:Key="EqualToIntConverter"/>
        <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringVis"/>
        <conv:ObjectEqualsConverter x:Key="ObjEq"/>
        <!-- Card base -->
        <Style x:Key="PCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCardGlass}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <!-- Section title -->
        <Style x:Key="STitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <!-- Row label -->
        <Style x:Key="RLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Row hint -->
        <Style x:Key="RHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>


    </UserControl.Resources>

    <Grid>
        <!-- Busy overlay -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
              Panel.ZIndex="99" Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⚙" FontSize="32" HorizontalAlignment="Center"
                           Foreground="{DynamicResource PrimaryBrush}"/>
                <TextBlock Text="{Binding BusyMessage}" Foreground="White"
                           FontSize="13" Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,24">

                <!-- ── HEADER ────────────────────────────────────────────────────────── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                  Fill="{DynamicResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Personalizar" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource DefaultTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Central de personalização avançada do sistema e da interface"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="32,4,0,0"/>
                    </StackPanel>
                    <!-- Status badge -->
                    <Border Grid.Column="1" CornerRadius="8" Padding="12,6" VerticalAlignment="Center"
                            Background="#1A000000" BorderThickness="1"
                            BorderBrush="{Binding StatusColor, Converter={StaticResource HexBrush}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0"
                                     Fill="{Binding StatusColor, Converter={StaticResource HexBrush}}"/>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── PERFIS ──────────────────────────────────────────────────────────── -->
                <Border Style="{StaticResource PCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"
                                  Fill="{DynamicResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Perfis de Otimização" Style="{StaticResource STitle}" Margin="0"/>
                        </StackPanel>
                        <TextBlock Text="Selecione um perfil pré-configurado ou personalize manualmente abaixo."
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,14"/>
                        <!-- Profile buttons -->
                        <UniformGrid Columns="4" Margin="0,0,0,14">
                            <Button Margin="0,0,6,0" Padding="0,12" Cursor="Hand"
                                    Command="{Binding ApplyProfileCommand}"
                                    CommandParameter="Normal"
                                    Tag="Normal"
                                    ToolTip="Configurações padrão do Windows — todas as animações e efeitos ativos">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                        <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
                                        <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1" CornerRadius="10"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#25FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="🌿" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Normal" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"
                                               Foreground="{DynamicResource DefaultTextBrush}"/>
                                    <TextBlock Text="Padrão" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="3,0,3,0" Padding="0,12" Cursor="Hand"
                                    Command="{Binding ApplyProfileCommand}"
                                    CommandParameter="Performance"
                                    ToolTip="Desativa animações pesadas e otimiza responsividade">

                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="#1A31A8FF"/>
                                        <Setter Property="BorderBrush" Value="#3031A8FF"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1" CornerRadius="10"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#2531A8FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Performance" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"
                                               Foreground="#31A8FF"/>
                                    <TextBlock Text="Balanceado" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="3,0,3,0" Padding="0,12" Cursor="Hand"
                                    Command="{Binding ApplyProfileCommand}"
                                    CommandParameter="Ultra"
                                    ToolTip="Máxima performance — desativa todos os efeitos visuais">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="#1AFF4B6B"/>
                                        <Setter Property="BorderBrush" Value="#30FF4B6B"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1" CornerRadius="10"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#25FF4B6B"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="🔥" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Ultra" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"
                                               Foreground="#FF4B6B"/>
                                    <TextBlock Text="MÃ¡ximo" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="6,0,0,0" Padding="0,12" Cursor="Hand"
                                    Command="{Binding ApplyProfileCommand}"
                                    CommandParameter="Custom"
                                    ToolTip="Configure cada opÃ§Ã£o manualmente abaixo">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="#1A8B31FF"/>
                                        <Setter Property="BorderBrush" Value="#308B31FF"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1" CornerRadius="10"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#258B31FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="🎛" FontSize="20" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Custom" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"
                                               Foreground="#8B31FF"/>
                                    <TextBlock Text="Manual" FontSize="9" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- â”€â”€ DUAS COLUNAS: AnimaÃ§Ãµes + Performance Visual â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Animações do Sistema -->
                    <Border Grid.Column="0" Style="{StaticResource PCard}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="M13,2.05V4.05C17.39,4.59 20.5,8.58 19.96,12.97C19.5,16.61 16.64,19.5 13,19.95V21.95C18.5,21.4 22.5,16.5 21.95,11C21.5,6.25 17.73,2.5 13,2.05M5.67,19.74C7.18,21 9.04,21.79 11,21.95V19.95C9.58,19.82 8.23,19.25 7.1,18.37L5.67,19.74M7.1,5.74C8.22,4.84 9.57,4.26 11,4.06V2.06C9.04,2.21 7.18,3.01 5.67,4.26L7.1,5.74M5.69,7.1L4.26,5.67C3,7.18 2.21,9.04 2.05,11H4.05C4.24,9.58 4.8,8.23 5.69,7.1M4.06,13H2.06C2.21,14.96 3.01,16.82 4.27,18.33L5.69,16.9C4.81,15.77 4.24,14.42 4.06,13Z"
                                      Fill="#31A8FF" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Animações do Sistema" Style="{StaticResource STitle}" Margin="0"/>
                            </StackPanel>

                            <!-- Toggle row helper template via inline -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Animações de Janela" Style="{StaticResource RLabel}"
                                               ToolTip="Controla a animaÃ§Ã£o de minimizar/maximizar janelas (MinAnimate)"/>
                                    <TextBlock Text="Minimizar/maximizar com efeito" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding WindowAnimations}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Animações de Menu" Style="{StaticResource RLabel}"
                                               ToolTip="Controla o delay de exibiÃ§Ã£o de menus (MenuShowDelay)"/>
                                    <TextBlock Text="Menus aparecem com fade/slide" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding MenuAnimations}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Animações da Taskbar" Style="{StaticResource RLabel}"
                                               ToolTip="AnimaÃ§Ã£o de botÃµes na barra de tarefas (TaskbarAnimations)"/>
                                    <TextBlock Text="BotÃµes da barra com animaÃ§Ã£o" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding TaskbarAnimations}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Sombras de Janela" Style="{StaticResource RLabel}"
                                               ToolTip="Sombras sob janelas e Ã­cones (ListviewShadow)"/>
                                    <TextBlock Text="Efeito de profundidade visual" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding DropShadows}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Suavização de Fonte" Style="{StaticResource RLabel}"
                                               ToolTip="ClearType â€” melhora legibilidade de texto (FontSmoothing)"/>
                                    <TextBlock Text="ClearType para texto mais nÃ­tido" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding FontSmoothing}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Performance Visual -->
                    <Border Grid.Column="2" Style="{StaticResource PCard}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="M7,2V13H10V22L17,10H13L17,2H7Z"
                                      Fill="#FFAA00" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Performance Visual" Style="{StaticResource STitle}" Margin="0"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Efeitos de Transparência" Style="{StaticResource RLabel}"
                                               ToolTip="Ativa/desativa transparÃªncia do sistema (EnableTransparency)"/>
                                    <TextBlock Text="Acrylic/Mica no sistema" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding TransparencyEffects}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Aceleração de Hardware" Style="{StaticResource RLabel}"
                                               ToolTip="Prioriza GPU no perfil de sistema (SystemResponsiveness=0)"/>
                                    <TextBlock Text="GPU com mÃ¡xima prioridade" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding HardwareAcceleration}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Explorer de Alta Resposta" Style="{StaticResource RLabel}"
                                               ToolTip="Reduz HungAppTimeout e WaitToKillAppTimeout para resposta mais rÃ¡pida"/>
                                    <TextBlock Text="Apps travados fecham mais rÃ¡pido" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding ExplorerHighPerf}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Hardware GPU Scheduling" Style="{StaticResource RLabel}"
                                               ToolTip="HAGS â€” reduz latência de GPU (requer reinicialização). HwSchMode=2"/>
                                    <TextBlock Text="Reduz latência de GPU (Win10 2004+)" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding HardwareScheduling}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Prioridade GPU para Jogos" Style="{StaticResource RLabel}"
                                               ToolTip="Define GPU Priority=8 e Scheduling Category=High para jogos"/>
                                    <TextBlock Text="GPU Priority=8 para máximo FPS" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding GamingGpuPriority}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Multi-Plane Overlay (MPO)" Style="{StaticResource RLabel}"
                                               ToolTip="MPO pode causar tearing em alguns sistemas. Desativar pode melhorar estabilidade."/>
                                    <TextBlock Text="Desativar pode corrigir tearing/stuttering" Style="{StaticResource RHint}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding MpoEnabled}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── GPU INFO + DIAGNÓSTICO ─────────────────────────────────── -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- GPU Info -->
                    <Border Grid.Column="0" Style="{StaticResource PCard}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="M4,6H20V16H4M20,18A2,2 0 0,0 22,16V6C22,4.89 21.1,4 20,4H4C2.89,4 2,4.89 2,6V16A2,2 0 0,0 4,18H0V20H24V18H20Z"
                                      Fill="#8B31FF" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="GPU Detectada" Style="{StaticResource STitle}" Margin="0"/>
                            </StackPanel>
                            <Border Background="#0DFFFFFF" CornerRadius="10" Padding="14,10" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding GpuName}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource DefaultTextBrush}"/>
                                    <TextBlock Text="Placa de vídeo principal detectada via WMI"
                                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="💡 Dica: Hardware GPU Scheduling (HAGS) requer reinicialização para ter efeito."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Diagnóstico de Gargalos -->
                    <Border Grid.Column="2" Style="{StaticResource PCard}" Margin="0">
                        <StackPanel>
