                                                            <!-- Badge Win11 only -->
                                                            <TextBlock Text="Win11" FontSize="7" HorizontalAlignment="Center"
                                                                       Foreground="#80FFFFFF" Margin="0,1,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#30FF4466"/>
                                                            <Setter TargetName="bd" Property="BorderBrush" Value="#60FF4466"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#25FF4466"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </RadioButton.Style>
                            </RadioButton>
                        </UniformGrid>

                        <!-- Opções extras -->
                        <Border Background="#0DFFFFFF" CornerRadius="10" Padding="14,12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Opções de Personalização" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <!-- Col 1 -->
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Limpar barra de endereço" Style="{StaticResource RLabel}"
                                                           ToolTip="clearAddress=true — remove fundo da barra de endereço"/>
                                                <TextBlock Text="clearAddress" Style="{StaticResource RHint}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding ExplorerClearAddress}"
                                                      VerticalAlignment="Center" Style="{StaticResource PremiumCheckBoxStyle}"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Limpar toolbar" Style="{StaticResource RLabel}"
                                                           ToolTip="clearBarBg=true — remove cor de fundo da scrollbar"/>
                                                <TextBlock Text="clearBarBg" Style="{StaticResource RHint}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding ExplorerClearBarBg}"
                                                      VerticalAlignment="Center" Style="{StaticResource PremiumCheckBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <!-- Col 2 -->
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Limpar WinUI/XamlIslands" Style="{StaticResource RLabel}"
                                                           ToolTip="clearWinUIBg=true — necessário no Win11 para blur na página Início (WinUI3/DesktopChildSiteBridge)"/>
                                                <TextBlock Text="clearWinUIBg (Win11)" Style="{StaticResource RHint}"/>
                                                <TextBlock Text="✅ Ative para blur na página Início (Win11)"
                                                           FontSize="9" Foreground="#00BFFF"
                                                           Visibility="{Binding IsWin11, Converter={StaticResource BoolVis}}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding ExplorerClearWinUIBg}"
                                                      VerticalAlignment="Center" Style="{StaticResource PremiumCheckBoxStyle}"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Mostrar linha separadora" Style="{StaticResource RLabel}"
                                                           ToolTip="showLine=true — exibe linha entre TreeView e DUIView"/>
                                                <TextBlock Text="showLine" Style="{StaticResource RHint}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding ExplorerShowLine}"
                                                      VerticalAlignment="Center" Style="{StaticResource PremiumCheckBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- Sliders ARGB -->
                                <Separator Margin="0,6,0,10" Background="#1AFFFFFF"/>
                                <TextBlock Text="Cor de Mistura (ARGB)" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Alpha" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ExplorerAlpha,Mode=TwoWay}" Style="{StaticResource ModernSlider}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ExplorerAlpha}" FontSize="10" Foreground="#00BFFF" VerticalAlignment="Center" Margin="6,0,0,0" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="R" FontSize="10" Foreground="#FF6B6B" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ExplorerColorR,Mode=TwoWay}" Style="{StaticResource ModernSlider}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ExplorerColorR}" FontSize="10" Foreground="#FF6B6B" VerticalAlignment="Center" Margin="6,0,0,0" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="G" FontSize="10" Foreground="#51CF66" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ExplorerColorG,Mode=TwoWay}" Style="{StaticResource ModernSlider}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ExplorerColorG}" FontSize="10" Foreground="#51CF66" VerticalAlignment="Center" Margin="6,0,0,0" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="B" FontSize="10" Foreground="#4DABF7" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ExplorerColorB,Mode=TwoWay}" Style="{StaticResource ModernSlider}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ExplorerColorB}" FontSize="10" Foreground="#4DABF7" VerticalAlignment="Center" Margin="6,0,0,0" FontWeight="SemiBold"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Botões de Ação -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Instalar -->
                            <Button Grid.Column="0" Command="{Binding InstallExplorerBlurCommand}"
                                    Cursor="Hand" Padding="14,10">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1A00BFFF"/>
                                        <Setter Property="BorderBrush" Value="#3000BFFF"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Foreground" Value="#00BFFF"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#2500BFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✅  " FontSize="13"/>
                                    <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Instalar Efeito"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ExplorerBlurInstalled}" Value="True">
                                                        <Setter Property="Text" Value="Aplicar Configurações"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                            <!-- Remover -->
                            <Button Grid.Column="2" Command="{Binding UninstallExplorerBlurCommand}"
                                    Cursor="Hand" Padding="14,10">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1AFF4466"/>
                                        <Setter Property="BorderBrush" Value="#30FF4466"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Foreground" Value="#FF4466"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#25FF4466"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑️  " FontSize="13"/>
                                    <TextBlock Text="Remover Efeito" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>


                    </StackPanel>
                </Border>

                <!-- ── ÍCONES DO WINDOWS 11 (Safe Registry) ────────────────────────── -->
                <Border Style="{StaticResource PCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Path Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                  Fill="#51CF66" Width="16" Height="16" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Ícones do Windows 11" Style="{StaticResource STitle}" Margin="0"/>
                            <Border CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                                    Background="#1A51CF66" BorderBrush="#3051CF66" BorderThickness="1">
                                <TextBlock Text="Safe Registry" FontSize="9" Foreground="#51CF66" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Transforma o visual do Windows 10 com os ícones modernos do Windows 11."
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,14"/>

                        <!-- Aviso Indisponibilidade para Windows 11 -->
                        <Border Visibility="{Binding IsWindows11, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="#1A31FF" BorderBrush="#3031FF" BorderThickness="1"
                                CornerRadius="8" Padding="12,10" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ℹ️" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Aviso: Seu Windows 11 já inclui estes ícones nativamente. Este ajuste foi desenvolvido exclusivamente para o Windows 10."
                                           Foreground="#8B31FF" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" MaxWidth="350"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1A51CF66" BorderBrush="#4051CF66" BorderThickness="1"
                                CornerRadius="8" Padding="12,8" Margin="0,0,0,14">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✅" FontSize="13" Foreground="#51CF66" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap">
                                    <Run Text="100% Nativo e Seguro: " FontWeight="SemiBold" Foreground="#51CF66"/>
                                    <Run Text="Nenhuma DLL original é modificada. Não ativa Antivírus e não é revertido pelo utilitário sfc /scannow."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="📁  Aplicar Pacote de Ícones" Style="{StaticResource RLabel}"
                                           ToolTip="Copia os ícones e aplica overrides na chave Shell Icons do Registro sem modificar mem/dll"/>
                                <TextBlock Text="Ativar visual do Windows 11 (piscará a tela para recarregar o explorer)" Style="{StaticResource RHint}"/>
                            </StackPanel>
                            <!-- Como definimos uma bool chamada Win11IconsEnabled no ViewModel -->
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding Win11IconsEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding IsWindows10}"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource PremiumCheckBoxStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── CURSORES PERSONALIZADOS ──────────────────────────────────────────── -->
                <Border Style="{StaticResource PCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <!-- Cabeçalho -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <!-- Ícone de cursor (path SVG) -->
                            <Path Data="M13.64,21.97C13.14,22.21 12.54,22 12.31,21.5L10.13,16.76L7.62,18.78C7.45,18.92 7.24,19 7,19A1,1 0 0,1 6,18V3A1,1 0 0,1 7,2C7.24,2 7.47,2.09 7.64,2.23L7.65,2.22L7.76,2.33L19.14,13.72C19.57,14.15 19.57,14.86 19.14,15.29C18.7,15.72 18,15.72 17.56,15.29L15.04,12.78L13.8,15.07L16.32,20.11C16.57,20.62 16.35,21.22 15.84,21.46L13.64,21.97Z"
                                  Fill="#CC88FF" Width="18" Height="18" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Cursores Personalizados" Style="{StaticResource STitle}" Margin="0"/>
                            <Border CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                                    Background="#1ACC88FF" BorderBrush="#30CC88FF" BorderThickness="1">
                                <TextBlock Text="Tempo Real" FontSize="9" Foreground="#CC88FF" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="Selecione um tema de cursor e aplique em tempo real, sem reiniciar o sistema. A escolha é salva automaticamente."
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <!-- Seção de Seleção de Cursor -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Escolha seu Estilo" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,2"/>
                                <TextBlock Text="A aplicação é instantânea. Clique no card desejado." Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                            </StackPanel>

                            <!-- Restaurar Padrão (Agora como botão secundário discreto) -->
                            <Button Grid.Column="1"
                                    Command="{Binding RestoreCursorCommand}"
                                    FocusVisualStyle="{x:Null}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#15FF4466"/>
                                        <Setter Property="BorderBrush" Value="#40FF4466"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Foreground" Value="#FF99AA"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="16,10"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="btnBorder" 
                                                            Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                                            CornerRadius="10" 
                                                            Padding="{TemplateBinding Padding}"
                                                            SnapsToDevicePixels="True">
                                                        <Grid>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                <TextBlock Text="↺" FontSize="16" Margin="0,-2,10,0" VerticalAlignment="Center" 
                                                                         Foreground="{TemplateBinding Foreground}"/>
                                                                <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="btnBorder" Property="Background" Value="#25FF4466"/>
                                                            <Setter TargetName="btnBorder" Property="BorderBrush" Value="#80FF4466"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.8"/>
                                                            <Setter TargetName="btnBorder" Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="Restaurar Original" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            </Button>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding AvailableCursorThemes}" Margin="0,0,0,20">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="CardBorder"
                                            Margin="0,0,10,0"
                                            CornerRadius="14" Padding="16,18"
                                            Cursor="Hand"
                                            BorderThickness="2"
                                            Background="#0AFFFFFF"
                                            BorderBrush="#10FFFFFF">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.ApplyCursorThemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource ObjEq}">
                                                                <Binding Path="."/>
                                                                <Binding Path="DataContext.SelectedCursorTheme" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="#20CC88FF"/>
                                                        <Setter Property="BorderBrush" Value="#80CC88FF"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#15FFFFFF"/>
                                                        <Setter Property="BorderBrush" Value="#30CC88FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <Border Width="46" Height="46" CornerRadius="23" Background="#12CC88FF" Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Emoji}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Description}" FontSize="9.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="140"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Status do Cursor -->
                        <Border Background="#10000000" CornerRadius="10" Padding="12,8" Visibility="{Binding CursorStatusMessage, Converter={StaticResource StringVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{Binding CursorStatusColor, Converter={StaticResource HexBrush}}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CursorStatusMessage}" Foreground="White" FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ── RODAPÉ: Restaurar Padrões ──────────────────────────────────────── -->


                <Border Style="{StaticResource PCard}" Margin="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Restaurar Configurações Padrão" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource DefaultTextBrush}"/>
                            <TextBlock Text="Reverte todas as personalizações para os valores originais do Windows"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="↩  Restaurar Padrões"
                                Command="{Binding RestoreDefaultsCommand}"
                                Cursor="Hand" Padding="16,9"
                                ToolTip="Restaura todas as configurações de personalização para os valores padrão do Windows">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1AFF4466"/>
                                    <Setter Property="BorderBrush" Value="#30FF4466"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="#FF4466"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#25FF4466"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

