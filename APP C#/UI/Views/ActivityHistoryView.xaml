<UserControl x:Class="VoltrisOptimizer.UI.Views.ActivityHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="850"
             Background="Transparent">

    <UserControl.DataContext>
        <viewmodels:ActivityHistoryViewModel/>
    </UserControl.DataContext>

    <Viewbox Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="24">
        <Grid Width="1000" Height="650">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Timeline Area -->
            </Grid.RowDefinitions>

            <!-- Header Area -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Back Button -->
                    <Button Command="{Binding GoBackCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="44" Height="44"
                            Margin="0,0,16,0"
                            ToolTip="Voltar para o Dashboard">
                        <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
                              Fill="{StaticResource TextPrimary}"
                              Width="20" Height="20"
                              Stretch="Uniform"/>
                    </Button>

                    <StackPanel>
                        <TextBlock Text="HISTÓRICO DE ATIVIDADES"
                                   FontSize="28"
                                   FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F8FAFC" Offset="0"/>
                                    <GradientStop Color="#94A3B8" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Monitoramento completo de todas as operações do sistema em tempo real"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#1A10B981" CornerRadius="12" Padding="14,8" Margin="0,0,12,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#10B981" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Grid.Column="1" Text="LIVE" FontSize="12" FontWeight="Black" Foreground="#10B981" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <Button Content="LIMPAR TUDO" 
                            Command="{Binding ClearHistoryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="20,0"
                            Height="40"/>
                </StackPanel>
            </Grid>

            <!-- Timeline / Content -->
            <Border Grid.Row="1" 
                    Background="{StaticResource BgCard}" 
                    CornerRadius="20" 
                    BorderBrush="{StaticResource BorderDefault}" 
                    BorderThickness="1"
                    Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table Header Labels (Aligned with content) -->
                    <Grid Grid.Row="0" Margin="40,0,0,20" Opacity="0.6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>   <!-- Message -->
                            <ColumnDefinition Width="180"/>  <!-- Time/Status -->
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="OPERAÇÃO / MENSAGEM DO SISTEMA" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" Text="DETALHES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    </Grid>

                    <!-- Logs Area -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <!-- Vertical Timeline Line (Perfectly Centered under nodes) -->
                            <Rectangle Fill="#1AFFFFFF" Width="1" HorizontalAlignment="Left" Margin="12,0,0,0" Grid.RowSpan="999"/>
                            
                            <ItemsControl ItemsSource="{Binding AllEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/> <!-- Timeline Node Col -->
                                                <ColumnDefinition Width="*"/>  <!-- Content Col -->
                                                <ColumnDefinition Width="180"/> <!-- Meta Col -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Timeline Node (Circular Pulse) -->
                                            <Border Grid.Column="0" Width="12" Height="12" CornerRadius="6" 
                                                    Background="{DynamicResource DarkBrush}" 
                                                    BorderBrush="{Binding TypeColor}" 
                                                    BorderThickness="2" 
                                                    VerticalAlignment="Top" 
                                                    Margin="0,5,0,0"
                                                    Panel.ZIndex="2">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="{Binding TypeColor}" Opacity="0.5"/>
                                                </Border.Effect>
                                            </Border>

                                            <!-- Message Content -->
                                            <StackPanel Grid.Column="1" Margin="16,0,32,0">
                                                <TextBlock Text="{Binding Message}" 
                                                         Foreground="{StaticResource TextPrimary}" 
                                                         FontSize="15" 
                                                         FontWeight="SemiBold" 
                                                         TextWrapping="Wrap"/>
                                            </StackPanel>
                                            
                                            <!-- Time and Status (Meta) -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Timestamp}" 
                                                         Foreground="{StaticResource TextSecondary}" 
                                                         FontSize="13" 
                                                         FontWeight="Medium"
                                                         Margin="0,0,0,4"/>
                                                <Border Padding="8,4" CornerRadius="6" HorizontalAlignment="Left">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding TypeColor}" Opacity="0.15"/>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Type}" 
                                                             Foreground="{Binding TypeColor}" 
                                                             FontSize="10" 
                                                             FontWeight="Black"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>
