<UserControl x:Class="VoltrisOptimizer.UI.Views.EnergyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VoltrisOptimizer.UI.Converters"
             Background="Transparent"
             UseLayoutRounding="True" SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:HexStringToBrushConverter x:Key="HexBrush"/>
        <Style x:Key="ECard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCardGlass}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style x:Key="SecTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="MLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="MVal" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="ABtn" TargetType="Button">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2AFFFFFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#31A8FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#35FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PBtn" TargetType="Button" BasedOn="{StaticResource ABtn}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF4B6B" Offset="0"/>
                        <GradientStop Color="#8B31FF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="PlanItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#20A855F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </UserControl.Resources>
    <ScrollViewer                   VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF4B6B" Offset="0"/>
                            <GradientStop Color="#8B31FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Smart Energy Engine" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource DefaultTextBrush}"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding DeviceTypeText}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding CpuName}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            <Border Grid.Column="1" CornerRadius="20" Padding="16,8" VerticalAlignment="Center"
                    BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#208B31FF" Offset="0"/>
                        <GradientStop Color="#2031A8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#8B31FF" Offset="0"/>
                        <GradientStop Color="#31A8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#00FF88" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="White">
                        <Run Text="Plano Ativo: "/>
                        <Run Text="{Binding ActivePlanName}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding BatteryText}" FontSize="11" Foreground="#FFAA00"
                               Margin="12,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding IsOnBattery, Converter={StaticResource BoolVis}}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ROW 1: ENERGY SCORE + MONITOR -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Score -->
            <Border Grid.Column="0" Style="{StaticResource ECard}">
                <StackPanel>
                    <TextBlock Text="Energy Score" Style="{StaticResource SecTitle}"/>
                    <Grid HorizontalAlignment="Center" Margin="0,8,0,16">
                        <Ellipse Width="90" Height="90">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="78" Height="78" Fill="{DynamicResource BgCardGlass}"/>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding EnergyScore.Grade}" FontSize="32" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="{Binding EnergyScore.GradeColor, Converter={StaticResource HexBrush}}"/>
                            <TextBlock Text="{Binding EnergyScore.Overall, StringFormat={}{0}pts}"
                                       FontSize="11" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                    <UniformGrid Columns="3">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding EnergyScore.Performance}" FontSize="18" FontWeight="Bold"
                                       Foreground="#FF4B6B" HorizontalAlignment="Center"/>
                            <TextBlock Text="Perf" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding EnergyScore.Efficiency}" FontSize="18" FontWeight="Bold"
                                       Foreground="#00FF88" HorizontalAlignment="Center"/>
                            <TextBlock Text="Efic" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding EnergyScore.Thermal}" FontSize="18" FontWeight="Bold"
                                       Foreground="#31A8FF" HorizontalAlignment="Center"/>
                            <TextBlock Text="Térm" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>
            <!-- Monitor -->
            <Border Grid.Column="2" Style="{StaticResource ECard}">
                <StackPanel>
                    <TextBlock Text="Monitor em Tempo Real" Style="{StaticResource SecTitle}"/>
                    <UniformGrid Columns="4" Margin="0,8,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="CPU Freq" Style="{StaticResource MLbl}" HorizontalAlignment="Center"/>
                            <TextBlock Style="{StaticResource MVal}" HorizontalAlignment="Center" Foreground="#FF4B6B"
                                       Text="{Binding CpuFreqMhz, StringFormat={}{0:F0}}"/>
                            <TextBlock Text="MHz" Style="{StaticResource MLbl}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="CPU Uso" Style="{StaticResource MLbl}" HorizontalAlignment="Center"/>
                            <TextBlock Style="{StaticResource MVal}" HorizontalAlignment="Center" Foreground="#8B31FF"
                                       Text="{Binding CpuUsage, StringFormat={}{0:F0}}"/>
                            <TextBlock Text="%" Style="{StaticResource MLbl}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Temperatura" Style="{StaticResource MLbl}" HorizontalAlignment="Center"/>
                            <TextBlock Style="{StaticResource MVal}" HorizontalAlignment="Center" Foreground="#FFAA00"
                                       Text="{Binding CpuTemp, StringFormat={}{0:F0}}"/>
                            <TextBlock Text="°C" Style="{StaticResource MLbl}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="RAM" Style="{StaticResource MLbl}" HorizontalAlignment="Center"/>
                            <TextBlock Style="{StaticResource MVal}" HorizontalAlignment="Center" Foreground="#31A8FF"
                                       Text="{Binding RamUsage, StringFormat={}{0:F0}}"/>
                            <TextBlock Text="%" Style="{StaticResource MLbl}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                    <!-- Throttling status inline -->
                    <Border CornerRadius="10" Padding="12,8" Margin="0,16,0,0" BorderThickness="1"
                            BorderBrush="{Binding ThrottlingStatus.StatusColorHex, Converter={StaticResource HexBrush}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding ThrottlingStatus.StatusColorHex, Converter={StaticResource HexBrush}}"
                                           Text="{Binding ThrottlingStatus.StatusText}"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="{Binding ThrottlingStatus.CurrentFreqMhz, StringFormat={}{0:F0}}"/>
                                    <Run Text=" MHz / "/>
                                    <Run Text="{Binding ThrottlingStatus.MaxFreqMhz, StringFormat={}{0:F0}}"/>
                                    <Run Text=" MHz máx"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"
                                       Foreground="{Binding ThrottlingStatus.StatusColorHex, Converter={StaticResource HexBrush}}"
                                       Text="{Binding ThrottlingStatus.FrequencyRatio, StringFormat={}{0:P0}}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ROW 2: SMART RECOMMENDATIONS -->
        <Border Grid.Row="2" Style="{StaticResource ECard}" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="🧠 Smart Energy Engine" Style="{StaticResource SecTitle}" Margin="0"/>
                    <Border CornerRadius="10" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                            Background="#20FFD700" BorderBrush="#FFD700" BorderThickness="1">
                        <TextBlock Text="IA ADAPTATIVA" FontSize="9" FontWeight="Bold" Foreground="#FFD700"/>
                    </Border>
                </StackPanel>
                <ItemsControl ItemsSource="{Binding Recommendations}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,10,0" CornerRadius="14" Padding="16,14" Cursor="Hand"
                                    Background="#12FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.ApplyProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <TextBlock Text="{Binding Icon}" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource DefaultTextBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,10"/>
                                    <Border Height="4" CornerRadius="2" Background="#15FFFFFF"/>
                                    <TextBlock Text="{Binding EnergyScore, StringFormat=Score: {0}}"
                                               FontSize="10" Foreground="{Binding AccentColor, Converter={StaticResource HexBrush}}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ROW 3: PLAN MANAGER + EDITOR -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Plan Manager -->
            <Border Grid.Column="0" Style="{StaticResource ECard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="⚡ Gerenciador de Planos" Style="{StaticResource SecTitle}"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Plans}" SelectedItem="{Binding SelectedPlan}"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource PlanItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource DefaultTextBrush}"/>
                                        <TextBlock Text="{Binding Guid}" FontSize="9"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border CornerRadius="8" Padding="6,2" Margin="4,0,0,0"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolVis}}"
                                                Background="#2000FF88" BorderBrush="#00FF88" BorderThickness="1">
                                            <TextBlock Text="ATIVO" FontSize="9" FontWeight="Bold" Foreground="#00FF88"/>
                                        </Border>
                                        <Border CornerRadius="8" Padding="6,2" Margin="4,0,0,0"
                                                Visibility="{Binding IsVoltris, Converter={StaticResource BoolVis}}"
                                                Background="#208B31FF" BorderBrush="#8B31FF" BorderThickness="1">
                                            <TextBlock Text="VOLTRIS" FontSize="9" FontWeight="Bold" Foreground="#8B31FF"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <WrapPanel Grid.Row="2" Margin="0,12,0,0">
                        <Button Content="✅ Ativar" Style="{StaticResource PBtn}" Margin="0,0,8,8"
                                Command="{Binding ActivatePlanCommand}" CommandParameter="{Binding SelectedPlan}"/>
                        <Button Content="📋 Clonar" Style="{StaticResource ABtn}" Margin="0,0,8,8"
                                Command="{Binding ClonePlanCommand}" CommandParameter="{Binding SelectedPlan}"/>
                        <Button Content="🗑️ Excluir" Style="{StaticResource ABtn}" Margin="0,0,8,8"
                                Command="{Binding DeletePlanCommand}" CommandParameter="{Binding SelectedPlan}"/>
                        <Button Content="📤 Exportar" Style="{StaticResource ABtn}" Margin="0,0,8,8"
                                Command="{Binding ExportPlanCommand}" CommandParameter="{Binding SelectedPlan}"/>
                        <Button Content="📥 Importar" Style="{StaticResource ABtn}"
                                Command="{Binding ImportPlanCommand}"/>
                    </WrapPanel>
                </Grid>
            </Border>
            <!-- Advanced Editor -->
            <Border Grid.Column="2" Style="{StaticResource ECard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🔧 Editor Avançado" Style="{StaticResource SecTitle}" Margin="0"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Text="{Binding SelectedPlan.Name, FallbackValue='Selecione um plano'}"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="240">
                        <StackPanel>
                            <TextBlock Text="CPU Mínimo" Style="{StaticResource MLbl}"/>
                            <Grid Margin="0,4,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Value="{Binding CpuMin}" Minimum="0" Maximum="100" VerticalAlignment="Center"
                                        Style="{StaticResource ModernSlider}"/>
                                <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{DynamicResource DefaultTextBrush}" FontWeight="SemiBold"
                                           Text="{Binding CpuMin, StringFormat={}{0}%}"/>
                            </Grid>
                            <TextBlock Text="CPU Máximo" Style="{StaticResource MLbl}"/>
                            <Grid Margin="0,4,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Value="{Binding CpuMax}" Minimum="0" Maximum="100" VerticalAlignment="Center"
                                        Style="{StaticResource ModernSlider}"/>
                                <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{DynamicResource DefaultTextBrush}" FontWeight="SemiBold"
                                           Text="{Binding CpuMax, StringFormat={}{0}%}"/>
                            </Grid>
                            <TextBlock Text="Modo Turbo Boost" Style="{StaticResource MLbl}"/>
                            <ComboBox SelectedIndex="{Binding CpuBoostMode}" Margin="0,4,0,12"
                                      Background="{DynamicResource BgCardGlass}"
                                      Foreground="{DynamicResource DefaultTextBrush}">
                                <ComboBoxItem Content="Desabilitado"/>
                                <ComboBoxItem Content="Habilitado"/>
                                <ComboBoxItem Content="Agressivo"/>
                                <ComboBoxItem Content="Eficiente Agressivo"/>
                            </ComboBox>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="USB Suspensão Seletiva" Style="{StaticResource MLbl}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding UsbSuspend}" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="PCIe Link State Power Mgmt" Style="{StaticResource MLbl}"/>
                            <ComboBox SelectedIndex="{Binding PcieLinkState}" Margin="0,4,0,12"
                                      Background="{DynamicResource BgCardGlass}"
                                      Foreground="{DynamicResource DefaultTextBrush}">
                                <ComboBoxItem Content="Desligado (Máxima Performance)"/>
                                <ComboBoxItem Content="Moderado"/>
                                <ComboBoxItem Content="Máxima Economia"/>
                            </ComboBox>
                            <TextBlock Text="Desligar Tela AC (min)" Style="{StaticResource MLbl}"/>
                            <Grid Margin="0,4,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Value="{Binding DisplayTimeoutAc}" Minimum="0" Maximum="60" VerticalAlignment="Center"
                                        Style="{StaticResource ModernSlider}"/>
                                <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{DynamicResource DefaultTextBrush}" FontWeight="SemiBold"
                                           Text="{Binding DisplayTimeoutAc, StringFormat={}{0}min}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="💾 Aplicar Configurações" Style="{StaticResource PBtn}"
                            Margin="0,12,0,0" HorizontalAlignment="Stretch"
                            Command="{Binding ApplyEditorSettingsCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ROW 4: DIAGNOSTICS + QUICK ACTIONS -->
        <Grid Grid.Row="4" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <!-- Diagnostics -->
            <Border Grid.Column="0" Style="{StaticResource ECard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🔍 Diagnóstico Avançado" Style="{StaticResource SecTitle}" Margin="0"/>
                        <Button Content="🔄 Analisar" Style="{StaticResource ABtn}" Margin="12,0,0,0"
                                Padding="10,4" FontSize="11" Command="{Binding RunDiagnosticsCommand}"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding DiagnosticIssues}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="12,8" Margin="0,0,0,6"
                                        Background="#0AFFFFFF" BorderThickness="1"
                                        BorderBrush="{Binding SeverityColorHex, Converter={StaticResource HexBrush}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SeverityIcon}"
                                                   FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource DefaultTextBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock FontSize="10" Foreground="{Binding SeverityColorHex, Converter={StaticResource HexBrush}}"
                                                       Text="{Binding Fix, StringFormat=💡 {0}}"
                                                       Visibility="{Binding Fix, Converter={StaticResource NullToVis}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <!-- Quick Actions -->
            <Border Grid.Column="2" Style="{StaticResource ECard}">
                <StackPanel>
                    <TextBlock Text="🧯 Ações Rápidas" Style="{StaticResource SecTitle}"/>
                    <Button Style="{StaticResource PBtn}" HorizontalAlignment="Stretch" Margin="0,0,0,10"
                            Command="{Binding FixAllIssuesCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Corrigir Problemas de Energia" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ABtn}" HorizontalAlignment="Stretch" Margin="0,0,0,10"
                            Command="{Binding UnlockMaxPerformanceCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🚀" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Desbloquear Performance Máxima" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ABtn}" HorizontalAlignment="Stretch" Margin="0,0,0,10"
                            Command="{Binding RestoreDefaultsCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Restaurar Configurações Padrão" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Border Height="1" Background="{DynamicResource BorderLight}" Margin="0,8,0,12"/>
                    <TextBlock Text="Status de Throttling" Style="{StaticResource MLbl}" Margin="0,0,0,8"/>
                    <Border CornerRadius="8" Padding="10,6" BorderThickness="1"
                            BorderBrush="{Binding ThrottlingStatus.StatusColorHex, Converter={StaticResource HexBrush}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                                     Fill="{Binding ThrottlingStatus.StatusColorHex, Converter={StaticResource HexBrush}}"/>
                            <TextBlock Text="{Binding ThrottlingStatus.StatusText}" FontSize="12"
                                       Foreground="{Binding ThrottlingStatus.StatusColorHex, Converter={StaticResource HexBrush}}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="5" CornerRadius="10" Padding="16,10" Margin="0,0,0,4"
                BorderThickness="1"
                BorderBrush="{Binding StatusColorHex, Converter={StaticResource HexBrush}}"
                Visibility="{Binding StatusMessage, Converter={StaticResource NullToVis}}">
            <Border.Background>
                <SolidColorBrush Color="#20FFFFFF"/>
            </Border.Background>
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontWeight="SemiBold"
                       Foreground="{Binding StatusColorHex, Converter={StaticResource HexBrush}}"/>
        </Border>

        <!-- LOADING OVERLAY -->
        <Border Grid.Row="0" Grid.RowSpan="6" Background="#80000000" CornerRadius="16"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⚡" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding BusyMessage}" FontSize="14" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
    </ScrollViewer>
</UserControl>
