<UserControl x:Class="VoltrisOptimizer.UI.Views.SecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:VoltrisOptimizer.UI.Converters"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="900" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            
            <!-- Converters adicionais -->
            <converters:BooleanToStatusTextConverter x:Key="BooleanToStatusTextConverter"/>
            <converters:BooleanToStatusColorConverter x:Key="BooleanToStatusColorConverter"/>
            
            <Storyboard x:Key="EntryAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" Fill="#0D31A8FF" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-300,-200,0">
                <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32,40,32,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- HEADER CENTRALIZADO (Grid.Row=0) -->
                <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                        <ContentControl Style="{StaticResource ModernPageHeaderIconStyle}">
                            <Path Data="{DynamicResource SecurityIcon}" 
                                  Fill="White" 
                                  Width="20" Height="20" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </ContentControl>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="{DynamicResource SecurityIcon}" Fill="{DynamicResource BrandBlue}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SEGURANÇA E PROTEÇÃO" 
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="12" FontWeight="Black"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrandBlue}"/>
                    </StackPanel>
                    
                    <TextBlock Text="Central de Segurança" 
                               Style="{DynamicResource PageTitleTextStyle}"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Gerencie as camadas de defesa e integridade do seu sistema operacional." 
                               Style="{DynamicResource BodyTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" Opacity="0.7"/>
                </StackPanel>


                <!-- AÇÕES RÁPIDAS NO TOPO (Grid.Row=1) -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                    <Button Content="Verificar e Atualizar Definições" Command="{Binding UpdateCommand}" Style="{DynamicResource PrimaryButtonStyle}" Width="300" Height="48" FontSize="14" FontWeight="Bold"/>
                </StackPanel>

                <!-- PAINEL WINDOWS UPDATE (Grid.Row=2) -->
                <Border Grid.Row="2" Style="{DynamicResource CardBorderStyle}" Margin="0,0,0,32">
                    <StackPanel Margin="28,24">
                        <!-- Header -->
                        <Grid Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#1A8B31FF" Padding="8" Margin="0,0,12,0">
                                    <Path Data="{DynamicResource SettingsIcon}" Fill="{DynamicResource BrandPurple}" Stretch="Uniform"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Windows Update" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Verifique e instale atualizações críticas do sistema" FontSize="11" Opacity="0.55" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Badge contador -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    CornerRadius="12" Padding="10,4"
                                    Visibility="{Binding UpdateCheckDone, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1A00FF94"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPendingUpdates}" Value="True">
                                                <Setter Property="Background" Value="#1AFBBF24"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding UpdateCountText}" FontSize="12" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BrandGreen}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPendingUpdates}" Value="True">
                                                    <Setter Property="Foreground" Value="#FBBF24"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>

                        <!-- Botões de ação -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="Verificar Atualizações"
                                    Command="{Binding CheckWindowsUpdatesCommand}"
                                    Style="{DynamicResource OutlineButtonStyle}"
                                    Height="40" Width="200" FontSize="13" Margin="0,0,12,0"
                                    IsEnabled="{Binding CanCheckUpdates}"/>
                            <Button Content="Instalar Atualizações"
                                    Command="{Binding InstallWindowsUpdatesCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Height="40" Width="200" FontSize="13"
                                    IsEnabled="{Binding HasPendingUpdates}"
                                    Visibility="{Binding UpdateCheckDone, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- Mensagem de status -->
                        <TextBlock Text="{Binding UpdateStatusMessage}"
                                   FontSize="12" Opacity="0.7"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,12"
                                   Visibility="{Binding UpdateCheckDone, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   TextWrapping="Wrap"/>

                        <!-- Aviso de reinicialização -->
                        <Border CornerRadius="8" Background="#1AFBBF24" Padding="12,8" Margin="0,0,0,12"
                                Visibility="{Binding RebootRequired, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" FontSize="14" Foreground="#FBBF24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Reinicialização necessária para concluir a instalação." FontSize="12" Foreground="#FBBF24" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Lista de atualizações pendentes -->
                        <ItemsControl ItemsSource="{Binding PendingUpdates}"
                                      Visibility="{Binding HasPendingUpdates, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      MaxHeight="220">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Background="#0DFFFFFF" Margin="0,0,0,6" Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding KBArticle}" FontSize="10" Opacity="0.5"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="6" Padding="6,3" Margin="8,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1A31A8FF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                                <Setter Property="Background" Value="#1AFF4B6B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Severity}" FontSize="10" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource BrandBlue}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCritical}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BrandPink}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" FontSize="11"
                                                       Opacity="0.5" Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- GRID DE CARDS DE STATUS (Grid.Row=3) -->
                <ItemsControl Grid.Row="3" Margin="0,0,0,32">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.Items>
                        <!-- Antivírus Card -->
                        <Border Style="{DynamicResource PremiumCard}" Margin="12" VerticalAlignment="Stretch">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Border Width="40" Height="40" CornerRadius="12" Background="#1A31A8FF" HorizontalAlignment="Left" Padding="10">
                                        <Path Data="{DynamicResource SecurityIcon}" Fill="{DynamicResource BrandBlue}" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{Binding Status.AntivirusEnabled, Converter={StaticResource BooleanToStatusTextConverter}}" 
                                               Foreground="{Binding Status.AntivirusEnabled, Converter={StaticResource BooleanToStatusColorConverter}}"
                                               FontWeight="Bold" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>
                                
                                <TextBlock Grid.Row="1" Text="Antivírus Principal" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Text="{Binding Status.AntivirusProduct}" Style="{DynamicResource BodyTextStyle}" Opacity="0.6" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,24" MinHeight="45"/>
                                
                                <Grid Grid.Row="3">
                                    <Button Content="Gerenciar" Command="{Binding OpenAntivirusCommand}" Style="{DynamicResource OutlineButtonStyle}" Height="40" FontSize="12" HorizontalAlignment="Stretch" Visibility="{Binding Status.AntivirusEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Corrigir" Command="{Binding OpenAntivirusCommand}" Style="{DynamicResource PrimaryButtonStyle}" Height="40" FontSize="12" HorizontalAlignment="Stretch" Visibility="{Binding Status.AntivirusEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Proteção em Tempo Real -->
                        <Border Style="{DynamicResource PremiumCard}" Margin="12" VerticalAlignment="Stretch">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Border Width="40" Height="40" CornerRadius="12" Background="#1A00FF94" HorizontalAlignment="Left" Padding="10">
                                        <Path Data="{DynamicResource PerformanceIcon}" Fill="{DynamicResource BrandGreen}" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{Binding Status.RealTimeProtectionEnabled, Converter={StaticResource BooleanToStatusTextConverter}}" 
                                               Foreground="{Binding Status.RealTimeProtectionEnabled, Converter={StaticResource BooleanToStatusColorConverter}}"
                                               FontWeight="Bold" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>

                                <TextBlock Grid.Row="1" Text="Tempo Real" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Text="Monitoramento ativo de ameaças e execução de malware." Style="{DynamicResource BodyTextStyle}" Opacity="0.6" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,24" MinHeight="45"/>

                                <Grid Grid.Row="3">
                                    <Button Content="Configurar" Command="{Binding OpenRealtimeProtectionCommand}" Style="{DynamicResource OutlineButtonStyle}" Height="40" FontSize="12" HorizontalAlignment="Stretch" Visibility="{Binding Status.RealTimeProtectionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Corrigir Agora" Command="{Binding OpenRealtimeProtectionCommand}" Style="{DynamicResource PrimaryButtonStyle}" Height="40" FontSize="12" HorizontalAlignment="Stretch" Visibility="{Binding Status.RealTimeProtectionEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Firewall -->
                        <Border Style="{DynamicResource PremiumCard}" Margin="12" VerticalAlignment="Stretch">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Border Width="40" Height="40" CornerRadius="12" Background="#1AFF4B6B" HorizontalAlignment="Left" Padding="10">
                                        <Path Data="{DynamicResource NetworkIcon}" Fill="{DynamicResource BrandPink}" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{Binding Status.FirewallEnabled, Converter={StaticResource BooleanToStatusTextConverter}}" 
                                               Foreground="{Binding Status.FirewallEnabled, Converter={StaticResource BooleanToStatusColorConverter}}"
                                               FontWeight="Bold" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>

                                <TextBlock Grid.Row="1" Text="Firewall de Rede" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Text="Bloqueio de conexões não autorizadas do Windows Defender." Style="{DynamicResource BodyTextStyle}" Opacity="0.6" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,24" MinHeight="45"/>

                                <Grid Grid.Row="3">
                                    <Button Content="Ver Firewall" Command="{Binding OpenFirewallCommand}" Style="{DynamicResource OutlineButtonStyle}" Height="40" FontSize="12" HorizontalAlignment="Stretch" Visibility="{Binding Status.FirewallEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Ativar Firewall" Command="{Binding OpenFirewallCommand}" Style="{DynamicResource PrimaryButtonStyle}" Height="40" FontSize="12" HorizontalAlignment="Stretch" Visibility="{Binding Status.FirewallEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Windows Update -->
                        <Border Style="{DynamicResource PremiumCard}" Margin="12" VerticalAlignment="Stretch">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Border Width="40" Height="40" CornerRadius="12" Background="#1A8B31FF" HorizontalAlignment="Left" Padding="10">
                                        <Path Data="{DynamicResource SettingsIcon}" Fill="{DynamicResource BrandPurple}" Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{Binding Status.WindowsUpdateEnabled, Converter={StaticResource BooleanToStatusTextConverter}}" 
                                               Foreground="{Binding Status.WindowsUpdateEnabled, Converter={StaticResource BooleanToStatusColorConverter}}"
                                               FontWeight="Bold" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>

                                <TextBlock Grid.Row="1" Text="Windows Update" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Text="Patches críticos de segurança e atualizações do sistema." Style="{DynamicResource BodyTextStyle}" Opacity="0.6" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,24" MinHeight="45"/>

                                <Grid Grid.Row="3">
                                    <Button Content="Ver Update" Command="{Binding OpenWindowsUpdateCommand}" Style="{DynamicResource OutlineButtonStyle}" Height="40" FontSize="12" HorizontalAlignment="Stretch" Visibility="{Binding Status.WindowsUpdateEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Content="Corrigir Update" Command="{Binding OpenWindowsUpdateCommand}" Style="{DynamicResource PrimaryButtonStyle}" Height="40" FontSize="12" HorizontalAlignment="Stretch" Visibility="{Binding Status.WindowsUpdateEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </ItemsControl.Items>
                </ItemsControl>


                <!-- SEÇÃO DE CONFIGURAÇÕES AVANÇADAS (Grid.Row=4) -->
                <Border Grid.Row="4" Style="{DynamicResource CardBorderStyle}" HorizontalAlignment="Stretch">
                    <StackPanel Margin="32">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Path Data="{DynamicResource SettingsIcon}" Fill="{DynamicResource BrandBlue}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" Opacity="0.8"/>
                            <TextBlock Text="Camadas Adicionais de Defesa" Style="{DynamicResource CardHeaderStyle}"/>
                        </StackPanel>

                        <!-- SmartScreen -->
                        <Grid Margin="0,0,0,24">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                                <TextBlock Text="Microsoft Defender SmartScreen" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,4"/>
                                <TextBlock Text="Proteção baseada em nuvem contra sites de phishing e programas maliciosos conhecidos." Style="{DynamicResource BodyTextStyle}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding IsSmartScreenEnabled}" Style="{DynamicResource PremiumCheckBoxStyle}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <Button Content="Configurar" Command="{Binding OpenSmartScreenCommand}" Style="{DynamicResource HyperlinkButtonStyle}" Foreground="{DynamicResource BrandBlue}" FontSize="12" Padding="0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Tamper Protection -->
                        <Grid Margin="0,0,0,24">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                                <TextBlock Text="Tamper Protection" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,4"/>
                                <TextBlock Text="Impede que aplicativos maliciosos alterem configurações críticas de segurança do sistema." Style="{DynamicResource BodyTextStyle}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Status.TamperProtectionEnabled, Converter={StaticResource BooleanToStatusTextConverter}}" 
                                           Foreground="{Binding Status.TamperProtectionEnabled, Converter={StaticResource BooleanToStatusColorConverter}}"
                                           FontWeight="Bold" FontSize="12" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <Button Content="Gerenciar" 
                                        Command="{Binding OpenTamperProtectionCommand}"
                                        Style="{DynamicResource HyperlinkButtonStyle}" 
                                        Foreground="{DynamicResource BrandBlue}" 
                                        FontSize="12" Padding="0"/>
                            </StackPanel>
                        </Grid>

                        <!-- UAC -->
                        <Grid Margin="0,0,0,24">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                                <TextBlock Text="UAC (Controle de Conta de Usuário)" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,4"/>
                                <TextBlock Text="Notifica quando programas tentam fazer alterações no computador que exigem privilégios administrativos." Style="{DynamicResource BodyTextStyle}" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Status.UacEnabled, Converter={StaticResource BooleanToStatusTextConverter}}" 
                                           Foreground="{Binding Status.UacEnabled, Converter={StaticResource BooleanToStatusColorConverter}}"
                                           FontWeight="Bold" FontSize="12" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <Button Content="Configurar" 
                                        Command="{Binding OpenUacCommand}"
                                        Style="{DynamicResource HyperlinkButtonStyle}" 
                                        Foreground="{DynamicResource BrandBlue}" 
                                        FontSize="12" Padding="0"/>
                            </StackPanel>
                        </Grid>
                        
                        <Separator Background="#1AFFFFFF" Margin="0,8,0,24"/>
                        
                        <TextBlock Text="Dica Pro: Algumas configurações de segurança avançada, como o VBS (Core Isolation), podem causar uma leve queda de performance em jogos pesados." 
                                   Style="{DynamicResource BodyTextStyle}" Opacity="0.4" FontSize="11" FontStyle="Italic" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>


