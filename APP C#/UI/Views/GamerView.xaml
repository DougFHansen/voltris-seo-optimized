<UserControl x:Class="VoltrisOptimizer.UI.Views.GamerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             xmlns:converters="clr-namespace:VoltrisOptimizer.UI.Converters"
             Background="{DynamicResource DarkBrush}">
    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="GamerVM" />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converter para visibilidade booleana -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <!-- Converter para booleano inverso -->
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            
            <!-- Converters para status do Modo Gamer -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <converters:BoolToStatusIconConverter x:Key="BoolToStatusIconConverter"/>
            <converters:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>
            
            <!-- Converter para temperatura -->
            <converters:TemperatureToWidthConverter x:Key="TemperatureToWidthConverter"/>
            
            <!-- Estilo de Card Premium para seções principais - RESPONSIVO -->
            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource CardGradientBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderGradientBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="0,0,0,16"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.2" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Estilo de Card Compacto -->
            <Style x:Key="CompactCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                <Setter Property="Padding" Value="16"/>
                <Setter Property="CornerRadius" Value="12"/>
            </Style>
            
            <!-- Estilo de Card Gamer (mais compacto para evitar cortes) -->
            <Style x:Key="GamerCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                <Setter Property="Padding" Value="14"/>
                <Setter Property="Margin" Value="0,0,0,16"/>
            </Style>
            
            <!-- Estilo de Header de Seção -->
            <Style x:Key="SectionHeaderStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="Margin" Value="0,0,0,16"/>
            </Style>
            
            <!-- Ícone de Seção -->
            <Style x:Key="SectionIconStyle" TargetType="Border">
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Margin" Value="0,0,12,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            
            <!-- Estilo de Botão Responsivo -->
            <Style x:Key="ResponsiveGamerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                <Setter Property="Height" Value="52"/>
                <Setter Property="MinWidth" Value="180"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-150,-150,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="90"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300" Height="300" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="70"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0"
                      Margin="0">
            <StackPanel Margin="24,16,24,24">
                
                <!-- Early Warning System (Inteligência Preditiva) -->
                <Border Visibility="{Binding HasWarning, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,16"
                        Padding="14,10"
                        CornerRadius="10"
                        BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush Color="#FF441111" Opacity="0.9"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FFFF4444" Opacity="0.5"/>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="Red" Opacity="0.25"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="ALERTA DE INTELIGÊNCIA PREDITIVA" 
                                      FontSize="11" FontWeight="Bold" 
                                      Foreground="#FFFF4444"/>
                            <TextBlock Text="{Binding WarningMessage}" 
                                      FontSize="14" FontWeight="SemiBold" 
                                      Foreground="{DynamicResource TextPrimary}" 
                                      TextWrapping="Wrap"
                                      Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Adaptive Power Intelligence (Modo Adaptativo) -->
                <Border Visibility="{Binding HasAdapterMessage, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,16"
                        Padding="14,10"
                        CornerRadius="10"
                        BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF112244" Offset="0"/>
                            <GradientStop Color="#FF111133" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FF4488FF" Opacity="0.5"/>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#FF4488FF" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="INTELIGÊNCIA DE ENERGIA ADAPTATIVA" 
                                      FontSize="11" FontWeight="Bold" 
                                      Foreground="#FF4488FF"/>
                            <TextBlock Text="{Binding AdapterMessage}" 
                                      FontSize="14" FontWeight="Medium" 
                                      Foreground="{DynamicResource TextPrimary}" 
                                      TextWrapping="Wrap"
                                      Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- ========== CABEÇALHO DO MODO GAMER ========== -->
                <StackPanel Margin="0,0,0,24" HorizontalAlignment="Center">
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-15" To="0" Duration="0:0:0.4">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    
                    <!-- Ícone com gradiente -->
                    <Border Width="52" Height="52" CornerRadius="13" Margin="0,0,0,14" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B31FF" Offset="0"/>
                                <GradientStop Color="#FF4B6B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#8B31FF" Opacity="0.45"/>
                        </Border.Effect>
                        <Path Data="M21,6H3A2,2 0 0,0 1,8V16A2,2 0 0,0 3,18H21A2,2 0 0,0 23,16V8A2,2 0 0,0 21,6M21,16H3V8H21M6,15H8V13H10V11H8V9H6V11H4V13H6M14.5,12A1.5,1.5 0 0,1 16,13.5A1.5,1.5 0 0,1 14.5,15A1.5,1.5 0 0,1 13,13.5A1.5,1.5 0 0,1 14.5,12M18.5,9A1.5,1.5 0 0,1 20,10.5A1.5,1.5 0 0,1 18.5,12A1.5,1.5 0 0,1 17,10.5A1.5,1.5 0 0,1 18.5,9Z" 
                              Fill="White"
                              Width="26" Height="26"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Text="Modo Gamer"
                              FontFamily="Segoe UI Variable Display, Segoe UI"
                              FontSize="28"
                              FontWeight="Bold"
                              HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Maximize o desempenho do sistema para jogos"
                              FontSize="13"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              HorizontalAlignment="Center"
                              Margin="0,5,0,0"/>
                </StackPanel>


                <!-- ========== CONTROLE MANUAL DO MODO GAMER - RESPONSIVO ========== -->
                <Border Style="{StaticResource GamerCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="🎮" FontSize="20"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Controle Manual do Modo Gamer"
                                          FontSize="18"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Ative ou desative o modo gamer manualmente"
                                          FontSize="13"
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Status do Modo Gamer -->
                        <Border Padding="12,8" CornerRadius="10" Margin="0,0,0,8"
                                Background="{Binding IsGamerModeActive, Converter={StaticResource BoolToColorConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding IsGamerModeActive, Converter={StaticResource BoolToStatusIconConverter}}"
                                          FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding IsGamerModeActive, Converter={StaticResource BoolToStatusTextConverter}}"
                                              FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="{Binding GamerModeStatusDescription}"
                                              FontSize="13" Foreground="{DynamicResource TextPrimary}" Opacity="0.8" Margin="0,2,0,0"
                                              TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Botões de Controle - RESPONSIVO COM GRID -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Botão ATIVAR -->
                            <Button x:Name="BtnActivateGamer"
                                    Grid.Column="0"
                                    Command="{Binding ActivateGamerModeCommand}"
                                    IsEnabled="{Binding IsGamerModeActive, Converter={StaticResource InverseBooleanConverter}}"
                                    Style="{StaticResource ResponsiveGamerButtonStyle}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⚡" FontSize="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ATIVAR" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Botão DESATIVAR -->
                            <Button x:Name="BtnDeactivateGamer"
                                    Grid.Column="2"
                                    Command="{Binding DeactivateGamerModeCommand}"
                                    IsEnabled="{Binding IsGamerModeActive}"
                                    Style="{StaticResource ResponsiveGamerButtonStyle}">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EF4444" Offset="0"/>
                                        <GradientStop Color="#DC2626" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🛑" FontSize="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="DESATIVAR" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Informação sobre otimizações -->
                        <Border Padding="8" CornerRadius="8" Margin="0,8,0,0"
                                Background="{DynamicResource InfoBackgroundBrush}"
                                BorderBrush="{DynamicResource InfoBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Ao ativar o Modo Gamer:"
                                          FontSize="13" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          LineHeight="16">
                                    • Todas as otimizações temporárias de performance são ativadas automaticamente<LineBreak/>
                                    • Processos desnecessários são suspensos<LineBreak/>
                                    • Prioridade máxima é dada aos jogos<LineBreak/>
                                    • Latência do sistema é reduzida ao mínimo
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>


                <!-- ========== ESTADO DO SISTEMA - RESPONSIVO ========== -->
                <Border Style="{StaticResource CompactCardStyle}" Margin="0,0,0,16" Padding="0">
                    <Grid>
                        <!-- Background com gradiente sutil e moderno -->
                        <Border CornerRadius="12" Background="{DynamicResource DarkPanelAltBrush}"/>
                        
                        <!-- Conteúdo Principal -->
                        <Grid Margin="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Ícone Ultra Moderno e Limpo -->
                            <Border Grid.Column="0" 
                                    Width="48" 
                                    Height="48" 
                                    CornerRadius="12" 
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource DarkPanelBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#26EF4444"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGamerModeActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="#2610B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.1" Color="Black"/>
                                </Border.Effect>
                                
                                <Grid>
                                    <Ellipse Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <BlurEffect Radius="12"/>
                                        </Ellipse.Effect>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#EF4444"/>
                                                <Setter Property="Opacity" Value="0.2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGamerModeActive}" Value="True">
                                                        <Setter Property="Fill" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    
                                    <Path HorizontalAlignment="Center" 
                                          VerticalAlignment="Center" 
                                          Width="20" 
                                          Height="20" 
                                          Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Data" Value="M13,3A9,9 0 0,0 4,12H1L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3Z"/>
                                                <Setter Property="Fill" Value="#EF4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGamerModeActive}" Value="True">
                                                        <Setter Property="Data" Value="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z"/>
                                                        <Setter Property="Fill" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Grid>
                            </Border>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,2,0,0">
                                <TextBlock Text="ESTADO DO SISTEMA" 
                                          FontSize="11" 
                                          FontWeight="Bold"
                                          Opacity="0.5"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          Margin="0,0,0,3"/>
                                          
                                <TextBlock FontSize="17" FontWeight="Bold" LineHeight="20" TextWrapping="Wrap">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.12" Color="Black"/>
                                    </TextBlock.Effect>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource GamerModeStatusConverter}">
                                                        <Binding Path="IsGamerModeActive"/>
                                                        <Binding Path="ActiveGameName"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGamerModeActive}" Value="True">
                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                            <Border Grid.Column="2" 
                                    Padding="8,4" 
                                    CornerRadius="6" 
                                    VerticalAlignment="Center"
                                    BorderThickness="1"
                                    Background="{DynamicResource DarkHoverBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#20EF4444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGamerModeActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="#2010B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="5" Height="5" Margin="0,0,6,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#EF4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGamerModeActive}" Value="True">
                                                        <Setter Property="Fill" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    
                                    <TextBlock FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="INATIVO"/>
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGamerModeActive}" Value="True">
                                                        <Setter Property="Text" Value="ATIVO"/>
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>


                <!-- ========== MODO GAMER AUTOMÁTICO - RESPONSIVO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0">
                            <StackPanel Style="{StaticResource SectionHeaderStyle}">
                                <Border Style="{StaticResource SectionIconStyle}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource PrimaryColor}" Opacity="0.2"/>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="20"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Detectar e Otimizar Jogos"
                                              FontSize="17"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Ativação inteligente ao detectar jogos"
                                              FontSize="12"
                                              Foreground="{DynamicResource TextMutedBrush}"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Ativar automaticamente ao detectar jogo"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                <CheckBox Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                         IsChecked="{Binding IsAutoModeEnabled, Mode=TwoWay}"
                                         VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                            <TextBlock Text="O sistema detecta automaticamente quando um jogo é iniciado e aplica todas as otimizações configuradas."
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      FontSize="14"
                                      TextWrapping="Wrap"
                                      LineHeight="20"/>
                        </StackPanel>
                        
                        <!-- Progresso de Detecção ou Botão -->
                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <StackPanel HorizontalAlignment="Stretch"
                                       Visibility="{Binding IsGameDetectionActive, Converter={StaticResource BoolToVis}}">
                                <ProgressBar Value="{Binding GameDetectionProgressPercent}"
                                             Height="6"
                                             Style="{StaticResource AnimatedProgressBarStyle}"
                                             Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding GameDetectionStatus}"
                                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding GamesFoundCount, StringFormat='{}Jogos encontrados: {0}'}"
                                           FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Button Content="🔍 Detectar Jogos"
                                   Style="{StaticResource NeonButtonStyle}"
                                   MinHeight="48"
                                   HorizontalAlignment="Stretch"
                                   Command="{Binding DetectGamesCommand}"
                                   Visibility="{Binding IsGameDetectionActive, Converter={StaticResource InverseBooleanConverter}}"/>
                        </Grid>
                    </Grid>
                </Border>


                <!-- ========== OTIMIZAÇÕES TEMPORÁRIAS - RESPONSIVO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#FF10B981" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Otimizações Temporárias de Performance"
                                          FontSize="17"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Otimizações avançadas ativadas automaticamente com o modo gamer (100% reversíveis)"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,2,0,0"
                                          TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Status da Sessão -->
                        <Border Background="{DynamicResource DarkPanelAltBrush}"
                                BorderBrush="{DynamicResource DarkBorderBrush}"
                                BorderThickness="1" 
                                CornerRadius="10" 
                                Padding="14" 
                                Margin="0,0,0,14">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Status:" 
                                          FontSize="13" 
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TemporaryOptimizationStatus}" 
                                          FontSize="16" 
                                          FontWeight="SemiBold"
                                          Foreground="{Binding IsTemporaryOptimizationSessionActive, Converter={StaticResource BooleanToColorConverter}}"/>
                                <TextBlock Text="✓ Ativação automática com modo gamer" 
                                          FontSize="12" 
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,6,0,0"
                                          FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Botões de Controle - RESPONSIVO -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0"
                                    Content="▶ Iniciar"
                                    Style="{StaticResource NeonButtonStyle}"
                                    Command="{Binding StartTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive, Converter={StaticResource InverseBooleanConverter}}"
                                    MinHeight="46"
                                    FontSize="13"
                                    ToolTip="Aplica otimizações temporárias: Frame Rate, Latência e Process Count Offload"/>
                            
                            <Button Grid.Column="2"
                                    Content="⏹ Parar"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Command="{Binding StopTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive}"
                                    MinHeight="46"
                                    FontSize="13"
                                    ToolTip="Reverte todas as otimizações temporárias aplicadas"/>
                            
                            <Button Grid.Column="4"
                                    Content="⚠ Rollback"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Command="{Binding ForceRollbackTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive}"
                                    MinHeight="46"
                                    FontSize="13"
                                    Foreground="{DynamicResource WarningBrush}"
                                    ToolTip="Rollback de emergência - força reversão imediata de todas as mudanças"/>
                        </Grid>
                        
                        <!-- Informações dos Módulos -->
                        <Expander Header="ℹ️ Módulos de Otimização" 
                                  IsExpanded="False"
                                  Margin="0,8,0,0">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock TextWrapping="Wrap" 
                                          FontSize="12"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          LineHeight="20">
                                    <Run Text="🎯 "/>
                                    <Run Text="Frame Rate Optimizations" FontWeight="SemiBold"/>
                                    <Run Text=": Desativa GameDVR, habilita Game Mode, otimiza prioridades"/>
                                    <LineBreak/>
                                    <Run Text="⏱️ "/>
                                    <Run Text="Latency Reduction" FontWeight="SemiBold"/>
                                    <Run Text=": Desativa Fullscreen Optimizations, otimiza TCP/IP, reduz input lag"/>
                                    <LineBreak/>
                                    <Run Text="📊 "/>
                                    <Run Text="Process Count Offload" FontWeight="SemiBold"/>
                                    <Run Text=": Reduz prioridade de processos de background, otimiza jogo"/>
                                    <LineBreak/>
                                    <LineBreak/>
                                    <Run Text="⚡ "/>
                                    <Run Text="Todas as otimizações entram em vigor imediatamente" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}"/>
                                    <LineBreak/>
                                    <Run Text="🔄 "/>
                                    <Run Text="São totalmente revertidas ao desativar o Modo Gamer" FontWeight="SemiBold" Foreground="{DynamicResource InfoBrush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>


                <!-- ========== OTIMIZAÇÕES PARA JOGOS - RESPONSIVO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="🚀" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Otimizações para Jogos"
                                          FontSize="17"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Configure as otimizações que serão aplicadas automaticamente"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Otimizações em Grid Responsivo -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- CPU -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="⚡ CPU" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeCpu, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- GPU -->
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="🎮 GPU" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="0" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeGpu, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Rede -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="🌐 Rede" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeNetwork, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Memória -->
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="💾 Memória" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="1" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeMemory, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Game Mode -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="🎯 Game Mode" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding EnableGameMode, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Latência -->
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="⏱️ Latência" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="2" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding ReduceLatency, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Background -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="🔒 Background" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding CloseBackgroundApps, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- FPS Boost -->
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="📈 FPS Boost" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="3" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding ApplyFpsBoost, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Extremo -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="🛡️ Extremo" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="4" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding EnableExtremeMode, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Anti-Stutter -->
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="🎛️ Anti-Stutter" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="4" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding EnableAntiStutter, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Adaptativo -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="📡 Adaptativo" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"
                                       ToolTip="Ativa otimizações de rede adaptativas baseadas no tipo de conexão e latência detectada."/>
                            <CheckBox Grid.Row="5" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding EnableAdaptiveNetwork, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- HPET -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="⏲️ HPET" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"
                                       ToolTip="Desativa o High Precision Event Timer via BCDEdit. Reduz latência de entrada ao forçar o sistema a usar o TSC (contador de ciclos da CPU), mais eficiente para jogos."/>
                            <CheckBox Grid.Row="6" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding DisableHpet, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Slideshow -->
                            <TextBlock Grid.Row="6" Grid.Column="3" Text="🖼️ Slideshow" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"
                                       ToolTip="Pausa a troca automática de wallpaper durante o jogo. Elimina ciclos de CPU e GPU desperdiçados com a renderização de novos planos de fundo."/>
                            <CheckBox Grid.Row="6" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding DisableWallpaperSlideshow, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Apps UWP -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="📱 Apps UWP" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"
                                       ToolTip="Desativa globalmente a execução de apps UWP em segundo plano (ex: Notícias, Clima, Xbox). Libera CPU e memória para o jogo."/>
                            <CheckBox Grid.Row="7" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding DisableUwpBackgroundApps, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- Serviços Pesados -->
                            <TextBlock Grid.Row="7" Grid.Column="3" Text="⚙️ Serviços" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" Margin="0,0,12,10"
                                       ToolTip="Para temporariamente Windows Search, SysMain/Superfetch e Server (LanmanServer). Libera CPU, disco e memória durante o jogo. Todos são reiniciados ao sair do Modo Gamer."/>
                            <CheckBox Grid.Row="7" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding DisableHeavyServices, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== BOTÃO APLICAR OTIMIZAÇÕES AVANÇADAS - RESPONSIVO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Button MinHeight="64" 
                               FontSize="17" 
                               FontWeight="Bold"
                               Command="{Binding ApplyProOptimizationsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NeonButtonStyle}">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#00C853" Offset="0"/>
                                                <GradientStop Color="#69F0AE" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="14" Color="#00C853" Opacity="0.35" ShadowDepth="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🚀" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Aplicar Otimizações Avançadas" FontSize="17"/>
                                    <TextBlock Text="(Aplicar agora e reiniciar depois)" FontSize="11" Opacity="0.8" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        
                        <!-- Botão de Reverter -->
                        <Button Margin="0,10,0,0"
                                Height="42"
                                Command="{Binding RevertProOptimizationsCommand}"
                                Background="Transparent"
                                BorderBrush="#40EF4444"
                                BorderThickness="1"
                                Foreground="#FF8A80"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#15EF4444"/>
                                            <Setter Property="BorderBrush" Value="#80EF4444"/>
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#25EF4444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔄" Margin="0,0,6,0" FontSize="13"/>
                                <TextBlock Text="Reverter Alterações (requer reinicialização do sistema)" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>


                <!-- ========== BIBLIOTECA DE JOGOS - RESPONSIVO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource SecondaryColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="📚" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Biblioteca de Jogos"
                                          FontSize="17"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Gerencie seus jogos e perfis personalizados"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Background="{DynamicResource DarkPanelAltBrush}"
                               BorderBrush="{DynamicResource DarkBorderBrush}"
                               BorderThickness="1"
                               CornerRadius="10"
                               Padding="4"
                               Margin="0,0,0,16">
                            <ListBox x:Name="GamesListBox"
                                    MinHeight="100"
                                    MaxHeight="160"
                                    ItemsSource="{Binding Games}"
                                    SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VirtualizingStackPanel.IsVirtualizing="True"
                                    VirtualizingStackPanel.VirtualizationMode="Recycling"
                                    ScrollViewer.CanContentScroll="True"
                                    Style="{StaticResource ModernListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="6,5">
                                            <TextBlock Text="🎮" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" 
                                                      FontWeight="Medium"
                                                      FontSize="13"
                                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        
                        <!-- Botões em Grid Responsivo -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" Content="✓ Aplicar"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="42" 
                                   FontSize="12"
                                   Command="{Binding ApplyProfileCommand}"/>
                            <Button Grid.Column="2" Content="➕ Criar"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="42" 
                                   FontSize="12"
                                   Command="{Binding CreateProfileCommand}"/>
                            <Button Grid.Column="4" Content="✕ Remover"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="42" 
                                   FontSize="12"
                                   Command="{Binding RemoveProfileCommand}"/>
                            <Button Grid.Column="6" Content="🗑️ Cache"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="42" 
                                   FontSize="12"
                                   Command="{Binding CleanCacheCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== AÇÕES ADICIONAIS - RESPONSIVO ========== -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" 
                           Content="🔄 Reverter Tudo"
                           Style="{StaticResource NeonSecondaryButtonStyle}" 
                           MinHeight="48" 
                           FontSize="13"
                           Command="{Binding RevertProOptimizationsCommand}"/>

                    <Button Grid.Column="2" 
                           Content="⏸️ Parar Sessão Atual"
                           Style="{StaticResource NeonSecondaryButtonStyle}" 
                           MinHeight="48" 
                           FontSize="13"
                           Command="{Binding DeactivateGamerModeCommand}"
                           IsEnabled="{Binding IsGamerModeActive}"/>
                </Grid>


                <!-- ========== DIAGNÓSTICO AVANÇADO - RESPONSIVO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource WarningColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Diagnóstico Avançado"
                                          FontSize="17"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Monitore performance em tempo real e identifique problemas"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- GPU Info -->
                        <Border Background="{DynamicResource DarkPanelAltBrush}"
                               BorderBrush="{DynamicResource DarkBorderBrush}"
                               BorderThickness="1"
                               CornerRadius="10"
                               Padding="14"
                               Margin="0,6,0,14">
                            <StackPanel>
                                <TextBlock Text="GPU"
                                          FontSize="11"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding GpuInfoText}"
                                          Foreground="{DynamicResource TextPrimaryBrush}" 
                                          FontSize="13" 
                                          FontWeight="SemiBold"
                                          TextWrapping="Wrap"
                                          Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" Content="⚡ Otimizar"
                                           Style="{StaticResource NeonButtonStyle}" 
                                           MinHeight="38" 
                                           FontSize="12"
                                           Command="{Binding OptimizeGpuCommand}"/>
                                    <Button Grid.Column="2" Content="🌡️ Temperatura"
                                           Style="{StaticResource NeonSecondaryButtonStyle}" 
                                           MinHeight="38" 
                                           FontSize="12"
                                           Command="{Binding CheckGpuTempCommand}"/>
                                </Grid>
                                <TextBlock Text="{Binding GpuTempText}" 
                                          Foreground="{DynamicResource SuccessBrush}"
                                          FontSize="12" 
                                          FontWeight="SemiBold" 
                                          Margin="0,10,0,0"
                                          HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Painel Térmico e Throttling -->
                        <Border Background="{DynamicResource DarkPanelAltBrush}"
                               BorderBrush="{DynamicResource DarkBorderBrush}"
                               BorderThickness="1"
                               CornerRadius="10"
                               Padding="14"
                               Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- CPU Temperature (Real-time) -->
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Temp CPU" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <!-- Indicador de temperatura estimada -->
                                        <TextBlock Text="~" FontSize="10" FontWeight="Bold" Foreground="#F59E0B" Margin="4,0,0,0" ToolTip="Temperatura estimada (limitada por hardware)">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTemperatureEstimated}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding CpuTemperature, StringFormat={}{0:F1}°C}" FontSize="16" FontWeight="Bold" Foreground="{Binding ThermalStatusColor}" Margin="0,3,0,0"/>
                                    <Border Height="3" Background="{DynamicResource DarkBrush}" CornerRadius="2" Margin="0,6,0,0">
                                        <Border Width="{Binding CpuTemperature, Converter={StaticResource TemperatureToWidthConverter}}" HorizontalAlignment="Left" Background="{Binding ThermalStatusColor}" CornerRadius="2"/>
                                    </Border>
                                </StackPanel>

                                <!-- GPU Temperature (Real-time) -->
                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="Temp GPU" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding GpuTemperature, StringFormat={}{0:F1}°C}" FontSize="16" FontWeight="Bold" Foreground="{Binding ThermalStatusColor}" Margin="0,3,0,0"/>
                                    <Border Height="3" Background="{DynamicResource DarkBrush}" CornerRadius="2" Margin="0,6,0,0">
                                        <Border Width="{Binding GpuTemperature, Converter={StaticResource TemperatureToWidthConverter}}" HorizontalAlignment="Left" Background="{Binding ThermalStatusColor}" CornerRadius="2"/>
                                    </Border>
                                </StackPanel>

                                <!-- Thermal Status -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Status Térmico" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" Background="{Binding ThermalStatusColor}"/>
                                        <TextBlock Text="{Binding ThermalStatus}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" Margin="5,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBlock Text="MONITORAMENTO ATIVO" FontSize="8" FontWeight="Bold" 
                                              Foreground="{DynamicResource SuccessBrush}"
                                              Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <Button Content="📈 Abrir Diagnóstico Completo"
                               Style="{StaticResource NeonSecondaryButtonStyle}"
                               MinHeight="46" 
                               HorizontalAlignment="Stretch" 
                               FontSize="13"
                               Command="{Binding OpenDiagnosticsCommand}"/>
                    </StackPanel>
                </Border>


                <!-- ========== PERFORMANCE MONITOR - RESPONSIVO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource PrimaryColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Performance Monitor" 
                                          FontSize="17" 
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Monitor de métricas em tempo real com análise avançada"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Opção: Ligar com o Modo Gamer -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                      Text="Ligar automaticamente com o Modo Gamer"
                                      FontSize="13" FontWeight="Medium"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      VerticalAlignment="Center"
                                      TextWrapping="Wrap"
                                      ToolTip="Quando ativado, o Performance Monitor será iniciado automaticamente ao ativar o Modo Gamer"/>
                            <CheckBox Grid.Column="1"
                                     Style="{DynamicResource PremiumCheckBoxStyle}"
                                     IsChecked="{Binding OverlayAutoStartWithGamerMode, Mode=TwoWay}"
                                     VerticalAlignment="Center"
                                     Margin="12,0,0,0"
                                     ToolTip="Quando ativado, o Performance Monitor será iniciado automaticamente ao ativar o Modo Gamer"/>
                        </Grid>

                        <!-- Controle do Performance Monitor -->
                        <TextBlock Text="Controle do Monitor:" 
                                  FontSize="13" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextSecondaryBrush}" 
                                  Margin="0,0,0,10"/>
                        
                        <!-- Botões Ativar/Desativar -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Botão ATIVAR -->
                            <Button x:Name="BtnActivateOverlay"
                                    Grid.Column="0"
                                    Command="{Binding ActivateOverlayCommand}"
                                    IsEnabled="{Binding OverlayEnabled, Converter={StaticResource InverseBooleanConverter}}"
                                    Height="46"
                                    FontSize="14"
                                    FontWeight="Bold">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#2563EB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="▶️" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ATIVAR" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Botão DESATIVAR -->
                            <Button x:Name="BtnDeactivateOverlay"
                                    Grid.Column="2"
                                    Command="{Binding DeactivateOverlayCommand}"
                                    IsEnabled="{Binding OverlayEnabled}"
                                    Height="46"
                                    FontSize="14"
                                    FontWeight="Bold">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EF4444" Offset="0"/>
                                        <GradientStop Color="#DC2626" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⏹️" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="DESATIVAR" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Métricas a exibir -->
                        <TextBlock Text="Métricas a Exibir:" 
                                  FontSize="13" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextSecondaryBrush}" 
                                  Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- FPS -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="FPS" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowFps, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- FrameTime -->
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="FrameTime" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="0" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowFrameTime, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- CPU % -->
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="CPU %" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="0" Grid.Column="7" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowCpuUsage, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- GPU % -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="GPU %" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowGpuUsage, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- RAM % -->
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="RAM %" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="1" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowRamUsage, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- VRAM % -->
                            <TextBlock Grid.Row="1" Grid.Column="6" Text="VRAM %" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="1" Grid.Column="7" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowVramUsage, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- CPU Temp -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU Temp" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowCpuTemp, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- GPU Temp -->
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="GPU Temp" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="2" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowGpuTemp, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- CPU Clock -->
                            <TextBlock Grid.Row="2" Grid.Column="6" Text="CPU Clock" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="2" Grid.Column="7" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowCpuClock, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>

                            <!-- GPU Clock -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="GPU Clock" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowGpuClock, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- Latency -->
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="Latency" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,10"/>
                            <CheckBox Grid.Row="3" Grid.Column="4" Style="{DynamicResource PremiumCheckBoxStyle}" IsChecked="{Binding OverlayShowInputLatency, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        </Grid>

                        <TextBlock Text="{Binding BusyMessage}" 
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="13" 
                                  Margin="0,12,0,0" 
                                  HorizontalAlignment="Center"
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ========== CORRIGIR ERROS NOS JOGOS ========== -->
                <Border Style="{StaticResource GamerCardStyle}">
                    <StackPanel>

                        <!-- Cabeçalho da seção -->
                        <StackPanel Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EF4444" Offset="0"/>
                                        <GradientStop Color="#F59E0B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🔧" FontSize="20"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Corrigir Erros nos Jogos"
                                          FontSize="18" FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Detecta e corrige problemas reais que impedem jogos de funcionar"
                                          FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Botões de ação -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Botão SCAN -->
                            <Button Grid.Column="0"
                                    Command="{Binding ScanGameErrorsCommand}"
                                    IsEnabled="{Binding CanStartGameRepair}"
                                    Height="44" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#31A8FF" Offset="0"/>
                                                    <GradientStop Color="#1D6FA4" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="SCAN RÁPIDO" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Botão REPARAR AGORA -->
                            <Button Grid.Column="2"
                                    Command="{Binding RepairGameErrorsCommand}"
                                    IsEnabled="{Binding HasGameRepairIssues}"
                                    Height="44" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#10B981" Offset="0"/>
                                                    <GradientStop Color="#059669" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⚡" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="REPARAR AGORA" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Botão CANCELAR -->
                            <Button Grid.Column="4"
                                    Command="{Binding CancelGameRepairCommand}"
                                    Height="44" Width="44" Cursor="Hand"
                                    ToolTip="Cancelar operação">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                        <Setter Property="Background" Value="#3A1A1A"/>
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="✕" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>

                        <!-- Barra de progresso -->
                        <Grid Margin="0,0,0,10"
                              Visibility="{Binding IsGameRepairScanning, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding GameRepairStatus}"
                                      FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                      Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>
                            <ProgressBar Grid.Row="1" Height="6" Minimum="0" Maximum="100"
                                        Value="{Binding GameRepairProgress}"
                                        Foreground="#31A8FF" Background="#1AFFFFFF"/>
                        </Grid>

                        <!-- Status quando rodando reparo -->
                        <Grid Margin="0,0,0,10"
                              Visibility="{Binding IsGameRepairRunning, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding GameRepairStatus}"
                                      FontSize="12" Foreground="#10B981"
                                      Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>
                            <ProgressBar Grid.Row="1" Height="6" Minimum="0" Maximum="100"
                                        Value="{Binding GameRepairProgress}"
                                        Foreground="#10B981" Background="#1AFFFFFF"/>
                        </Grid>

                        <!-- Relatório / Status -->
                        <Border Visibility="{Binding HasGameRepairReport, Converter={StaticResource BoolToVis}}"
                                Padding="12,10" CornerRadius="10" Margin="0,0,0,10"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#0A10B981"/>
                                    <Setter Property="BorderBrush" Value="#2010B981"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GameRepairAllOk}" Value="False">
                                            <Setter Property="Background" Value="#0AFFA500"/>
                                            <Setter Property="BorderBrush" Value="#20FFA500"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="✅"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GameRepairAllOk}" Value="False">
                                                    <Setter Property="Text" Value="⚠️"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding GameRepairReport}"
                                          FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                          TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Lista de problemas detectados -->
                        <ItemsControl ItemsSource="{Binding GameRepairIssues}"
                                      Visibility="{Binding HasGameRepairIssues, Converter={StaticResource BoolToVis}}"
                                      Margin="0,0,0,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" CornerRadius="8" Margin="0,0,0,6"
                                            Background="#0AFFFFFF" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#20FFA500"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                        <Setter Property="BorderBrush" Value="#20FF4444"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Severity}" Value="Info">
                                                        <Setter Property="BorderBrush" Value="#2031A8FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="⚠️"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                <Setter Property="Text" Value="❌"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Severity}" Value="Info">
                                                                <Setter Property="Text" Value="ℹ️"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11"
                                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                                          TextWrapping="Wrap" Margin="0,2,0,0" Opacity="0.8"/>
                                                <TextBlock Text="{Binding FixDescription}" FontSize="11"
                                                          Foreground="#31A8FF" Margin="0,2,0,0"
                                                          Visibility="{Binding CanAutoFix, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                            <Border Grid.Column="2" Padding="6,3" CornerRadius="4" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#20FFA500"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanAutoFix}" Value="True">
                                                                <Setter Property="Background" Value="#2010B981"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="MANUAL"/>
                                                            <Setter Property="Foreground" Value="#FFA500"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanAutoFix}" Value="True">
                                                                    <Setter Property="Text" Value="AUTO"/>
                                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Toggle: Scan automático ao iniciar jogos -->
                        <Border Padding="10,8" CornerRadius="8" Background="#08FFFFFF" BorderThickness="1"
                                BorderBrush="{DynamicResource BorderLight}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Scan Automático ao Iniciar Jogos"
                                              FontSize="13" FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Verifica erros automaticamente quando um jogo é detectado"
                                              FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" Style="{DynamicResource PremiumCheckBoxStyle}"
                                          IsChecked="{Binding AutoScanOnGameStart, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
