<UserControl x:Class="VoltrisOptimizer.UI.Views.SystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-120,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,24,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header Centralizado -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <!-- Ícone moderno com gradiente -->
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#6366F1" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="M22.7,19L13.6,9.9C14.5,7.6 14,4.9 12.1,3C10.1,1 7.1,0.6 4.7,1.7L9,6L6,9L1.6,4.7C0.4,7.1 0.9,10.1 2.9,12.1C4.8,14 7.5,14.5 9.8,13.6L18.9,22.7C19.3,23.1 19.9,23.1 20.3,22.7L22.6,20.4C23.1,20 23.1,19.3 22.7,19Z" 
                              Fill="White"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Sistema"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Ferramentas avançadas de manutenção e reparo"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Cards em Grid -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Restauração do Sistema -->
                    <Border Grid.Row="0" Grid.Column="0"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.1">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#059669" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="💾" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Restauração do Sistema"
                                          FontWeight="SemiBold"
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <Button x:Name="CreateRestorePointButton"
                                   Content="💾 Criar Ponto de Restauração"
                                   Style="{StaticResource NeonButtonStyle}"
                                   MinHeight="48"
                                   FontSize="13"
                                   HorizontalAlignment="Stretch"
                                   Click="CreateRestorePointButton_Click"
                                   Margin="0,0,0,12"/>
                            
                            <Button x:Name="RestoreSystemButton"
                                   Content="↩️ Restaurar Sistema"
                                   Style="{StaticResource NeonSecondaryButtonStyle}"
                                   MinHeight="46"
                                   FontSize="13"
                                   HorizontalAlignment="Stretch"
                                   Click="RestoreSystemButton_Click"/>
                        </StackPanel>
                    </Border>
                    

                    
                    <!-- Drivers e Hardware -->
                    <Border Grid.Row="2" Grid.Column="0"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.3">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8B5CF6" Offset="0"/>
                                            <GradientStop Color="#6D28D9" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Drivers e Hardware"
                                          FontWeight="SemiBold"
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <Button x:Name="UpdateDriversButton"
                                   Content="⚙️ Atualizar Controladores"
                                   Style="{StaticResource NeonButtonStyle}"
                                   MinHeight="48"
                                   FontSize="13"
                                   HorizontalAlignment="Stretch"
                                   Click="UpdateDriversButton_Click"/>
                            
                            <TextBlock Text="Abre o Gerenciador de Dispositivos do Windows"
                                      FontSize="12"
                                      Foreground="{DynamicResource TextMutedBrush}"
                                      TextWrapping="Wrap"
                                      Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Monitoramento -->
                    <Border Grid.Row="0" Grid.Column="2"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.4">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#1D4ED8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Monitoramento"
                                          FontWeight="SemiBold"
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <Button x:Name="ResourceMonitorButton"
                                   Content="📊 Monitor de Recursos"
                                   Style="{StaticResource NeonButtonStyle}"
                                   MinHeight="48"
                                   FontSize="13"
                                   HorizontalAlignment="Stretch"
                                   Click="ResourceMonitorButton_Click"/>
                            
                            <TextBlock Text="Abre o Monitor de Recursos do Windows"
                                      FontSize="12"
                                      Foreground="{DynamicResource TextMutedBrush}"
                                      TextWrapping="Wrap"
                                      Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Informações do Sistema -->
                    <Border Grid.Row="2" Grid.Column="2"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.6">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#14B8A6" Offset="0"/>
                                            <GradientStop Color="#0D9488" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="ℹ️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Informações do Sistema"
                                          FontWeight="SemiBold"
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button x:Name="SystemInfoButton"
                                       Content="💻 Sobre o Sistema"
                                       Style="{StaticResource NeonSecondaryButtonStyle}"
                                       MinHeight="44"
                                       FontSize="12"
                                       Grid.Column="0"
                                       Click="SystemInfoButton_Click"/>
                                
                                <Button x:Name="TaskManagerButton"
                                       Content="📋 Gerenciador"
                                       Style="{StaticResource NeonSecondaryButtonStyle}"
                                       MinHeight="44"
                                       FontSize="12"
                                       Grid.Column="2"
                                       Click="TaskManagerButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Controle de Energia (Nova Seção) -->
                    <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24"
                            Margin="0,0,0,0">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.7">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EF4444" Offset="0"/>
                                            <GradientStop Color="#DC2626" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Controle de Energia"
                                          FontWeight="SemiBold"
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button x:Name="RestartButton"
                                       Content="🔄 Reiniciar Computador"
                                       Style="{StaticResource NeonButtonStyle}"
                                       MinHeight="50"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Grid.Column="0"
                                       Click="RestartButton_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#D97706" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                                
                                <Button x:Name="ShutdownButton"
                                       Content="🔴 Desligar Computador"
                                       Style="{StaticResource NeonButtonStyle}"
                                       MinHeight="50"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Grid.Column="2"
                                       Click="ShutdownButton_Click">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EF4444" Offset="0"/>
                                            <GradientStop Color="#DC2626" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                            </Grid>
                            
                            <TextBlock Text="⚠️ Estes comandos podem ser executados remotamente pelo site"
                                      FontSize="11"
                                      Foreground="{DynamicResource TextMutedBrush}"
                                      TextWrapping="Wrap"
                                      Margin="0,14,0,0"
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
