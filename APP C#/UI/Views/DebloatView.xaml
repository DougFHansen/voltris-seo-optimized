<UserControl x:Class="VoltrisOptimizer.UI.Views.DebloatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:VoltrisOptimizer.UI.Converters"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="900" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <!-- Converter local: true → Collapsed, false → Visible -->
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
            <!-- Converter: count=0 → Visible (empty state) -->
            <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>

            <Storyboard x:Key="EntryAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Atmospheric background glow -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" Fill="#0D31A8FF"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-300,-200,0">
                <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,40,32,40">

                <!-- ══════════════════════════════════════════════════════════ -->
                <!-- HEADER -->
                <!-- ══════════════════════════════════════════════════════════ -->
                <StackPanel Margin="0,0,0,40" HorizontalAlignment="Center">
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                        <ContentControl Style="{StaticResource ModernPageHeaderIconStyle}">
                            <Path Data="{DynamicResource DebloatIcon}"
                                  Fill="White" Width="20" Height="20"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </ContentControl>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="{DynamicResource DebloatIcon}" Fill="{DynamicResource BrandBlue}"
                              Width="14" Height="14" Stretch="Uniform"
                              Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="OTIMIZAÇÃO DE ESPAÇO"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="12" FontWeight="Black"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrandBlue}"/>
                    </StackPanel>

                    <TextBlock Text="Debloat do Sistema"
                               Style="{DynamicResource PageTitleTextStyle}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Remova aplicativos desnecessários e limpe arquivos temporários para ganhar performance e espaço."
                               Style="{DynamicResource BodyTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" Opacity="0.7"/>
                </StackPanel>

                <!-- ══════════════════════════════════════════════════════════ -->
                <!-- CARD: LIMPEZA RÁPIDA -->
                <!-- ══════════════════════════════════════════════════════════ -->
                <Border Style="{DynamicResource CardBorderStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,32">
                    <StackPanel Margin="24">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Path Data="{DynamicResource CleanupIcon}" Fill="{DynamicResource BrandBlue}"
                                  Width="20" Height="20" Stretch="Uniform"
                                  Margin="0,0,12,0" Opacity="0.8"/>
                            <TextBlock Text="Limpeza de Sistema" Style="{DynamicResource CardHeaderStyle}"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center" Margin="0,0,32,0">
                                <TextBlock Text="Limpeza de Arquivos Temporários"
                                           FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14" Margin="0,0,0,4"/>
                                <TextBlock Text="Remove caches do Windows, pastas Temp, arquivos de log antigos e restos de instalações."
                                           Style="{DynamicResource BodyTextStyle}"
                                           Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Botão desabilitado durante desinstalação -->
                            <Button Grid.Column="1"
                                    Content="Limpar Agora"
                                    Command="{Binding CleanTempCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    MinWidth="140" MinHeight="40"
                                    IsEnabled="{Binding IsNotBusy}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════════════════════ -->
                <!-- CARD: GERENCIAR APLICATIVOS -->
                <!-- ══════════════════════════════════════════════════════════ -->
                <Border Style="{DynamicResource CardBorderStyle}" HorizontalAlignment="Stretch">
                    <StackPanel Margin="24">

                        <!-- Header do card -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Path Data="{DynamicResource SystemIcon}" Fill="{DynamicResource BrandBlue}"
                                      Width="18" Height="18" Stretch="Uniform"
                                      Margin="0,0,12,0" Opacity="0.8" VerticalAlignment="Center"/>
                                <TextBlock Text="Gerenciar Aplicativos Instalados"
                                           Style="{DynamicResource CardHeaderStyle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Linha de ações: contador + botões -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Contador de selecionados -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SelectedCountText}"
                                           Foreground="{DynamicResource BrandBlue}"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="13"/>

                                <!-- Botões de ação -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">

                                    <!-- Botão DESINSTALAR — visível quando não está desinstalando -->
                                    <Button Content="Desinstalar Selecionados"
                                            Command="{Binding UninstallSelectedCommand}"
                                            Style="{DynamicResource PrimaryButtonStyle}"
                                            MinWidth="180" MinHeight="36"
                                            FontSize="12" Margin="0,0,10,0" Padding="14,8"
                                            Background="#FF4B6B"
                                            IsEnabled="{Binding HasSelectedApps}"
                                            Visibility="{Binding IsUninstalling,
                                                Converter={StaticResource InverseBoolToVisConverter}}"/>

                                    <!-- Botão CANCELAR — visível apenas durante desinstalação -->
                                    <Button Content="⛔  Cancelar Desinstalação"
                                            Command="{Binding CancelUninstallCommand}"
                                            MinWidth="200" MinHeight="36"
                                            FontSize="12" Margin="0,0,10,0" Padding="14,8"
                                            Cursor="Hand"
                                            Visibility="{Binding IsUninstalling,
                                                Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#2A1010"/>
                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                                <Setter Property="BorderBrush" Value="#FF4B4B"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="8"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#3A1515"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6B6B"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Botão ATUALIZAR LISTA — desabilitado durante desinstalação -->
                                    <Button Content="Atualizar Lista"
                                            Command="{Binding RefreshCommand}"
                                            Style="{DynamicResource OutlineButtonStyle}"
                                            MinWidth="120" MinHeight="36"
                                            FontSize="12" Padding="12,8"
                                            IsEnabled="{Binding IsNotBusy}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- ══════════════════════════════════════════════════ -->
                        <!-- BARRA DE PROGRESSO INLINE (visível durante desinstalação) -->
                        <!-- ══════════════════════════════════════════════════ -->
                        <Border Margin="0,0,0,20" CornerRadius="12" Padding="16,14"
                                Visibility="{Binding IsUninstalling, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0D1A2A" Offset="0"/>
                                    <GradientStop Color="#0A1520" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#31A8FF" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>

                            <StackPanel>
                                <!-- Status message + percentual -->
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="{Binding UninstallStatusMessage}"
                                               Foreground="#A0C8E8"
                                               FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding UninstallProgress, StringFormat={}{0}%}"
                                               HorizontalAlignment="Right"
                                               Foreground="#31A8FF"
                                               FontSize="12" FontWeight="Bold"/>
                                </Grid>

                                <!-- ProgressBar nativa estilizada com gradiente -->
                                <ProgressBar Value="{Binding UninstallProgress}"
                                             Maximum="100"
                                             Height="6"
                                             BorderThickness="0"
                                             Background="#15FFFFFF">
                                    <ProgressBar.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF4B6B" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="0.5"/>
                                            <GradientStop Color="#31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </ProgressBar.Foreground>
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ProgressBar">
                                                        <Border CornerRadius="4"
                                                                Background="{TemplateBinding Background}"
                                                                Height="{TemplateBinding Height}">
                                                            <Border x:Name="PART_Track">
                                                                <Border x:Name="PART_Indicator"
                                                                        Background="{TemplateBinding Foreground}"
                                                                        CornerRadius="4"
                                                                        HorizontalAlignment="Left"/>
                                                            </Border>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </StackPanel>
                        </Border>

                        <!-- ══════════════════════════════════════════════════ -->
                        <!-- LISTA DE APPS — bloqueada durante desinstalação -->
                        <!-- ══════════════════════════════════════════════════ -->
                        <ItemsControl ItemsSource="{Binding Apps}"
                                      IsEnabled="{Binding IsNotBusy}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#08FFFFFF" CornerRadius="12"
                                            Margin="0,0,0,10" Padding="16"
                                            BorderBrush="#11FFFFFF" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <!-- Opacidade reduzida quando bloqueado -->
                                                    <DataTrigger Binding="{Binding IsSelectionLocked}" Value="True">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="44" Height="44" Background="#1AFFFFFF"
                                                        CornerRadius="10" Margin="0,0,16,0" Padding="8">
                                                    <Image Source="{Binding IconPath, Converter={StaticResource ImagePathConverter}}"
                                                           MaxWidth="28" MaxHeight="28"
                                                           Stretch="Uniform"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               FontWeight="Bold" FontSize="14"
                                                               Margin="0,0,0,2"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding IsWin32, Converter={StaticResource Win32ToTypeTextConverter}}"
                                                                   FontSize="11" Opacity="0.5"
                                                                   Foreground="{DynamicResource TextPrimary}"/>
                                                        <TextBlock Text=" • " Foreground="{DynamicResource TextPrimary}"
                                                                   Opacity="0.3" Margin="4,0"/>
                                                        <TextBlock Text="Pronto para desinstalar"
                                                                   FontSize="11" Opacity="0.5"
                                                                   Foreground="{DynamicResource BrandBlue}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Checkbox — desabilitado quando bloqueado -->
                                            <CheckBox IsChecked="{Binding IsSelected}"
                                                      IsEnabled="{Binding IsCheckboxEnabled}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"
                                                      Style="{DynamicResource PremiumCheckBoxStyle}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <TextBlock Text="Nenhum aplicativo encontrado."
                                   Style="{DynamicResource BodyTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,40" Opacity="0.4"
                                   Visibility="{Binding Apps.Count,
                                       Converter={StaticResource ZeroToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
