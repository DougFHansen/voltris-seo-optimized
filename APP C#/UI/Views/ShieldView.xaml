<UserControl x:Class="VoltrisOptimizer.UI.Views.ShieldView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:VoltrisOptimizer.UI.Converters"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="900" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            
            <!-- Converters adicionais -->
            <converters:StartupLocationToStringConverter x:Key="StartupLocationToString"/>
            <converters:AdwareSeverityToColorConverter x:Key="AdwareSeverityToColor"/>
            <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <converters:BooleanToStatusTextConverter x:Key="BooleanToStatusTextConverter"/>
            <converters:BooleanToStatusColorConverter x:Key="BooleanToStatusColorConverter"/>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            
            <Storyboard x:Key="EntryAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" Fill="#0D8B31FF" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-300,-200,0">
                <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="400" Height="400" Fill="#0D31A8FF" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-150,0,0,-150">
                <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24,40,24,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- HEADER CENTRALIZADO -->
                <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                        <ContentControl Style="{StaticResource ModernPageHeaderIconStyle}">
                            <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,3.27L18.53,6.31C18.4,11.23 15.68,15.7 12,17.29C8.32,15.7 5.6,11.23 5.47,6.31L12,3.27M12,4.89L7.38,7C7.54,10.6 9.47,13.84 12,15.11C14.53,13.84 16.46,10.6 16.62,7L12,4.89Z" 
                                  Fill="White" 
                                  Width="20" Height="20" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </ContentControl>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" Fill="{DynamicResource BrandPurple}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PROTEÇÃO INTELIGENTE" 
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="12" FontWeight="Black"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrandPurple}"/>
                    </StackPanel>
                    
                    <TextBlock Text="Voltris Shield" 
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    
                    <TextBlock Text="Proteção leve contra adware, PUPs e ameaças comuns" 
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" Opacity="0.8"/>
                </StackPanel>

                <!-- STATUS DE PROTEÇÃO -->
                <Border Grid.Row="1" Margin="0,0,0,32" Padding="24" CornerRadius="16" BorderThickness="2"
                        Background="{DynamicResource BgCard}">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{Binding StatusColor.Color}"/>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="{Binding StatusColor.Color}" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Ícone de Status -->
                        <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30" Margin="0,0,20,0">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding StatusColor.Color}" Opacity="0.2"/>
                            </Border.Background>
                            <TextBlock Text="{Binding StatusIcon}" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding StatusColor}"/>
                        </Border>
                        
                        <!-- Informações -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusMessage}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding LastScanTime, StringFormat='Última verificação: {0}'}" FontSize="13" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding ThreatsDetected, StringFormat='{}{0} ameaças detectadas'}" FontSize="13" Foreground="{DynamicResource BrandPink}" Margin="0,2,0,0" Visibility="{Binding ThreatsDetected, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        
                        <!-- Botão Toggle -->
                        <Button Grid.Column="2" Command="{Binding ToggleProtectionCommand}" Height="44" MinWidth="140" Padding="20,0" FontSize="13" FontWeight="Bold">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProtectionActive}" Value="True">
                                            <Setter Property="Content" Value="Desativar Proteção"/>
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#EF4444" Offset="0"/>
                                                        <GradientStop Color="#DC2626" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsProtectionActive}" Value="False">
                                            <Setter Property="Content" Value="Ativar Proteção"/>
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#10B981" Offset="0"/>
                                                        <GradientStop Color="#059669" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- GRID DE AÇÕES -->
                <ItemsControl Grid.Row="2" Margin="0,0,0,32" MinWidth="560">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.Items>
                        <!-- Scan Rápido -->
                        <Border Style="{DynamicResource PremiumCard}" Margin="8" MinWidth="180">
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Width="48" Height="48" CornerRadius="12" Background="#1A31A8FF" HorizontalAlignment="Left" Margin="0,0,0,16" Padding="12">
                                    <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                                          Fill="{DynamicResource BrandBlue}" Stretch="Uniform"/>
                                </Border>
                                
                                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                    <TextBlock Text="Scan Rápido" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                    <TextBlock Text="Verifica Downloads e arquivos temporários em busca de ameaças comuns." 
                                               FontSize="12" Foreground="{DynamicResource TextSecondary}" Opacity="0.8" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                                
                                <Button Grid.Row="2" Content="Executar" Command="{Binding RunQuickScanCommand}" Style="{DynamicResource PrimaryButtonStyle}" Height="42" FontSize="12" Margin="0,16,0,0" Padding="16,8" HorizontalAlignment="Stretch" IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}"/>
                            </Grid>
                        </Border>

                        <!-- Scan Completo -->
                        <Border Style="{DynamicResource PremiumCard}" Margin="8" MinWidth="180">
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Width="48" Height="48" CornerRadius="12" Background="#1A8B31FF" HorizontalAlignment="Left" Margin="0,0,0,16" Padding="12">
                                    <Path Data="M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M10,22C9.75,22 9.54,21.82 9.5,21.58L9.13,18.93C8.5,18.68 7.96,18.34 7.44,17.94L4.95,18.95C4.73,19.03 4.46,18.95 4.34,18.73L2.34,15.27C2.21,15.05 2.27,14.78 2.46,14.63L4.57,12.97L4.5,12L4.57,11L2.46,9.37C2.27,9.22 2.21,8.95 2.34,8.73L4.34,5.27C4.46,5.05 4.73,4.96 4.95,5.05L7.44,6.05C7.96,5.66 8.5,5.32 9.13,5.07L9.5,2.42C9.54,2.18 9.75,2 10,2H14C14.25,2 14.46,2.18 14.5,2.42L14.87,5.07C15.5,5.32 16.04,5.66 16.56,6.05L19.05,5.05C19.27,4.96 19.54,5.05 19.66,5.27L21.66,8.73C21.79,8.95 21.73,9.22 21.54,9.37L19.43,11L19.5,12L19.43,13L21.54,14.63C21.73,14.78 21.79,15.05 21.66,15.27L19.66,18.73C19.54,18.95 19.27,19.04 19.05,18.95L16.56,17.95C16.04,18.34 15.5,18.68 14.87,18.93L14.5,21.58C14.46,21.82 14.25,22 14,22H10Z" 
                                          Fill="{DynamicResource BrandPurple}" Stretch="Uniform"/>
                                </Border>
                                
                                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                    <TextBlock Text="Scan Completo" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                    <TextBlock Text="Análise profunda do sistema incluindo Program Files, AppData e inicialização." 
                                               FontSize="12" Foreground="{DynamicResource TextSecondary}" Opacity="0.8" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                                
                                <Button Grid.Row="2" Content="Executar" Command="{Binding RunFullScanCommand}" Style="{DynamicResource PrimaryButtonStyle}" Height="42" FontSize="12" Margin="0,16,0,0" Padding="16,8" HorizontalAlignment="Stretch" IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}"/>
                            </Grid>
                        </Border>

                        <!-- Scan de Adware -->
                        <Border Style="{DynamicResource PremiumCard}" Margin="8" MinWidth="180">
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Width="48" Height="48" CornerRadius="12" Background="#1AFF4B6B" HorizontalAlignment="Left" Margin="0,0,0,16" Padding="12">
                                    <Path Data="M13,14H11V10H13M13,18H11V16H13M1,21H23L12,2L1,21Z" 
                                          Fill="{DynamicResource BrandPink}" Stretch="Uniform"/>
                                </Border>
                                
                                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                    <TextBlock Text="Scan de Adware" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="16" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                    <TextBlock Text="Detecta toolbars, hijackers, PUPs e programas indesejados instalados no sistema." 
                                               FontSize="12" Foreground="{DynamicResource TextSecondary}" Opacity="0.8" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                                
                                <Button Grid.Row="2" Content="Executar" Command="{Binding RunAdwareScanCommand}" Style="{DynamicResource PrimaryButtonStyle}" Height="42" FontSize="12" Margin="0,16,0,0" Padding="16,8" HorizontalAlignment="Stretch" IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}"/>
                            </Grid>
                        </Border>
                    </ItemsControl.Items>
                </ItemsControl>

                <!-- PROGRESSO DO SCAN (visível durante scan) -->
                <Border Grid.Row="3" Margin="0,0,0,16" Padding="24,20" CornerRadius="16" 
                        Background="{DynamicResource BgCard}" BorderThickness="1" BorderBrush="#2831A8FF"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="🔍" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ScanProgressText}" FontSize="14" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding ScanProgress}" Minimum="0" Maximum="100" Height="8" 
                                     Background="#20FFFFFF" Foreground="#8B31FF" BorderThickness="0"/>
                        <TextBlock Text="{Binding ScanProgress, StringFormat='{}{0}%'}" FontSize="11" 
                                   Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Right" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- RESULTADOS DO SCAN -->
                <Border Grid.Row="3" Margin="0,0,0,32" Padding="28" CornerRadius="16" BorderThickness="2" BorderBrush="#3331A8FF"
                        Background="{DynamicResource BgCard}"
                        Visibility="{Binding IsScanResultVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect>
                        <DropShadowEffect Color="#31A8FF" BlurRadius="16" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Header dos resultados -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" 
                                          Fill="{DynamicResource BrandPurple}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ScanResultType}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text=" — Resultados" FontSize="18" Foreground="{DynamicResource TextSecondary}" Opacity="0.7"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ScanResultSummary}" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                            
                            <Button Grid.Column="1" Content="Fechar" Command="{Binding ClearScanResultsCommand}" 
                                    Style="{DynamicResource OutlineButtonStyle}" Height="36" Width="90" FontSize="12" Padding="12,6"/>
                        </Grid>
                        
                        <!-- Lista de ameaças encontradas -->
                        <Border Background="{DynamicResource BgInput}" CornerRadius="12" BorderBrush="#1CFFFFFF" BorderThickness="1" 
                                MaxHeight="400" Visibility="{Binding ScanThreatItems.Count, Converter={StaticResource BoolToVis}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ScanThreatItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="16,14" BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Ícone de Severidade -->
                                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Margin="0,0,16,0">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding SeverityColor.Color}" Opacity="0.15"/>
                                                        </Border.Background>
                                                        <TextBlock Text="⚠" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   Foreground="{Binding SeverityColor}"/>
                                                    </Border>
                                                    
                                                    <!-- Informações da ameaça -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" 
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                                                            <Border CornerRadius="4" Padding="8,2" Margin="10,0,0,0">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding SeverityColor.Color}" Opacity="0.2"/>
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding SeverityText}" FontSize="10" FontWeight="Bold" Foreground="{Binding SeverityColor}"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Path}" FontSize="11" Foreground="{DynamicResource TextSecondary}" 
                                                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,3" MaxWidth="450"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Tipo: " FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                            <TextBlock Text="{Binding ThreatTypeDisplay}" FontSize="11" Foreground="{DynamicResource TextSecondary}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    
                                                    <!-- Ações por ameaça -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                                        <Button Content="Ignorar" 
                                                                Command="{Binding DataContext.IgnoreScanThreatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                CommandParameter="{Binding}" Style="{DynamicResource OutlineButtonStyle}" 
                                                                Height="34" Width="80" FontSize="11" Margin="0,0,6,0" Padding="6,4"/>
                                                        <Button Content="Quarentena" 
                                                                Command="{Binding DataContext.QuarantineScanThreatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                CommandParameter="{Binding}" Style="{DynamicResource OutlineButtonStyle}" 
                                                                Height="34" Width="95" FontSize="11" Margin="0,0,6,0" Padding="6,4"/>
                                                        <Button Content="Remover" 
                                                                Command="{Binding DataContext.RemoveScanThreatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                CommandParameter="{Binding}" Height="34" Width="85" FontSize="11" Padding="6,4">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                <GradientStop Color="#EF4444" Offset="0"/>
                                                                                <GradientStop Color="#DC2626" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        
                        <!-- Estado limpo (sem ameaças) -->
                        <Border Padding="32" Visibility="{Binding ScanThreatItems.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✓" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" Foreground="#00FF94" Opacity="0.7"/>
                                <TextBlock Text="Sistema limpo" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Nenhuma ameaça foi encontrada durante a verificação" FontSize="12" 
                                           Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- SEÇÕES ADICIONAIS -->
                <StackPanel Grid.Row="4">
                    <!-- Windows Defender Integration -->
                    <Border Style="{DynamicResource CardBorderStyle}" Margin="0,0,0,24">
                        <StackPanel Margin="32">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" Fill="{DynamicResource BrandGreen}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" Opacity="0.8"/>
                                <TextBlock Text="Integração com Windows Defender" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Status do Windows Defender" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Proteção: " FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding IsDefenderEnabled, Converter={StaticResource BooleanToStatusTextConverter}}" 
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="{Binding IsDefenderEnabled, Converter={StaticResource BooleanToStatusColorConverter}}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Definições: " FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                        <TextBlock Text="{Binding IsDefenderUpToDate, Converter={StaticResource BooleanToStatusTextConverter}}" 
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="{Binding IsDefenderUpToDate, Converter={StaticResource BooleanToStatusColorConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <WrapPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Atualizar Status" Command="{Binding RefreshDefenderStatusCommand}" Style="{DynamicResource OutlineButtonStyle}" Height="38" MinWidth="120" FontSize="12" Margin="0,4,8,4" Padding="14,6"/>
                                    <Button Content="Iniciar Scan" Command="{Binding StartDefenderScanCommand}" Style="{DynamicResource PrimaryButtonStyle}" Height="38" MinWidth="100" FontSize="12" Margin="0,4,0,4" Padding="14,6"/>
                                </WrapPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Modo Gamer -->
                    <Border Style="{DynamicResource CardBorderStyle}">
