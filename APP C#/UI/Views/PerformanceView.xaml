<UserControl x:Class="VoltrisOptimizer.UI.Views.PerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             xmlns:conv="clr-namespace:VoltrisOptimizer.UI.Converters"
             xmlns:views="clr-namespace:VoltrisOptimizer.UI.Views"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="PerformanceVM" />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="450" Height="450" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-100,-180,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,32">
            <Grid Margin="28,24,28,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header Centralizado -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#059669" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#10B981" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="M13,2.05V5.08C16.39,5.57 19,8.47 19,12C19,12.9 18.82,13.75 18.5,14.54L21.12,16.07C21.68,14.83 22,13.45 22,12C22,6.82 18.05,2.55 13,2.05M12,19A7,7 0 0,1 5,12C5,8.47 7.61,5.57 11,5.08V2.05C5.94,2.55 2,6.81 2,12A10,10 0 0,0 12,22C15.3,22 18.23,20.39 20.05,17.91L17.45,16.38C16.17,18 14.21,19 12,19Z" 
                              Fill="White"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Desempenho Ultra"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold"
                                  TextOptions.TextFormattingMode="Display"
                                  TextOptions.TextRenderingMode="ClearType"
                                  Foreground="{StaticResource VoltrisGradientHorizontalBrush}">
                        </TextBlock>
                        <TextBlock Text="Otimizações inteligentes baseadas no seu hardware"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- ============================================ -->
                <!-- CARD DE PERFIL DO SISTEMA -->
                <!-- ============================================ -->
                <Border Grid.Row="1" Margin="0,0,0,16" Background="{DynamicResource DarkPanelBrush}">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4010B981" Offset="0"/>
                            <GradientStop Color="#3000D4FF" Offset="0.5"/>
                            <GradientStop Color="#208B31FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="16"/>
                            <Setter Property="Padding" Value="20,16"/>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#10B981" Opacity="0.15"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#00D4FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#10B981" Opacity="0.4"/>
                                    </Border.Effect>
                                    <TextBlock Text="🖥️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PERFIL DO SISTEMA"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Detectado automaticamente"
                                              FontSize="11"
                                              Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Informações do Sistema -->
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- CPU -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                                    <TextBlock Text="{Binding ProfileCpu}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}" 
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.ToolTip>
                                            <ToolTip Background="#1A1A20" BorderBrush="#303040" BorderThickness="1" Padding="12,8" Placement="Mouse">
                                                <TextBlock Text="{Binding FullProfileCpu}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" MaxWidth="350"/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                    <TextBlock Text="PROCESSADOR" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6"/>
                                </StackPanel>
                                
                                <!-- RAM -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding ProfileRam}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.ToolTip>
                                            <ToolTip Background="#1A1A20" BorderBrush="#303040" BorderThickness="1" Padding="12,8" Placement="Mouse">
                                                <TextBlock Text="{Binding FullProfileRam}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" MaxWidth="350"/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                    <TextBlock Text="MEMÓRIA RAM" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6"/>
                                </StackPanel>
                                
                                <!-- Disco -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding ProfileStorage}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.ToolTip>
                                            <ToolTip Background="#1A1A20" BorderBrush="#303040" BorderThickness="1" Padding="12,8" Placement="Mouse">
                                                <TextBlock Text="{Binding FullProfileStorage}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" MaxWidth="350"/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                    <TextBlock Text="ARMAZENAMENTO" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6"/>
                                </StackPanel>
                                
                                <!-- GPU -->
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="{Binding ProfileGpu}" 
                                               FontSize="13" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource TextPrimaryBrush}" 
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.ToolTip>
                                            <ToolTip Background="#1A1A20" BorderBrush="#303040" BorderThickness="1" Padding="12,8" Placement="Mouse">
                                                <TextBlock Text="{Binding FullProfileGpu}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" MaxWidth="350"/>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                    <TextBlock Text="PLACA DE VÍDEO" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.6"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Badge de Tipo de PC -->
                        <Border Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="14,8" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ProfileTypeIcon}" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ProfileType}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- ============================================ -->
                <!-- AÇÕES RÁPIDAS -->
                <!-- ============================================ -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Botão Otimização Automática -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00D4FF" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="🚀" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Otimização Inteligente"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Analisa e aplica a melhor estratégia"
                                              FontSize="11"
                                              Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" x:Name="AutoProgressPanel" Margin="0,0,0,10">
                                <TextBlock x:Name="AutoProgressText" Text="{Binding IntelligentStatusMessage}" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="AutoProgress" Height="4" Background="{DynamicResource DarkBorderBrush}" Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0" Maximum="100" IsIndeterminate="True" Visibility="{Binding IsOptimizing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                            
                            <Button Grid.Row="2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Bottom"
                                    MinHeight="44"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Command="{Binding IntelligentOptimizeCommand}"
                                    >
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" CornerRadius="10" Padding="16,12">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#00D4FF" Offset="0"/>
                                                                <GradientStop Color="#8B31FF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00D4FF" Opacity="0.3"/>
                                                        </Border.Effect>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#00D4FF" Opacity="0.5"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Aplicar Otimização Inteligente"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Botão Reverter -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#F59E0B" Opacity="0.2"/>
                                    </Border.Background>
                                    <TextBlock Text="↩️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Reverter Tudo"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Restaura configurações originais"
                                              FontSize="11"
                                              Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Button Grid.Row="1"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Bottom"
                                    MinHeight="44"
                                    FontWeight="SemiBold"
                                    Command="{Binding RevertAllCommand}"
                                    >
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Reverter"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- ============================================ -->
                <!-- CATEGORIAS DE OTIMIZAÇÃO -->
                <!-- ============================================ -->
                <ItemsControl Grid.Row="3" ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{DynamicResource PremiumCard}"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <!-- Header da Categoria -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,12,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding CategoryColor}" Opacity="0.2"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Icon}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                          FontSize="14" 
                                                          FontWeight="SemiBold"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}" 
                                                          FontSize="11"
                                                          Foreground="{DynamicResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Status de Trabalho -->
                                            <TextBlock Text="{Binding StatusText}" 
                                                      FontSize="11"
                                                      Foreground="{Binding CategoryColor, Converter={StaticResource ColorToBrushConverter}}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"
                                                      Visibility="{Binding IsWorking, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="{Binding CategoryColor}" Opacity="0.5"/>
                                                </TextBlock.Effect>
                                            </TextBlock>

                                            <!-- Botões de Ação Modernos (SaaS Design) -->
                                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsNotWorking, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <!-- Botão Aplicar (Premium) -->
                                                <Button Command="{Binding ApplyCommand}"
                                                        Margin="0,0,10,0"
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="border" CornerRadius="8" Padding="14,6" RenderTransformOrigin="0.5,0.5">
                                                                            <Border.RenderTransform>
                                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                            </Border.RenderTransform>
                                                                            <Border.Background>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                                                                    <GradientStop Color="#0088FF" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Border.Background>
                                                                            <Border.Effect>
                                                                                <DropShadowEffect x:Name="glow" BlurRadius="10" ShadowDepth="0" Color="#00D4FF" Opacity="0.3"/>
                                                                            </Border.Effect>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="⚡" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" Opacity="0.9"/>
                                                                                <TextBlock Text="Aplicar" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Trigger.EnterActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2">
                                                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2">
                                                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                            <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.2"/>
                                                                                            <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="BlurRadius" To="18" Duration="0:0:0.2"/>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </Trigger.EnterActions>
                                                                                <Trigger.ExitActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                                                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                                                                            <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.2"/>
                                                                                            <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="BlurRadius" To="10" Duration="0:0:0.2"/>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </Trigger.ExitActions>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="border" Property="RenderTransform">
                                                                                    <Setter.Value>
                                                                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Botão Reverter (Sutil/Outline) -->
                                                <Button Command="{Binding RevertCommand}"
                                                        Margin="0,0,14,0"
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="border" CornerRadius="8" Padding="12,6" Background="Transparent" BorderBrush="#30FFFFFF" BorderThickness="1.2" RenderTransformOrigin="0.5,0.5">
                                                                            <Border.RenderTransform>
                                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                            </Border.RenderTransform>
                                                                            <TextBlock x:Name="text" Text="Reverter" FontSize="11" FontWeight="SemiBold" Foreground="#A0FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                                                                <Setter TargetName="border" Property="BorderBrush" Value="#60FFFFFF"/>
                                                                                <Setter TargetName="text" Property="Foreground" Value="White"/>
                                                                                <Trigger.EnterActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.2"/>
                                                                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.2"/>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </Trigger.EnterActions>
                                                                                <Trigger.ExitActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                                                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </Trigger.ExitActions>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>

                                            <!-- Checkbox de Seleção Geral (Sempre visível e destacado) -->
                                            <CheckBox IsChecked="{Binding IsSelectedAll, Mode=TwoWay}"
                                                      ToolTip="Selecionar tudo nesta categoria"
                                                      Style="{DynamicResource ModernCheckBoxStyle}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>

                                            <!-- Alternar Expansão (Chevron) -->
                                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                         Cursor="Hand">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="border" Width="28" Height="28" CornerRadius="8" Background="#12FFFFFF">
                                                            <Viewbox Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Path x:Name="chevron" 
                                                                      Data="M 0 0 L 5 5 L 10 0" 
                                                                      Stroke="{DynamicResource TextMutedBrush}" 
                                                                      StrokeThickness="2" 
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      RenderTransformOrigin="0.5,0.5">
                                                                    <Path.RenderTransform>
                                                                        <RotateTransform Angle="0"/>
                                                                    </Path.RenderTransform>
                                                                </Path>
                                                            </Viewbox>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="chevron" Property="RenderTransform">
                                                                    <Setter.Value>
                                                                        <RotateTransform Angle="180"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#30FFFFFF"/>
                                                                <Setter TargetName="chevron" Property="Stroke" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Lista de Otimizações -->
                                    <ItemsControl ItemsSource="{Binding Optimizations}" 
                                                  Visibility="{Binding ExpandedVisibility}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#08FFFFFF" 
                                                        CornerRadius="10" 
                                                        Padding="14,12" 
                                                        Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <CheckBox Grid.Column="0" 
                                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                 ToolTip="{Binding IncompatibilityReason}"
                                                                 Margin="0,0,12,0"
                                                                 VerticalAlignment="Center"/>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" 
                                                                      FontSize="12" 
                                                                      FontWeight="Medium"
                                                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Description}" 
                                                                      FontSize="10" 
                                                                      Foreground="{DynamicResource TextMutedBrush}"/>
                                                        </StackPanel>
                                                        
                                                        <!-- Impacto -->
                                                        <Border Grid.Column="2"
                                                               Background="{Binding ImpactColor}"
                                                               CornerRadius="6"
                                                               Padding="8,4"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ImpactText}" 
                                                                      FontSize="9" 
                                                                      FontWeight="Bold"
                                                                      Foreground="{DynamicResource TextPrimary}"/>
                                                        </Border>
                                                        
                                                        <!-- Recomendado -->
                                                        <Border Grid.Column="3"
                                                               Visibility="{Binding RecommendedVisibility}"
                                                               Background="#1510B981"
                                                               CornerRadius="6"
                                                               Padding="8,4"
                                                               Margin="0,0,6,0"
                                                               VerticalAlignment="Center">
                                                            <TextBlock Text="✓ REC" 
                                                                      FontSize="9" 
                                                                      FontWeight="Bold"
                                                                      Foreground="#10B981"/>
                                                        </Border>

                                                        <!-- Botão Aplicar Individual -->
                                                        <Button Grid.Column="4"
                                                                Command="{Binding ApplyIndividualCommand}"
                                                                ToolTip="Aplicar esta otimização"
                                                                Cursor="Hand"
                                                                Margin="0,0,4,0"
                                                                VerticalAlignment="Center">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="applyBorder" Background="#1510B981" CornerRadius="6" Padding="8,4" BorderBrush="#3010B981" BorderThickness="1">
                                                                                    <TextBlock Text="▶" FontSize="9" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="applyBorder" Property="Background" Value="#2510B981"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>

                                                        <!-- Botão Reverter Individual -->
                                                        <Button Grid.Column="5"
                                                                Command="{Binding RevertIndividualCommand}"
                                                                ToolTip="Reverter esta otimização"
                                                                Cursor="Hand"
                                                                VerticalAlignment="Center">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="revertBorder" Background="#15F59E0B" CornerRadius="6" Padding="8,4" BorderBrush="#30F59E0B" BorderThickness="1">
                                                                                    <TextBlock Text="↩" FontSize="9" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="revertBorder" Property="Background" Value="#25F59E0B"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
