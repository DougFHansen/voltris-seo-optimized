<UserControl x:Class="VoltrisOptimizer.UI.Views.GameDiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="450" Height="450" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-180,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="280" Height="280" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,100,150">
                <Ellipse.Effect>
                    <BlurEffect Radius="60"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
            <Grid Margin="24,24,24,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header Centralizado -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <!-- Ícone moderno com gradiente Voltris -->
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#8B31FF" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="M9.4,16.6L4.8,12L9.4,7.4L8,6L2,12L8,18L9.4,16.6M14.6,16.6L19.2,12L14.6,7.4L16,6L22,12L16,18L14.6,16.6Z" 
                              Fill="White"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Diagnóstico"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Monitoramento inteligente de causas de quedas"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Cards de Métricas - Layout Responsivo Ultra Moderno -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.Resources>
                        <Style x:Key="MetricCardStyle" TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource BgCardGlass}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="20"/>
                            <Setter Property="Padding" Value="24"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    
                    <!-- CPU -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.1">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#1D4ED8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#3B82F6" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" 
                                          Fill="White"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Processador"
                                          FontWeight="SemiBold"
                                          FontSize="15"
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="CpuInfoText"
                                      Text="Carregando..."
                                      FontSize="12"
                                      FontFamily="Segoe UI Variable, Segoe UI"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="18"/>
                            <Border Background="{DynamicResource DarkPanelAltBrush}" 
                                    CornerRadius="10" 
                                    Height="80"
                                    Margin="0,14,0,0"
                                    Padding="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="CpuGraph"
                                       Background="Transparent"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- GPU -->
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.15">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#059669" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#10B981" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Path Data="M21,6H3A2,2 0 0,0 1,8V16A2,2 0 0,0 3,18H21A2,2 0 0,0 23,16V8A2,2 0 0,0 21,6M11,13H8V16H6V13H3V11H6V8H8V11H11V13M15.5,15A1.5,1.5 0 0,1 14,13.5A1.5,1.5 0 0,1 15.5,12A1.5,1.5 0 0,1 17,13.5A1.5,1.5 0 0,1 15.5,15M19.5,12A1.5,1.5 0 0,1 18,10.5A1.5,1.5 0 0,1 19.5,9A1.5,1.5 0 0,1 21,10.5A1.5,1.5 0 0,1 19.5,12Z" 
                                          Fill="White"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Placa de Vídeo"
                                          FontWeight="SemiBold"
                                          FontSize="15"
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="GpuInfoText"
                                      Text="Carregando..."
                                      FontSize="12"
                                      FontFamily="Segoe UI Variable, Segoe UI"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="18"/>
                            <TextBlock x:Name="FpsText"
                                      Text="FPS: N/D"
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      FontFamily="Segoe UI Variable, Segoe UI"
                                      Foreground="{DynamicResource PrimaryBrush}"
                                      Margin="0,8,0,0"/>
                            <Border Background="{DynamicResource DarkPanelAltBrush}" 
                                    CornerRadius="10" 
                                    Height="55"
                                    Margin="0,10,0,0"
                                    Padding="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="GpuGraph"
                                       Background="Transparent"/>
                            </Border>
                            <Border Background="{DynamicResource DarkPanelAltBrush}" 
                                    CornerRadius="10" 
                                    Height="55"
                                    Margin="0,8,0,0"
                                    Padding="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="FpsGraph"
                                       Background="Transparent"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- RAM -->
                    <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource MetricCardStyle}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.2">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8B5CF6" Offset="0"/>
                                            <GradientStop Color="#6D28D9" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#8B5CF6" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" 
                                          Fill="White"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Memória RAM"
                                          FontWeight="SemiBold"
                                          FontSize="15"
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="RamInfoText"
                                      Text="Carregando..."
                                      FontSize="12"
                                      FontFamily="Segoe UI Variable, Segoe UI"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="18"/>
                            <Border Background="{DynamicResource DarkPanelAltBrush}" 
                                    CornerRadius="10" 
                                    Height="80"
                                    Margin="0,14,0,0"
                                    Padding="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="RamGraph"
                                       Background="Transparent"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Temperatura -->
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.25">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#D97706" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#F59E0B" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Path Data="M15,13V5H13V13H5V15H13V23H15V15H23V13H15M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z" 
                                          Fill="White"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Temperatura"
                                          FontWeight="SemiBold"
                                          FontSize="15"
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel x:Name="TemperatureInfoPanel" Margin="0,0,0,14">
                                <TextBlock x:Name="TemperatureInfoText"
                                          Text="Carregando..."
                                          FontSize="12"
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          TextWrapping="Wrap"
                                          LineHeight="18"/>
                                <!-- Indicadores de temperatura com cores dinâmicas -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Border x:Name="CpuTempIndicator"
                                            Width="8" Height="8"
                                            CornerRadius="4"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                        </Border.Effect>
                                    </Border>
                                    <TextBlock x:Name="CpuTempText"
                                              Text="CPU: --°C"
                                              FontSize="11"
                                              FontFamily="Segoe UI Variable, Segoe UI"
                                              Foreground="{DynamicResource TextMutedBrush}"
                                              Margin="0,0,12,0"/>
                                    <Border x:Name="GpuTempIndicator"
                                            Width="8" Height="8"
                                            CornerRadius="4"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                        </Border.Effect>
                                    </Border>
                                    <TextBlock x:Name="GpuTempText"
                                              Text="GPU: --°C"
                                              FontSize="11"
                                              FontFamily="Segoe UI Variable, Segoe UI"
                                              Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="{DynamicResource DarkPanelAltBrush}" 
                                    CornerRadius="10" 
                                    Height="80"
                                    Margin="0,0,0,0"
                                    Padding="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="TemperatureGraph"
                                       Background="Transparent"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Disco -->
                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.3">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#D97706" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#F59E0B" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Path Data="M6,2C4.89,2 4,2.89 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2H6M13,3.5L18.5,9H13V3.5M6,4H12V10H18V20H6V4Z" 
                                          Fill="White"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="SSD/Disco"
                                          FontWeight="SemiBold"
                                          FontSize="15"
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="DiskInfoText"
                                      Text="Carregando..."
                                      FontSize="12"
                                      FontFamily="Segoe UI Variable, Segoe UI"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="18"/>
                            <Border Background="{DynamicResource DarkPanelAltBrush}" 
                                    CornerRadius="10" 
                                    Height="80"
                                    Margin="0,14,0,0"
                                    Padding="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="DiskGraph"
                                       Background="Transparent"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Energia -->
                    <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource MetricCardStyle}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.35">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EC4899" Offset="0"/>
                                            <GradientStop Color="#DB2777" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#EC4899" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Path Data="M11,21H10L11,14H7.5C7.16,14 7,13.76 7,13.5C7,13.35 7.04,13.23 7.12,13.13L13,3H14L13,10H16.5C16.82,10 17,10.25 17,10.5C17,10.66 16.95,10.78 16.88,10.88L11,21Z" 
                                          Fill="White"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Energia"
                                          FontWeight="SemiBold"
                                          FontSize="15"
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="PowerInfoText"
                                      Text="Carregando..."
                                      FontSize="12"
                                      FontFamily="Segoe UI Variable, Segoe UI"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="18"/>
                            <Border Background="{DynamicResource DarkPanelAltBrush}" 
                                    CornerRadius="10" 
                                    Height="80"
                                    Margin="0,14,0,0"
                                    Padding="2"
                                    ClipToBounds="True">
                                <Canvas x:Name="PowerGraph"
                                       Background="Transparent"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Causa Provável (Redesenhada) -->
                    <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource MetricCardStyle}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1.5">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <!-- Ícone de Causa (Escaneamento Inteligente) -->
                                <Border Width="54" Height="48" CornerRadius="14" Margin="0,0,18,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#26F59E0B" Offset="0"/>
                                            <GradientStop Color="#0DF59E0B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" 
                                          Fill="{DynamicResource WarningBrush}" Width="26" Height="26" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Path.Effect>
                                            <DropShadowEffect BlurRadius="10" Color="#F59E0B" Opacity="0.5" ShadowDepth="0"/>
                                        </Path.Effect>
                                    </Path>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Diagnóstico de Causa" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Causa raiz detectada pelo sistema neurônal" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Border Background="{DynamicResource DarkPanelAltBrush}" CornerRadius="12" Padding="16">
                                <TextBlock x:Name="CauseText" Text="Monitorando estabilidade..." FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Maiores Consumidores (Redesenhado Profissionalmente) -->
                    <Border Grid.Row="4" Grid.Column="4" Style="{StaticResource MetricCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0" Background="#1AFFFFFF">
                                    <Path Data="M3,5H21V19H3V5M5,7V17H19V7H5M12,9L16,13L12,17V14H8V12H12V9Z" 
                                          Fill="{DynamicResource PrimaryBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Consumo de Recursos" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <ItemsControl x:Name="TopProcessesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Background="#08FFFFFF" CornerRadius="8" Padding="10,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource DefaultTextBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <ProgressBar Value="{Binding Percent, Mode=OneWay}" Height="3" Margin="0,4,0,0" Background="#1AFFFFFF" Foreground="{DynamicResource VoltrisGradientBrush}" BorderThickness="0" IsIndeterminate="False"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayValue}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Análise e Incidentes -->
                <Border Grid.Row="2" 
                        Background="{DynamicResource DarkPanelBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24">
                    <Border.RenderTransform>
                        <TranslateTransform/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard BeginTime="0:0:0.4">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#06B6D4" Offset="0"/>
                                        <GradientStop Color="#0891B2" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#06B6D4" Opacity="0.4"/>
                                </Border.Effect>
                                <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                                      Fill="White"
                                      Width="22" Height="22"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Análise Inteligente"
                                      FontWeight="SemiBold"
                                      FontSize="18"
                                      FontFamily="Segoe UI Variable Display, Segoe UI"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        
                        <Border Background="{DynamicResource DarkPanelAltBrush}" 
                                BorderBrush="{DynamicResource DarkBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="4" Height="40" CornerRadius="2" Background="{DynamicResource VoltrisGradientBrush}" Margin="0,0,16,0"/>
                                <TextBlock x:Name="AnalysisText"
                                          Text="Iniciando monitoramento neural..."
                                          FontSize="14"
                                          FontWeight="Medium"
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          TextWrapping="Wrap"
                                          LineHeight="22"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Cabeçalho de Incidentes -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,14,0" Background="#1AF54444">
                                <Path Data="M13,13H11V7H13M13,17H11V15H13M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" 
                                      Fill="#EF4444" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Histórico de Incidentes" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Anomalias detectadas pelo Neural Core" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Background="{DynamicResource DarkPanelAltBrush}"
                                BorderBrush="{DynamicResource BorderLight}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="16"
                                MaxHeight="220">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="IncidentsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource DarkPanelBrush}"
                                                    BorderBrush="{DynamicResource BorderLight}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12"
                                                    Margin="0,0,0,8">
                                                <TextBlock Text="{Binding}"
                                                          FontSize="12"
                                                          FontFamily="Segoe UI Variable, Segoe UI"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                                          TextWrapping="Wrap"
                                                          LineHeight="18"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        
                        <Button x:Name="ExportCsvButton"
                               Style="{StaticResource NeonButtonStyle}"
                               MinHeight="48"
                               HorizontalAlignment="Left"
                               Padding="24,0"
                               Margin="0,20,0,0"
                               Click="ExportCsvButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M8,13H16V11H8V13M8,17H13V15H8V17Z" 
                                      Fill="White"
                                      Width="18" Height="18"
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="Exportar CSV" 
                                          FontFamily="Segoe UI Variable, Segoe UI"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
