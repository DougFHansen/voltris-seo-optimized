<UserControl x:Class="VoltrisOptimizer.UI.Views.DisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VoltrisOptimizer.UI.Converters"
             Background="Transparent"
             UseLayoutRounding="True" SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:InverseBooleanConverter x:Key="InverseBool"/>
        <conv:HexStringToBrushConverter x:Key="HexBrush"/>
        <Style x:Key="DCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCardGlass}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="#0DFFFFFF"/>
            <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
        <Style x:Key="STitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="MetricVal" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource DefaultTextBrush}"/>
        </Style>
        <Style x:Key="MetricLbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
        <Style x:Key="ApplyBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A31A8FF"/>
            <Setter Property="BorderBrush" Value="#3031A8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#31A8FF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2531A8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Busy overlay -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
              Panel.ZIndex="99" Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🖥" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding BusyMessage}" Foreground="White"
                           FontSize="13" Margin="0,8,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,24">

                <!-- ── HEADER ─────────────────────────────────────────────────── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20,18C21.1,18 22,17.1 22,16V6C22,4.89 21.1,4 20,4H4A2,2 0 0,0 2,6V16A2,2 0 0,0 4,18H0V20H24V18H20M4,6H20V16H4V6Z"
                                  Fill="{DynamicResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Tela" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource DefaultTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Central de controle avançado de display — muito além do painel do Windows"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="32,4,0,0"/>
                    </StackPanel>
                    <!-- Status + Monitor selector -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox ItemsSource="{Binding Monitors}"
                                  SelectedItem="{Binding SelectedMonitor}"
                                  DisplayMemberPath="Name"
                                  MinWidth="180" Margin="0,0,10,0"
                                  ToolTip="Selecione o monitor a controlar"
                                  Style="{DynamicResource ModernComboBoxStyle}"/>
                        <Border CornerRadius="8" Padding="10,6" Background="#1A000000" BorderThickness="1"
                                BorderBrush="{Binding StatusColor, Converter={StaticResource HexBrush}}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0"
                                         Fill="{Binding StatusColor, Converter={StaticResource HexBrush}}"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ── MÉTRICAS EM TEMPO REAL ─────────────────────────────────── -->
                <Border Style="{StaticResource DCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"
                                      Fill="#00FF88" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Métricas em Tempo Real" Style="{StaticResource STitle}" Margin="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="▶  Iniciar" Command="{Binding StartMonitoringCommand}"
                                        Style="{StaticResource ApplyBtn}" Margin="0,0,8,0"
                                        ToolTip="Inicia monitoramento contínuo das métricas de display (atualiza a cada 2s)"/>
                                <Button Content="⏹  Parar" Command="{Binding StopMonitoringCommand}"
                                        Padding="16,8" Cursor="Hand" FontSize="12"
                                        ToolTip="Para o monitoramento em tempo real">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#1AFF4466"/>
                                            <Setter Property="BorderBrush" Value="#30FF4466"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Foreground" Value="#FF4466"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background" Value="#25FF4466"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="4" Margin="0,0,0,4">
                            <!-- Hz Real -->
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentHz, StringFormat={}{0:F0} Hz}"
                                               Style="{StaticResource MetricVal}"
                                               Foreground="{DynamicResource PrimaryBrush}"/>
                                    <TextBlock Text="Taxa de Atualização Real" Style="{StaticResource MetricLbl}"/>
                                    <TextBlock Text="Frequência atual do monitor" FontSize="9"
                                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Input Lag -->
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding EstimatedInputLagMs, StringFormat={}{0:F2} ms}"
                                               Style="{StaticResource MetricVal}"
                                               Foreground="{Binding InputLagColor, Converter={StaticResource HexBrush}}"/>
                                    <TextBlock Text="Input Lag Estimado" Style="{StaticResource MetricLbl}"/>
                                    <TextBlock Text="Latência por frame (1000/Hz)" FontSize="9"
                                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Tearing -->
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock FontSize="22" FontWeight="Bold"
                                               Text="{Binding TearingDetected}"
                                               Foreground="{Binding TearingColor, Converter={StaticResource HexBrush}}"/>
                                    <TextBlock Text="Tearing" Style="{StaticResource MetricLbl}"/>
                                    <TextBlock Text="Baseado no estado do DWM" FontSize="9"
                                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Frame Pacing -->
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="{Binding FramePacingMs, StringFormat={}{0:F2} ms}"
                                               Style="{StaticResource MetricVal}"
                                               Foreground="{Binding StutterColor, Converter={StaticResource HexBrush}}"/>
                                    <TextBlock Text="Frame Pacing" Style="{StaticResource MetricLbl}"/>
                                    <TextBlock Text="Variação entre frames" FontSize="9"
                                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ── CONTROLE AVANÇADO: Hz + Resolução ──────────────────────── -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Taxa de Atualização -->
                    <Border Grid.Column="0" Style="{StaticResource DCard}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M16.2,16.2L11,13V7H12.5V12.2L17,14.9L16.2,16.2Z"
                                      Fill="#31A8FF" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Taxa de Atualização" Style="{StaticResource STitle}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Text="Selecione a taxa de atualização suportada pelo monitor:"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,10"/>
                            <ComboBox ItemsSource="{Binding AvailableHz}"
                                      SelectedItem="{Binding SelectedHz}"
                                      Margin="0,0,0,12"
                                      ToolTip="Taxas de atualização suportadas pelo monitor selecionado"
                                      Style="{DynamicResource ModernComboBoxStyle}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat={}{0} Hz}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Content="⚡  Aplicar Taxa de Atualização"
                                    Command="{Binding ApplyRefreshRateCommand}"
                                    Style="{StaticResource ApplyBtn}"
                                    ToolTip="Aplica a taxa de atualização selecionada via ChangeDisplaySettingsEx"/>
                            <TextBlock Text="⚠ Taxas não suportadas serão rejeitadas automaticamente."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Resolução -->
                    <Border Grid.Column="2" Style="{StaticResource DCard}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="M1,1H23V17H13V19H15V21H9V19H11V17H1V1M3,3V15H21V3H3Z"
                                      Fill="#8B31FF" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Resolução" Style="{StaticResource STitle}" Margin="0"/>
                            </StackPanel>
                            <TextBlock Text="Selecione a resolução desejada:"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,10"/>
                            <ComboBox ItemsSource="{Binding AvailableResolutions}"
                                      SelectedItem="{Binding SelectedResolution}"
                                      Margin="0,0,0,12"
                                      ToolTip="Resoluções suportadas pelo monitor selecionado"
                                      Style="{DynamicResource ModernComboBoxStyle}"/>
                            <Button Content="🖥  Aplicar Resolução"
                                    Command="{Binding ApplyResolutionCommand}"
                                    Style="{StaticResource ApplyBtn}"
                                    ToolTip="Aplica a resolução selecionada via ChangeDisplaySettingsEx"/>
                            <TextBlock Text="💡 Resoluções personalizadas podem ser adicionadas via drivers da GPU."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── VSync + Gamma ───────────────────────────────────────────── -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- VSync -->
                    <Border Grid.Column="0" Style="{StaticResource DCard}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z"
                                      Fill="#00FF88" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Sincronização Vertical (VSync)" Style="{StaticResource STitle}" Margin="0"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="VSync via DWM" Foreground="{DynamicResource DefaultTextBrush}"
                                               FontSize="12" FontWeight="SemiBold"
                                               ToolTip="Controla o VSync através do DWM (Desktop Window Manager)"/>
                                    <TextBlock Text="Elimina tearing — pode aumentar input lag em jogos"
                                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,3,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding VSyncEnabled}" VerticalAlignment="Center"
                                          Style="{StaticResource PremiumCheckBoxStyle}"/>
                            </Grid>
                            <TextBlock Text="💡 Para jogos, prefira VSync nas configurações do jogo ou via painel da GPU."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Gamma -->
                    <Border Grid.Column="2" Style="{StaticResource DCard}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Path Data="M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z"
                                      Fill="#FFAA00" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Gamma / Brilho" Style="{StaticResource STitle}" Margin="0"/>
                            </StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Slider Minimum="0.5" Maximum="2.5" Value="{Binding GammaValue}"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"
                                        ToolTip="Ajuste de gamma via Windows Color System (0.5 = escuro, 2.5 = claro)"
                                        />
                                <TextBlock Grid.Column="1" Text="{Binding GammaValue, StringFormat={}{0:F1}}"
                                           Foreground="{DynamicResource DefaultTextBrush}"
                                           FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <Button Content="🌟  Aplicar Gamma"
                                    Command="{Binding ApplyGammaCommand}"
                                    Style="{StaticResource ApplyBtn}"
                                    ToolTip="Aplica o valor de gamma via Windows Color System"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── FERRAMENTAS DE TESTE ───────────────────────────────────── -->
                <Border Style="{StaticResource DCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Path Data="M14.5,2.5C14.5,3.88 12,7 12,7C12,7 9.5,3.88 9.5,2.5A2.5,2.5 0 0,1 12,0A2.5,2.5 0 0,1 14.5,2.5M12,8C13.1,8 14,8.9 14,10C14,11.1 13.1,12 12,12C10.9,12 10,11.1 10,10C10,8.9 10.9,8 12,8M21,10C21,14.42 17.5,18.07 12.97,18.5L14,22H10L11.03,18.5C6.5,18.07 3,14.42 3,10A9,9 0 0,1 12,1A9,9 0 0,1 21,10Z"
                                  Fill="#FF4B6B" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Ferramentas de Diagnóstico" Style="{StaticResource STitle}" Margin="0"/>
                        </StackPanel>
                        <TextBlock Text="Execute testes visuais para diagnosticar problemas de display:"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,14"/>

                        <UniformGrid Columns="3" Margin="0,0,0,14">
                            <!-- Ghosting -->
                            <Border Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1"
                                    CornerRadius="12" Padding="16,14" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="👻" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Teste de Ghosting" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"
                                               Foreground="{DynamicResource DefaultTextBrush}"/>
                                    <TextBlock Text="Detecta rastros em movimento rápido via análise de frame pacing"
                                               FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <Button Content="Executar Teste"
                                            Command="{Binding RunGhostingTestCommand}"
                                            IsEnabled="{Binding IsTestRunning, Converter={StaticResource InverseBool}}"
                                            Style="{StaticResource ApplyBtn}" HorizontalAlignment="Center"
                                            ToolTip="Analisa frame pacing para detectar risco de ghosting"/>
                                </StackPanel>
                            </Border>
                            <!-- Tearing -->
                            <Border Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1"
                                    CornerRadius="12" Padding="16,14" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="⚡" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Teste de Tearing" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"
                                               Foreground="{DynamicResource DefaultTextBrush}"/>
                                    <TextBlock Text="Verifica se o DWM Composition está ativo e detecta tearing de tela"
                                               FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <Button Content="Executar Teste"
                                            Command="{Binding RunTearingTestCommand}"
                                            IsEnabled="{Binding IsTestRunning, Converter={StaticResource InverseBool}}"
                                            Style="{StaticResource ApplyBtn}" HorizontalAlignment="Center"
                                            ToolTip="Verifica estado do DWM para detectar tearing"/>
                                </StackPanel>
                            </Border>
                            <!-- Input Lag -->
                            <Border Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1"
                                    CornerRadius="12" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="🎯" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Teste de Input Lag" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"
                                               Foreground="{DynamicResource DefaultTextBrush}"/>
                                    <TextBlock Text="Estima o input lag baseado na taxa de atualização atual do monitor"
                                               FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <Button Content="Executar Teste"
                                            Command="{Binding RunInputLagTestCommand}"
                                            IsEnabled="{Binding IsTestRunning, Converter={StaticResource InverseBool}}"
                                            Style="{StaticResource ApplyBtn}" HorizontalAlignment="Center"
                                            ToolTip="Mede input lag estimado baseado em Hz atual"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Resultado do teste -->
                        <Border Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1"
                                CornerRadius="10" Padding="14,10"
                                Visibility="{Binding IsTestRunning, Converter={StaticResource BoolVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏳" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding TestResult}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1"
                                CornerRadius="10" Padding="14,10" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0"
                                         Fill="{Binding TestResultColor, Converter={StaticResource HexBrush}}"/>
                                <TextBlock Text="{Binding TestResult}" FontSize="12"
                                           Foreground="{Binding TestResultColor, Converter={StaticResource HexBrush}}"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── RESTAURAR PADRÕES ───────────────────────────────────────── -->
                <Border Style="{StaticResource DCard}" Margin="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Restaurar Configurações de Display" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource DefaultTextBrush}"/>
                            <TextBlock Text="Reverte resolução e taxa de atualização para os valores do registro do Windows"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="↩  Restaurar Padrões"
                                Command="{Binding RestoreDefaultsCommand}"
                                Cursor="Hand" Padding="16,9" FontSize="12"
                                ToolTip="Restaura as configurações de display para os valores salvos no registro">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1AFF4466"/>
                                    <Setter Property="BorderBrush" Value="#30FF4466"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="#FF4466"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#25FF4466"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
