<Window x:Class="VoltrisOptimizer.UI.Views.BenchmarkTutorialPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Benchmark — Guia Completo"
        Width="780" Height="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="600" MinHeight="500"
        Background="{DynamicResource DarkBrush}">

    <Window.Resources>
        <!-- Card Style -->
        <Style x:Key="TutorialCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- Section Title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Body Text -->
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <!-- Metric Badge -->
        <Style x:Key="MetricBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="350" Height="350"
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-100,-120,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="90"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,36">

                <!-- ======== HEADER ======== -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B31FF" Offset="0"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="M14,2H6C4.9,2,4,2.9,4,4v16c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V8L14,2z M16,18H8v-2h8V18z M16,14H8v-2h8V14z M13,9V3.5L18.5,9H13z" Fill="White" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Benchmark — Guia Completo"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Aprenda a utilizar o sistema de benchmark para analisar e melhorar o desempenho do seu PC."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Separator Background="#15FFFFFF" Margin="0,14,0,18"/>

                <!-- ======== 1. O QUE É O BENCHMARK ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#2531A8FF" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M15.5,12C18,12 20,14 20,16.5C20,17.38 19.75,18.21 19.31,18.9L22.39,22L21,23.39L17.88,20.32C17.19,20.75 16.37,21 15.5,21C13,21 11,19 11,16.5C11,14 13,12 15.5,12M15.5,14A2.5,2.5 0 0,0 13,16.5A2.5,2.5 0 0,0 15.5,19A2.5,2.5 0 0,0 18,16.5A2.5,2.5 0 0,0 15.5,14M5,3H19C20.1,3 21,3.9 21,5V14.03C20.5,13.22 19.8,12.54 19,12.03V5H5V19H9.5C9.81,19.75 10.26,20.42 10.81,21H5C3.9,21 3,20.1 3,19V5C3,3.9 3.9,3 5,3M7,7H17V9H7V7M7,11H12.03C11.23,11.5 10.54,12.2 10.03,13H7V11M7,15H9.17C9.06,15.5 9,16 9,16.5V17H7V15Z" Fill="#31A8FF" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="O que é o Benchmark?" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            O Benchmark é uma ferramenta de análise que mede o desempenho real do seu computador em diversas áreas: processador (CPU), memória RAM, disco (SSD/HDD) e responsividade do sistema operacional.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0">
                            Diferente de benchmarks genéricos, o Voltris mede métricas que impactam diretamente a sua experiência: velocidade de abertura de programas, fluidez da interface e latência do agendador de tarefas do Windows.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0">
                            O objetivo principal é permitir que você veja, com números reais, o impacto das otimizações aplicadas pelo Voltris no seu sistema.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== 2. BENCHMARK INICIAL ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#2531A8FF" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12H8A4,4 0 0,1 12,8V6M12,10L15.5,15.5" Fill="#31A8FF" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Como executar o Benchmark Inicial" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            O Benchmark Inicial captura uma "foto" do desempenho atual do seu sistema, antes de qualquer otimização. Ele serve como linha de base para comparação futura.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,0" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            Quando executar:
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,4,0,0">
                            • Logo após instalar o Voltris, antes de aplicar otimizações
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Após reinstalar o Windows ou atualizar drivers
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Sempre que quiser ter um ponto de referência atualizado
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,0" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            O que acontece durante o teste:
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,4,0,0">
                            O sistema executa uma série de testes automatizados que duram aproximadamente 30 a 60 segundos. Durante esse período, o processador, memória e disco são testados com cargas controladas para medir a capacidade real de cada componente.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== 3. OTIMIZAÇÕES ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#25EAB308" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M7,2v11h3v9l7-12h-4l4-8H7z" Fill="#EAB308" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Aplicação de Otimizações" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            Após o Benchmark Inicial, você pode aplicar as otimizações do Voltris através das páginas de Performance, Modo Gamer ou Benchmark Completo.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0">
                            As otimizações ajustam configurações do Windows como prioridades de CPU, gerenciamento de memória, agendamento de tarefas e configurações de energia para extrair o máximo desempenho do seu hardware.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0">
                            O Benchmark Final serve justamente para medir o impacto dessas otimizações com dados concretos.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== 4. BENCHMARK FINAL ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#258B31FF" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,19c-3.87,0-7-3.13-7-7c0-3.87,3.13-7,7-7s7,3.13,7,7C19,15.87,15.87,19,12,19z M13,7h-2v5.41l4.29,4.29l1.41-1.41L13,11.59V7z" Fill="#8B31FF" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Benchmark Final" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            O Benchmark Final executa exatamente os mesmos testes do Benchmark Inicial, mas agora com as otimizações ativas. Isso garante uma comparação justa e precisa.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0">
                            Execute-o após aplicar otimizações e aguardar pelo menos 15 segundos para o sistema estabilizar. O botão "Benchmark Completo" faz tudo isso automaticamente.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== 5. COMPARAÇÃO ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#25FF4B6B" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M9,3L5,6.99H8V14H10V6.99H13L9,3M16,17.01V10H14V17.01H11L15,21L19,17.01H16Z" Fill="#FF4B6B" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Comparação de Resultados" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            Após executar ambos os benchmarks, clique em "Comparar" para ver uma tabela detalhada com os valores antes e depois de cada métrica.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,0" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            Como interpretar os resultados:
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,4,0,0">
                            • Valores em verde indicam melhoria de desempenho
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Valores em vermelho indicam redução (raro, pode ocorrer por variação natural)
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Percentuais acima de +5% representam ganhos significativos
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Variações de ±2% são normais e esperadas entre execuções
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== 6. SCORE ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#25FF4B6B" Offset="0"/>
                                        <GradientStop Color="#25EAB308" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="M5,16L3,5L8.5,10L12,4L15.5,10L21,5L19,16H5M19,19A1,1 0 0,1 18,20H6A1,1 0 0,1 5,19V18H19V19Z" Fill="#EAB308" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Score do Sistema" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            O Score Global é uma nota ponderada que combina todas as métricas em um único número de 0 a 100. Ele é calculado com os seguintes pesos:
                        </TextBlock>

                        <!-- Score weights grid -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource MetricBadge}" Background="#15FF4B6B">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CPU" FontSize="12" FontWeight="SemiBold" Foreground="#FF4B6B" HorizontalAlignment="Center"/>
                                    <TextBlock Text="35%" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource MetricBadge}" Background="#158B31FF">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Memória" FontSize="12" FontWeight="SemiBold" Foreground="#8B31FF" HorizontalAlignment="Center"/>
                                    <TextBlock Text="20%" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource MetricBadge}" Background="#1531A8FF">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Disco" FontSize="12" FontWeight="SemiBold" Foreground="#31A8FF" HorizontalAlignment="Center"/>
                                    <TextBlock Text="25%" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource MetricBadge}" Background="#1510B981">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Scheduler" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                    <TextBlock Text="10%" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource MetricBadge}" Background="#15EAB308">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="UI" FontSize="12" FontWeight="SemiBold" Foreground="#EAB308" HorizontalAlignment="Center"/>
                                    <TextBlock Text="10%" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Style="{StaticResource BodyText}" Margin="0,12,0,0">
                            Um score acima de 75 indica um sistema com bom desempenho. Acima de 85 é excelente. Abaixo de 50 sugere que otimizações podem trazer melhorias significativas.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== 7. MÉTRICAS ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Background="#2510B981" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Path Data="M3,3h18c1.1,0,2,0.9,2,2v14c0,1.1-0.9,2-2,2H3c-1.1,0-2-0.9-2-2V5C1,3.9,1.9,3,3,3z M12,7c-2.76,0-5,2.24-5,5s2.24,5,5,5s5-2.24,5-5S14.76,7,12,7z M12,15c-1.66,0-3-1.34-3-3s1.34-3,3-3s3,1.34,3,3S13.66,15,12,15z" Fill="#10B981" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Métricas Analisadas" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>

                        <Border Background="#10FF4B6B" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="CPU Performance" FontSize="13" FontWeight="SemiBold" Foreground="#FF4B6B"/>
                                <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0">
                                    Mede a capacidade de processamento com operações matemáticas intensivas (ponto flutuante, inteiros, hashing SHA-256). Testa single-thread e multi-thread.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#108B31FF" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Memory Performance" FontSize="13" FontWeight="SemiBold" Foreground="#8B31FF"/>
                                <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0">
                                    Avalia a velocidade de leitura/escrita da memória RAM, latência de acesso e throughput com padrões sequenciais e aleatórios.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#1031A8FF" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Disk Performance" FontSize="13" FontWeight="SemiBold" Foreground="#31A8FF"/>
                                <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0">
                                    Testa a velocidade de leitura e escrita do disco (SSD ou HDD) com operações sequenciais e aleatórias de 4KB, simulando uso real do sistema.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#1010B981" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Scheduler Latency" FontSize="13" FontWeight="SemiBold" Foreground="#10B981"/>
                                <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0">
                                    Mede a latência do agendador de tarefas do Windows — quanto tempo o sistema leva para alternar entre processos. Valores baixos significam maior fluidez.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#10EAB308" CornerRadius="8" Padding="14,10" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="UI Responsiveness" FontSize="13" FontWeight="SemiBold" Foreground="#EAB308"/>
                                <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0">
                                    Avalia a responsividade da interface gráfica — tempo de resposta do Dispatcher do WPF e fluidez geral da interação com o sistema.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ======== 8. BENCHMARK COMPLETO ======== -->
                <Border Style="{StaticResource TutorialCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#258B31FF" Offset="0"/>
                                        <GradientStop Color="#2531A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="M7,2v11h3v9l7-12h-4l4-8H7z" Fill="White" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Benchmark Completo (Automático)" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            O botão "Benchmark Completo" executa todo o fluxo automaticamente em 4 fases:
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,8,0,0">
                            1. Executa o Benchmark Inicial (linha de base)
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            2. Aplica as otimizações recomendadas do Voltris
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            3. Aguarda 15 segundos para estabilização do sistema
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            4. Executa o Benchmark Final e gera a comparação
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,0">
                            Esta é a forma mais prática de ver o impacto das otimizações com um único clique.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== 9. BOAS PRÁTICAS ======== -->
                <Border Margin="0,0,0,14" CornerRadius="12" Padding="20,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#15EAB308" Offset="0"/>
                            <GradientStop Color="#1531A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#30EAB308" Offset="0"/>
                            <GradientStop Color="#3031A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#25EAB308" Offset="0"/>
                                        <GradientStop Color="#2531A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="M12,2A7,7 0 0,1 19,9C19,11.38 17.81,13.47 16,14.74V17A1,1 0 0,1 15,18H9A1,1 0 0,1 8,17V14.74C6.19,13.47 5,11.38 5,9A7,7 0 0,1 12,2M9,21V20H15V21A1,1 0 0,1 14,22H10A1,1 0 0,1 9,21M12,4A5,5 0 0,0 7,9C7,11.05 8.23,12.81 10,13.58V16H14V13.58C15.77,12.81 17,11.05 17,9A5,5 0 0,0 12,4Z" Fill="#EAB308" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Boas Práticas" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}">
                            Para obter resultados mais precisos e consistentes:
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,8,0,0">
                            • Feche programas pesados (navegadores, jogos, editores de vídeo) antes de iniciar
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Não utilize o computador durante a execução do benchmark
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Mantenha o notebook conectado à tomada (modo bateria reduz desempenho)
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Execute o benchmark 2 a 3 vezes e considere a média para maior precisão
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Aguarde pelo menos 2 minutos após ligar o PC para que serviços de fundo estabilizem
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="12,2,0,0">
                            • Se o sistema detectar thermal throttling, aguarde o PC esfriar antes de repetir
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ======== BOTÃO FECHAR ======== -->
                <Button x:Name="BtnClose" Click="BtnClose_Click" HorizontalAlignment="Center"
                        Cursor="Hand" Margin="0,4,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" CornerRadius="10" Padding="32,10"
                                                Background="#1531A8FF" BorderBrush="#3031A8FF" BorderThickness="1">
                                            <TextBlock Text="Entendi, voltar ao Benchmark" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#2531A8FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
