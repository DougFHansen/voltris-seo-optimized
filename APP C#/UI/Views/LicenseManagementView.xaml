<UserControl x:Class="VoltrisOptimizer.UI.Views.LicenseManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="620" d:DesignWidth="900"
             FontFamily="Segoe UI, Inter, Sans-Serif"
             UseLayoutRounding="True" SnapsToDevicePixels="True">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#181825"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A6A6C0"/>
        <SolidColorBrush x:Key="CheckColor" Color="#31FF6B"/>

        <!-- Estilos Globais -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="ValueStyle">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ModernIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3E3E5E"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="12" SnapsToDevicePixels="True">
                             <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#35354F"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#7F30FF"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#7F30FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E1E2E"/>
                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DestructiveButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernIconButtonStyle}">
            <Setter Property="BorderBrush" Value="#3E2020"/>
            <Setter Property="Background" Value="#2A1515"/>
            <Style.Triggers>
                 <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3F1A1A"/>
                    <Setter Property="BorderBrush" Value="#FF4B6B"/>
                    <Setter Property="Foreground" Value="#FF4B6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="#333344" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- TITLE BAR / CLOSE BUTTON -->
            <Grid Grid.Row="0" Panel.ZIndex="999" Margin="0,16,16,0" VerticalAlignment="Top" HorizontalAlignment="Right">
                <Button Click="CloseWindow_Click" 
                        Width="32" Height="32" 
                        Background="Transparent" BorderThickness="0" 
                        Cursor="Hand" ToolTip="Fechar">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="16">
                                <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                                      Fill="#AAFFFFFF" Stretch="Uniform" Margin="8"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- MODERN HEADER -->
            <Border Grid.Row="0" Margin="24,24,24,12" CornerRadius="16" Height="140">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0" RadiusX="1" RadiusY="1">
                        <GradientStop Color="#160826" Offset="0"/>
                        <GradientStop Color="#0F0F16" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#30FFFFFF" Offset="0"/>
                        <GradientStop Color="#05FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="10" Opacity="0.6"/>
                </Border.Effect>
                
                <Grid Margin="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status Icon -->
                    <Grid Width="72" Height="72" Margin="0,0,24,0">
                        <Ellipse Fill="#152E20">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#31FF6B" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <Viewbox Width="32" Height="32">
                            <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" 
                                  Fill="{StaticResource CheckColor}"/>
                        </Viewbox>
                    </Grid>

                    <!-- Title and Details -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Licença Ativa e Protegida" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#2A1545" CornerRadius="6" Padding="10,4" Margin="0,0,12,0" BorderBrush="#3D1E66" BorderThickness="1">
                                <TextBlock x:Name="HeaderPlanText" Text="ENTERPRISE" FontSize="12" FontWeight="Bold" Foreground="#B080FF" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="HeaderExpiryText" Text="Válido até 25/12/2030" FontSize="14" Foreground="#A0A0B0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Verified Badge -->
                    <Border Grid.Column="2" Background="#102518" BorderBrush="#1E5230" BorderThickness="1" CornerRadius="8" Padding="16,8" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,11.99H7V10.99H12V11.99M17,10.99C17,10.99 17,10.99 17,10.99H13V11.99H17V10.99Z" 
                                  Fill="#31FF6B" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="VERIFICADO" FontSize="13" FontWeight="Bold" Foreground="#31FF6B" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" Margin="24,0,24,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: DETAILS -->
                <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="16" Padding="32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Detalhes da Licença" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,32"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1 -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="CHAVE DO PRODUTO" Style="{StaticResource LabelStyle}"/>
                                <Grid Margin="0,0,24,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LicenseKeyText" Text="VOLTRIS-ENT-XXXX..." 
                                             IsReadOnly="True" Background="#121216" BorderThickness="0" Foreground="#A0A0B0" 
                                             Padding="12,10" VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="13">
                                        <TextBox.Template>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                </Border>
                                            </ControlTemplate>
                                        </TextBox.Template>
                                    </TextBox>
                                    <Button Grid.Column="1" Style="{StaticResource ModernIconButtonStyle}" 
                                            Click="CopyLicenseKey_Click"
                                            Padding="10" Margin="8,0,0,0" ToolTip="Copiar">
                                        <Viewbox Width="14" Height="14">
                                            <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" 
                                                  Fill="White"/>
                                        </Viewbox>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock Text="STATUS" Style="{StaticResource LabelStyle}"/>
                                <TextBlock x:Name="StatusText" Text="Ativo" Style="{StaticResource ValueStyle}" Foreground="#31FF6B" FontSize="16"/>
                            </StackPanel>

                            <!-- Row 2 -->
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="PLANO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock x:Name="PlanTypeText" Text="Enterprise" Style="{StaticResource ValueStyle}" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="VALIDADE" Style="{StaticResource LabelStyle}"/>
                                <TextBlock x:Name="ExpiryDateText" Text="Vitalício" Style="{StaticResource ValueStyle}" FontSize="16"/>
                            </StackPanel>

                            <!-- Row 3 -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="DISPOSITIVOS" Style="{StaticResource LabelStyle}"/>
                                <TextBlock x:Name="DevicesText" Text="Ilimitado" Style="{StaticResource ValueStyle}" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="DATA DE ATIVAÇÃO" Style="{StaticResource LabelStyle}"/>
                                <TextBlock x:Name="ActivationDateText" Text="01/01/2026" Style="{StaticResource ValueStyle}" FontSize="16"/>
                            </StackPanel>
                            
                            <!-- Row 4 -->
                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                <TextBlock Text="DEVICE ID (Hardware)" Style="{StaticResource LabelStyle}"/>
                                <TextBlock x:Name="DeviceIdText" Text="XXXX-XXXX-XXXX-XXXX" FontFamily="Consolas" Foreground="#505060" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- RIGHT: ACTIONS -->
                <Border Grid.Column="2" Padding="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Ações Rápidas" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>

                        <Button Click="ChangeLicense_Click" Style="{StaticResource ModernIconButtonStyle}" Margin="0,0,0,16">
                             <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,12,0">
                                    <Path Data="M12,6V9L16,5L12,1V4A8,8 0 0,0 4,12C4,13.57 4.46,15.03 5.24,16.26L6.7,14.8C6.25,13.97 6,13 6,12A6,6 0 0,1 12,6M18.76,7.74L17.3,9.2C17.74,10.04 18,11 18,12A6,6 0 0,1 12,18V15L8,19L12,23V20A8,8 0 0,0 20,12C20,10.43 19.54,8.97 18.76,7.74Z" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Viewbox>
                                <TextBlock Text="Trocar Licença" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Click="BuyLicense_Click" Style="{StaticResource ModernIconButtonStyle}" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,12,0">
                                    <Path Data="M11,9H13V6H16V4H13V1H11V4H8V6H11M7,18A2,2 0 0,0 9,20A2,2 0 0,0 11,18A2,2 0 0,0 9,16A2,2 0 0,0 7,18M17,18A2,2 0 0,0 19,20A2,2 0 0,0 21,18A2,2 0 0,0 19,16A2,2 0 0,0 17,18M7.17,14.75L7.2,14.63L8.1,13H15.55C16.3,13 16.96,12.59 17.3,11.97L21.16,4.96L19.42,4H19.41L18.31,6L15.55,11H8.53L8.4,10.73L6.16,6L5.21,4L4.27,2H1V4H3L6.6,11.59L5.25,14.03C5.09,14.32 5,14.65 5,15A2,2 0 0,0 7,17H19V15H7.42C7.29,15 7.17,14.89 7.17,14.75Z" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Viewbox>
                                <TextBlock Text="Comprar Nova Licença" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Click="Support_Click" Style="{StaticResource ModernIconButtonStyle}" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,12,0">
                                    <Path Data="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.11,4 20,4Z" 
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Viewbox>
                                <TextBlock Text="Suporte Premium" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Separator Opacity="0.1" Background="White" Margin="0,16,0,24"/>

                        <Button Click="DeactivateLicense_Click" Style="{StaticResource DestructiveButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,12,0">
                                    <Path Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M9,8H11V17H9V8M13,8H15V17H13V8Z" 
                                          Fill="#FF4B6B"/>
                                </Viewbox>
                                <TextBlock Text="Desativar Licença" Foreground="#FF4B6B" FontSize="14"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
