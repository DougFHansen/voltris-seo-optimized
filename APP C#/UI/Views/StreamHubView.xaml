<UserControl x:Class="VoltrisOptimizer.UI.Views.StreamHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             Background="{DynamicResource DarkBrush}">
    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="StreamHubVM"/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="HubCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderGradientBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.18" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="PlatformDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ChatBubbleStyle" TargetType="Border">
            <Setter Property="Background" Value="#0DFFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="AlertCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="HubActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>
    </UserControl.Resources>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="500" Height="500" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-200,0" Opacity="0.4">
                <Ellipse.Fill><RadialGradientBrush>
                    <GradientStop Color="#9146FF" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush></Ellipse.Fill>
                <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100" Opacity="0.3">
                <Ellipse.Fill><RadialGradientBrush>
                    <GradientStop Color="#FF4B6B" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush></Ellipse.Fill>
                <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
            </Ellipse>
        </Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,16,24,24">
                <!-- ═══ CABEÇALHO ═══ -->
                <StackPanel Margin="0,0,0,20" HorizontalAlignment="Center">
                    <Border Width="56" Height="56" CornerRadius="14" Margin="0,0,0,12" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#9146FF" Offset="0"/>
                                <GradientStop Color="#FF4B6B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#9146FF" Opacity="0.5"/>
                        </Border.Effect>
                        <!-- Ícone de streaming (antena/sinal) -->
                        <Path Data="M12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12A2,2 0 0,1 12,10M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2Z"
                              Fill="White" Width="28" Height="28" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Stream Hub" FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="28" FontWeight="Bold" HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#9146FF" Offset="0"/>
                                <GradientStop Color="#FF4B6B" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Copiloto inteligente para streamers" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- ═══ ALERTA CRÍTICO (topo) ═══ -->
                <Border Visibility="{Binding HasCriticalAlert, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,12" Padding="14,10" CornerRadius="10" BorderThickness="1"
                        BorderBrush="#40FF4466">
                    <Border.Background>
                        <SolidColorBrush Color="#FF441111" Opacity="0.9"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="Red" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⛔" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ALERTA CRÍTICO DETECTADO" FontSize="11" FontWeight="Bold" Foreground="#FF4466"/>
                            <TextBlock Text="{Binding ActiveAlerts[0].Message}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- ═══ CONTROLES PRINCIPAIS ═══ -->
                <Border Style="{StaticResource HubCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding LiveStatusText}" FontSize="22" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding LiveStatusColor}"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding StreamDuration, StringFormat='Duração: {0}'}"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,0"
                                       Visibility="{Binding IsLive, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding StartCommand}" Style="{StaticResource HubActionButtonStyle}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                                    Margin="0,0,8,0">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#9146FF" Offset="0"/>
                                        <GradientStop Color="#FF4B6B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="INICIAR HUB" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding StopCommand}" Style="{StaticResource HubActionButtonStyle}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                                <Button.Background>
                                    <SolidColorBrush Color="#EF4444"/>
                                </Button.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="■" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="PARAR" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- ═══ MÉTRICAS EM TEMPO REAL ═══ -->
                <Border Style="{StaticResource HubCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Border.Background><SolidColorBrush Color="#31A8FF" Opacity="0.2"/></Border.Background>
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12H8A4,4 0 0,1 12,8V6"
                                      Fill="#31A8FF" Width="16" Height="16" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Monitoramento em Tempo Real" Style="{StaticResource SectionTitleStyle}" Margin="0" VerticalAlignment="Center"/>
                            <!-- Health Score Badge -->
                            <Border Margin="12,0,0,0" Padding="8,3" CornerRadius="12" VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding HealthScoreColor}"/>
                                </Border.Background>
                                <TextBlock Text="{Binding HealthScoreText}" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                            </Border>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Bitrate -->
                            <Border Grid.Column="0" Background="#0DFFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="BITRATE" Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding BitrateText}" Style="{StaticResource MetricValueStyle}">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding BitrateColor}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- Dropped Frames -->
                            <Border Grid.Column="1" Background="#0DFFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="FRAMES PERDIDOS" Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding DroppedFramesText}" Style="{StaticResource MetricValueStyle}">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding DroppedFramesColor}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- CPU -->
                            <Border Grid.Column="2" Background="#0DFFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="CPU" Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding CpuUsageText}" Style="{StaticResource MetricValueStyle}">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding CpuUsageColor}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <!-- Mic -->
                            <Border Grid.Column="3" Background="#0DFFFFFF" CornerRadius="10" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="MICROFONE" Style="{StaticResource MetricLabelStyle}"/>
                                    <TextBlock Text="{Binding MicStatusText}" FontSize="16" FontWeight="Bold">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding MicStatusColor}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- Cena Ativa + FPS -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎬 Cena: " FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ActiveScene}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="FPS: " FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Fps}" FontSize="12" FontWeight="Bold"
                                           Foreground="#00FF88" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- ═══ PLATAFORMAS ═══ -->
                <Border Style="{StaticResource HubCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Plataformas Conectadas" Style="{StaticResource SectionTitleStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- OBS -->
                            <Border Grid.Column="0" Background="#0DFFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Ellipse Style="{StaticResource PlatformDotStyle}">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding ObsStatusColor}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="OBS Studio" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ObsStatusText}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <Button Command="{Binding ConnectObsCommand}" Margin="0,8,0,0"
                                            Style="{StaticResource HubActionButtonStyle}" Height="30" FontSize="11"
                                            Visibility="{Binding ObsConnected, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                        <Button.Background><SolidColorBrush Color="#1A1A2E"/></Button.Background>
                                        <TextBlock Text="Conectar OBS"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                            <!-- Twitch -->
                            <Border Grid.Column="1" Background="#0DFFFFFF" CornerRadius="10" Padding="12,10" Margin="0,0,6,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Ellipse Style="{StaticResource PlatformDotStyle}" Fill="#9146FF"/>
                                        <TextBlock Text="Twitch" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TwitchStatusText}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <Button Command="{Binding ConnectTwitchCommand}" Margin="0,8,0,0"
                                            Style="{StaticResource HubActionButtonStyle}" Height="30" FontSize="11"
                                            Visibility="{Binding TwitchConnected, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                        <Button.Background><SolidColorBrush Color="#9146FF" Opacity="0.3"/></Button.Background>
                                        <TextBlock Text="Conectar Twitch"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                            <!-- YouTube -->
                            <Border Grid.Column="2" Background="#0DFFFFFF" CornerRadius="10" Padding="12,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Ellipse Style="{StaticResource PlatformDotStyle}" Fill="#FF0000"/>
                                        <TextBlock Text="YouTube" FontSize="12" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding YouTubeStatusText}" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    <Button Command="{Binding ConnectYouTubeCommand}" Margin="0,8,0,0"
                                            Style="{StaticResource HubActionButtonStyle}" Height="30" FontSize="11"
                                            Visibility="{Binding YouTubeConnected, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                        <Button.Background><SolidColorBrush Color="#FF0000" Opacity="0.3"/></Button.Background>
                                        <TextBlock Text="Conectar YouTube"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
                <!-- ═══ LAYOUT INFERIOR: CHAT + ALERTAS + HIGHLIGHTS ═══ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>
                    <!-- CHAT UNIFICADO -->
                    <Border Grid.Column="0" Style="{StaticResource HubCardStyle}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="260"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="💬 Chat Unificado" Style="{StaticResource SectionTitleStyle}" Margin="0" VerticalAlignment="Center"/>
                                <Border Margin="10,0,0,0" Padding="6,2" CornerRadius="8" Background="#20FFFFFF" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalMessages, StringFormat='{}{0} msgs'}"
                                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                </Border>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="ChatScrollViewer">
                                <ItemsControl ItemsSource="{Binding ChatMessages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ChatBubbleStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Badge da plataforma -->
                                                    <Border Grid.Column="0" Width="20" Height="20" CornerRadius="4"
                                                            Margin="0,0,8,0" VerticalAlignment="Top">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{Binding UsernameColor}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding PlatformIcon}" FontSize="10"
                                                                   FontWeight="Bold" Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding BadgeEmoji}" FontSize="11" Margin="0,0,3,0"
                                                                       Visibility="{Binding BadgeEmoji, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="Bold">
                                                                <TextBlock.Foreground>
                                                                    <SolidColorBrush Color="{Binding UsernameColor}"/>
                                                                </TextBlock.Foreground>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Content}" FontSize="12"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <!-- PAINEL DIREITO: ALERTAS + HIGHLIGHTS + COPILOTO -->
                    <StackPanel Grid.Column="2">
                        <!-- ALERTAS -->
                        <Border Style="{StaticResource HubCardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="⚠️ Alertas" Style="{StaticResource SectionTitleStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="8" VerticalAlignment="Center"
                                            Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVis}}">
                                        <Border.Background><SolidColorBrush Color="#FF4466" Opacity="0.3"/></Border.Background>
                                        <TextBlock Text="{Binding ActiveAlerts.Count}" FontSize="11" FontWeight="Bold" Foreground="#FF4466"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Nenhum alerta ativo ✅" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Visibility="{Binding HasAlerts, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                <ItemsControl ItemsSource="{Binding ActiveAlerts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource AlertCardStyle}" Margin="0,0,0,6">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SeverityColor}" Opacity="0.1"/>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="{Binding SeverityColor}" Opacity="0.4"/>
                                                </Border.BorderBrush>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding SeverityIcon}" FontSize="13" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Bold">
                                                            <TextBlock.Foreground>
                                                                <SolidColorBrush Color="{Binding SeverityColor}"/>
                                                            </TextBlock.Foreground>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Message}" FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                    <TextBlock Text="{Binding SuggestedAction}" FontSize="10"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               TextWrapping="Wrap" Margin="0,3,0,0" FontStyle="Italic"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <!-- COPILOTO DE ENGAJAMENTO (DIFERENCIAL) -->
                        <Border Style="{StaticResource HubCardStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="28" Height="28" CornerRadius="7" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#9146FF" Offset="0"/>
                                                <GradientStop Color="#31A8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="🤖" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Copiloto" Style="{StaticResource SectionTitleStyle}" Margin="0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Nenhuma sugestão no momento" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Visibility="{Binding HasSuggestions, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>
                                <!-- Sugestão principal em destaque -->
                                <Border Visibility="{Binding HasSuggestions, Converter={StaticResource BoolToVis}}"
                                        Padding="12,10" CornerRadius="10" BorderThickness="1" Margin="0,0,0,6">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A9146FF" Offset="0"/>
                                            <GradientStop Color="#1A31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#9146FF" Opacity="0.4"/>
                                    </Border.BorderBrush>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding TopSuggestion.Icon}" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding TopSuggestion.Title}" FontSize="12" FontWeight="Bold"
                                                       Foreground="#9146FF"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding TopSuggestion.Message}" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <Button Command="{Binding DismissSuggestionCommand}"
                                                CommandParameter="{Binding TopSuggestion.Id}"
                                                Margin="0,8,0,0" Height="28" FontSize="11"
                                                Style="{StaticResource HubActionButtonStyle}">
                                            <Button.Background><SolidColorBrush Color="#20FFFFFF"/></Button.Background>
                                            <TextBlock Text="✓ Entendido"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        <!-- HIGHLIGHTS -->
                        <Border Style="{StaticResource HubCardStyle}" Margin="0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="✨ Highlights" Style="{StaticResource SectionTitleStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="8" Background="#20FFAA00" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding HighlightCount}" FontSize="11" FontWeight="Bold" Foreground="#FFAA00"/>
                                    </Border>
                                </StackPanel>
                                <Button Command="{Binding MarkHighlightCommand}" Margin="0,0,0,10"
                                        Style="{StaticResource HubActionButtonStyle}" Height="36">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFAA00" Offset="0"/>
                                            <GradientStop Color="#FF6B35" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📌" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="MARCAR HIGHLIGHT" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="Nenhum highlight ainda" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Visibility="{Binding HighlightCount, Converter={StaticResource BoolToVis}, ConverterParameter=Zero}"/>
                                <ItemsControl ItemsSource="{Binding Highlights}" MaxHeight="180">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0DFFFFFF" CornerRadius="8" Padding="10,6" Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding TriggerIcon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Description}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding StreamTimestamp, StringFormat='{}{0:hh\\:mm\\:ss}'}"
                                                               FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                <!-- ═══ CONFIGURAÇÕES ═══ -->
                <Border Style="{StaticResource HubCardStyle}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="⚙️ Configurações" Style="{StaticResource SectionTitleStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="OBS WebSocket URL" Style="{StaticResource MetricLabelStyle}"/>
                                <TextBox Text="{Binding Settings.ObsWebSocketUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#15FFFFFF" Foreground="White" BorderBrush="#30FFFFFF"
                                         Padding="8,6" Margin="0,4,0,10" FontSize="12"/>
                                <TextBlock Text="Canal Twitch" Style="{StaticResource MetricLabelStyle}"/>
                                <TextBox Text="{Binding Settings.TwitchChannelName, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#15FFFFFF" Foreground="White" BorderBrush="#30FFFFFF"
                                         Padding="8,6" Margin="0,4,0,10" FontSize="12"/>
                                <TextBlock Text="OAuth Token Twitch" Style="{StaticResource MetricLabelStyle}"/>
                                <PasswordBox x:Name="TwitchTokenBox" Background="#15FFFFFF" Foreground="White"
                                             BorderBrush="#30FFFFFF" Padding="8,6" Margin="0,4,0,0" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="YouTube API Key" Style="{StaticResource MetricLabelStyle}"/>
                                <TextBox Text="{Binding Settings.YouTubeApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#15FFFFFF" Foreground="White" BorderBrush="#30FFFFFF"
                                         Padding="8,6" Margin="0,4,0,10" FontSize="12"/>
                                <TextBlock Text="YouTube Live Chat ID" Style="{StaticResource MetricLabelStyle}"/>
                                <TextBox Text="{Binding Settings.YouTubeLiveChatId, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#15FFFFFF" Foreground="White" BorderBrush="#30FFFFFF"
                                         Padding="8,6" Margin="0,4,0,10" FontSize="12"/>
                                <TextBlock Text="Bitrate Mínimo (kbps)" Style="{StaticResource MetricLabelStyle}"/>
                                <TextBox Text="{Binding Settings.BitrateDropThresholdKbps, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#15FFFFFF" Foreground="White" BorderBrush="#30FFFFFF"
                                         Padding="8,6" Margin="0,4,0,0" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                        <Button Command="{Binding SaveSettingsCommand}" Margin="0,14,0,0"
                                Style="{StaticResource HubActionButtonStyle}" HorizontalAlignment="Right">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#9146FF" Offset="0"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="SALVAR CONFIGURAÇÕES" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
