<UserControl x:Class="VoltrisOptimizer.UI.Views.PrivacyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="900" d:DesignWidth="1100">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <Storyboard x:Key="EntryAnimation">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                        <PowerEase EasingMode="EaseOut" Power="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TranslateTransform/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" Fill="#0D31A8FF" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-300,-200,0">
                <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32,40,10,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- HEADER CENTRALIZADO (Grid.Row=0) -->
                <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                        <ContentControl Style="{StaticResource ModernPageHeaderIconStyle}">
                            <Path Data="{DynamicResource PrivacyIcon}" 
                                  Fill="White" 
                                  Width="20" Height="20" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </ContentControl>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Path Data="{DynamicResource PrivacyIcon}" Fill="{DynamicResource BrandBlue}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PROTEÇÃO DE DADOS" 
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="12" FontWeight="Black"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrandBlue}"/>
                    </StackPanel>
                    
                    <TextBlock Text="Controle de Privacidade" 
                               Style="{DynamicResource PageTitleTextStyle}"
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Maximize sua privacidade desativando telemetria e rastreamento de dados pela Microsoft." 
                               Style="{DynamicResource BodyTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" Opacity="0.7"/>
                </StackPanel>

                <!-- CONTEÚDE EM CARD VERTICAL (Grid.Row=1) -->
                <Border Grid.Row="1" Style="{DynamicResource CardBorderStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,20">
                    <StackPanel Margin="32">
                        
                        <!-- SEÇÃO 1: DADOS E RASTREIO -->
                        <StackPanel Margin="0,0,0,32">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Path Data="{DynamicResource SettingsIcon}" Fill="{DynamicResource BrandBlue}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" Opacity="0.8"/>
                                <TextBlock Text="Dados e Rastreio" Style="{DynamicResource CardHeaderStyle}"/>
                            </StackPanel>

                            <UniformGrid Columns="2">
                                <!-- Telemetria -->
                                <Grid Margin="0,0,24,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Telemetria" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Dados de diagnóstico e uso enviados à MS." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsTelemetryDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Localização -->
                                <Grid Margin="0,0,0,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Localização" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Acesso à posição geográfica por apps." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsLocationDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- ID Anúncios -->
                                <Grid Margin="0,0,24,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="ID de Publicidade" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Anúncios baseados em perfil de uso." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsAdvertisingIdDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Histórico de Atividades -->
                                <Grid Margin="0,0,0,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Linha do Tempo" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Sincronização de atividades entre dispositivos." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsActivityFeedDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Recall/CoPilot -->
                                <Grid Margin="0,0,24,0">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Windows Recall" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Snapshots e IA de histórico de tela." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsRecallDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </UniformGrid>
                        </StackPanel>

                        <Separator Background="#1AFFFFFF" Margin="0,0,0,32"/>

                        <!-- SEÇÃO 2: ENTRADA E ESCRITA -->
                        <StackPanel Margin="0,0,0,32">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Path Data="{DynamicResource DiagnosticsIcon}" Fill="{DynamicResource BrandBlue}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" Opacity="0.8"/>
                                <TextBlock Text="Entrada e Escrita" Style="{DynamicResource CardHeaderStyle}"/>
                            </StackPanel>

                            <UniformGrid Columns="2">
                                <!-- Escrita à Mão -->
                                <Grid Margin="0,0,24,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Escrita à Mão" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Coleta de dados para melhoria de escrita." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsHandwritingDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Coleta Linguística -->
                                <Grid Margin="0,0,0,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Coleta de Texto" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Melhoria de digitação via nuvem da MS." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsTextInputDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Personalização de Entrada -->
                                <Grid Margin="0,0,24,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Personalização" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Dicionário de usuário sincronizado na nuvem." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsPersonalizationDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Fala Online -->
                                <Grid Margin="0,0,0,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Fala Online" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Reconhecimento de voz baseado em nuvem." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsOnlineSpeechDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </UniformGrid>
                        </StackPanel>

                        <Separator Background="#1AFFFFFF" Margin="0,0,0,32"/>

                        <!-- SEÇÃO 3: SERVIÇOS E NUVEM -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Path Data="{DynamicResource SystemIcon}" Fill="{DynamicResource BrandBlue}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" Opacity="0.8"/>
                                <TextBlock Text="Serviços e Nuvem" Style="{DynamicResource CardHeaderStyle}"/>
                            </StackPanel>

                            <UniformGrid Columns="2">
                                <!-- OneDrive -->
                                <Grid Margin="0,0,24,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Microsoft OneDrive" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Sincronização de arquivos e backups." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsOneDriveDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Cortana/Copilot -->
                                <Grid Margin="0,0,0,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Cortana e Copilot" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Assistentes virtuais e inteligência artificial." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsCoPilotDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Bluetooth Ad -->
                                <Grid Margin="0,0,24,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Anúncios Bluetooth" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Propagandas de dispositivos via Bluetooth." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsBluetoothDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Clipboard Sync -->
                                <Grid Margin="0,0,0,20">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Área de Transferência" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Sincronização de Recortar/Colar na nuvem." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsClipboardSyncDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Diag Toasts -->
                                <Grid Margin="0,0,24,0">
                                    <StackPanel VerticalAlignment="Center" Margin="0,0,50,0">
                                        <TextBlock Text="Avisos de Diagnóstico" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,2"/>
                                        <TextBlock Text="Notificações de feedback e solicitações da MS." Style="{DynamicResource BodyTextStyle}" Opacity="0.5" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding IsDiagToastDisabled}" Style="{DynamicResource PremiumCheckBoxStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </UniformGrid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2" Text="Nota: Algumas alterações de privacidade podem exigir o reinício do Windows para serem aplicadas completamente." 
                           Style="{DynamicResource BodyTextStyle}" Opacity="0.4" FontSize="11" Margin="0,32,0,0" TextAlignment="Center" FontStyle="Italic"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>


