<UserControl x:Class="VoltrisOptimizer.UI.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Design System Colors -->
        <Color x:Key="ColorAccent1">#FF4B6B</Color>
        <Color x:Key="ColorAccent2">#8B31FF</Color>
        <Color x:Key="ColorAccent3">#31A8FF</Color>
        
        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF4B6B" Offset="0"/>
            <GradientStop Color="#8B31FF" Offset="0.5"/>
            <GradientStop Color="#31A8FF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Glass Card Style (matches Dashboard) -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCardGlass}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Entry Animation -->
        <Storyboard x:Key="EntryAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Background decorativo (GPU-friendly, sem BlurEffect) -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="500" Height="500" 
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-180,-100,0"
                     Opacity="0.07">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B31FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400" 
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100"
                     Opacity="0.05">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#31A8FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <!-- Main Layout: NO ScrollViewer, tudo cabe na tela -->
        <Grid Margin="24,20,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Row 0: Header -->
                <RowDefinition Height="12"/>     <!-- Row 1: Spacer -->
                <RowDefinition Height="Auto"/>   <!-- Row 2: System Info + Actions -->
                <RowDefinition Height="12"/>     <!-- Row 3: Spacer -->
                <RowDefinition Height="*"/>      <!-- Row 4: Categories Table (fills remaining) -->
                <RowDefinition Height="12"/>     <!-- Row 5: Spacer -->
                <RowDefinition Height="120"/>    <!-- Row 6: Log Console -->
            </Grid.RowDefinitions>

            <!-- ============================================ -->
            <!-- ROW 0: HEADER -->
            <!-- ============================================ -->
            <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Título -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M19,4h-3.5l-1-1h-5l-1,1H5v2h14M6,19a2,2 0 0,0 2,2h8a2,2 0 0,0 2,-2V7H6V19Z" 
                                  Fill="White" Width="22" Height="22" Stretch="Uniform" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Limpeza Ultra" 
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="20" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="Manutenção profunda e segura do sistema" 
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- System Status (direita) -->
                    <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- OS -->
                        <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,6" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="SISTEMA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7"/>
                                <TextBlock x:Name="OsVersionText" Text="Windows..." FontSize="12" FontWeight="Medium" 
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <!-- Disk -->
                        <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,6" MinWidth="140">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="DISCO (C:)" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7"/>
                                    <TextBlock x:Name="DriveFreeSpaceText" Text="-- GB Livres" FontSize="9" 
                                               Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar x:Name="DriveUsageBar" Height="5" Background="#15FFFFFF" 
                                             BorderThickness="0" Value="0" Foreground="{StaticResource MainGradient}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- ROW 2: ACTION BUTTONS -->
            <!-- ============================================ -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="20,10">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="ANÁLISE E LIMPEZA" FontSize="13" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="A limpeza é segura e irreversível. Analise primeiro, depois execute." 
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button x:Name="BtnAnalyze" Click="BtnAnalyze_Click" Cursor="Hand" MinWidth="160" MinHeight="36" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Padding" Value="16,8"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Analisar Sistema" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnClean" Click="BtnClean_Click" IsEnabled="False" Opacity="0.5" Cursor="Hand" MinWidth="160" MinHeight="36">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NeonButtonStyle}">
                                    <Setter Property="Padding" Value="16,8"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✨" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Executar Limpeza" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- ROW 4: CATEGORIES TABLE (preenche o espaço) -->
            <!-- ============================================ -->
            <Border Grid.Row="4" Style="{StaticResource GlassCard}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>   <!-- Table Header -->
                        <RowDefinition Height="Auto"/> <!-- Divider -->
                        <RowDefinition Height="*"/>    <!-- List (fills) -->
                    </Grid.RowDefinitions>

                    <!-- Table Header -->
                    <Grid Grid.Row="0" Background="#08FFFFFF" Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>   <!-- Checkbox -->
                            <ColumnDefinition Width="44"/>   <!-- Icon -->
                            <ColumnDefinition Width="*"/>    <!-- Name -->
                            <ColumnDefinition Width="Auto"/> <!-- Size -->
                            <ColumnDefinition Width="Auto"/> <!-- Status -->
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="SelectAllCheck" Style="{StaticResource ModernCheckBoxStyle}" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center" 
                                  Checked="SelectAllCheck_Checked" Unchecked="SelectAllCheck_Unchecked" 
                                  ToolTip="Selecionar Tudo"/>
                        <TextBlock Grid.Column="2" Text="CATEGORIA" FontSize="10" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Opacity="0.8"/>
                        <TextBlock Grid.Column="3" Text="TAMANHO" FontSize="10" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,16,0" Opacity="0.8"/>
                        <TextBlock Grid.Column="4" Text="STATUS" FontSize="10" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" Opacity="0.8"/>
                    </Grid>

                    <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource BorderLight}" Opacity="0.3"/>

                    <!-- Categories List -->
                    <ListView Grid.Row="2" x:Name="CategoriesList" 
                              Background="Transparent" BorderThickness="0"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              Padding="0">
                        <ListView.Template>
                            <ControlTemplate TargetType="ListView">
                                <Border Background="{TemplateBinding Background}">
                                    <ScrollViewer Focusable="false" Padding="0">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </ListView.Template>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                    Padding="0" SnapsToDevicePixels="true">
                                                <ContentPresenter HorizontalAlignment="Stretch" 
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0CFFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" Style="{StaticResource ModernCheckBoxStyle}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    <Border Grid.Column="1" Width="30" Height="30" CornerRadius="8" Background="#0CFFFFFF">
                                        <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center" FontSize="15"/>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,6,10,6">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6" 
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontSize="12" FontWeight="Medium" 
                                               Foreground="{Binding SizeColor}" VerticalAlignment="Center" Margin="12,0,16,0"/>

                                    <Border Grid.Column="4" Background="{Binding BadgeBackground}" CornerRadius="10" 
                                            Padding="10,3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding BadgeText}" FontSize="10" FontWeight="Bold" 
                                                   Foreground="{Binding BadgeForeground}"/>
                                    </Border>

                                    <Rectangle Grid.ColumnSpan="5" Height="1" Fill="#06FFFFFF" VerticalAlignment="Bottom"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyStatePanel" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Visible">
                        <TextBlock Text="📊" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.3"/>
                        <TextBlock Text="Aguardando Análise" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" 
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Clique em Analisar Sistema para verificar seus arquivos." 
                                   FontSize="12" Margin="0,6,0,0" HorizontalAlignment="Center" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================ -->
            <!-- ROW 6: LOG CONSOLE -->
            <!-- ============================================ -->
            <Border Grid.Row="6" Style="{StaticResource GlassCard}" Padding="14,10" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CONSOLE DE LIMPEZA" FontSize="9" FontWeight="Bold" 
                               Foreground="{DynamicResource TextMutedBrush}" Opacity="0.5" Margin="0,0,0,6"/>

                    <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LogViewerItems" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Message}" Foreground="{Binding Color}" 
                                               FontFamily="Consolas, Courier New" FontSize="11" Margin="0,1" 
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>