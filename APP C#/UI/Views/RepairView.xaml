<UserControl x:Class="VoltrisOptimizer.UI.Views.RepairView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="RepairGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F59E0B" Offset="0"/>
            <GradientStop Color="#EF4444" Offset="0.5"/>
            <GradientStop Color="#8B31FF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCardGlass}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tool Card Button Style -->
        <Style x:Key="ToolCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder" Background="#08FFFFFF" CornerRadius="14"
                                BorderBrush="{DynamicResource BorderLight}" BorderThickness="1"
                                Padding="20,16" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#12FFFFFF"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource BorderAccent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#0AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="EntryAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntryAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Background decorativo (GPU-friendly, sem BlurEffect) -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="500" Height="500" 
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-180,-100,0" Opacity="0.07">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#F59E0B" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400" 
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100" Opacity="0.05">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#8B31FF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <!-- Main Layout: NO ScrollViewer -->
        <Grid Margin="24,20,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Row 0: Header -->
                <RowDefinition Height="12"/>     <!-- Row 1: Spacer -->
                <RowDefinition Height="Auto"/>   <!-- Row 2: Actions -->
                <RowDefinition Height="12"/>     <!-- Row 3: Spacer -->
                <RowDefinition Height="*"/>      <!-- Row 4: Tools (fills remaining) -->
                <RowDefinition Height="12"/>     <!-- Row 5: Spacer -->
                <RowDefinition Height="100"/>    <!-- Row 6: Log Console -->
            </Grid.RowDefinitions>

            <!-- ROW 0: HEADER -->
            <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F59E0B" Offset="0"/>
                                    <GradientStop Color="#EF4444" Offset="0.5"/>
                                    <GradientStop Color="#8B31FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="{StaticResource RepairIcon}" 
                                  Fill="White" Width="20" Height="20" Stretch="Uniform" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Reparo" 
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="20" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                        <GradientStop Color="#EF4444" Offset="0.5"/>
                                        <GradientStop Color="#8B31FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="Manutenção profunda e correção de erros do sistema" 
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,6" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="SISTEMA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7"/>
                                <TextBlock x:Name="OsVersionText" Text="Windows..." FontSize="12" FontWeight="Medium" 
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,6">
                            <StackPanel>
                                <TextBlock Text="STATUS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.7"/>
                                <TextBlock x:Name="RepairStatusText" Text="Pronto" FontSize="12" FontWeight="Medium" 
                                           Foreground="#10B981"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- ROW 2: ACTION BUTTONS -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="20,10">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="REPARO E MANUTENÇÃO" FontSize="13" FontWeight="Bold" 
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="Escolha uma ação de reparo. A otimização completa inclui limpeza e reparos profundos." 
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7"/>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button x:Name="FullRepairButton" Click="FullRepairButton_Click" Cursor="Hand" MinWidth="180" MinHeight="36" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Padding" Value="16,8"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Reparação Completa" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="RepairSystemButton" Click="RepairSystemButton_Click" Cursor="Hand" MinWidth="180" MinHeight="36">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NeonButtonStyle}">
                                    <Setter Property="Padding" Value="16,8"/>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔧" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Reparo DISM + SFC" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- ROW 4: TOOLS AREA (fills remaining space) -->
            <Border Grid.Row="4" Style="{StaticResource GlassCard}" Padding="16" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Section Title -->
                        <RowDefinition Height="12"/>    <!-- Spacer -->
                        <RowDefinition Height="*"/>     <!-- Cards Grid -->
                    </Grid.RowDefinitions>

                    <!-- Section Title -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="8" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#EC4899" Offset="0"/>
                                    <GradientStop Color="#BE185D" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🛠️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Ferramentas do Windows" FontSize="14" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Ferramentas nativas para manutenção e otimização" 
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Tool Cards Grid — fills remaining space evenly -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Limpeza de Disco Card -->
                        <Button Grid.Column="0" x:Name="DiskCleanupButton" Click="DiskCleanupButton_Click"
                                Style="{StaticResource ToolCardButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Icon + Title -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#0CFFFFFF" Margin="0,0,12,0">
                                        <TextBlock Text="🧹" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Limpeza de Disco" FontSize="14" FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="cleanmgr.exe" FontSize="10" FontFamily="Consolas" 
                                                   Foreground="{DynamicResource TextMutedBrush}" Opacity="0.5"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Description -->
                                <TextBlock Grid.Row="1" 
                                           Text="Remove arquivos temporários, cache e dados desnecessários do Windows para liberar espaço em disco." 
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" 
                                           TextWrapping="Wrap" Margin="0,10,0,0" VerticalAlignment="Top"/>

                                <!-- Footer -->
                                <Border Grid.Row="2" Background="#0AFFFFFF" CornerRadius="8" Padding="0,8" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Abrir Ferramenta" FontSize="12" FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" 
                                              Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14" 
                                              Stretch="Uniform" Margin="6,0,0,0" VerticalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Desfragmentar Card -->
                        <Button Grid.Column="2" x:Name="DefragButton" Click="DefragButton_Click"
                                Style="{StaticResource ToolCardButtonStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Icon + Title -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border Width="40" Height="40" CornerRadius="10" Background="#0CFFFFFF" Margin="0,0,12,0">
                                        <TextBlock Text="💿" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Desfragmentar Unidades" FontSize="14" FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="dfrgui.exe" FontSize="10" FontFamily="Consolas" 
                                                   Foreground="{DynamicResource TextMutedBrush}" Opacity="0.5"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Description -->
                                <TextBlock Grid.Row="1" 
                                           Text="Otimiza a organização dos dados no disco para melhor desempenho de leitura e escrita." 
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.7" 
                                           TextWrapping="Wrap" Margin="0,10,0,0" VerticalAlignment="Top"/>

                                <!-- Footer -->
                                <Border Grid.Row="2" Background="#0AFFFFFF" CornerRadius="8" Padding="0,8" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Abrir Ferramenta" FontSize="12" FontWeight="SemiBold" 
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <Path Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" 
                                              Fill="{DynamicResource TextPrimaryBrush}" Width="14" Height="14" 
                                              Stretch="Uniform" Margin="6,0,0,0" VerticalAlignment="Center" Opacity="0.6"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- ROW 6: LOG CONSOLE -->
            <Border Grid.Row="6" Style="{StaticResource GlassCard}" Padding="14,10" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CONSOLE DE REPARO" FontSize="9" FontWeight="Bold" 
                               Foreground="{DynamicResource TextMutedBrush}" Opacity="0.5" Margin="0,0,0,6"/>

                    <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LogViewerItems" Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Message}" Foreground="{Binding Color}" 
                                               FontFamily="Consolas, Courier New" FontSize="11" Margin="0,1" 
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
