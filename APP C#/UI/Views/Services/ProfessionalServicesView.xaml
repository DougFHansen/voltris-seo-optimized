<UserControl x:Class="VoltrisOptimizer.UI.Views.ProfessionalServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VoltrisOptimizer.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource BgPrimary}">
    
    <UserControl.Resources>
        <!-- Style to map IconKey strings from ViewModel to actual Geometry resources -->
        <Style x:Key="ServiceIconStyle" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource VoltrisGradientHorizontalBrush}"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IconKey}" Value="SettingsIcon">
                    <Setter Property="Data" Value="{StaticResource SettingsIcon}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKey}" Value="PerformanceIcon">
                    <Setter Property="Data" Value="{StaticResource PerformanceIcon}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKey}" Value="BoltIcon">
                    <Setter Property="Data" Value="{StaticResource BoltIcon}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKey}" Value="DiagnosticsIcon">
                    <Setter Property="Data" Value="{StaticResource DiagnosticsIcon}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKey}" Value="GamerIcon">
                    <Setter Property="Data" Value="{StaticResource GamerIcon}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IconKey}" Value="LogsIcon">
                    <Setter Property="Data" Value="{StaticResource LogsIcon}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="ProfessionalServicesVM"/>
    </UserControl.DataContext>

    <Grid>
        <!-- Atmospheric Background Effects (Enterprise Premium) -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="600" Height="600" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="0,-300,0,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="32,48,32,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Page Header -->
                    <RowDefinition Height="*"/>    <!-- Content Grid -->
                </Grid.RowDefinitions>

                <!-- ============================================ -->
                <!-- PAGE HEADER (Centered)                       -->
                <!-- ============================================ -->
                <StackPanel Grid.Row="0" Margin="0,0,0,60" HorizontalAlignment="Center">
                    <Border Width="70" Height="70" CornerRadius="18" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                <GradientStop Color="{DynamicResource SecondaryColor}" Offset="0.5"/>
                                <GradientStop Color="{DynamicResource PrimaryColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.5"/>
                        </Border.Effect>
                        <Path Data="{StaticResource ServicesIcon}" 
                              Fill="White" Width="36" Height="36" 
                              Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" HorizontalAlignment="Center" TextAlignment="Center">
                        <Run Text="Serviços Profissionais "/><Run Text="Voltris" Foreground="{DynamicResource VoltrisGradient}"/>
                    </TextBlock>
                    
                    <TextBlock Text="Intervenções de alto nível realizadas por engenheiros especialistas para cenários onde a automação não é suficiente." 
                               Style="{StaticResource BodyTextStyle}"
                               MaxWidth="800" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ============================================ -->
                <!-- SERVICES GRID (Full Width & Responsive)      -->
                <!-- ============================================ -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Services}" HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="12" HorizontalAlignment="Stretch"
                                    Style="{DynamicResource PremiumCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Icon -->
                                        <RowDefinition Height="Auto"/> <!-- Title -->
                                        <RowDefinition Height="*"/>    <!-- Description -->
                                        <RowDefinition Height="Auto"/> <!-- Action -->
                                    </Grid.RowDefinitions>

                                    <!-- Service Icon -->
                                    <Border Grid.Row="0" Width="48" Height="48" CornerRadius="10" 
                                            Background="{DynamicResource DarkPanelAltBrush}" 
                                            HorizontalAlignment="Left" Margin="0,0,0,20">
                                        <Path Style="{StaticResource ServiceIconStyle}"/>
                                    </Border>

                                    <TextBlock Grid.Row="1" Text="{Binding Title}" 
                                               Style="{StaticResource SectionTitleTextStyle}"
                                               Margin="0,0,0,12" TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2" Text="{Binding Description}" 
                                               Style="{StaticResource BodyTextStyle}"
                                               TextWrapping="Wrap"
                                               MinHeight="80" Margin="0,0,0,24"/>

                                    <Button Grid.Row="3" 
                                            Content="{Binding ButtonText}"
                                            Command="{Binding DataContext.OpenWhatsAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Message}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Height="44"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
