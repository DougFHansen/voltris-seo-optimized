<UserControl x:Class="VoltrisOptimizer.UI.Views.BenchmarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VoltrisOptimizer.UI.Views"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             xmlns:converters="clr-namespace:VoltrisOptimizer.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource PageBackgroundBrush}">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Progress / Status -->
            <RowDefinition Height="*"/>    <!-- Results Area / Initial State -->
            <RowDefinition Height="Auto"/> <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Validação Científica de Performance" 
                       FontSize="24" FontWeight="SemiBold" 
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock Text="Benchmark observacional passivo de alta precisão" 
                       FontSize="14" 
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Status Message (always visible) -->
        <Border Grid.Row="1" 
                Padding="16" Background="{DynamicResource CardBackgroundBrush}" 
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="Medium" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Progress, StringFormat={}{0:F0}%}" Grid.Column="1" 
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                           Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- Progress Bar (visible only when running) -->
        <Border Grid.Row="1" Margin="0,60,0,0"
                Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6" 
                             Foreground="{DynamicResource AccentBrush}" 
                             Background="{DynamicResource ProgressBarBackgroundBrush}"
                             BorderThickness="0" Margin="0,8,0,0"/>
                
                <TextBlock Text="⚠️ Por favor, não utilize o computador durante a validação para garantir precisão estatística."
                           FontSize="12" Foreground="{DynamicResource WarningBrush}" Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Initial State (visible when NOT running and NO result) -->
        <Border Grid.Row="2" Margin="0,16,0,0"
                Padding="32" Background="{DynamicResource CardBackgroundBrush}" 
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasResult}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🧪" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Validação Científica de Otimizações" 
                           FontSize="18" FontWeight="SemiBold" 
                           Foreground="{DynamicResource PrimaryTextBrush}" 
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" 
                           Foreground="{DynamicResource SecondaryTextBrush}" 
                           FontSize="13" MaxWidth="500" LineHeight="22">
                    Este benchmark captura métricas do sistema antes e depois das otimizações,
                    analisando estatisticamente o impacto real em CPU, memória, disco e responsividade.
                </TextBlock>
                <Separator Background="{DynamicResource BorderBrush}" Margin="40,20"/>
                <Grid HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="📈" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="CPU Idle" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="💾" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Memória" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <TextBlock Text="💿" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Disco" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Latência" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Clique em 'Iniciar Benchmark Científico' para começar a validação." 
                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" 
                           HorizontalAlignment="Center" Margin="0,16,0,0" FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- Results Area -->
        <Grid Grid.Row="2" Margin="0,24,0,0" Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/> <!-- Main Score -->
                <ColumnDefinition Width="2.5*"/> <!-- Detailed Metrics -->
            </Grid.ColumnDefinitions>

            <!-- Verdict Card -->
            <Border Grid.Column="0" Margin="0,0,12,0"
                    Padding="24" Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="VEREDITO" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="{Binding ResultVerdict}" 
                               FontSize="20" FontWeight="Bold" 
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,16"/>

                    <Border Background="{DynamicResource AccentOpacityBrush}" CornerRadius="16" Padding="16,8" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="GANHO REAL: " FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="{Binding ResultGain}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Confiança: " Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding ResultConfidence}" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Detailed Metrics Table -->
            <Border Grid.Column="1" Margin="12,0,0,0"
                    Padding="24" Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Detalhamento Técnico" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <!-- Header Row -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="MÉTRICA" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                        <TextBlock Text="DELTA" Grid.Column="1" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right"/>
                        <TextBlock Text="STATUS" Grid.Column="2" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Grid.Row="2" Background="{DynamicResource BorderBrush}" Margin="0,0,0,12"/>

                    <!-- Metric Rows (Static for now, bindable later) -->
                    <!-- CPU Idle Stability -->
                    <Grid Grid.Row="3" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Estabilidade de CPU (Idle)" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Redução de ruído de processamento" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ResultCpuIdleDelta}" Grid.Column="1" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="--" Grid.Column="2" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}"/> 
                    </Grid>

                    <!-- RAM Available -->
                    <Grid Grid.Row="4" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Memória Disponível" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="RAM livre para aplicações" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ResultRamDelta}" Grid.Column="1" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryTextBrush}"/>
                         <TextBlock Text="--" Grid.Column="2" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Grid>

                     <!-- UX Latency -->
                    <Grid Grid.Row="5" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Responsividade do Sistema" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Latência de resposta a input" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ResultUxDelta}" Grid.Column="1" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryTextBrush}"/>
                         <TextBlock Text="--" Grid.Column="2" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Start/Action Button -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <!-- Botão de Retomar (Aparece apenas quando há validação pendente) -->
            <Button Command="{Binding ResumeBenchmarkCommand}" 
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Visibility="{Binding HasPendingPostReboot, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="24,10" Margin="0,0,12,0"
                    Background="{DynamicResource GreenGradientBrush}">
                <TextBlock Text="Retomar Validação Pós-Reinício" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>
            </Button>

            <Button Command="{Binding RunStandardBenchmarkCommand}" 
                    Style="{DynamicResource PrimaryButtonStyle}"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                    Padding="24,10">
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Iniciar Benchmark Científico"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasResult}" Value="True">
                                    <Setter Property="Text" Value="Nova Validação"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
