<UserControl x:Class="VoltrisOptimizer.UI.Views.SchedulerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-150,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300" Height="300" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-80,0,0,-80">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,24,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header Centralizado -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <!-- Ícone moderno com gradiente -->
                    <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F59E0B" Offset="0"/>
                                <GradientStop Color="#EF4444" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#F59E0B" Opacity="0.5"/>
                        </Border.Effect>
                        <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                              Fill="White"
                              Width="22" Height="22"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Agendamento Inteligente"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F59E0B" Offset="0"/>
                                    <GradientStop Color="#EF4444" Offset="0.5"/>
                                    <GradientStop Color="#8B31FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Automatize suas otimizações de forma profissional"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- ============================================ -->
                <!-- CRIAR NOVA TAREFA -->
                <!-- ============================================ -->
                <Border Grid.Row="1" Margin="0,0,0,20">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource DarkPanelColor}"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#40F59E0B" Offset="0"/>
                            <GradientStop Color="#30EF4444" Offset="0.5"/>
                            <GradientStop Color="#208B31FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="18"/>
                            <Setter Property="Padding" Value="28,24"/>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#F59E0B" Opacity="0.15"/>
                    </Border.Effect>
                    
                    <StackPanel>
                        <!-- Header do Card -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Width="44" Height="44" CornerRadius="12" Margin="0,0,16,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#10B981" Opacity="0.4"/>
                                </Border.Effect>
                                <TextBlock Text="➕" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Criar Nova Tarefa"
                                          FontWeight="Bold"
                                          FontSize="18"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Configure quando e o que otimizar automaticamente"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Formulário -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Nome da Tarefa -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                                <TextBlock Text="📝 Nome da Tarefa"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,10"/>
                                <TextBox x:Name="TaskNameTextBox"
                                        Style="{StaticResource ModernTextBoxStyle}"
                                        MinHeight="48"
                                        FontSize="14"/>
                            </StackPanel>
                            
                            <!-- Tipo de Agendamento -->
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,20">
                                <TextBlock Text="📅 Frequência"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,10"/>
                                <ComboBox x:Name="ScheduleTypeComboBox"
                                         Style="{StaticResource ModernComboBoxStyle}"
                                         MinHeight="48"
                                         FontSize="14"
                                         SelectionChanged="ScheduleTypeComboBox_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            
                            <!-- Seleção de Horário -->
                            <StackPanel x:Name="TimePickerPanel" Grid.Row="1" Grid.Column="0" Margin="0,0,0,20">
                                <TextBlock Text="⏰ Horário de Execução"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <ComboBox x:Name="HourComboBox" Grid.Column="0"
                                             Style="{StaticResource ModernComboBoxStyle}"
                                             MinHeight="48" MinWidth="90" FontSize="14"/>
                                    
                                    <TextBlock Grid.Column="1" Text=":" FontSize="22" FontWeight="Bold"
                                              Foreground="{DynamicResource PrimaryBrush}"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    
                                    <ComboBox x:Name="MinuteComboBox" Grid.Column="2"
                                             Style="{StaticResource ModernComboBoxStyle}"
                                             MinHeight="48" MinWidth="90" FontSize="14"/>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Seleção de Dias (para Semanal) -->
                            <StackPanel x:Name="DaysPickerPanel" Grid.Row="1" Grid.Column="2" Margin="0,0,0,20" Visibility="Collapsed">
                                <TextBlock Text="📆 Dias da Semana"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,10"/>
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox x:Name="DaySun" Content="Dom" Style="{StaticResource ModernCheckBoxStyle}" Margin="0,0,10,8" FontSize="12"/>
                                    <CheckBox x:Name="DayMon" Content="Seg" Style="{StaticResource ModernCheckBoxStyle}" Margin="0,0,10,8" FontSize="12"/>
                                    <CheckBox x:Name="DayTue" Content="Ter" Style="{StaticResource ModernCheckBoxStyle}" Margin="0,0,10,8" FontSize="12"/>
                                    <CheckBox x:Name="DayWed" Content="Qua" Style="{StaticResource ModernCheckBoxStyle}" Margin="0,0,10,8" FontSize="12"/>
                                    <CheckBox x:Name="DayThu" Content="Qui" Style="{StaticResource ModernCheckBoxStyle}" Margin="0,0,10,8" FontSize="12"/>
                                    <CheckBox x:Name="DayFri" Content="Sex" Style="{StaticResource ModernCheckBoxStyle}" Margin="0,0,10,8" FontSize="12"/>
                                    <CheckBox x:Name="DaySat" Content="Sáb" Style="{StaticResource ModernCheckBoxStyle}" Margin="0,0,0,8" FontSize="12"/>
                                </WrapPanel>
                            </StackPanel>
                            
                            <!-- Ações a Executar -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,24">
                                <TextBlock Text="⚡ Ações a Executar"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Margin="0,0,10,0" Padding="14,12" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonUp="ActionCleanup_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#10B981" Opacity="0.1"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#10B981" Opacity="0.3"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#10B981" Opacity="0.2"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="🧹" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <CheckBox x:Name="ActionCleanup" Content="Limpeza" 
                                                     Style="{StaticResource ModernCheckBoxStyle}"
                                                     FontSize="12" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Grid.Column="1" Margin="5,0" Padding="14,12" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonUp="ActionPerformance_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#8B5CF6" Opacity="0.1"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#8B5CF6" Opacity="0.3"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#8B5CF6" Opacity="0.2"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="⚡" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <CheckBox x:Name="ActionPerformance" Content="Desempenho" 
                                                     Style="{StaticResource ModernCheckBoxStyle}"
                                                     FontSize="12" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Grid.Column="2" Margin="5,0" Padding="14,12" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonUp="ActionNetwork_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#3B82F6" Opacity="0.1"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#3B82F6" Opacity="0.3"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#3B82F6" Opacity="0.2"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="🌐" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <CheckBox x:Name="ActionNetwork" Content="Rede" 
                                                     Style="{StaticResource ModernCheckBoxStyle}"
                                                     FontSize="12" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Grid.Column="3" Margin="10,0,0,0" Padding="14,12" CornerRadius="12" Cursor="Hand"
                                            MouseLeftButtonUp="ActionAdvanced_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#EF4444" Opacity="0.1"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderBrush">
                                                    <Setter.Value>
                                                        <SolidColorBrush Color="#EF4444" Opacity="0.3"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#EF4444" Opacity="0.2"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="🔧" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <CheckBox x:Name="ActionAdvanced" Content="Avançado" 
                                                     Style="{StaticResource ModernCheckBoxStyle}"
                                                     FontSize="12" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Botão Adicionar -->
                            <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                   Click="AddTaskButton_Click"
                                   MinHeight="56"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" CornerRadius="14" Padding="24,16">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#10B981" Offset="0"/>
                                                                <GradientStop Color="#059669" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#10B981" Opacity="0.4"/>
                                                        </Border.Effect>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBlock Text="➕" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Adicionar Tarefa Agendada" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#10B981" Opacity="0.6"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- ============================================ -->
                <!-- LISTA DE TAREFAS AGENDADAS -->
                <!-- ============================================ -->
                <Border Grid.Row="2"
                        Background="{DynamicResource DarkPanelBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="24">
                    <Border.RenderTransform>
                        <TranslateTransform/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard BeginTime="0:0:0.2">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header da Lista -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal">
                                <Border Width="44" Height="44" CornerRadius="12" Margin="0,0,16,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#1D4ED8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#3B82F6" Opacity="0.4"/>
                                    </Border.Effect>
                                    <TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Tarefas Agendadas"
                                              FontWeight="Bold"
                                              FontSize="18"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="TaskCountText" Text="0 tarefas configuradas"
                                              FontSize="12"
                                              Foreground="{DynamicResource TextMutedBrush}"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Button Grid.Column="1"
                                   Content="🔄 Atualizar"
                                   Style="{StaticResource NeonSecondaryButtonStyle}"
                                   MinHeight="44"
                                   Padding="20,0"
                                   Click="RefreshTasks_Click"/>
                        </Grid>
                        
                        <!-- Lista -->
                        <ScrollViewer Grid.Row="1"
                                    VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled"
                                    MaxHeight="350">
                            <StackPanel x:Name="TasksContainer">
                                <!-- Mensagem quando não há tarefas -->
                                <Border x:Name="EmptyMessage"
                                       Background="{DynamicResource DarkHoverBrush}"
                                       CornerRadius="14"
                                       Padding="40,50"
                                       Visibility="Visible">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.5"/>
                                        <TextBlock Text="Nenhuma tarefa agendada"
                                                  FontSize="16"
                                                  FontWeight="SemiBold"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="Crie sua primeira tarefa usando o formulário acima"
                                                  FontSize="13"
                                                  Foreground="{DynamicResource TextMutedBrush}"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                                
                                <ItemsControl x:Name="TasksListBox">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
