<Window x:Class="VoltrisOptimizer.UI.Controls.ModernTrayMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayMenu"
        Width="280"
        MinWidth="280"
        MaxWidth="280"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Border x:Name="MenuBorder"
           BorderBrush="{DynamicResource DarkBorderBrush}"
           BorderThickness="1"
           CornerRadius="12"
           Padding="0"
           ClipToBounds="True">
        <Border.Background>
            <!-- Base escura sólida — mesma cor base da MainWindow -->
            <SolidColorBrush Color="#0A0A0F"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" 
                            ShadowDepth="0" 
                            Opacity="0.5" 
                            Color="Black"/>
        </Border.Effect>
        
        <Grid ClipToBounds="True">
            <!-- Camada 1: Ellipses coloridas com cores DIRETAS e opacidade forte
                 No menu pequeno, as ellipses precisam ser menores e com opacidade maior
                 para que as cores (rosa #FF4B6B, roxo #8B31FF, azul #31A8FF) fiquem visíveis -->
            
            <!-- Rosa/Accent — canto superior esquerdo -->
            <Ellipse Width="200" Height="200"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-60,-60,0,0"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <SolidColorBrush Color="#FF4B6B" Opacity="0.18"/>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Roxo/Secondary — canto inferior direito -->
            <Ellipse Width="180" Height="180"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-50,-50"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <SolidColorBrush Color="#8B31FF" Opacity="0.18"/>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Azul/Primary — centro -->
            <Ellipse Width="140" Height="140"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsHitTestVisible="False">
                <Ellipse.Fill>
                    <SolidColorBrush Color="#31A8FF" Opacity="0.15"/>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="70"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Camada 2: Overlay escuro para legibilidade
                 Opacidade baixa para deixar as cores passarem -->
            <Border IsHitTestVisible="False"
                    Opacity="0.25">
                <Border.Background>
                    <SolidColorBrush Color="#0A0A0F"/>
                </Border.Background>
            </Border>
            
            <!-- Conteúdo do menu -->
            <StackPanel Margin="8">
            <!-- Header -->
            <Border Background="{DynamicResource DarkPanelAltBrush}"
                   CornerRadius="8"
                   Padding="12,10"
                   Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="⚡"
                              FontSize="20"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Voltris Optimizer"
                                  FontSize="13"
                                  FontWeight="SemiBold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock x:Name="TrayVersionText"
                                  Text="v3.0.0"
                                  FontSize="10"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Ações Rápidas -->
            <TextBlock Text="Ações Rápidas"
                      FontSize="11"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource TextMutedBrush}"
                      Margin="8,0,8,6"/>
            
            <Button x:Name="ShowButton"
                   Content="👁️ Mostrar"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Margin="0,0,0,4"
                   Click="ShowButton_Click"/>
            
            <Button x:Name="DashboardButton"
                   Content="🏠 Dashboard"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Margin="0,0,0,4"
                   Click="DashboardButton_Click"/>
            
            <Button x:Name="CleanupButton"
                   Content="🧹 Limpeza Rápida"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Margin="0,0,0,4"
                   Click="CleanupButton_Click"/>
            
            <Button x:Name="PerformanceButton"
                   Content="⚡ Otimizar Agora"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Margin="0,0,0,8"
                   Click="PerformanceButton_Click"/>
            
            <!-- Separador -->
            <Border Height="1"
                   Background="{DynamicResource DarkBorderBrush}"
                   Margin="0,0,0,8"
                   Opacity="0.5"/>
            
            <!-- Navegação -->
            <TextBlock Text="Navegação"
                      FontSize="11"
                      FontWeight="SemiBold"
                      Foreground="{DynamicResource TextMutedBrush}"
                      Margin="8,0,8,6"/>
            
            <Button x:Name="HistoryButton"
                   Content="📊 Histórico"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Margin="0,0,0,4"
                   Click="HistoryButton_Click"/>
            
            <Button x:Name="SchedulerButton"
                   Content="⏰ Agendamento"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Margin="0,0,0,4"
                   Click="SchedulerButton_Click"/>
            
            <Button x:Name="SettingsButton"
                   Content="⚙️ Configurações"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Margin="0,0,0,8"
                   Click="SettingsButton_Click"/>
            
            <!-- Separador -->
            <Border Height="1"
                   Background="{DynamicResource DarkBorderBrush}"
                   Margin="0,0,0,8"
                   Opacity="0.5"/>
            
            <!-- Sistema -->
            <Button x:Name="AboutButton"
                   Content="ℹ️ Sobre"
                   Style="{StaticResource SecondaryButtonStyle}"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Margin="0,0,0,4"
                   Click="AboutButton_Click"/>
            
            <Button x:Name="ExitButton"
                   Content="🚪 Sair"
                   Height="36"
                   HorizontalContentAlignment="Left"
                   Padding="12,0"
                   Click="ExitButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
        </Grid>
    </Border>
</Window>
