<UserControl x:Class="VoltrisOptimizer.UI.Controls.UnlinkConfirmationDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Border Background="#121218" 
            BorderBrush="#FFFFFF1A" 
            BorderThickness="1" 
            CornerRadius="20" 
            Padding="0"
            Width="420"
            MaxWidth="90vw">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" 
                            ShadowDepth="0" 
                            Opacity="0.6" 
                            Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header com ícone de alerta -->
            <Border Grid.Row="0"
                    Background="#1E1E1E"
                    CornerRadius="20,20,0,0"
                    Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Ícone de alerta vermelho -->
                    <Border Grid.Column="0"
                            Width="48" 
                            Height="48" 
                            Background="#FF4B6B20"
                            CornerRadius="24"
                            Margin="0,0,16,0">
                        <Viewbox Width="24" Height="24">
                            <TextBlock Text="⚠️" 
                                     FontSize="24" 
                                     VerticalAlignment="Center" 
                                     HorizontalAlignment="Center"/>
                        </Viewbox>
                    </Border>
                    
                    <!-- Título -->
                    <TextBlock Grid.Column="1"
                              Text="Desvincular Computador"
                              Foreground="White"
                              FontFamily="Segoe UI"
                              FontSize="18"
                              FontWeight="Bold"
                              VerticalAlignment="Center"/>
                    
                    <!-- Botão fechar -->
                    <Button Grid.Column="2"
                           x:Name="CloseButton"
                           Content="✕"
                           Width="32"
                           Height="32"
                           Background="Transparent"
                           Foreground="#AAAAAA"
                           BorderThickness="0"
                           FontSize="16"
                           FontWeight="Bold"
                           Click="CloseButton_Click"
                           Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="16">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF4B6B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Conteúdo -->
            <Border Grid.Row="1" 
                    Padding="24,20">
                <StackPanel>
                    <!-- Mensagem principal -->
                    <TextBlock Text="Tem certeza que deseja desvincular este dispositivo da sua conta Voltris Enterprise?"
                              Foreground="White"
                              FontFamily="Segoe UI"
                              FontSize="14"
                              TextWrapping="Wrap"
                              LineHeight="22"
                              Margin="0,0,0,20"/>
                    
                    <!-- Efeitos da desvinculação -->
                    <Border Background="#FFFFFF0A" 
                            BorderBrush="#FFFFFF1A" 
                            BorderThickness="1" 
                            CornerRadius="12" 
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Ao desvincular, você perderá:"
                                      Foreground="#AAAAAA"
                                      FontFamily="Segoe UI"
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,12"/>
                            
                            <StackPanel Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="•" 
                                             Foreground="#FF4B6B" 
                                             FontFamily="Segoe UI" 
                                             FontSize="14" 
                                             FontWeight="Bold" 
                                             Width="15"/>
                                    <TextBlock Text="Acesso remoto ao dispositivo" 
                                             Foreground="#CCCCCC" 
                                             FontFamily="Segoe UI" 
                                             FontSize="13"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="•" 
                                             Foreground="#FF4B6B" 
                                             FontFamily="Segoe UI" 
                                             FontSize="14" 
                                             FontWeight="Bold" 
                                             Width="15"/>
                                    <TextBlock Text="Sincronização automática" 
                                             Foreground="#CCCCCC" 
                                             FontFamily="Segoe UI" 
                                             FontSize="13"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="•" 
                                             Foreground="#FF4B6B" 
                                             FontFamily="Segoe UI" 
                                             FontSize="14" 
                                             FontWeight="Bold" 
                                             Width="15"/>
                                    <TextBlock Text="Comandos e telemetria" 
                                             Foreground="#CCCCCC" 
                                             FontFamily="Segoe UI" 
                                             FontSize="13"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Botões -->
            <Border Grid.Row="2"
                    Background="#1E1E1E"
                    CornerRadius="0,0,20,20"
                    Padding="24,20">
                <StackPanel Orientation="Horizontal" 
                           HorizontalAlignment="Right"
                           Margin="0,0,-12,0">
                    <Button x:Name="CancelButton"
                           Content="Cancelar"
                           Width="100"
                           Height="36"
                           Background="#232323"
                           Foreground="#CCCCCC"
                           BorderBrush="#8B31FF40"
                           BorderThickness="1"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Click="CancelButton_Click"
                           Margin="0,0,12,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   BorderBrush="{TemplateBinding BorderBrush}"
                                                   BorderThickness="{TemplateBinding BorderThickness}"
                                                   CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#8B31FF20"/>
                                        <Setter Property="BorderBrush" Value="#8B31FF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button x:Name="ConfirmButton"
                           Content="Desvincular"
                           Width="120"
                           Height="36"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="White"
                           Click="ConfirmButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="8">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="15" 
                                                                    ShadowDepth="0" 
                                                                    Opacity="0.4" 
                                                                    Color="#FF4B6B"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>