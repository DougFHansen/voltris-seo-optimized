<UserControl x:Class="VoltrisOptimizer.UI.Controls.OnboardingLockModal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <Grid x:Name="ModalRoot" Visibility="Collapsed">
        <!-- Fundo Escurecido com Blur -->
        <Border Background="#CC05050A">
            <Border.Effect>
                <BlurEffect Radius="0"/>
            </Border.Effect>
        </Border>
        
        <!-- Conteúdo do Modal -->
        <Border x:Name="ModalContent"
                Width="450"
                Height="Auto"
                MinWidth="400"
                MinHeight="250"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Background="#12121A"
                BorderBrush="#252535"
                BorderThickness="1"
                CornerRadius="24"
                Padding="32">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.8"/>
            </Border.Effect>
            
            <StackPanel VerticalAlignment="Center">
                <!-- Ícone de Bloqueio com Gradiente -->
                <Viewbox Width="64" Height="64" Margin="0,0,0,24">
                    <Grid>
                        <Ellipse Width="64" Height="64">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#8B31FF" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        
                        <!-- Ícone de Cadeado White -->
                        <Path Data="M32,18 C26.48,18 22,22.48 22,28 L22,32 L20,32 C18.9,32 18,32.9 18,34 L18,50 C18,51.1 18.9,52 20,52 L44,52 C45.1,52 46,51.1 46,50 L46,34 C46,32.9 45.1,32 44,32 L42,32 L42,28 C42,22.48 37.52,18 32,18 Z M32,22 C35.31,22 38,24.69 38,28 L38,32 L26,32 L26,28 C26,24.69 28.69,22 32,22 Z"
                              Fill="White"
                              Width="34" Height="34"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Grid>
                </Viewbox>
                
                <TextBlock Text="Acesso Restrito"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                
                <TextBlock Text="Você precisa completar o tutorial e Perfil Inteligente para conseguir acessar o Sidebar e configurações no geral do programa."
                           FontSize="14"
                           Foreground="#A0A0B0"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           LineHeight="22"
                           Margin="0,0,0,32"/>
                
                <!-- Botão Entendido -->
                <Button x:Name="OkButton"
                        Content="Entendido"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="180"
                        Height="45"
                        Click="OkButton_Click"
                        Cursor="Hand">
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
