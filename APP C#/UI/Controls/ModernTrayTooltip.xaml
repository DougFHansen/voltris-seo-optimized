<Window x:Class="VoltrisOptimizer.UI.Controls.ModernTrayTooltip"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayTooltip"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        Focusable="False">

    <Border x:Name="RootBorder"
            CornerRadius="14"
            Padding="18,16"
            ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush x:Name="RootBg" Color="#0F0F18" Opacity="0.95"/>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#3A2060" Offset="0"/>
                <GradientStop Color="#1A2A50" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.BorderThickness>1</Border.BorderThickness>
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.65" Color="Black"/>
        </Border.Effect>

        <StackPanel>
            <!-- Header: Ícone + Nome + Versão -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <!-- Ícone do app (raio/bolt) com gradiente -->
                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2A0A40" Offset="0"/>
                            <GradientStop Color="#0A1A40" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Path Data="M7,2V13H10V22L17,10H13L17,2H7Z"
                          Stretch="Uniform" Width="18" Height="18"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Path.Fill>
                    </Path>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Voltris Optimizer" FontSize="13.5" FontWeight="Bold"
                               FontFamily="Segoe UI Variable Display, Segoe UI">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock x:Name="VersionText" Text="v1.0.0" FontSize="10"
                               Foreground="#5A6070" Margin="0,2,0,0"
                               FontFamily="Segoe UI Variable Text, Segoe UI"/>
                </StackPanel>
            </StackPanel>

            <!-- Separador gradiente -->
            <Border Height="1" Margin="0,0,0,12" Opacity="0.35">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF4B6B" Offset="0"/>
                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                        <GradientStop Color="#31A8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Voltris Shield -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Ícone Shield colorido -->
                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="7"
                        Background="#1A0050FF" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z"
                          Stretch="Uniform" Width="14" Height="14"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="#31A8FF"/>
                </Border>
                <TextBlock Grid.Column="1" Text="Voltris Shield" FontSize="12"
                           Foreground="#9CA3AF" VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
                <!-- Badge status -->
                <Border Grid.Column="2" x:Name="ShieldBadge" CornerRadius="8" Padding="9,3"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush x:Name="ShieldBadgeBg" Color="#0D3B1E"/>
                    </Border.Background>
                    <TextBlock x:Name="ShieldStatusText" Text="Ativo" FontSize="10.5"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable Text, Segoe UI">
                        <TextBlock.Foreground>
                            <SolidColorBrush x:Name="ShieldStatusFg" Color="#4ADE80"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Perfil Inteligente -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Ícone Perfil (target/crosshair) -->
                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="7"
                        Background="#1A8B31FF" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10Z"
                          Stretch="Uniform" Width="14" Height="14"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="#8B31FF"/>
                </Border>
                <TextBlock Grid.Column="1" Text="Perfil Inteligente" FontSize="12"
                           Foreground="#9CA3AF" VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
                <TextBlock Grid.Column="2" x:Name="ProfileText" Text="—" FontSize="11.5"
                           FontWeight="SemiBold" Foreground="#E5E7EB" VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
            </Grid>

            <!-- Plano de Energia -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Ícone Energia (raio) -->
                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="7"
                        Background="#1AFF4B6B" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Path Data="M7,2V13H10V22L17,10H13L17,2H7Z"
                          Stretch="Uniform" Width="13" Height="13"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Fill="#FF4B6B"/>
                </Border>
                <TextBlock Grid.Column="1" Text="Plano de Energia" FontSize="12"
                           Foreground="#9CA3AF" VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
                <TextBlock Grid.Column="2" x:Name="PowerPlanText" Text="—" FontSize="11.5"
                           FontWeight="SemiBold" Foreground="#E5E7EB" VerticalAlignment="Center"
                           MaxWidth="120" TextTrimming="CharacterEllipsis"
                           FontFamily="Segoe UI Variable Text, Segoe UI"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
