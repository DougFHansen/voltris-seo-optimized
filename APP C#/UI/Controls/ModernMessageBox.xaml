<Window x:Class="VoltrisOptimizer.UI.Controls.ModernMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        MinWidth="480"
        MaxWidth="640"
        MinHeight="220"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
    
    <!-- Glassmorphism Container -->
    <Border BorderBrush="{DynamicResource DarkBorderBrush}"
            BorderThickness="1.5"
            CornerRadius="16"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" 
                            ShadowDepth="0" 
                            Opacity="0.5" 
                            Color="#000000"/>
        </Border.Effect>
        
        <!-- Background Gradient Overlay -->
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.95">
                <GradientStop Color="#1A1A1E" Offset="0"/>
                <GradientStop Color="#252530" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Content -->
                <RowDefinition Height="*"/>
                <!-- Buttons -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Decorative Gradient Top -->
            <Border Grid.Row="0" 
                    Height="4" 
                    CornerRadius="16,16,0,0"
                    VerticalAlignment="Top">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF4B6B" Offset="0"/>
                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                        <GradientStop Color="#31A8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            
            <!-- Header -->
            <Border Grid.Row="0"
                    Background="Transparent"
                    Padding="28,24,28,20"
                    Margin="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Icon with Gradient Background -->
                    <Border Grid.Column="0"
                            Width="48"
                            Height="48"
                            CornerRadius="12"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#20FF4B6B" Offset="0"/>
                                <GradientStop Color="#208B31FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock x:Name="IconText"
                                  FontSize="28"
                                  FontWeight="Bold"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                    </Border>
                    
                    <!-- Title with Gradient -->
                    <TextBlock x:Name="TitleText"
                              Grid.Column="1"
                              FontFamily="Segoe UI Variable Display, Segoe UI"
                              FontSize="20"
                              FontWeight="Bold"
                              VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    
                    <!-- Close Button -->
                    <Button Grid.Column="2"
                           x:Name="CloseButton"
                           Content="✕"
                           Width="32"
                           Height="32"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Background="Transparent"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           BorderThickness="0"
                           FontSize="16"
                           FontWeight="Bold"
                           Click="CloseButton_Click"
                           Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border"
                                                   Background="{TemplateBinding Background}"
                                                   CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#30FF3B3B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FF3B3B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Separator -->
            <Rectangle Grid.Row="0" 
                      Height="1" 
                      Fill="#15FFFFFF" 
                      VerticalAlignment="Bottom"
                      Margin="28,0"/>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="400"
                          Padding="28,24">
                <TextBlock x:Name="MessageText"
                          Text="{Binding Message}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          FontFamily="Segoe UI Variable, Segoe UI"
                          FontSize="15"
                          FontWeight="Medium"
                          TextWrapping="Wrap"
                          LineHeight="24"
                          Opacity="0.9"
                          LineStackingStrategy="BlockLineHeight"/>
            </ScrollViewer>
            
            <!-- Separator -->
            <Rectangle Grid.Row="1" 
                      Height="1" 
                      Fill="#15FFFFFF" 
                      VerticalAlignment="Bottom"
                      Margin="28,0"/>
            
            <!-- Buttons -->
            <Border Grid.Row="2"
                   Background="Transparent"
                   Padding="28,20,28,24">
                <StackPanel x:Name="ButtonsPanel"
                           Orientation="Horizontal"
                           HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
