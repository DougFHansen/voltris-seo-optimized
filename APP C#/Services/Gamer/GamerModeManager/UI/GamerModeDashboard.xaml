<UserControl x:Class="VoltrisOptimizer.Services.Gamer.GamerModeManager.UI.GamerModeDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">
    
    <UserControl.Resources>
        <!-- Cores -->
        <Color x:Key="AccentColor">#7C3AED</Color>
        <Color x:Key="AccentColorLight">#A855F7</Color>
        <Color x:Key="SuccessColor">#10B981</Color>
        <Color x:Key="WarningColor">#F59E0B</Color>
        <Color x:Key="DangerColor">#EF4444</Color>
        <Color x:Key="BackgroundColor">#0A0A0F</Color>
        <Color x:Key="CardColor">#111827</Color>
        <Color x:Key="BorderColor">#1F2937</Color>
        
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentColorLight}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
        <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        
        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        
        <!-- Metric Card Style -->
        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>
        
        <!-- Button Styles -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource AccentColor}" Offset="0"/>
                        <GradientStop Color="{StaticResource AccentColorLight}" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Progress Bar Style -->
        <Style x:Key="MetricProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" CornerRadius="3" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="🎮 Modo Gamer" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="StatusText" Text="Inativo" Foreground="#9CA3AF" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ToggleButton" Content="▶ Ativar Modo Gamer" 
                            Style="{StaticResource PrimaryButtonStyle}" Click="ToggleButton_Click"/>
                    <Button x:Name="EmergencyButton" Content="⚠ Rollback" Margin="12,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}" Click="EmergencyButton_Click"
                            ToolTip="Rollback de emergência"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Status Indicator -->
        <Border Grid.Row="1" Margin="24,0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Status Principal -->
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="#6B7280"/>
                    <TextBlock x:Name="CurrentGameText" Text="Nenhum jogo detectado" 
                               Foreground="White" FontSize="15" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                
                <!-- Power Plan -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="24,0">
                    <TextBlock Text="⚡ Plano:" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PowerPlanText" Text="-" Foreground="White" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                
                <!-- GPU -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="24,0">
                    <TextBlock Text="🎮 GPU:" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <TextBlock x:Name="GpuText" Text="-" Foreground="White" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                
                <!-- Session Time -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="24,0,0,0">
                    <TextBlock Text="⏱ Sessão:" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SessionTimeText" Text="00:00:00" Foreground="White" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Metrics Grid -->
        <Grid Grid.Row="2" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- CPU Temperature -->
            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="CPU Temp" Foreground="#9CA3AF" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="CpuTempText" Text="--" FontSize="28" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="°C" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel>
                    <ProgressBar x:Name="CpuTempBar" Value="0" Maximum="100" 
                                 Style="{StaticResource MetricProgressBar}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- GPU Temperature -->
            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="GPU Temp" Foreground="#9CA3AF" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="GpuTempText" Text="--" FontSize="28" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="°C" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel>
                    <ProgressBar x:Name="GpuTempBar" Value="0" Maximum="100" 
                                 Style="{StaticResource MetricProgressBar}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- CPU Usage -->
            <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="CPU Uso" Foreground="#9CA3AF" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="CpuUsageText" Text="--" FontSize="28" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="%" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel>
                    <ProgressBar x:Name="CpuUsageBar" Value="0" Maximum="100" 
                                 Style="{StaticResource MetricProgressBar}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- GPU Usage -->
            <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="GPU Uso" Foreground="#9CA3AF" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="GpuUsageText" Text="--" FontSize="28" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="%" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel>
                    <ProgressBar x:Name="GpuUsageBar" Value="0" Maximum="100" 
                                 Style="{StaticResource MetricProgressBar}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- RAM Usage -->
            <Border Grid.Column="4" Style="{StaticResource MetricCardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="RAM Uso" Foreground="#9CA3AF" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="RamUsageText" Text="--" FontSize="28" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="%" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel>
                    <ProgressBar x:Name="RamUsageBar" Value="0" Maximum="100" 
                                 Style="{StaticResource MetricProgressBar}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Logs Area -->
        <Grid Grid.Row="3" Margin="24,16,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Event Logs -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="📋 Logs de Eventos" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                        <Button x:Name="ClearLogsButton" Content="Limpar" Margin="12,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="12,4" FontSize="11"
                                Click="ClearLogsButton_Click"/>
                    </StackPanel>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LogsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,2" Background="#0D1117" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" 
                                                       Foreground="#6B7280" FontSize="11" FontFamily="Consolas"/>
                                            <Border Grid.Column="1" Margin="8,0" Padding="4,1" CornerRadius="3"
                                                    Background="{Binding LevelBrush}">
                                                <TextBlock Text="{Binding LevelText}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Message}" Foreground="#E5E7EB" 
                                                       FontSize="12" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- Quick Settings -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="⚙ Configurações Rápidas" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    
                    <StackPanel Grid.Row="1">
                        <CheckBox x:Name="AutoActivateCheck" Content="Ativar automaticamente ao iniciar jogo" 
                                  Foreground="#E5E7EB" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="AutoDeactivateCheck" Content="Desativar ao fechar jogo" 
                                  Foreground="#E5E7EB" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="OptimizePowerCheck" Content="Otimizar plano de energia" 
                                  Foreground="#E5E7EB" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="OptimizeGpuCheck" Content="Otimizar GPU" 
                                  Foreground="#E5E7EB" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="HighPriorityCheck" Content="Prioridade alta para jogos" 
                                  Foreground="#E5E7EB" IsChecked="True" Margin="0,0,0,12"/>
                        <CheckBox x:Name="AutoRollbackCheck" Content="Rollback automático em superaquecimento" 
                                  Foreground="#E5E7EB" IsChecked="True" Margin="0,0,0,16"/>
                        
                        <Separator Background="#1F2937" Margin="0,0,0,16"/>
                        
                        <!-- Temperature Limits -->
                        <TextBlock Text="Limites de Temperatura" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,8"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU Máx:" Foreground="#E5E7EB" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="CpuMaxTempBox" Text="90" Width="40" TextAlignment="Center"
                                         Background="#1F2937" Foreground="White" BorderBrush="#374151"/>
                                <TextBlock Text="°C" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GPU Máx:" Foreground="#E5E7EB" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="GpuMaxTempBox" Text="85" Width="40" TextAlignment="Center"
                                         Background="#1F2937" Foreground="White" BorderBrush="#374151"/>
                                <TextBlock Text="°C" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        
                        <Button Content="💾 Salvar Configurações" Margin="0,20,0,0"
                                Style="{StaticResource SecondaryButtonStyle}" Click="SaveSettingsButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

