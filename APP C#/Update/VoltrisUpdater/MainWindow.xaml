<Window x:Class="VoltrisUpdater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltris Optimizer - Updating Engine"
        Width="500" Height="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <LinearGradientBrush x:Key="ProgressGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8E2DE2" Offset="0"/>
            <GradientStop Color="#4A00E0" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Border CornerRadius="24" Background="#0A0A0F" BorderThickness="1" BorderBrush="#252535">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.8"/>
        </Border.Effect>
        
        <Grid>
            <!-- Atmospheric Glows -->
            <Ellipse Width="300" Height="300" Fill="#158E2DE2" Margin="-100,-100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>

            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Logo Section -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <!-- Logo Removido para estabilidade -->
                    <TextBlock Text="VOLTRIS OPTIMIZER" Foreground="#8E2DE2" FontWeight="Black" FontSize="14" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Atualizando Sistema Core" 
                               FontSize="20" FontWeight="Bold" Foreground="White"
                               Margin="0,20,0,0" FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    
                    <TextBlock Text="Aguarde o término da instalação enterprise." 
                               FontSize="12" Foreground="#606070" 
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Info Display (With Scroll) -->
                <Border Grid.Row="1" Background="#12121A" CornerRadius="16" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ContentPanel" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusTitle" Text="INSTALAÇÃO EM CURSO" 
                                       FontSize="10" FontWeight="Black" Foreground="#4A00E0" 
                                       Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            
                            <TextBlock x:Name="StatusText" 
                                       Text="Inicializando camadas de subscrição..." 
                                       FontSize="13" Foreground="#D0D0D5" 
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Professional Progress Section -->
                <StackPanel Grid.Row="2" Margin="0,32,0,0">
                    <Grid Margin="0,0,0,10">
                        <TextBlock x:Name="StepLabel" Text="Etapa 1 de 4" FontSize="11" Foreground="#606070"/>
                        <TextBlock x:Name="PercentLabel" Text="0%" FontSize="11" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    
                    <Border Background="#1A1A25" CornerRadius="4" Height="6">
                        <Border x:Name="ProgressBar" 
                                HorizontalAlignment="Left" 
                                Width="0"
                                CornerRadius="4"
                                Background="{StaticResource ProgressGradient}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#4A00E0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
