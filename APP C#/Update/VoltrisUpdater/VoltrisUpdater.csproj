<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>VoltrisUpdater</AssemblyName>
    <RootNamespace>VoltrisUpdater</RootNamespace>
    <Version>1.0.0.9</Version>
    <Authors>Voltris Corporation</Authors>
    <Company>Voltris Corporation</Company>
    <Product>Voltris Optimizer Updater</Product>
    <Description>Atualizador automático do Voltris Optimizer</Description>
    <Copyright>Copyright © VOLTRIS 2025</Copyright>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">win-x64</RuntimeIdentifier>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    <ApplicationIcon>favicon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="..\..\Images\voltris.png">
      <Link>Images\voltris.png</Link>
    </Resource>
    <Resource Include="..\..\Images\favicon.ico">
      <Link>favicon.ico</Link>
    </Resource>
  </ItemGroup>

  <!-- Payload ZIP embarcado (auto-update) -->
  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'win-x86'">
    <EmbeddedResource Include="Payload\VOLTris_Optimizer_x86.zip">
      <LogicalName>VoltrisUpdater.Payload.zip</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'win-x64'">
    <EmbeddedResource Include="Payload\VOLTris_Optimizer_x64.zip">
      <LogicalName>VoltrisUpdater.Payload.zip</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>


