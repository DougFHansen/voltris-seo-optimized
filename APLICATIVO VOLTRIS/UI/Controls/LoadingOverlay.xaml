<UserControl x:Class="VoltrisOptimizer.UI.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:VoltrisOptimizer.UI.Controls"
             x:Name="OverlayControl"
             Visibility="Collapsed"
             IsHitTestVisible="True">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Animação de entrada -->
        <Storyboard x:Key="ShowAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Animação de saída -->
        <Storyboard x:Key="HideAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="1" To="0"
                           Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Animação de texto pulsante -->
        <Storyboard x:Key="TextPulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingText"
                           Storyboard.TargetProperty="Opacity"
                           From="0.7" To="1"
                           Duration="0:0:0.6"
                           AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource TextPulseAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid Background="#E00A0A0F">
        <!-- Blur Background Effect -->
        <Border Background="#CC0A0A0F"/>
        
        <!-- Content -->
        <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <TranslateTransform/>
            </StackPanel.RenderTransform>
            
            <!-- Spinner -->
            <local:LoadingSpinner SpinnerSize="80"
                                  Margin="0,0,0,24"/>
            
            <!-- Loading Text -->
            <TextBlock x:Name="LoadingText"
                      Text="{Binding LoadingMessage, ElementName=OverlayControl, FallbackValue=Carregando...}"
                      FontFamily="Segoe UI Variable, Segoe UI"
                      FontSize="16"
                      FontWeight="Medium"
                      Foreground="#B4B4C0"
                      HorizontalAlignment="Center"/>
            
            <!-- Progress Bar (opcional) -->
            <Border x:Name="ProgressContainer"
                    Visibility="{Binding ShowProgress, ElementName=OverlayControl, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,20,0,0"
                    Width="300"
                    Height="4"
                    Background="#2A2A3A"
                    CornerRadius="2">
                <Border x:Name="ProgressFill"
                        HorizontalAlignment="Left"
                        Width="0"
                        CornerRadius="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF4B6B" Offset="0"/>
                            <GradientStop Color="#8B31FF" Offset="0.5"/>
                            <GradientStop Color="#31A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#8B31FF" Opacity="0.5"/>
                    </Border.Effect>
                </Border>
            </Border>
            
            <!-- Progress Text -->
            <TextBlock x:Name="ProgressTextBlock"
                      Text="{Binding ProgressText, ElementName=OverlayControl}"
                      FontFamily="Segoe UI Variable, Segoe UI"
                      FontSize="12"
                      Foreground="#6B6B80"
                      HorizontalAlignment="Center"
                      Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>

