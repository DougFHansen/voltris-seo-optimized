<Window x:Class="VoltrisOptimizer.UI.Windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="580" Height="380"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        RenderOptions.BitmapScalingMode="HighQuality"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    
    <Window.Resources>
        <!-- Animação de Pulso suave para o Logo -->
        <Storyboard x:Key="LogoPulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LogoGlow"
                           Storyboard.TargetProperty="Opacity"
                           From="0.3" To="0.6" Duration="0:0:2"
                           AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Animação sutil da barra -->
        <Storyboard x:Key="ProgressGlow" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ProgressGlowEffect"
                           Storyboard.TargetProperty="Opacity"
                           From="0.6" To="1" Duration="0:0:1.2"
                           AutoReverse="True"/>
        </Storyboard>
        
        <!-- Animação de rotação dos orbs -->
        <Storyboard x:Key="OrbRotation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="OrbContainer"
                           Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                           From="0" To="360" Duration="0:0:20"/>
        </Storyboard>
    </Window.Resources>
    
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Fade In suave -->
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                   From="0" To="1" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
            <BeginStoryboard Storyboard="{StaticResource LogoPulse}"/>
            <BeginStoryboard Storyboard="{StaticResource ProgressGlow}"/>
            <BeginStoryboard Storyboard="{StaticResource OrbRotation}"/>
        </EventTrigger>
    </Window.Triggers>
    
    <Grid>
        <!-- Container Principal - 100% arredondado sem transparência -->
        <Border CornerRadius="16" 
                Margin="0"
                ClipToBounds="True"
                Background="#0A0A0F">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" 
                                ShadowDepth="0" 
                                Opacity="0.7" 
                                Color="Black"/>
            </Border.Effect>
            <Border.BorderBrush>
                <SolidColorBrush Color="#1E1E2E"/>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness>1</Thickness>
            </Border.BorderThickness>
            
            <Grid>
                <!-- Orbs animados de fundo -->
                <Canvas x:Name="OrbContainer" IsHitTestVisible="False"
                        RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <RotateTransform Angle="0"/>
                    </Canvas.RenderTransform>
                    
                    <Ellipse Width="200" Height="200" 
                            Canvas.Left="-40" Canvas.Top="-40">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#25FF4B6B" Offset="0"/>
                                <GradientStop Color="#00FF4B6B" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    
                    <Ellipse Width="180" Height="180" 
                            Canvas.Right="-30" Canvas.Bottom="-30">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#208B31FF" Offset="0"/>
                                <GradientStop Color="#008B31FF" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    
                    <Ellipse Width="150" Height="150" 
                            Canvas.Right="100" Canvas.Top="-20">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#1531A8FF" Offset="0"/>
                                <GradientStop Color="#0031A8FF" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Canvas>
                
                <!-- Borda sutil com gradiente -->
                <Border CornerRadius="16" 
                       BorderThickness="1"
                       IsHitTestVisible="False">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#25FFFFFF" Offset="0"/>
                            <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#05FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                </Border>
                
                <!-- Conteúdo Principal -->
                <Grid Margin="40,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Logo centralizado -->
                    <Grid Grid.Row="0" 
                         HorizontalAlignment="Center" 
                         VerticalAlignment="Center">
                        
                        <!-- Glow atrás do Logo -->
                        <Border x:Name="LogoGlow"
                               Width="280" Height="180"
                               CornerRadius="40"
                               Opacity="0.4"
                               IsHitTestVisible="False"
                               Margin="0,-20,0,0">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#308B31FF" Offset="0"/>
                                    <GradientStop Color="#15FF4B6B" Offset="0.5"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                        
                        <!-- Container da Imagem -->
                        <Viewbox Stretch="Uniform" 
                                MaxWidth="380" 
                                MaxHeight="200">
                            <Image x:Name="LogoImage" 
                                  Stretch="Uniform" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"
                                  RenderOptions.BitmapScalingMode="HighQuality"
                                  UseLayoutRounding="True"
                                  SnapsToDevicePixels="True"/>
                        </Viewbox>
                    </Grid>
                    
                    <!-- Área Inferior: Progress + Status -->
                    <StackPanel Grid.Row="1" 
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom">
                        
                        <!-- Barra de Progresso Ultra Moderna -->
                        <Border Width="400" 
                               Height="3" 
                               Background="#1A1A1F"
                               CornerRadius="2"
                               Margin="0,0,0,14">
                            <Grid>
                                <!-- Barra de Preenchimento -->
                                <Border x:Name="ProgressFill"
                                       HorizontalAlignment="Left"
                                       Width="0"
                                       CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF4B6B" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="0.5"/>
                                            <GradientStop Color="#31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="ProgressGlowEffect"
                                                        BlurRadius="10" 
                                                        ShadowDepth="0" 
                                                        Color="#8B31FF" 
                                                        Opacity="0.8"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Texto de Status -->
                        <TextBlock x:Name="StatusText"
                                  Text="Inicializando..."
                                  HorizontalAlignment="Center"
                                  FontFamily="Segoe UI Variable, Segoe UI"
                                  FontSize="12"
                                  FontWeight="Medium"
                                  Foreground="#6B7280"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
