<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ============================================ -->
    <!-- VOLTRIS OPTIMIZER - ENTERPRISE DESIGN 2024  -->
    <!-- Ultra Modern Glassmorphism + Neon Glow      -->
    <!-- ============================================ -->
    
    <!-- ============================================ -->
    <!-- CORES PRINCIPAIS DA MARCA (Premium Gradient) -->
    <!-- ============================================ -->
    <Color x:Key="AccentColor">#FF4B6B</Color>
    <Color x:Key="SecondaryColor">#8B31FF</Color>
    <Color x:Key="PrimaryColor">#31A8FF</Color>
    
    <!-- Cores Extras Premium -->
    <Color x:Key="CyanColor">#00D4FF</Color>
    <Color x:Key="MagentaColor">#FF00FF</Color>
    <Color x:Key="GoldColor">#FFD700</Color>
    <Color x:Key="NeonGreenColor">#00FF88</Color>
    
    <!-- ============================================ -->
    <!-- DARK THEME - ULTRA PREMIUM -->
    <!-- ============================================ -->
    <Color x:Key="DarkColor">#0A0A0F</Color>
    <Color x:Key="DarkPanelColor">#12121A</Color>
    <Color x:Key="DarkPanelAltColor">#1A1A24</Color>
    <Color x:Key="DarkBorderColor">#2A2A3A</Color>
    <Color x:Key="DarkHoverColor">#252535</Color>
    <Color x:Key="DarkActiveColor">#1E1E28</Color>
    
    <!-- Glassmorphism Colors -->
    <Color x:Key="GlassColor">#15FFFFFF</Color>
    <Color x:Key="GlassBorderColor">#25FFFFFF</Color>
    <Color x:Key="GlassHoverColor">#20FFFFFF</Color>
    
    <!-- ============================================ -->
    <!-- CORES DE TEXTO -->
    <!-- ============================================ -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#B4B4C0</Color>
    <Color x:Key="TextMutedColor">#6B6B80</Color>
    <Color x:Key="TextDisabledColor">#4A4A5A</Color>
    
    <!-- ============================================ -->
    <!-- CORES DE STATUS (Neon Glow Style) -->
    <!-- ============================================ -->
    <Color x:Key="SuccessColor">#00FF88</Color>
    <Color x:Key="SuccessGlowColor">#3000FF88</Color>
    <Color x:Key="SuccessDarkColor">#00CC6A</Color>
    
    <Color x:Key="WarningColor">#FFAA00</Color>
    <Color x:Key="WarningGlowColor">#30FFAA00</Color>
    <Color x:Key="WarningDarkColor">#CC8800</Color>
    
    <Color x:Key="ErrorColor">#FF4466</Color>
    <Color x:Key="ErrorGlowColor">#30FF4466</Color>
    <Color x:Key="ErrorDarkColor">#CC3355</Color>
    
    <Color x:Key="InfoColor">#00D4FF</Color>
    <Color x:Key="InfoGlowColor">#3000D4FF</Color>
    <Color x:Key="InfoDarkColor">#00AACC</Color>
    
    <!-- ============================================ -->
    <!-- BRUSHES SÓLIDOS -->
    <!-- ============================================ -->
    <SolidColorBrush x:Key="DarkBrush" Color="{StaticResource DarkColor}"/>
    <SolidColorBrush x:Key="DarkPanelBrush" Color="{StaticResource DarkPanelColor}"/>
    <SolidColorBrush x:Key="DarkPanelAltBrush" Color="{StaticResource DarkPanelAltColor}"/>
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorderColor}"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="{StaticResource DarkHoverColor}"/>
    <SolidColorBrush x:Key="DarkActiveBrush" Color="{StaticResource DarkActiveColor}"/>
    
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyanColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="LightBrush" Color="{StaticResource TextPrimaryColor}"/>
    
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    
    <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource GlassColor}"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorderColor}"/>
    
    <!-- ============================================ -->
    <!-- GRADIENTES VOLTRIS PREMIUM -->
    <!-- ============================================ -->
    
    <!-- Gradiente Principal Diagonal (Rosa → Roxo → Azul) -->
    <LinearGradientBrush x:Key="VoltrisGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF4B6B" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#31A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradiente Horizontal -->
    <LinearGradientBrush x:Key="VoltrisGradientHorizontalBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF4B6B" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#31A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradiente Neon Intenso -->
    <LinearGradientBrush x:Key="NeonGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00D4FF" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#FF00FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradiente Aurora (Premium) -->
    <LinearGradientBrush x:Key="AuroraGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00FF88" Offset="0"/>
        <GradientStop Color="#00D4FF" Offset="0.33"/>
        <GradientStop Color="#8B31FF" Offset="0.66"/>
        <GradientStop Color="#FF4B6B" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradiente Vertical -->
    <LinearGradientBrush x:Key="VoltrisGradientVerticalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF4B6B" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#31A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ============================================ -->
    <!-- GLASSMORPHISM GRADIENTS -->
    <!-- ============================================ -->
    
    <!-- Glass Card Background -->
    <LinearGradientBrush x:Key="GlassCardBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#20FFFFFF" Offset="0"/>
        <GradientStop Color="#08FFFFFF" Offset="0.5"/>
        <GradientStop Color="#05FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Glass Card Border (Brilho sutil) -->
    <LinearGradientBrush x:Key="GlassCardBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#40FFFFFF" Offset="0"/>
        <GradientStop Color="#15FFFFFF" Offset="0.5"/>
        <GradientStop Color="#08FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Glass Dark -->
    <LinearGradientBrush x:Key="GlassDarkBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#301A1A24" Offset="0"/>
        <GradientStop Color="#5012121A" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Shimmer Effect (para loading) -->
    <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00FFFFFF" Offset="0"/>
        <GradientStop Color="#30FFFFFF" Offset="0.5"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ============================================ -->
    <!-- CARD GRADIENTS (Premium) -->
    <!-- ============================================ -->
    
    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A1A24" Offset="0"/>
        <GradientStop Color="#12121A" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="CardHoverGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#252535" Offset="0"/>
        <GradientStop Color="#1A1A24" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Border Gradient Sutil -->
    <LinearGradientBrush x:Key="BorderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#308B31FF" Offset="0"/>
        <GradientStop Color="#20FF4B6B" Offset="0.5"/>
        <GradientStop Color="#1031A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Active Border Gradient -->
    <LinearGradientBrush x:Key="ActiveBorderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#8031A8FF" Offset="0"/>
        <GradientStop Color="#808B31FF" Offset="0.5"/>
        <GradientStop Color="#80FF4B6B" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ============================================ -->
    <!-- GLOW EFFECTS -->
    <!-- ============================================ -->
    
    <SolidColorBrush x:Key="AccentBlurBrush" Color="#FF4B6B" Opacity="0.15"/>
    <SolidColorBrush x:Key="SecondaryBlurBrush" Color="#8B31FF" Opacity="0.15"/>
    <SolidColorBrush x:Key="PrimaryBlurBrush" Color="#31A8FF" Opacity="0.15"/>
    <SolidColorBrush x:Key="CyanBlurBrush" Color="#00D4FF" Opacity="0.15"/>
    
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#FF4B6B" Opacity="0.5"/>
    <SolidColorBrush x:Key="SecondaryGlowBrush" Color="#8B31FF" Opacity="0.5"/>
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#31A8FF" Opacity="0.5"/>
    
    <!-- ============================================ -->
    <!-- GRADIENTES DE COMPATIBILIDADE -->
    <!-- ============================================ -->
    
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF4B6B" Offset="0"/>
        <GradientStop Color="#8B31FF" Offset="0.5"/>
        <GradientStop Color="#31A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="DarkGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0A0A0F" Offset="0"/>
        <GradientStop Color="#12121A" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SectionGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#401A1A24" Offset="0"/>
        <GradientStop Color="#2012121A" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="HoverGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#25FF4B6B" Offset="0"/>
        <GradientStop Color="#158B31FF" Offset="0.5"/>
        <GradientStop Color="#0831A8FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Cores adicionais -->
    <Color x:Key="PrimaryLightColor">#5BB8FF</Color>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    
    <!-- ============================================ -->
    <!-- GRADIENTES DE STATUS -->
    <!-- ============================================ -->
    
    <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00FF88" Offset="0"/>
        <GradientStop Color="#00CC6A" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="WarningGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFAA00" Offset="0"/>
        <GradientStop Color="#FF8800" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="ErrorGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF4466" Offset="0"/>
        <GradientStop Color="#FF2244" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="InfoGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00D4FF" Offset="0"/>
        <GradientStop Color="#0088FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ============================================ -->
    <!-- RADIAL GRADIENTS (para efeitos especiais) -->
    <!-- ============================================ -->
    
    <RadialGradientBrush x:Key="SpotlightBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#408B31FF" Offset="0"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </RadialGradientBrush>
    
    <RadialGradientBrush x:Key="GlowSpotBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#6031A8FF" Offset="0"/>
        <GradientStop Color="#2031A8FF" Offset="0.5"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </RadialGradientBrush>

</ResourceDictionary>
