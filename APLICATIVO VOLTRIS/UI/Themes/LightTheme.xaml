<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ============================================ -->
    <!-- VOLTRIS OPTIMIZER - LIGHT THEME PROFISSIONAL -->
    <!-- Design moderno estilo Vale do Silício       -->
    <!-- ============================================ -->
    
    <!-- ============================================ -->
    <!-- CORES BASE DO TEMA CLARO -->
    <!-- ============================================ -->
    
    <!-- Fundos principais - Tons suaves e profissionais -->
    <Color x:Key="LightBgColor">#F8FAFC</Color>
    <Color x:Key="LightPanelColor">#FFFFFF</Color>
    <Color x:Key="LightPanelAltColor">#F1F5F9</Color>
    <Color x:Key="LightBorderColor">#E2E8F0</Color>
    <Color x:Key="LightHoverColor">#EEF2FF</Color>
    <Color x:Key="LightActiveColor">#E0E7FF</Color>
    
    <!-- Cores de Texto para Light Theme - Alto contraste -->
    <Color x:Key="LightTextPrimaryColor">#0F172A</Color>
    <Color x:Key="LightTextSecondaryColor">#334155</Color>
    <Color x:Key="LightTextMutedColor">#64748B</Color>
    <Color x:Key="LightTextDisabledColor">#94A3B8</Color>
    
    <!-- ============================================ -->
    <!-- CORES PRIMÁRIAS DA MARCA (preservadas) -->
    <!-- ============================================ -->
    <Color x:Key="AccentColor">#FF4B6B</Color>
    <Color x:Key="SecondaryColor">#8B31FF</Color>
    <Color x:Key="PrimaryColor">#2563EB</Color>
    
    <!-- Cores de Status -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    
    <!-- ============================================ -->
    <!-- SOBRESCREVENDO BRUSHES DARK PARA LIGHT -->
    <!-- ============================================ -->
    
    <!-- Fundos principais -->
    <SolidColorBrush x:Key="DarkBrush" Color="{StaticResource LightBgColor}"/>
    <SolidColorBrush x:Key="DarkPanelBrush" Color="{StaticResource LightPanelColor}"/>
    <SolidColorBrush x:Key="DarkPanelAltBrush" Color="{StaticResource LightPanelAltColor}"/>
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource LightBorderColor}"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="{StaticResource LightHoverColor}"/>
    <SolidColorBrush x:Key="DarkActiveBrush" Color="{StaticResource LightActiveColor}"/>
    
    <!-- Brushes de compatibilidade -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource LightBgColor}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource LightPanelColor}"/>
    <SolidColorBrush x:Key="PanelAltBackgroundBrush" Color="{StaticResource LightPanelAltColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource LightBorderColor}"/>
    
    <!-- ============================================ -->
    <!-- CORES DE TEXTO PARA LIGHT THEME -->
    <!-- ============================================ -->
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource LightTextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource LightTextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource LightTextMutedColor}"/>
    <SolidColorBrush x:Key="DefaultTextBrush" Color="{StaticResource LightTextPrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource LightTextSecondaryColor}"/>
    <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightTextPrimaryColor}"/>
    
    <!-- ============================================ -->
    <!-- CORES PRIMÁRIAS (Ajustadas para Light) -->
    <!-- ============================================ -->
    
    <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#7C3AED"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#EC4899"/>
    <SolidColorBrush x:Key="CyanBrush" Color="#0891B2"/>
    
    <!-- Status Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    
    <!-- ============================================ -->
    <!-- GRADIENTES AJUSTADOS PARA LIGHT THEME -->
    <!-- ============================================ -->
    
    <!-- Blur Suave (opacidade reduzida para fundo claro) -->
    <SolidColorBrush x:Key="AccentBlurBrush" Color="#EC4899" Opacity="0.08"/>
    <SolidColorBrush x:Key="SecondaryBlurBrush" Color="#7C3AED" Opacity="0.08"/>
    <SolidColorBrush x:Key="PrimaryBlurBrush" Color="#2563EB" Opacity="0.08"/>
    <SolidColorBrush x:Key="CyanBlurBrush" Color="#0891B2" Opacity="0.08"/>
    
    <!-- Glow mais suave para fundo claro -->
    <SolidColorBrush x:Key="AccentGlowBrush" Color="#EC4899" Opacity="0.20"/>
    <SolidColorBrush x:Key="SecondaryGlowBrush" Color="#7C3AED" Opacity="0.20"/>
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#2563EB" Opacity="0.20"/>
    
    <!-- Gradiente Voltris (mantido para branding) -->
    <LinearGradientBrush x:Key="VoltrisGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EC4899" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="0.5"/>
        <GradientStop Color="#2563EB" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="VoltrisGradientHorizontalBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#EC4899" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="0.5"/>
        <GradientStop Color="#2563EB" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="VoltrisGradientVerticalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#EC4899" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="0.5"/>
        <GradientStop Color="#2563EB" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Card Gradient para Light Theme -->
    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F8FAFC" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="CardHoverGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8FAFC" Offset="0"/>
        <GradientStop Color="#EEF2FF" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradiente de Borda Sutil para Light -->
    <LinearGradientBrush x:Key="BorderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#302563EB" Offset="0"/>
        <GradientStop Color="#207C3AED" Offset="0.5"/>
        <GradientStop Color="#15EC4899" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Active Border Gradient -->
    <LinearGradientBrush x:Key="ActiveBorderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#602563EB" Offset="0"/>
        <GradientStop Color="#507C3AED" Offset="0.5"/>
        <GradientStop Color="#40EC4899" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Glass Effect para Light (sombra sutil) -->
    <LinearGradientBrush x:Key="GlassGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#08000000" Offset="0"/>
        <GradientStop Color="#04000000" Offset="0.3"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="GlassCardBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#FAFAFA" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="GlassCardBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#20000000" Offset="0"/>
        <GradientStop Color="#10000000" Offset="1"/>
    </LinearGradientBrush>
    
    <SolidColorBrush x:Key="GlassBrush" Color="#FFFFFF" Opacity="0.9"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#E2E8F0"/>
    
    <!-- Hover Gradient para Light -->
    <LinearGradientBrush x:Key="HoverGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#15EC4899" Offset="0"/>
        <GradientStop Color="#107C3AED" Offset="0.5"/>
        <GradientStop Color="#082563EB" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Dark Gradient redefinido para Light -->
    <LinearGradientBrush x:Key="DarkGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F8FAFC" Offset="0"/>
        <GradientStop Color="#F1F5F9" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Section Gradient para Light -->
    <LinearGradientBrush x:Key="SectionGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F8FAFC" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Glass Dark redefinido para Light -->
    <LinearGradientBrush x:Key="GlassDarkBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F8FAFC" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Gradiente Primário -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#EC4899" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="0.5"/>
        <GradientStop Color="#2563EB" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Neon Gradient (ajustado para Light) -->
    <LinearGradientBrush x:Key="NeonGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0891B2" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="0.5"/>
        <GradientStop Color="#EC4899" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Aurora Gradient -->
    <LinearGradientBrush x:Key="AuroraGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10B981" Offset="0"/>
        <GradientStop Color="#0891B2" Offset="0.33"/>
        <GradientStop Color="#7C3AED" Offset="0.66"/>
        <GradientStop Color="#EC4899" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ============================================ -->
    <!-- GRADIENTES DE STATUS -->
    <!-- ============================================ -->
    
    <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#10B981" Offset="0"/>
        <GradientStop Color="#059669" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="WarningGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F59E0B" Offset="0"/>
        <GradientStop Color="#D97706" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="ErrorGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#EF4444" Offset="0"/>
        <GradientStop Color="#DC2626" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="InfoGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3B82F6" Offset="0"/>
        <GradientStop Color="#2563EB" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ============================================ -->
    <!-- RADIAL GRADIENTS -->
    <!-- ============================================ -->
    
    <RadialGradientBrush x:Key="SpotlightBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#207C3AED" Offset="0"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </RadialGradientBrush>
    
    <RadialGradientBrush x:Key="GlowSpotBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#302563EB" Offset="0"/>
        <GradientStop Color="#102563EB" Offset="0.5"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </RadialGradientBrush>
    
    <!-- Cores adicionais -->
    <Color x:Key="PrimaryLightColor">#60A5FA</Color>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    
    <!-- Shimmer Effect -->
    <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00000000" Offset="0"/>
        <GradientStop Color="#10000000" Offset="0.5"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ============================================ -->
    <!-- FEATURE CARD STYLE PARA LIGHT -->
    <!-- ============================================ -->
    
    <LinearGradientBrush x:Key="FeatureCardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#082563EB" Offset="0"/>
        <GradientStop Color="#057C3AED" Offset="0.5"/>
        <GradientStop Color="#03EC4899" Offset="1"/>
    </LinearGradientBrush>
    
</ResourceDictionary>
