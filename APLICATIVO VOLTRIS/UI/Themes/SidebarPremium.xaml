<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ============================================ -->
    <!-- VOLTRIS PREMIUM SIDEBAR - DESIGN MODERNO    -->
    <!-- Glassmorphism + Neon + Animações Suaves     -->
    <!-- ============================================ -->
    
    <!-- ============================================ -->
    <!-- ESTILO DO SIDEBAR CONTAINER                 -->
    <!-- ============================================ -->
    <Style x:Key="PremiumSidebarContainerStyle" TargetType="Border">
        <Setter Property="Width" Value="260"/>
        <Setter Property="MinWidth" Value="240"/>
        <Setter Property="MaxWidth" Value="300"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource DarkBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4031A8FF" Offset="0"/>
                    <GradientStop Color="#308B31FF" Offset="0.5"/>
                    <GradientStop Color="#20FF4B6B" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" 
                                  ShadowDepth="0" 
                                  Color="#8B31FF" 
                                  Opacity="0.15" 
                                  Direction="90"/>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DO HEADER (LOGO SECTION)             -->
    <!-- ============================================ -->
    <Style x:Key="PremiumSidebarHeaderStyle" TargetType="Border">
        <Setter Property="Padding" Value="20,28,20,24"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#151520" Offset="0"/>
                    <GradientStop Color="#1A1A28" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4031A8FF" Offset="0"/>
                    <GradientStop Color="#308B31FF" Offset="0.5"/>
                    <GradientStop Color="#20FF4B6B" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DO FOOTER (STATUS SECTION)           -->
    <!-- ============================================ -->
    <Style x:Key="PremiumSidebarFooterStyle" TargetType="Border">
        <Setter Property="Padding" Value="20,16,20,16"/>
        <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#20FF007A" Offset="0"/>
                    <GradientStop Color="#308B31FF" Offset="0.5"/>
                    <GradientStop Color="#4000D4FF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>
    
    <!-- ============================================ -->
    <!-- BOTÃO DE NAVEGAÇÃO PREMIUM MODERNO          -->
    <!-- ============================================ -->
    <Style x:Key="PremiumNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,6,16,6"/>
        <Setter Property="Margin" Value="8,1,8,1"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="0,0,0,0" ClipToBounds="False">
                        <!-- Indicador Lateral Neon Animado -->
                        <Border x:Name="LeftIndicator"
                                Width="0"
                                HorizontalAlignment="Left"
                                CornerRadius="0,4,4,0"
                                Opacity="0"
                                VerticalAlignment="Stretch"
                                Margin="-2,4,0,4"
                                ClipToBounds="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF007A" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#00D4FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect x:Name="indicatorGlow"
                                                  BlurRadius="12" 
                                                  ShadowDepth="0" 
                                                  Color="#8B31FF" 
                                                  Opacity="0"/>
                            </Border.Effect>
                        </Border>
                        
                        <!-- Background com Glassmorphism Moderno -->
                            <Border x:Name="BackgroundBorder"
                                Background="Transparent"
                                CornerRadius="10"
                                Margin="0,0,0,0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="scaleTransform" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="translateTransform" X="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            
                            <Grid>
                                <!-- Efeito Glass Overlay -->
                                <Border CornerRadius="10"
                                        Opacity="0"
                                        IsHitTestVisible="False"
                                        x:Name="GlassOverlay">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#15FFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                
                                <!-- Shimmer Effect Moderno -->
                                <Border x:Name="ShimmerBorder"
                                        CornerRadius="10"
                                        Opacity="0"
                                        IsHitTestVisible="False">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="-1,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                                            <GradientStop Color="#25FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                
                                <ContentPresenter HorizontalAlignment="Left" 
                                                  VerticalAlignment="Center"
                                                  Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- Hover State - Animações Suaves -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BackgroundBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A1A28" Offset="0"/>
                                        <GradientStop Color="#151520" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="GlassOverlay" Property="Opacity" Value="0.2"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- Slide Right Suave -->
                                        <DoubleAnimation Storyboard.TargetName="translateTransform"
                                                       Storyboard.TargetProperty="X"
                                                       To="6"
                                                       Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- Scale Up Sutil -->
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="1.03"
                                                       Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="1.03"
                                                       Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- Indicator Appear -->
                                        <DoubleAnimation Storyboard.TargetName="LeftIndicator"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="1"
                                                       Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="LeftIndicator"
                                                       Storyboard.TargetProperty="Width"
                                                       To="4"
                                                       Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- Indicator Glow -->
                                        <DoubleAnimation Storyboard.TargetName="indicatorGlow"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="0.8"
                                                       Duration="0:0:0.25"/>
                                        <!-- Shimmer Animation -->
                                        <DoubleAnimation Storyboard.TargetName="ShimmerBorder"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="0.3"
                                                       Duration="0:0:0.4"
                                                       AutoReverse="True"
                                                       RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="translateTransform"
                                                       Storyboard.TargetProperty="X"
                                                       To="0"
                                                       Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="1"
                                                       Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="scaleTransform"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="1"
                                                       Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="LeftIndicator"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="0"
                                                       Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="LeftIndicator"
                                                       Storyboard.TargetProperty="Width"
                                                       To="0"
                                                       Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="indicatorGlow"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="0"
                                                       Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="GlassOverlay"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="0"
                                                       Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ShimmerBorder"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="0"
                                                       Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ============================================ -->
    <!-- BOTÃO DE NAVEGAÇÃO ATIVO (PREMIUM)          -->
    <!-- ============================================ -->
    <Style x:Key="PremiumNavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource PremiumNavButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="0,0,0,0" ClipToBounds="False">
                        <!-- Indicador Lateral VISÍVEL com Glow Intenso -->
                        <Border x:Name="LeftIndicator"
                                Width="4"
                                HorizontalAlignment="Left"
                                CornerRadius="0,4,4,0"
                                Opacity="1"
                                VerticalAlignment="Stretch"
                                Margin="-2,4,0,4"
                                ClipToBounds="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF007A" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#00D4FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" 
                                                  ShadowDepth="0" 
                                                  Color="#8B31FF" 
                                                  Opacity="1"/>
                            </Border.Effect>
                        </Border>
                        
                        <!-- Background Ativo com Gradiente Neon Premium -->
                        <Border x:Name="BackgroundBorder"
                                CornerRadius="10"
                                Margin="0,0,0,0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#151520" Offset="0"/>
                                    <GradientStop Color="#1A1A28" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4031A8FF" Offset="0"/>
                                    <GradientStop Color="#308B31FF" Offset="0.5"/>
                                    <GradientStop Color="#20FF4B6B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" 
                                                  ShadowDepth="0" 
                                                  Color="#8B31FF" 
                                                  Opacity="0.2"/>
                            </Border.Effect>
                            
                            <Grid>
                                <!-- Glass Overlay Ativo -->
                                <Border CornerRadius="10"
                                        Opacity="0.15"
                                        IsHitTestVisible="False"
                                        x:Name="GlassOverlay">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#20FFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                
                                <!-- Pulse Effect -->
                                <Border x:Name="PulseBorder"
                                        CornerRadius="10"
                                        Opacity="0.3"
                                        IsHitTestVisible="False">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                                            <GradientStop Color="#40FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                
                                <ContentPresenter HorizontalAlignment="Left" 
                                                  VerticalAlignment="Center"
                                                  Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- Pulse Animation para Item Ativo -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BackgroundBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A1A28" Offset="0"/>
                                        <GradientStop Color="#202030" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="BackgroundBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="20" 
                                                      ShadowDepth="0" 
                                                      Color="#8B31FF" 
                                                      Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="PulseStoryboard">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PulseBorder"
                                                       Storyboard.TargetProperty="Opacity"
                                                       From="0.3"
                                                       To="0.6"
                                                       Duration="0:0:1.5"
                                                       AutoReverse="True"
                                                       RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <!-- Auto Pulse quando ativo (sempre rodando) -->
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard x:Name="AutoPulseStoryboard">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="PulseBorder"
                                                   Storyboard.TargetProperty="Opacity"
                                                   From="0.3"
                                                   To="0.5"
                                                   Duration="0:0:1.5"
                                                   AutoReverse="True"
                                                   RepeatBehavior="Forever">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DO SCROLLVIEWER PREMIUM              -->
    <!-- ============================================ -->
    <Style x:Key="PremiumSidebarScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="0,4,0,4"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
    </Style>
    
    <!-- ============================================ -->
    <!-- ESTILO DO STATUS INDICATOR                  -->
    <!-- ============================================ -->
    <Style x:Key="PremiumStatusIndicatorStyle" TargetType="Border">
        <Setter Property="Height" Value="4"/>
        <Setter Property="Background" Value="#1A1A1F"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>
    
    <Style x:Key="PremiumStatusIndicatorFillStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF007A" Offset="0"/>
                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                    <GradientStop Color="#00D4FF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="10" 
                                  ShadowDepth="0" 
                                  Color="#8B31FF" 
                                  Opacity="0.8"/>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>

