    <!-- ============================================ -->
    <!-- BARRA DE PROGRESSO ANIMADA COM GLOW -->
    <!-- ============================================ -->
    <Style x:Key="AnimatedProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="{StaticResource DarkBorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource VoltrisGradientHorizontalBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Height="{TemplateBinding Height}"/>
                        <Border x:Name="Indicator"
                                Background="{StaticResource VoltrisGradientHorizontalBrush}"
                                CornerRadius="4"
                                HorizontalAlignment="Left"
                                Width="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ============================================ -->
    <!-- CHECKBOX MODERNO COM CHECKMARK ANIMADO -->
    <!-- ============================================ -->
    <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Container do Checkbox -->
                        <Border x:Name="checkBoxBorder"
                                Grid.Column="0"
                                Width="22"
                                Height="22"
                                Background="{StaticResource DarkPanelBrush}"
                                BorderBrush="{StaticResource DarkBorderBrush}"
                                BorderThickness="2"
                                CornerRadius="6"
                                Margin="0,0,12,0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="checkBoxScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            
                            <!-- Checkmark Icon -->
                            <Path x:Name="CheckMark"
                                  Data="M 3,7 L 7,11 L 13,3"
                                  Stroke="White"
                                  StrokeThickness="2.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Opacity="0"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="2"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="checkMarkScale" ScaleX="0" ScaleY="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        
                        <ContentPresenter Grid.Column="1"
                                        VerticalAlignment="Center"
                                        RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Estado Checked com Animação -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="checkBoxBorder" Property="Background" Value="{StaticResource VoltrisGradientBrush}"/>
                            <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="Transparent"/>
                            <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- Bounce do checkbox -->
                                        <DoubleAnimation Storyboard.TargetName="checkBoxScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       From="1" To="1.15"
                                                       Duration="0:0:0.1"
                                                       AutoReverse="True">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="checkBoxScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       From="1" To="1.15"
                                                       Duration="0:0:0.1"
                                                       AutoReverse="True">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- Animação do checkmark -->
                                        <DoubleAnimation Storyboard.TargetName="checkMarkScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       From="0" To="1"
                                                       Duration="0:0:0.2"
                                                       BeginTime="0:0:0.05">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="checkMarkScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       From="0" To="1"
                                                       Duration="0:0:0.2"
                                                       BeginTime="0:0:0.05">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="checkMarkScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="0"
                                                       Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="checkMarkScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="0"
                                                       Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="checkBoxBorder" Property="Background" Value="{StaticResource DarkHoverBrush}"/>
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
