<UserControl x:Class="VoltrisOptimizer.UI.Views.LyraResponseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <!-- Recursos Locais (definidos primeiro) -->
    <UserControl.Resources>
        <DropShadowEffect x:Key="ModernCardShadow"
                         BlurRadius="24" 
                         ShadowDepth="0" 
                         Opacity="0.25" 
                         Color="Black"/>
    </UserControl.Resources>
    
    <Grid Margin="24,20,24,20"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        
        <!-- ============================================ -->
        <!-- ESTADO DE CARREGAMENTO -->
        <!-- ============================================ -->
        <Grid x:Name="LoadingState"
              Visibility="Visible"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header com Gradiente -->
            <Border Grid.Row="0"
                   Background="{StaticResource DarkPanelAltBrush}"
                   BorderBrush="{StaticResource DarkBorderBrush}"
                   BorderThickness="1"
                   CornerRadius="16"
                   Padding="32,24"
                   Effect="{StaticResource ModernCardShadow}">
                <StackPanel>
                    <!-- Ícone e Título -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border Width="64" Height="64"
                               Background="{StaticResource VoltrisGradientBrush}"
                               CornerRadius="16"
                               Margin="0,0,16,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" 
                                                ShadowDepth="0" 
                                                Opacity="0.6" 
                                                Color="{StaticResource PrimaryColor}"/>
                            </Border.Effect>
                            <TextBlock Text="✨"
                                      FontSize="36"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Consultando a Lyra..."
                                      FontSize="28"
                                      FontWeight="Bold"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="Sua assistente de IA está processando sua solicitação..."
                                      FontSize="12"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Pergunta do Usuário -->
                    <Border Background="{StaticResource DarkPanelBrush}"
                           BorderBrush="{StaticResource PrimaryBrush}"
                           BorderThickness="1"
                           CornerRadius="12"
                           Padding="20,16"
                           Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Sua pergunta:"
                                      FontSize="11"
                                      Foreground="{StaticResource TextMutedBrush}"
                                      FontWeight="Medium"
                                      Margin="0,0,0,8"/>
                            <TextBlock x:Name="UserQuestionText"
                                      Text=""
                                      FontSize="15"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="22"
                                      FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Animação de Carregamento -->
            <Grid Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <!-- ProgressBar Indeterminado com Gradiente -->
                    <ProgressBar x:Name="LoadingProgressBar"
                                IsIndeterminate="True"
                                Height="8"
                                Width="500"
                                Margin="0,0,0,32"
                                Background="{StaticResource DarkBorderBrush}"
                                BorderThickness="0">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                    
                    <!-- Status Dinâmico -->
                    <TextBlock x:Name="StatusText"
                              Text="Conectando..."
                              FontSize="14"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              HorizontalAlignment="Center"
                              TextAlignment="Center"
                              FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Grid>
        
        <!-- ============================================ -->
        <!-- ESTADO DE RESPOSTA -->
        <!-- ============================================ -->
        <Grid x:Name="ResponseState"
              Visibility="Collapsed"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header da Resposta -->
            <Border Grid.Row="0"
                   Background="{StaticResource DarkPanelAltBrush}"
                   BorderBrush="{StaticResource DarkBorderBrush}"
                   BorderThickness="1"
                   CornerRadius="16"
                   Padding="32,24"
                   Effect="{StaticResource ModernCardShadow}">
                <StackPanel>
                    <!-- Ícone e Título -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border Width="56" Height="56"
                               Background="{StaticResource VoltrisGradientBrush}"
                               CornerRadius="14"
                               Margin="0,0,16,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" 
                                                ShadowDepth="0" 
                                                Opacity="0.5" 
                                                Color="{StaticResource PrimaryColor}"/>
                            </Border.Effect>
                            <TextBlock Text="✨"
                                      FontSize="32"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Resposta da Lyra"
                                      FontSize="24"
                                      FontWeight="Bold"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="Sua assistente especialista em Windows"
                                      FontSize="11"
                                      Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Pergunta do Usuário (mostrar novamente) -->
                    <Border Background="{StaticResource DarkPanelBrush}"
                           BorderBrush="{StaticResource PrimaryBrush}"
                           BorderThickness="1"
                           CornerRadius="12"
                           Padding="20,16"
                           Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Sua pergunta:"
                                      FontSize="11"
                                      Foreground="{StaticResource TextMutedBrush}"
                                      FontWeight="Medium"
                                      Margin="0,0,0,8"/>
                            <TextBlock x:Name="UserQuestionTextResponse"
                                      Text=""
                                      FontSize="14"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      TextWrapping="Wrap"
                                      LineHeight="20"
                                      FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Resposta Formatada -->
            <Border Grid.Row="4"
                   Background="{StaticResource DarkPanelAltBrush}"
                   BorderBrush="{StaticResource DarkBorderBrush}"
                   BorderThickness="1"
                   CornerRadius="16"
                   Padding="32,24"
                   VerticalAlignment="Stretch"
                   Effect="{StaticResource ModernCardShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalAlignment="Stretch"
                            Padding="0">
                    <StackPanel>
                        <TextBlock x:Name="ResponseText"
                                  Text=""
                                  FontSize="14"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  TextWrapping="Wrap"
                                  LineHeight="24"
                                  Margin="0,0,0,24"/>
                        
                        <!-- Ações Sugeridas -->
                        <ItemsControl x:Name="ActionsContainer"
                                     Visibility="Collapsed"
                                     Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="Transparent"
                                           BorderThickness="0"
                                           Padding="0"
                                           Margin="0,0,0,12"
                                           Click="ActionButton_Click"
                                           Cursor="Hand"
                                           HorizontalContentAlignment="Stretch">
                                        <Button.Content>
                                            <Border Background="{StaticResource DarkPanelBrush}"
                                                   BorderBrush="{StaticResource PrimaryBrush}"
                                                   BorderThickness="1"
                                                   CornerRadius="10"
                                                   Padding="16,12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource DarkPanelAltBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource SecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Ícone -->
                                                    <Border Grid.Column="0"
                                                           Width="36" Height="36"
                                                           Background="{StaticResource VoltrisGradientBrush}"
                                                           CornerRadius="8"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center">
                                                        <TextBlock Text="🔍"
                                                                  FontSize="18"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                    </Border>
                                                    
                                                    <!-- Texto da Ação -->
                                                    <TextBlock Grid.Column="1"
                                                             Text="{Binding}"
                                                             FontSize="13"
                                                             Foreground="{StaticResource TextPrimaryBrush}"
                                                             TextWrapping="Wrap"
                                                             VerticalAlignment="Center"
                                                             FontWeight="Medium"/>
                                                </Grid>
                                            </Border>
                                        </Button.Content>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- Botão Voltar -->
            <Button Grid.Row="6"
                   x:Name="BackButton"
                   Content="← Voltar ao Dashboard"
                   Style="{StaticResource NeonButtonStyle}"
                   MinHeight="48"
                   Height="Auto"
                   FontSize="14"
                   Padding="32,14"
                   HorizontalAlignment="Center"
                   MinWidth="240"
                   Click="BackButton_Click"
                   Cursor="Hand">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="12" 
                                    ShadowDepth="0" 
                                    Opacity="0.4" 
                                    Color="{StaticResource PrimaryColor}"/>
                </Button.Effect>
            </Button>
        </Grid>
    </Grid>
</UserControl>
