<UserControl x:Class="VoltrisOptimizer.UI.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sipviews="clr-namespace:VoltrisOptimizer.Core.SystemIntelligenceProfiler.UI.Views"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-120,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300" Height="300" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header Centralizado -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center" Orientation="Horizontal">
                <StackPanel.RenderTransform>
                    <TranslateTransform/>
                </StackPanel.RenderTransform>
                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>
                
                <!-- Ícone moderno com gradiente -->
                <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#14B8A6" Offset="0"/>
                            <GradientStop Color="#10B981" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#14B8A6" Opacity="0.4"/>
                    </Border.Effect>
                    <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M13,13V18H10V13H13M14,13H17V18H14V13M7,13H10V18H7V13Z" 
                          Fill="White"
                          Width="20" Height="20"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>
                
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Logs"
                              FontFamily="Segoe UI Variable Display, Segoe UI"
                              FontSize="26"
                              FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Visualize os registros de atividades do sistema"
                              FontSize="12"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Estatísticas de Logs -->
            <Border Grid.Row="1"
                    Background="{DynamicResource DarkPanelBrush}"
                    BorderBrush="{DynamicResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Info Count -->
                    <Border Grid.Column="0" Margin="0,0,8,0" Padding="16,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource PrimaryColor}" Opacity="0.1"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="InfoCountText" Text="0" FontSize="24" FontWeight="Bold"
                                      Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="INFO" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" 
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Success Count -->
                    <Border Grid.Column="1" Margin="4,0" Padding="16,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource SuccessColor}" Opacity="0.1"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="SuccessCountText" Text="0" FontSize="24" FontWeight="Bold"
                                      Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="SUCCESS" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" 
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Warning Count -->
                    <Border Grid.Column="2" Margin="4,0" Padding="16,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource WarningColor}" Opacity="0.1"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="WarningCountText" Text="0" FontSize="24" FontWeight="Bold"
                                      Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="WARNING" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" 
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Error Count -->
                    <Border Grid.Column="3" Margin="8,0,0,0" Padding="16,12" CornerRadius="10">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource ErrorColor}" Opacity="0.1"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="ErrorCountText" Text="0" FontSize="24" FontWeight="Bold"
                                      Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="ERROR" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" 
                                      HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Filtros e Busca -->
            <Border Grid.Row="2"
                    Background="{DynamicResource DarkPanelBrush}"
                    BorderBrush="{DynamicResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20"
                    Margin="0,0,0,16">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard BeginTime="0:0:0.1">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="SearchTextBox"
                            Grid.Column="0"
                            Style="{StaticResource ModernTextBoxStyle}"
                            MinHeight="44"
                            Margin="0,0,20,0"
                            TextChanged="SearchTextBox_TextChanged"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="FilterInfoCheckBox"
                                 Content="INFO"
                                 IsChecked="True"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Margin="0,0,14,0"
                                 Checked="FilterCheckBox_Changed"
                                 Unchecked="FilterCheckBox_Changed"
                                 Style="{StaticResource ModernCheckBoxStyle}"/>
                        
                        <CheckBox x:Name="FilterSuccessCheckBox"
                                 Content="SUCCESS"
                                 IsChecked="True"
                                 Foreground="{DynamicResource SuccessBrush}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Margin="0,0,14,0"
                                 Checked="FilterCheckBox_Changed"
                                 Unchecked="FilterCheckBox_Changed"
                                 Style="{StaticResource ModernCheckBoxStyle}"/>
                        
                        <CheckBox x:Name="FilterWarningCheckBox"
                                 Content="WARNING"
                                 IsChecked="True"
                                 Foreground="{DynamicResource WarningBrush}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Margin="0,0,14,0"
                                 Checked="FilterCheckBox_Changed"
                                 Unchecked="FilterCheckBox_Changed"
                                 Style="{StaticResource ModernCheckBoxStyle}"/>
                        
                        <CheckBox x:Name="FilterErrorCheckBox"
                                 Content="ERROR"
                                 IsChecked="True"
                                 Foreground="{DynamicResource ErrorBrush}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Checked="FilterCheckBox_Changed"
                                 Unchecked="FilterCheckBox_Changed"
                                 Style="{StaticResource ModernCheckBoxStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Área de Logs -->
            <Border Grid.Row="3"
                    Background="{DynamicResource DarkPanelBrush}"
                    BorderBrush="{DynamicResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16"
                    Margin="0,0,0,16">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard BeginTime="0:0:0.2">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                
                <ListBox x:Name="LogsListBox"
                        Background="Transparent"
                        BorderThickness="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        FontFamily="Cascadia Code, Consolas, monospace"
                        FontSize="11"
                        SelectionMode="Extended">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Margin" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DarkPanelAltBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DarkPanelAltBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
            
            <!-- Console do Profiler -->
            <Border Grid.Row="4"
                    Background="{DynamicResource DarkPanelBrush}"
                    BorderBrush="{DynamicResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20"
                    Margin="0,0,0,16"
                    MaxHeight="180">
                <Border.RenderTransform>
                    <TranslateTransform/>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard BeginTime="0:0:0.3">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                    <GradientStop Color="#6D28D9" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🖥️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Console do Profiler"
                                  FontWeight="SemiBold"
                                  FontSize="15"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <sipviews:LogConsoleView Grid.Row="1"/>
                </Grid>
            </Border>
            
            <!-- Botões -->
            <StackPanel Grid.Row="5"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right">
                <StackPanel.RenderTransform>
                    <TranslateTransform/>
                </StackPanel.RenderTransform>
                <StackPanel.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard BeginTime="0:0:0.4">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </StackPanel.Triggers>
                
                <Button x:Name="RefreshButton"
                       Content="🔄 Atualizar"
                       Style="{StaticResource NeonSecondaryButtonStyle}"
                       MinHeight="46"
                       Padding="20,0"
                       Click="RefreshButton_Click"
                       Margin="0,0,12,0"/>
                
                <Button x:Name="ClearLogsButton"
                       Content="🗑️ Limpar Logs"
                       Style="{StaticResource NeonSecondaryButtonStyle}"
                       MinHeight="46"
                       Padding="20,0"
                       Click="ClearLogsButton_Click"
                       Margin="0,0,12,0"/>
                
                <Button x:Name="ExportLogsButton"
                       Content="📥 Exportar Logs"
                       Style="{StaticResource NeonButtonStyle}"
                       MinHeight="46"
                       Padding="20,0"
                       Click="ExportLogsButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
