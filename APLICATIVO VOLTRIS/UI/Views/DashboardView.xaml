<UserControl x:Class="VoltrisOptimizer.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             Background="{DynamicResource DarkBrush}">
    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="DashboardVM" />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Card Moderno com Glass Effect -->
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20,18"/>
        </Style>
        
        <!-- Ícones -->
        <Geometry x:Key="StatusIcon">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z</Geometry>
        <Geometry x:Key="CleanupIcon">M19.36,2.72L20.78,4.14L15.06,9.85C16.13,11.39 16.28,13.24 15.38,14.44L9.06,8.12C10.26,7.22 12.11,7.37 13.65,8.44L19.36,2.72M5.93,17.57C3.92,15.56 2.69,13.16 2.35,10.92L7.23,8.83L14.67,16.27L12.58,21.15C10.34,20.81 7.94,19.58 5.93,17.57Z</Geometry>
        <Geometry x:Key="ComputerIcon">M4,6H20V16H4M20,18A2,2 0 0,0 22,16V6C22,4.89 21.1,4 20,4H4C2.89,4 2,4.89 2,6V16A2,2 0 0,0 4,18H0V20H24V18H20Z</Geometry>
        <Geometry x:Key="AdaptiveIcon">M12,3A9,9 0 0,0 3,12H0L4,16L8,12H5A7,7 0 0,1 12,5A7,7 0 0,1 19,12A7,7 0 0,1 12,19C10.5,19 9.09,18.5 7.94,17.7L6.5,19.14C8.04,20.3 9.94,21 12,21A9,9 0 0,0 21,12A9,9 0 0,0 12,3M14,12A2,2 0 0,0 12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12Z</Geometry>
        <Geometry x:Key="AIIcon">M21.33,12.91C21.42,14.46 20.71,15.95 19.44,16.86L20.21,18.35C20.44,18.8 20.47,19.33 20.27,19.8C20.08,20.27 19.69,20.64 19.21,20.8L18.42,21.05C18.25,21.11 18.06,21.14 17.88,21.14C17.37,21.14 16.89,20.91 16.56,20.5L14.44,18.16L14.14,18.38C12.57,19.43 10.56,19.64 8.8,18.94L8.03,18.66L7.59,19.26C7.18,19.8 6.55,20.13 5.88,20.15C5.21,20.17 4.56,19.87 4.13,19.34L3.67,18.77C3.24,18.23 3.09,17.53 3.25,16.87L3.58,15.5C2.38,14.2 1.81,12.46 2.03,10.74C2.24,9 3.17,7.44 4.59,6.43C6.01,5.43 7.79,5.04 9.5,5.36L9.77,4.46C9.96,3.82 10.4,3.28 11,2.96C11.58,2.63 12.28,2.54 12.93,2.71L13.76,2.94C14.42,3.12 14.97,3.56 15.29,4.16C15.61,4.76 15.67,5.47 15.47,6.13L14.7,8.53C15.34,9.28 15.78,10.18 15.97,11.16L17.64,11.44C18.31,11.55 18.88,11.93 19.24,12.49C19.6,13.06 19.71,13.75 19.54,14.41L20.13,14.5C20.5,14.53 20.87,14.37 21.11,14.07C21.35,13.77 21.42,13.37 21.33,12.91Z</Geometry>
        <Geometry x:Key="RocketIcon">M12.25,2.71L12.66,3.13L13.08,2.71C13.47,2.32 14.1,2.32 14.5,2.71C14.89,3.1 14.89,3.73 14.5,4.13L12.66,5.96L10.83,4.13C10.44,3.73 10.44,3.1 10.83,2.71C11.22,2.32 11.85,2.32 12.25,2.71M3,13L4,14V18A2,2 0 0,0 6,20H18A2,2 0 0,0 20,18V14L21,13V20H3V13M12,5A8,8 0 0,1 20,13H4A8,8 0 0,1 12,5M12,7A6,6 0 0,0 6,13H18A6,6 0 0,0 12,7Z</Geometry>
        
        <!-- Animação de entrada para cards -->
        <Storyboard x:Key="CardFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-150,-150,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="250" Height="250" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,200,100">
                <Ellipse.Effect>
                    <BlurEffect Radius="60"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
            <Grid Margin="24,16,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header Centralizado -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <!-- Ícone moderno com gradiente -->
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#3B82F6" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="M3,13H5V11H3V13M3,17H5V15H3V17M3,9H5V7H3V9M7,13H21V11H7V13M7,17H21V15H7V17M7,7V9H21V7H7Z" 
                              Fill="White"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Dashboard"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Visão geral do seu sistema e otimizações"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Cards de Status Principais -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card Status do Sistema -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.1">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#059669" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="{StaticResource StatusIcon}" 
                                          Fill="White"
                                          Width="18" Height="18"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Status do Sistema" 
                                          FontWeight="SemiBold" 
                                          FontSize="14"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Margin="0,4,0,12">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Ellipse x:Name="StatusIndicator" 
                                            Width="10" Height="10" 
                                            Fill="{DynamicResource SuccessBrush}"
                                            Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#22C55E" Opacity="0.6"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock x:Name="SystemStatusText" 
                                              Text="Verificando..." 
                                              FontSize="26" 
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock x:Name="SystemStatusDescription" 
                                          Text="Analisando saúde do sistema" 
                                          FontSize="12" 
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <Button Grid.Row="2"
                                    x:Name="VerifySystemButton"
                                    Click="VerifySystemButton_Click"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,10"
                                    FontSize="12"
                                    FontWeight="SemiBold">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Verificar Sistema"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Card Limpeza Disponível -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.2">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#D97706" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="{StaticResource CleanupIcon}" 
                                          Fill="White"
                                          Width="18" Height="18"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Limpeza Disponível" 
                                          FontWeight="SemiBold" 
                                          FontSize="14"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Margin="0,4,0,12">
                                <TextBlock x:Name="CleanupSizeText" 
                                          Text="Analisando..." 
                                          FontSize="26" 
                                          FontWeight="Bold"
                                          Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock x:Name="CleanupDetailsText"
                                          Text="arquivos temporários detectados" 
                                          FontSize="12" 
                                          Foreground="{DynamicResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                            
                            <Button Grid.Row="2"
                                    Style="{StaticResource NeonButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,10"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Command="{Binding QuickCleanupCommand}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🧹" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Limpar Agora"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Progress Indicator Profissional -->
                            <StackPanel Grid.Row="3" 
                                        Visibility="{Binding IsCleaning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Margin="0,12,0,0">
                                <TextBlock Text="{Binding CleanupStatus}" 
                                          FontSize="12" 
                                          FontWeight="Medium"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,8"/>
                                <ProgressBar Height="4" 
                                            IsIndeterminate="True"
                                            Background="#2A2A3A"
                                            BorderThickness="0">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Setter Property="Background" Value="#2A2A3A"/>
                                            <Setter Property="Foreground">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Cards de Informação -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card Informações do Sistema -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.3">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#1D4ED8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="{StaticResource ComputerIcon}" 
                                          Fill="White"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Informações do Sistema" 
                                          FontWeight="SemiBold" 
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Windows:" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="WindowsVersionText" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,8" HorizontalAlignment="Right"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Processador:" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ProcessorText" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,8" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Memória:" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RAMText" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,8" HorizontalAlignment="Right"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Armazenamento:" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="StorageText" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,8" HorizontalAlignment="Right"/>
                                
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Desempenho:" FontSize="13" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="PerformancePercentText" FontSize="13" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold" Margin="8,8" HorizontalAlignment="Right"/>
                                
                                <!-- Botão Melhorar Desempenho (aparece quando < 80%) -->
                                <Button Grid.Row="5" Grid.ColumnSpan="2"
                                        x:Name="ImprovePerformanceButton"
                                        Visibility="Collapsed"
                                        Click="ImprovePerformanceButton_Click"
                                        Style="{StaticResource NeonButtonStyle}"
                                        HorizontalAlignment="Stretch"
                                        Padding="12,10"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Margin="0,16,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="ImprovePerformanceText" Text="Melhorar Desempenho"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Card Modo Adaptativo -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.4">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8B5CF6" Offset="0"/>
                                            <GradientStop Color="#6D28D9" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="{StaticResource AdaptiveIcon}" 
                                          Fill="White"
                                          Width="20" Height="20"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Modo Adaptativo" 
                                          FontWeight="SemiBold" 
                                          FontSize="16"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Ellipse Width="10" Height="10" Fill="{DynamicResource SuccessBrush}" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#22C55E" Opacity="0.5"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="AdaptiveStatusText" 
                                          Text="Ativo" 
                                          FontSize="20" 
                                          FontWeight="SemiBold"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            
                            <Border Background="{DynamicResource DarkBorderBrush}" Height="1" Margin="0,0,0,16" Opacity="0.5"/>
                            
                            <TextBlock Text="Último Incidente" 
                                      FontWeight="SemiBold" 
                                      FontSize="12"
                                      Foreground="{DynamicResource TextMutedBrush}"
                                      Margin="0,0,0,8"/>
                            <TextBlock x:Name="IncidentText" 
                                      Text="Nenhum incidente detectado" 
                                      FontSize="13" 
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      TextWrapping="Wrap"
                                      MaxWidth="400"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Card Assistente Inteligente -->
                <Border Grid.Row="3" Style="{StaticResource DashboardCard}" Padding="28">
                    <Border.RenderTransform>
                        <TranslateTransform/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard BeginTime="0:0:0.5">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Width="48" Height="48" CornerRadius="14" Margin="0,0,16,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="{StaticResource AIIcon}" 
                                      Width="24" Height="24"
                                      Stretch="Uniform"
                                      Fill="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Assistente Inteligente Lyra" 
                                          FontWeight="Bold" 
                                          FontSize="18"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Pergunte sobre otimizações ou solicite diagnósticos" 
                                          FontSize="13"
                                          Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Input de Chat -->
                        <Border Background="{DynamicResource DarkPanelAltBrush}"
                                BorderBrush="{DynamicResource DarkBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="4"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AIChatInput" 
                                        Grid.Column="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        FontSize="14"
                                        Padding="14,12"
                                        VerticalContentAlignment="Center"
                                        Text="Digite sua pergunta ou problema..."/>
                                <Button Grid.Column="1" 
                                        Style="{StaticResource NeonButtonStyle}"
                                        Padding="18,12"
                                        Margin="4"
                                        MinWidth="0"
                                        MinHeight="0"
                                        x:Name="SendQueryButton"
                                        Click="AskAIButton_Click">
                                    <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" 
                                          Fill="White" 
                                          Width="18" Height="18" 
                                          Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <!-- Botões de Ação Rápida -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0"
                                    x:Name="OptimizationButton"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Click="OptimizationButton_Click"
                                    Padding="12,14"
                                    MinHeight="52">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🚀" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Otimização Inteligente" 
                                              VerticalAlignment="Center"
                                              FontSize="12"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Grid.Column="2"
                                    x:Name="DiagnosticButton"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Click="DiagnosticButton_Click"
                                    Padding="12,14"
                                    MinHeight="52">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Diagnóstico" 
                                              VerticalAlignment="Center"
                                              FontSize="12"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Grid.Column="4"
                                    x:Name="AskAIButton" 
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Click="AskAIButton_Click"
                                    Padding="12,14"
                                    MinHeight="52">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🤖" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Perguntar à IA" 
                                              VerticalAlignment="Center"
                                              FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        
                        <!-- Resposta da IA -->
                        <Border x:Name="AIResponseBorder"
                                Background="{DynamicResource DarkPanelAltBrush}"
                                BorderBrush="{DynamicResource DarkBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18"
                                Margin="0,20,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="AIResponseText" 
                                          Text="" 
                                          TextWrapping="Wrap"
                                          FontSize="13"
                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                          LineHeight="22"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
    </Grid>
</UserControl>
