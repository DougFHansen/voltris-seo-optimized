<UserControl x:Class="VoltrisOptimizer.UI.Views.OnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Resources>
        <!-- Animação de entrada -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                            From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                            From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Animação de confete/comemoração -->
        <Storyboard x:Key="CelebrationAnimation">
            <DoubleAnimation Storyboard.TargetName="CelebrationIcon"
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                            From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CelebrationIcon"
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                            From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CelebrationOverlay"
                            Storyboard.TargetProperty="Opacity"
                            From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                     From="0" To="1" Duration="0:0:0.5"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-100,-100,0,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-80,-80">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <!-- Container principal -->
        <Border Background="{DynamicResource DarkPanelBrush}"
                CornerRadius="16"
                MaxWidth="700"
                MinWidth="500"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="24,60,24,60"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" 
                                  ShadowDepth="0" 
                                  Opacity="0.4" 
                                  Color="Black"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header com gradiente -->
                <Border Grid.Row="0" 
                        CornerRadius="16,16,0,0"
                        Padding="32,28,32,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#15FF4B6B" Offset="0"/>
                            <GradientStop Color="#108B31FF" Offset="0.5"/>
                            <GradientStop Color="#0531A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    
                    <StackPanel>
                        <TextBlock x:Name="StepTitleText"
                                   Text="Bem-vindo ao Voltris Optimizer!"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="StepDescriptionText"
                                   Text="Vamos configurar seu sistema de otimização em alguns passos rápidos."
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Content Area com scroll -->
                <!-- Content Area com scroll removido (agora global) -->
                <ContentControl Grid.Row="1" 
                                x:Name="StepContentControl"
                                Padding="32,20,32,16">
                        <ContentControl.RenderTransform>
                            <TranslateTransform/>
                        </ContentControl.RenderTransform>
                </ContentControl>
                
                <!-- Footer com navegação -->
                <Border Grid.Row="2" 
                        Background="{DynamicResource DarkPanelAltBrush}"
                        CornerRadius="0,0,16,16"
                        Padding="32,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Botão Pular -->
                        <Button x:Name="SkipButton"
                                Grid.Column="0"
                                Content="Pular Tutorial"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinHeight="42"
                                MinWidth="120"
                                Padding="20,10"
                                Click="SkipButton_Click"/>
                        
                        <!-- Indicadores de progresso -->
                        <StackPanel Grid.Column="1" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Ellipse x:Name="Step1Indicator" 
                                     Width="10" Height="10" 
                                     Fill="{DynamicResource PrimaryBrush}"
                                     Margin="5,0"/>
                            <Ellipse x:Name="Step2Indicator" 
                                     Width="10" Height="10" 
                                     Fill="{DynamicResource DarkBorderBrush}"
                                     Margin="5,0"/>
                            <Ellipse x:Name="Step3Indicator" 
                                     Width="10" Height="10" 
                                     Fill="{DynamicResource DarkBorderBrush}"
                                     Margin="5,0"/>
                            <Ellipse x:Name="Step4Indicator" 
                                     Width="10" Height="10" 
                                     Fill="{DynamicResource DarkBorderBrush}"
                                     Margin="5,0"/>
                        </StackPanel>
                        
                        <!-- Botões de navegação -->
                        <StackPanel Grid.Column="2" 
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="BackButton"
                                    Content="← Anterior"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinHeight="42"
                                    MinWidth="110"
                                    Padding="16,10"
                                    Margin="0,0,12,0"
                                    Click="BackButton_Click"
                                    Visibility="Collapsed"/>
                            
                            <Button x:Name="NextButton"
                                    Content="Próximo →"
                                    Style="{StaticResource ModernButtonStyle}"
                                    MinHeight="42"
                                    MinWidth="130"
                                    Padding="20,10"
                                    Click="NextButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        
        <!-- Modal de Comemoração (overlay) -->
        <Grid x:Name="CelebrationOverlay" 
              Visibility="Collapsed" 
              Opacity="0"
              Background="#E0000000"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Panel.ZIndex="100">
            <Border Background="{DynamicResource DarkPanelBrush}"
                    CornerRadius="24"
                    MaxWidth="420"
                    MaxHeight="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="40">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                </Border.Effect>
                
                <StackPanel HorizontalAlignment="Center">
                    <!-- Ícone de celebração animado -->
                    <Border x:Name="CelebrationIcon"
                            Width="100" Height="100" 
                            CornerRadius="50" 
                            HorizontalAlignment="Center"
                            Margin="0,0,0,24"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#059669" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#10B981" Opacity="0.5"/>
                        </Border.Effect>
                        <TextBlock Text="✓" FontSize="48" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Confetes decorativos -->
                    <Canvas Width="300" Height="60" HorizontalAlignment="Center" Margin="0,-20,0,0">
                        <TextBlock Text="🎉" FontSize="24" Canvas.Left="20" Canvas.Top="10"/>
                        <TextBlock Text="✨" FontSize="20" Canvas.Left="60" Canvas.Top="25"/>
                        <TextBlock Text="🎊" FontSize="22" Canvas.Left="120" Canvas.Top="5"/>
                        <TextBlock Text="⭐" FontSize="18" Canvas.Left="180" Canvas.Top="30"/>
                        <TextBlock Text="🎉" FontSize="24" Canvas.Left="240" Canvas.Top="15"/>
                        <TextBlock Text="✨" FontSize="20" Canvas.Left="280" Canvas.Top="35"/>
                    </Canvas>
                    
                    <!-- Título -->
                    <TextBlock Text="Parabéns!"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,8">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    
                    <!-- Mensagem -->
                    <TextBlock Text="Todas as otimizações foram aplicadas com sucesso!"
                               FontSize="15"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    
                    <TextBlock Text="Seu sistema está agora otimizado para máximo desempenho."
                               FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,32"/>
                    
                    <!-- Botão para ir ao Dashboard -->
                    <Button x:Name="GoToDashboardButton"
                            MinHeight="52"
                            MinWidth="220"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Click="GoToDashboardButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NeonButtonStyle}">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF4B6B" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="0.5"/>
                                            <GradientStop Color="#31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Ir para Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
