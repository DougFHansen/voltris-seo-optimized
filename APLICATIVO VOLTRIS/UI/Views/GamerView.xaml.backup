<UserControl x:Class="VoltrisOptimizer.UI.Views.GamerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             Background="{DynamicResource DarkBrush}">
    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="GamerVM" />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/UI/Themes/Styles.xaml"/>
                <ResourceDictionary Source="/UI/Themes/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converter para visibilidade booleana -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            
            <!-- Estilo de Card Premium para seções principais -->
            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A1A24" Offset="0"/>
                            <GradientStop Color="#12121A" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#35FFFFFF" Offset="0"/>
                            <GradientStop Color="#10FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="28"/>
                <Setter Property="Margin" Value="0,0,0,24"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.25" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Estilo de Card Compacto -->
            <Style x:Key="CompactCardStyle" TargetType="Border">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A1A24" Offset="0"/>
                            <GradientStop Color="#12121A" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#35FFFFFF" Offset="0"/>
                            <GradientStop Color="#10FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="0,0,0,24"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.25" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Estilo de Header de Seção -->
            <Style x:Key="SectionHeaderStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="Margin" Value="0,0,0,20"/>
            </Style>
            
            <!-- Ícone de Seção -->
            <Style x:Key="SectionIconStyle" TargetType="Border">
                <Setter Property="Width" Value="44"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Margin" Value="0,0,16,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Fallback visual se DataContext for null -->
        <TextBlock x:Name="DebugText" 
                   Text="Carregando página Gamer..." 
                   Foreground="White" 
                   FontSize="16" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Top"
                   Margin="20"
                   Visibility="Collapsed"/>
        
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="450" Height="450" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-100,-180,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,8,0">
            <StackPanel Margin="32,28,32,32">
                
                <!-- ========== 1. CABEÇALHO DO MODO GAMER ========== -->
                <StackPanel Margin="0,0,0,40" HorizontalAlignment="Center">
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    
                    <!-- Ícone com gradiente -->
                    <Border Width="64" Height="64" CornerRadius="16" Margin="0,0,0,20" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B31FF" Offset="0"/>
                                <GradientStop Color="#FF4B6B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                        </Border.Effect>
                        <Path Data="M21,6H3A2,2 0 0,0 1,8V16A2,2 0 0,0 3,18H21A2,2 0 0,0 23,16V8A2,2 0 0,0 21,6M21,16H3V8H21M6,15H8V13H10V11H8V9H6V11H4V13H6M14.5,12A1.5,1.5 0 0,1 16,13.5A1.5,1.5 0 0,1 14.5,15A1.5,1.5 0 0,1 13,13.5A1.5,1.5 0 0,1 14.5,12M18.5,9A1.5,1.5 0 0,1 20,10.5A1.5,1.5 0 0,1 18.5,12A1.5,1.5 0 0,1 17,10.5A1.5,1.5 0 0,1 18.5,9Z" 
                              Fill="White"
                              Width="32" Height="32"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Text="Modo Gamer"
                              FontFamily="Segoe UI Variable Display, Segoe UI"
                              FontSize="36"
                              FontWeight="Bold"
                              HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Maximize o desempenho do sistema para jogos com otimizações inteligentes e automáticas"
                              FontSize="15"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              HorizontalAlignment="Center"
                              TextWrapping="Wrap"
                              MaxWidth="600"
                              Margin="0,8,0,0"
                              LineHeight="22"/>
                </StackPanel>

                <!-- ========== 2. MODO GAMER AUTOMÁTICO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <StackPanel Style="{StaticResource SectionHeaderStyle}">
                                <Border Style="{StaticResource SectionIconStyle}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#408B31FF" Offset="0"/>
                                            <GradientStop Color="#40FF4B6B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="24"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Modo Gamer Automático"
                                              FontSize="20"
                                              FontWeight="SemiBold"
                                              Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Ativação inteligente ao detectar jogos em execução"
                                              FontSize="13"
                                              Foreground="{StaticResource TextMutedBrush}"
                                              Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <CheckBox Content="Ativar automaticamente ao detectar jogo"
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding IsAutoModeEnabled, Mode=TwoWay}"
                                     Margin="0,0,0,12"
                                     FontSize="15"
                                     FontWeight="Medium"/>
                            <TextBlock Text="O sistema monitora processos em execução e aplica automaticamente todas as otimizações configuradas quando um jogo é detectado."
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="13"
                                      TextWrapping="Wrap"
                                      LineHeight="20"/>
                        </StackPanel>
                        
                        <Button Grid.Column="2"
                               Content="🔍 Detectar Jogos"
                               Style="{StaticResource NeonButtonStyle}"
                               MinHeight="56"
                               MinWidth="200"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Command="{Binding DetectGamesCommand}"/>
                    </Grid>
                </Border>

                <!-- ========== 3. BIBLIOTECA DE JOGOS ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4031A8FF" Offset="0"/>
                                        <GradientStop Color="#408B31FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📚" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Biblioteca de Jogos"
                                          FontSize="20"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Gerencie seus jogos e perfis de otimização personalizados"
                                          FontSize="13"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Background="{StaticResource DarkPanelAltBrush}"
                               BorderBrush="{StaticResource DarkBorderBrush}"
                               BorderThickness="1"
                               CornerRadius="14"
                               Padding="4"
                               Margin="0,0,0,20">
                            <ListBox x:Name="GamesListBox"
                                    MinHeight="140"
                                    MaxHeight="200"
                                    ItemsSource="{Binding Games}"
                                    SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource ModernListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" 
                                               CornerRadius="8" 
                                               Padding="12,10"
                                               Margin="2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🎮" FontSize="18" Margin="0,0,14,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" 
                                                          FontWeight="Medium"
                                                          FontSize="15"
                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                          VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        
                        <UniformGrid Columns="4" HorizontalAlignment="Stretch">
                            <Button Content="✓ Aplicar Perfil"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="48" 
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Margin="0,0,6,0"
                                   Command="{Binding ApplyProfileCommand}"/>
                            <Button Content="➕ Criar Perfil"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="48" 
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Margin="6,0,6,0"
                                   Command="{Binding CreateProfileCommand}"/>
                            <Button Content="✕ Remover"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="48" 
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Margin="6,0,6,0"
                                   Command="{Binding RemoveProfileCommand}"/>
                            <Button Content="🗑️ Limpar Cache"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="48" 
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Margin="6,0,0,0"
                                   Command="{Binding CleanCacheCommand}"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ========== 4. OTIMIZAÇÕES PARA JOGOS ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#40FF4B6B" Offset="0"/>
                                        <GradientStop Color="#4031A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🚀" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Otimizações para Jogos"
                                          FontSize="20"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Configure as otimizações que serão aplicadas automaticamente"
                                          FontSize="13"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Grade de 3 colunas para otimizações -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Linha 1 -->
                            <CheckBox Content="⚡ CPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeCpu, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="0"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>
                            <CheckBox Content="🎮 GPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeGpu, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="2"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>
                            <CheckBox Content="🌐 Rede" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeNetwork, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="4"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>
                            
                            <!-- Linha 2 -->
                            <CheckBox Content="💾 Memória" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeMemory, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="0"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>
                            <CheckBox Content="🎯 Game Mode" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding EnableGameMode, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="2"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>
                            <CheckBox Content="⏱️ Reduzir Latência" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding ReduceLatency, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="4"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>

                            <!-- Linha 3 -->
                            <CheckBox Content="🔒 Fechar Apps Background" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding CloseBackgroundApps, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="0"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>
                            <CheckBox Content="📈 FPS Boost" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding ApplyFpsBoost, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="2"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>
                            <CheckBox Content="🛡️ Modo Extremo" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding EnableExtremeMode, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="4"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Margin="0,0,0,16"/>

                            <!-- Linha 4 -->
                            <CheckBox Content="🎛️ Anti-Stutter" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding EnableAntiStutter, Mode=TwoWay}" 
                                     Grid.Row="3" Grid.Column="0"
                                     FontSize="14"
                                     FontWeight="Medium"/>
                            <CheckBox Content="📡 Rede Adaptativa" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding EnableAdaptiveNetwork, Mode=TwoWay}" 
                                     Grid.Row="3" Grid.Column="2"
                                     FontSize="14"
                                     FontWeight="Medium"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== 5. OTIMIZAÇÕES TEMPORÁRIAS DE PERFORMANCE ========== -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#40FF10B9" Offset="0"/>
                                        <GradientStop Color="#20FF10B9" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4DFF10B9" Offset="0"/>
                                        <GradientStop Color="#4DFF0596" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="⚡" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Otimizações Temporárias de Performance"
                                          FontSize="20"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Otimizações avançadas aplicadas apenas durante a sessão gamer (100% reversíveis)"
                                          FontSize="13"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Status da Sessão -->
                        <Border Background="{StaticResource DarkPanelAltBrush}"
                                BorderBrush="{StaticResource DarkBorderBrush}"
                                BorderThickness="1" 
                                CornerRadius="14" 
                                Padding="20" 
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Status da Sessão:" 
                                              FontSize="12" 
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TemporaryOptimizationStatus}" 
                                              FontSize="18" 
                                              FontWeight="SemiBold"
                                              Foreground="{Binding IsTemporaryOptimizationSessionActive, Converter={StaticResource BooleanToColorConverter}}"
                                              Margin="0,0,0,0"/>
                                </StackPanel>
                                
                                <CheckBox Grid.Column="2"
                                         Content="Ativar automaticamente com modo gamer"
                                         IsChecked="{Binding AutoActivateTemporaryOptimizations, Mode=TwoWay}"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource ModernCheckBoxStyle}"
                                         FontSize="13"
                                         ToolTip="Quando ativado, as otimizações temporárias serão aplicadas automaticamente ao ativar o modo gamer"/>
                            </Grid>
                        </Border>
                        
                        <!-- Botões de Controle -->
                        <UniformGrid Columns="3" Margin="0,0,0,16">
                            <Button Content="▶ Iniciar Sessão"
                                    Style="{StaticResource NeonButtonStyle}"
                                    Command="{Binding StartTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive, Converter={StaticResource InverseBooleanConverter}}"
                                    Margin="0,0,6,0"
                                    MinHeight="52"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    ToolTip="Aplica otimizações temporárias: Frame Rate, Latência e Process Count Offload"/>
                            
                            <Button Content="⏹ Parar Sessão"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Command="{Binding StopTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive}"
                                    Margin="6,0,6,0"
                                    MinHeight="52"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    ToolTip="Reverte todas as otimizações temporárias aplicadas"/>
                            
                            <Button Content="⚠ Rollback de Emergência"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Command="{Binding ForceRollbackTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive}"
                                    Margin="6,0,0,0"
                                    MinHeight="52"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource WarningBrush}"
                                    ToolTip="Rollback de emergência - força reversão imediata de todas as mudanças"/>
                        </UniformGrid>
                        
                        <!-- Informações dos Módulos -->
                        <Expander Header="ℹ️ Informações dos Módulos de Otimização" 
                                  IsExpanded="False"
                                  Margin="0,8,0,0">
                            <StackPanel Margin="0,16,0,0">
                                <TextBlock TextWrapping="Wrap" 
                                          FontSize="12"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          LineHeight="22">
                                    <Run Text="🎯 "/>
                                    <Run Text="Frame Rate Optimizations" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Run Text=": Desativa GameDVR, habilita HAGS, otimiza DPC"/>
                                    <LineBreak/><LineBreak/>
                                    <Run Text="⏱️ "/>
                                    <Run Text="Latency Reduction" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Run Text=": Desativa Fullscreen Optimizations, otimiza TCP/IP"/>
                                    <LineBreak/><LineBreak/>
                                    <Run Text="📊 "/>
                                    <Run Text="Process Count Offload" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Run Text=": Reduz prioridade de processos de background, otimiza jogo"/>
                                    <LineBreak/><LineBreak/>
                                    <Run Text="⚠️ " Foreground="{StaticResource WarningBrush}"/>
                                    <Run Text="Nota: Algumas otimizações (DPC Timeout, HAGS) podem requerer reinicialização para efeito completo" 
                                          Foreground="{StaticResource WarningBrush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- ========== 6. DIAGNÓSTICO AVANÇADO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#40FFD97706" Offset="0"/>
                                        <GradientStop Color="#40FFEF4444" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Diagnóstico Avançado"
                                          FontSize="20"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Monitore performance em tempo real e identifique gargalos"
                                          FontSize="13"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- GPU Info -->
                            <Border Grid.Column="0" 
                                   Background="{StaticResource DarkPanelAltBrush}"
                                   BorderBrush="{StaticResource DarkBorderBrush}"
                                   BorderThickness="1" 
                                   CornerRadius="14" 
                                   Padding="20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{StaticResource SuccessColor}" Opacity="0.2"/>
                                            </Border.Background>
                                            <TextBlock Text="🖥️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Otimização de GPU" 
                                                  FontSize="16" 
                                                  FontWeight="SemiBold"
                                                  Foreground="{StaticResource TextPrimaryBrush}" 
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{Binding GpuInfoText}"
                                              Foreground="{StaticResource TextSecondaryBrush}" 
                                              FontSize="13" 
                                              Margin="0,0,0,20"
                                              TextWrapping="Wrap"
                                              LineHeight="20"/>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Button Grid.Column="0" 
                                               Content="⚡ Otimizar GPU"
                                               Style="{StaticResource NeonButtonStyle}" 
                                               MinHeight="48" 
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Command="{Binding OptimizeGpuCommand}"/>
                                        <Button Grid.Column="2" 
                                               Content="🌡️ Temperatura"
                                               Style="{StaticResource NeonSecondaryButtonStyle}" 
                                               MinHeight="48" 
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Command="{Binding CheckGpuTempCommand}"/>
                                    </Grid>
                                    
                                    <TextBlock Text="{Binding GpuTempText}" 
                                              Foreground="{StaticResource SuccessBrush}"
                                              FontSize="14" 
                                              FontWeight="SemiBold" 
                                              Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Diagnóstico Real-Time -->
                            <Border Grid.Column="2" 
                                   Background="{StaticResource DarkPanelAltBrush}"
                                   BorderBrush="{StaticResource DarkBorderBrush}"
                                   BorderThickness="1" 
                                   CornerRadius="14" 
                                   Padding="20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{StaticResource WarningColor}" Opacity="0.2"/>
                                            </Border.Background>
                                            <TextBlock Text="📈" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Diagnóstico Real-Time" 
                                                  FontSize="16" 
                                                  FontWeight="SemiBold"
                                                  Foreground="{StaticResource TextPrimaryBrush}" 
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <TextBlock Text="{Binding FpsText}" 
                                              FontSize="28" 
                                              FontWeight="Bold"
                                              Foreground="{StaticResource PrimaryBrush}" 
                                              Margin="0,0,0,16"
                                              HorizontalAlignment="Center"/>
                                    
                                    <Border Background="{StaticResource DarkBrush}"
                                           BorderBrush="{StaticResource DarkBorderBrush}"
                                           BorderThickness="1" 
                                           CornerRadius="12" 
                                           Padding="12" 
                                           Margin="0,0,0,20"
                                           MinHeight="70">
                                        <Canvas x:Name="FpsCanvas" Height="60"/>
                                    </Border>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Button Grid.Column="0" 
                                               Content="▶ Iniciar"
                                               Style="{StaticResource NeonButtonStyle}" 
                                               MinHeight="44" 
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Command="{Binding StartDiagnosticsCommand}"/>
                                        <Button Grid.Column="2" 
                                               Content="📥 Exportar CSV"
                                               Style="{StaticResource NeonSecondaryButtonStyle}" 
                                               MinHeight="44" 
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Command="{Binding ExportCsvCommand}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== 7. OSD OVERLAY ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4031A8FF" Offset="0"/>
                                        <GradientStop Color="#408B31FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📺" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="OSD Overlay (On-Screen Display)" 
                                          FontSize="20" 
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Exiba métricas em tempo real durante os jogos"
                                          FontSize="13"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Toggle Ativar OSD -->
                        <CheckBox Content="Ativar OSD Overlay" 
                                 Style="{StaticResource ModernCheckBoxStyle}"
                                 IsChecked="{Binding OverlayEnabled, Mode=TwoWay}" 
                                 FontSize="15" 
                                 FontWeight="SemiBold" 
                                 Margin="0,0,0,24"/>

                        <!-- Métricas a exibir -->
                        <TextBlock Text="Métricas a Exibir:" 
                                  FontSize="15" 
                                  FontWeight="SemiBold"
                                  Foreground="{StaticResource TextSecondaryBrush}" 
                                  Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox Content="FPS" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowFps, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="0"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="FrameTime" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowFrameTime, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="2"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="CPU %" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowCpuUsage, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="4"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>

                            <CheckBox Content="GPU %" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowGpuUsage, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="0"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="RAM %" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowRamUsage, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="2"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="VRAM %" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowVramUsage, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="4"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>

                            <CheckBox Content="Temp CPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowCpuTemp, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="0"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="Temp GPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowGpuTemp, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="2"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="Clock CPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowCpuClock, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="4"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>

                            <CheckBox Content="Clock GPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowGpuClock, Mode=TwoWay}" 
                                     Grid.Row="3" Grid.Column="0"
                                     FontSize="14"/>
                            <CheckBox Content="Input Latency" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowInputLatency, Mode=TwoWay}" 
                                     Grid.Row="3" Grid.Column="2"
                                     FontSize="14"/>
                        </Grid>

                        <!-- Posição e Aparência -->
                        <Separator Margin="0,0,0,20" Background="{StaticResource DarkBorderBrush}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Posição:" 
                                      Grid.Row="0" Grid.Column="0" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,16,16"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="14"
                                      FontWeight="Medium"
                                      MinWidth="140"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" 
                                     Style="{StaticResource ModernComboBoxStyle}" 
                                     MinHeight="44"
                                     Margin="0,0,0,16">
                                <ComboBoxItem Content="Canto Superior Esquerdo" Tag="TopLeft"/>
                                <ComboBoxItem Content="Canto Superior Direito" Tag="TopRight" IsSelected="True"/>
                                <ComboBoxItem Content="Canto Inferior Esquerdo" Tag="BottomLeft"/>
                                <ComboBoxItem Content="Canto Inferior Direito" Tag="BottomRight"/>
                                <ComboBoxItem Content="Superior Central" Tag="TopCenter"/>
                                <ComboBoxItem Content="Inferior Central" Tag="BottomCenter"/>
                            </ComboBox>

                            <TextBlock Text="Tamanho da Fonte:" 
                                      Grid.Row="1" Grid.Column="0" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,16,16"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="14"
                                      FontWeight="Medium"
                                      MinWidth="140"/>
                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,16">
                                <Slider Minimum="10" 
                                       Maximum="24" 
                                       Value="{Binding OverlayFontSize, Mode=TwoWay}"
                                       TickFrequency="2" 
                                       IsSnapToTickEnabled="True" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,70,0"/>
                                <TextBlock HorizontalAlignment="Right" 
                                          VerticalAlignment="Center"
                                          Foreground="{StaticResource TextMutedBrush}" 
                                          FontSize="13">
                                    <TextBlock.Text>
                                        <Binding Path="OverlayFontSize">
                                            <Binding.StringFormat>{0:F0}px</Binding.StringFormat>
                                        </Binding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>

                            <TextBlock Text="Opacidade:" 
                                      Grid.Row="2" Grid.Column="0" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,16,16"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="14"
                                      FontWeight="Medium"
                                      MinWidth="140"/>
                            <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,16">
                                <Slider Minimum="0.3" 
                                       Maximum="1.0" 
                                       Value="{Binding OverlayOpacity, Mode=TwoWay}"
                                       TickFrequency="0.1" 
                                       IsSnapToTickEnabled="True" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,70,0"/>
                                <TextBlock HorizontalAlignment="Right" 
                                          VerticalAlignment="Center"
                                          Foreground="{StaticResource TextMutedBrush}" 
                                          FontSize="13">
                                    <TextBlock.Text>
                                        <Binding Path="OverlayOpacity">
                                            <Binding.StringFormat>{0:P0}</Binding.StringFormat>
                                        </Binding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>

                            <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   Content="🧪 Testar Overlay" 
                                   Style="{StaticResource NeonSecondaryButtonStyle}"
                                   MinHeight="48" 
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Margin="0,8,0,0"
                                   Command="{Binding TestOverlayCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== 8. INCIDENTES DETECTADOS ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#40FFEF4444" Offset="0"/>
                                        <GradientStop Color="#40FFDC2626" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="⚠️" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Incidentes Detectados" 
                                          FontSize="20" 
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Problemas de performance identificados durante o jogo"
                                          FontSize="13"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Background="{StaticResource DarkPanelAltBrush}"
                               BorderBrush="{StaticResource DarkBorderBrush}"
                               BorderThickness="1" 
                               CornerRadius="14" 
                               Padding="4"
                               MaxHeight="160">
                            <ListBox ItemsSource="{Binding Incidents}" 
                                    MinHeight="100" 
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    Style="{StaticResource ModernListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" 
                                               CornerRadius="10" 
                                               Padding="14,10"
                                               Margin="2">
                                            <StackPanel>
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <Binding Path="Timestamp">
                                                            <Binding.StringFormat>{0:HH:mm:ss}</Binding.StringFormat>
                                                        </Binding>
                                                    </TextBlock.Text>
                                                </TextBlock> 
                                                          FontSize="11" 
                                                          Foreground="{StaticResource TextMutedBrush}"
                                                          Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding Cause}" 
                                                          FontWeight="SemiBold" 
                                                          FontSize="14" 
                                                          Foreground="{StaticResource WarningBrush}"
                                                          Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Summary}" 
                                                          FontSize="13" 
                                                          Foreground="{StaticResource TextSecondaryBrush}"
                                                          TextWrapping="Wrap"
                                                          LineHeight="18"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ========== 9. BOTÕES DE AÇÃO PRINCIPAL ========== -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" 
                           MinHeight="64" 
                           FontSize="17" 
                           FontWeight="SemiBold"
                           Command="{Binding RunGamerModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="24,14"/>
                                <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
                                <Setter Property="FontSize" Value="15"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="MinHeight" Value="52"/>
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF4B6B" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="0.5"/>
                                            <GradientStop Color="#31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🚀" FontSize="22" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <TextBlock Text="Executar Otimização Gamer" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Grid.Column="2" 
                           Content="⏸️ Desativar Modo Gamer"
                           Style="{StaticResource NeonSecondaryButtonStyle}" 
                           MinHeight="64" 
                           FontSize="16"
                           FontWeight="SemiBold"
                           Command="{Binding DeactivateGamerModeCommand}"/>
                </Grid>

                <!-- ========== 10. STATUS DO SISTEMA ========== -->
                <Border CornerRadius="18" Padding="28,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#15FF4B6B" Offset="0"/>
                            <GradientStop Color="#0D8B31FF" Offset="0.5"/>
                            <GradientStop Color="#0831A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#35FF4B6B" Offset="0"/>
                            <GradientStop Color="#258B31FF" Offset="0.5"/>
                            <GradientStop Color="#1831A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" 
                               Width="48" 
                               Height="48" 
                               CornerRadius="14" 
                               Margin="0,0,18,0">
                            <Border.Background>
                                <SolidColorBrush Color="{StaticResource PrimaryColor}" Opacity="0.3"/>
                            </Border.Background>
                            <TextBlock Text="📌" 
                                      FontSize="22" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Status do Sistema" 
                                      FontWeight="SemiBold" 
                                      FontSize="16"
                                      Foreground="{StaticResource TextPrimaryBrush}" 
                                      Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding StatusText}"
                                      Foreground="{StaticResource TextSecondaryBrush}" 
                                      FontSize="14"
                                      TextWrapping="Wrap"
                                      LineHeight="22"/>
                        </StackPanel>
                    </Grid>
                </Border>
            
                <!-- Loading Overlay -->
                <Border Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                       Background="#80000000" 
                       CornerRadius="18" 
                       Padding="28" 
                       Margin="0,24,0,0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" 
                                   Width="280" 
                                   Height="6"
                                   Background="{StaticResource DarkBorderBrush}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Style="{StaticResource AnimatedProgressBarStyle}"/>
                        <TextBlock Text="{Binding BusyMessage}" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="15" 
                                  Margin="0,18,0,0" 
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
