<UserControl x:Class="VoltrisOptimizer.UI.Views.GamerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             Background="{DynamicResource DarkBrush}">
    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="GamerVM" />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Themes/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converter para visibilidade booleana -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            
            <!-- Estilo de Card Premium para seções principais -->
            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A1A24" Offset="0"/>
                            <GradientStop Color="#12121A" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#35FFFFFF" Offset="0"/>
                            <GradientStop Color="#10FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="28"/>
                <Setter Property="Margin" Value="0,0,0,24"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.25" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>
            
            <!-- Estilo de Card Compacto -->
            <Style x:Key="CompactCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                <Setter Property="Padding" Value="20"/>
                <Setter Property="CornerRadius" Value="16"/>
            </Style>
            
            <!-- Estilo de Header de Seção -->
            <Style x:Key="SectionHeaderStyle" TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="Margin" Value="0,0,0,20"/>
            </Style>
            
            <!-- Ícone de Seção -->
            <Style x:Key="SectionIconStyle" TargetType="Border">
                <Setter Property="Width" Value="44"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Margin" Value="0,0,16,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="450" Height="450" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-100,-180,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,8,0">
            <StackPanel Margin="32,28,32,32">
                
                <!-- ========== CABEÇALHO DO MODO GAMER ========== -->
                <StackPanel Margin="0,0,0,32" HorizontalAlignment="Center">
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    
                    <!-- Ícone com gradiente -->
                    <Border Width="56" Height="56" CornerRadius="14" Margin="0,0,0,16" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B31FF" Offset="0"/>
                                <GradientStop Color="#FF4B6B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#8B31FF" Opacity="0.5"/>
                        </Border.Effect>
                        <Path Data="M21,6H3A2,2 0 0,0 1,8V16A2,2 0 0,0 3,18H21A2,2 0 0,0 23,16V8A2,2 0 0,0 21,6M21,16H3V8H21M6,15H8V13H10V11H8V9H6V11H4V13H6M14.5,12A1.5,1.5 0 0,1 16,13.5A1.5,1.5 0 0,1 14.5,15A1.5,1.5 0 0,1 13,13.5A1.5,1.5 0 0,1 14.5,12M18.5,9A1.5,1.5 0 0,1 20,10.5A1.5,1.5 0 0,1 18.5,12A1.5,1.5 0 0,1 17,10.5A1.5,1.5 0 0,1 18.5,9Z" 
                              Fill="White"
                              Width="28" Height="28"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Text="Modo Gamer"
                              FontFamily="Segoe UI Variable Display, Segoe UI"
                              FontSize="32"
                              FontWeight="Bold"
                              HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="Maximize o desempenho do sistema para jogos"
                              FontSize="14"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              HorizontalAlignment="Center"
                              Margin="0,6,0,0"/>
                </StackPanel>

                <!-- ========== BOTÕES DE AÇÃO PRINCIPAL ========== -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" 
                           MinHeight="64" 
                           FontSize="17" 
                           FontWeight="SemiBold"
                           Command="{Binding RunGamerModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NeonButtonStyle}">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF4B6B" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="0.5"/>
                                            <GradientStop Color="#31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🚀" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Executar Otimização Gamer" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Grid.Column="2" 
                           Content="⏸️ Desativar Modo Gamer"
                           Style="{StaticResource NeonSecondaryButtonStyle}" 
                           MinHeight="64" 
                           FontSize="16"
                           Command="{Binding DeactivateGamerModeCommand}"/>
                </Grid>

                <!-- ========== MODO GAMER AUTOMÁTICO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <StackPanel Style="{StaticResource SectionHeaderStyle}">
                                <Border Style="{StaticResource SectionIconStyle}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource PrimaryColor}" Opacity="0.2"/>
                                    </Border.Background>
                                    <TextBlock Text="⚡" FontSize="22"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Modo Gamer Automático"
                                              FontSize="18"
                                              FontWeight="SemiBold"
                                              Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Ativação inteligente ao detectar jogos"
                                              FontSize="12"
                                              Foreground="{StaticResource TextMutedBrush}"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <CheckBox Content="Ativar automaticamente ao detectar jogo"
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding IsAutoModeEnabled, Mode=TwoWay}"
                                     Margin="0,0,0,12"
                                     FontSize="14"/>
                            <TextBlock Text="O sistema detecta automaticamente quando um jogo é iniciado e aplica todas as otimizações configuradas."
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="13"
                                      TextWrapping="Wrap"
                                      LineHeight="20"/>
                        </StackPanel>
                        
                        <Button Grid.Column="2"
                               Content="🔍 Detectar Jogos"
                               Style="{StaticResource NeonButtonStyle}"
                               MinHeight="52"
                               MinWidth="180"
                               VerticalAlignment="Center"
                               Command="{Binding DetectGamesCommand}"/>
                    </Grid>
                </Border>

                <!-- ========== BIBLIOTECA DE JOGOS ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource SecondaryColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="📚" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Biblioteca de Jogos"
                                          FontSize="18"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Gerencie seus jogos e perfis personalizados"
                                          FontSize="12"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Background="{StaticResource DarkPanelAltBrush}"
                               BorderBrush="{StaticResource DarkBorderBrush}"
                               BorderThickness="1"
                               CornerRadius="12"
                               Padding="4"
                               Margin="0,0,0,20">
                            <ListBox x:Name="GamesListBox"
                                    MinHeight="120"
                                    MaxHeight="180"
                                    ItemsSource="{Binding Games}"
                                    SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource ModernListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,6">
                                            <TextBlock Text="🎮" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" 
                                                      FontWeight="Medium"
                                                      FontSize="14"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        
                        <UniformGrid Columns="4" HorizontalAlignment="Stretch">
                            <Button Content="✓ Aplicar"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="44" 
                                   FontSize="13"
                                   Margin="0,0,6,0"
                                   Command="{Binding ApplyProfileCommand}"/>
                            <Button Content="➕ Criar"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="44" 
                                   FontSize="13"
                                   Margin="3,0,3,0"
                                   Command="{Binding CreateProfileCommand}"/>
                            <Button Content="✕ Remover"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="44" 
                                   FontSize="13"
                                   Margin="3,0,3,0"
                                   Command="{Binding RemoveProfileCommand}"/>
                            <Button Content="🗑️ Cache"
                                   Style="{StaticResource NeonSecondaryButtonStyle}" 
                                   MinHeight="44" 
                                   FontSize="13"
                                   Margin="6,0,0,0"
                                   Command="{Binding CleanCacheCommand}"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ========== OTIMIZAÇÕES PARA JOGOS ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource AccentColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="🚀" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Otimizações para Jogos"
                                          FontSize="18"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Configure as otimizações que serão aplicadas automaticamente"
                                          FontSize="12"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Grade de 3 colunas para otimizações -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Linha 1 -->
                            <CheckBox Content="⚡ CPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeCpu, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="0"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="🎮 GPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeGpu, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="1"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="🌐 Rede" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeNetwork, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="2"
                                     Margin="0,0,0,12"/>
                            
                            <!-- Linha 2 -->
                            <CheckBox Content="💾 Memória" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OptimizeMemory, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="0"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="🎯 Game Mode" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding EnableGameMode, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="1"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="⏱️ Latência" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding ReduceLatency, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="2"
                                     Margin="0,0,0,12"/>
                            
                            <!-- Linha 3 -->
                            <CheckBox Content="🔒 Background" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding CloseBackgroundApps, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="0"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="📈 FPS Boost" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding ApplyFpsBoost, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="1"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="🛡️ Extremo" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding EnableExtremeMode, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="2"
                                     Margin="0,0,0,12"/>
                            
                            <!-- Linha 4 -->
                            <CheckBox Content="🎛️ Anti-Stutter" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding EnableAntiStutter, Mode=TwoWay}" 
                                     Grid.Row="3" Grid.Column="0"/>
                            <CheckBox Content="📡 Adaptativo" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding EnableAdaptiveNetwork, Mode=TwoWay}" 
                                     Grid.Row="3" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== OTIMIZAÇÕES TEMPORÁRIAS DE PERFORMANCE ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="#FF10B981" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="⚡" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Otimizações Temporárias de Performance"
                                          FontSize="18"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Otimizações avançadas aplicadas apenas durante a sessão gamer (100% reversíveis)"
                                          FontSize="12"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Status da Sessão -->
                        <Border Background="{StaticResource DarkPanelAltBrush}"
                                BorderBrush="{StaticResource DarkBorderBrush}"
                                BorderThickness="1" 
                                CornerRadius="12" 
                                Padding="16" 
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Status:" 
                                              FontSize="12" 
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding TemporaryOptimizationStatus}" 
                                              FontSize="16" 
                                              FontWeight="SemiBold"
                                              Foreground="{Binding IsTemporaryOptimizationSessionActive, Converter={StaticResource BooleanToColorConverter}}"/>
                                </StackPanel>
                                
                                <CheckBox Grid.Column="2"
                                         Content="Ativar automaticamente com modo gamer"
                                         IsChecked="{Binding AutoActivateTemporaryOptimizations, Mode=TwoWay}"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource ModernCheckBoxStyle}"
                                         ToolTip="Quando ativado, as otimizações temporárias serão aplicadas automaticamente ao ativar o modo gamer"/>
                            </Grid>
                        </Border>
                        
                        <!-- Botões de Controle -->
                        <UniformGrid Columns="3" Margin="0,0,0,12">
                            <Button Content="▶ Iniciar Sessão"
                                    Style="{StaticResource NeonButtonStyle}"
                                    Command="{Binding StartTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive, Converter={StaticResource InverseBooleanConverter}}"
                                    Margin="0,0,4,0"
                                    MinHeight="48"
                                    ToolTip="Aplica otimizações temporárias: Frame Rate, Latência e Process Count Offload"/>
                            
                            <Button Content="⏹ Parar Sessão"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Command="{Binding StopTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive}"
                                    Margin="4,0,4,0"
                                    MinHeight="48"
                                    ToolTip="Reverte todas as otimizações temporárias aplicadas"/>
                            
                            <Button Content="⚠ Rollback"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    Command="{Binding ForceRollbackTemporaryOptimizationCommand}"
                                    IsEnabled="{Binding IsTemporaryOptimizationSessionActive}"
                                    Margin="4,0,0,0"
                                    MinHeight="48"
                                    Foreground="{StaticResource WarningBrush}"
                                    ToolTip="Rollback de emergência - força reversão imediata de todas as mudanças"/>
                        </UniformGrid>
                        
                        <!-- Informações dos Módulos -->
                        <Expander Header="ℹ️ Módulos de Otimização" 
                                  IsExpanded="False"
                                  Margin="0,8,0,0">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock TextWrapping="Wrap" 
                                          FontSize="11"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          LineHeight="20">
                                    <Run Text="🎯 "/>
                                    <Run Text="Frame Rate Optimizations" FontWeight="SemiBold"/>
                                    <Run Text=": Desativa GameDVR, habilita HAGS, otimiza DPC"/>
                                    <LineBreak/>
                                    <Run Text="⏱️ "/>
                                    <Run Text="Latency Reduction" FontWeight="SemiBold"/>
                                    <Run Text=": Desativa Fullscreen Optimizations, otimiza TCP/IP"/>
                                    <LineBreak/>
                                    <Run Text="📊 "/>
                                    <Run Text="Process Count Offload" FontWeight="SemiBold"/>
                                    <Run Text=": Reduz prioridade de processos de background, otimiza jogo"/>
                                    <LineBreak/>
                                    <LineBreak/>
                                    <Run Text="⚠️ "/>
                                    <Run Text="Nota: Algumas otimizações (DPC Timeout, HAGS) podem requerer reinicialização para efeito completo"/>
                                </TextBlock>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- ========== DIAGNÓSTICO AVANÇADO ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource WarningColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="📊" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Diagnóstico Avançado"
                                          FontSize="18"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Monitore performance em tempo real e identifique problemas"
                                          FontSize="12"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- GPU Info -->
                            <Border Grid.Column="0" 
                                   Background="{StaticResource DarkPanelAltBrush}"
                                   BorderBrush="{StaticResource DarkBorderBrush}"
                                   BorderThickness="1"
                                   CornerRadius="12"
                                   Padding="16"
                                   Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="GPU"
                                              FontSize="12"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding GpuInfoText}"
                                              Foreground="{StaticResource TextPrimaryBrush}" 
                                              FontSize="14" 
                                              FontWeight="SemiBold"
                                              TextWrapping="Wrap"
                                              Margin="0,0,0,12"/>
                                    <Button Content="⚡ Otimizar"
                                           Style="{StaticResource NeonButtonStyle}" 
                                           MinHeight="40" 
                                           Command="{Binding OptimizeGpuCommand}"/>
                                    <Button Content="🌡️ Temperatura"
                                           Style="{StaticResource NeonSecondaryButtonStyle}" 
                                           MinHeight="40" 
                                           Margin="0,8,0,0"
                                           Command="{Binding CheckGpuTempCommand}"/>
                                    <TextBlock Text="{Binding GpuTempText}" 
                                              Foreground="{StaticResource SuccessBrush}"
                                              FontSize="13" 
                                              FontWeight="SemiBold" 
                                              Margin="0,12,0,0"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- FPS Monitor -->
                            <Border Grid.Column="2" 
                                   Background="{StaticResource DarkPanelAltBrush}"
                                   BorderBrush="{StaticResource DarkBorderBrush}"
                                   BorderThickness="1"
                                   CornerRadius="12"
                                   Padding="16"
                                   Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="FPS"
                                              FontSize="12"
                                              Foreground="{StaticResource TextSecondaryBrush}"
                                              Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding FpsText}" 
                                              FontSize="32" 
                                              FontWeight="Bold"
                                              Foreground="{StaticResource PrimaryBrush}" 
                                              Margin="0,0,0,12"
                                              HorizontalAlignment="Center"/>
                                    
                                    <Border Background="{StaticResource DarkBrush}"
                                           BorderBrush="{StaticResource DarkBorderBrush}"
                                           BorderThickness="1" 
                                           CornerRadius="8" 
                                           Padding="8" 
                                           Margin="0,0,0,12"
                                           MinHeight="50">
                                        <Canvas x:Name="FpsCanvas" Height="50"/>
                                    </Border>
                                    
                                    <Button Content="▶ Iniciar"
                                           Style="{StaticResource NeonButtonStyle}" 
                                           MinHeight="40" 
                                           Command="{Binding StartDiagnosticsCommand}"/>
                                    <Button Content="📥 Exportar CSV"
                                           Style="{StaticResource NeonSecondaryButtonStyle}" 
                                           MinHeight="40" 
                                           Margin="0,8,0,0"
                                           Command="{Binding ExportCsvCommand}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <Button Content="📈 Abrir Diagnóstico Completo"
                               Style="{StaticResource NeonSecondaryButtonStyle}"
                               MinHeight="48" 
                               HorizontalAlignment="Stretch" 
                               Margin="0,16,0,0" 
                               Command="{Binding OpenDiagnosticsCommand}"/>
                    </StackPanel>
                </Border>

                <!-- ========== OSD OVERLAY ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource PrimaryColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="📺" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="OSD Overlay (On-Screen Display)" 
                                          FontSize="18" 
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Exiba métricas em tempo real durante os jogos"
                                          FontSize="12"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Toggle Ativar OSD -->
                        <CheckBox Content="Ativar OSD Overlay" 
                                 Style="{StaticResource ModernCheckBoxStyle}"
                                 IsChecked="{Binding OverlayEnabled, Mode=TwoWay}" 
                                 FontSize="15" 
                                 FontWeight="SemiBold" 
                                 Margin="0,0,0,24"/>

                        <!-- Métricas a exibir -->
                        <TextBlock Text="Métricas a Exibir:" 
                                  FontSize="14" 
                                  FontWeight="SemiBold"
                                  Foreground="{StaticResource TextSecondaryBrush}" 
                                  Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <CheckBox Content="FPS" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowFps, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="0"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="FrameTime" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowFrameTime, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="1"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="CPU %" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowCpuUsage, Mode=TwoWay}" 
                                     Grid.Row="0" Grid.Column="2"
                                     Margin="0,0,0,12"/>

                            <CheckBox Content="GPU %" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowGpuUsage, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="0"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="RAM %" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowRamUsage, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="1"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="VRAM %" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowVramUsage, Mode=TwoWay}" 
                                     Grid.Row="1" Grid.Column="2"
                                     Margin="0,0,0,12"/>

                            <CheckBox Content="Temp CPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowCpuTemp, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="0"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="Temp GPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowGpuTemp, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="1"
                                     Margin="0,0,0,12"/>
                            <CheckBox Content="Clock CPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowCpuClock, Mode=TwoWay}" 
                                     Grid.Row="2" Grid.Column="2"
                                     Margin="0,0,0,12"/>

                            <CheckBox Content="Clock GPU" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowGpuClock, Mode=TwoWay}" 
                                     Grid.Row="3" Grid.Column="0"/>
                            <CheckBox Content="Input Latency" 
                                     Style="{StaticResource ModernCheckBoxStyle}"
                                     IsChecked="{Binding OverlayShowInputLatency, Mode=TwoWay}" 
                                     Grid.Row="3" Grid.Column="1"/>
                        </Grid>

                        <!-- Posição e Aparência -->
                        <Separator Margin="0,0,0,20" Background="{StaticResource DarkBorderBrush}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Posição:" 
                                      Grid.Row="0" Grid.Column="0" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,16,12"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="13"
                                      MinWidth="120"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" 
                                     ItemsSource="{Binding OverlayPositions}"
                                     SelectedItem="{Binding OverlaySelectedPosition, Mode=TwoWay}"
                                     Style="{StaticResource ModernComboBoxStyle}" 
                                     MinHeight="40"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Tamanho da Fonte:" 
                                      Grid.Row="1" Grid.Column="0" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,16,12"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="13"
                                      MinWidth="120"/>
                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <Slider Minimum="10" 
                                       Maximum="24" 
                                       Value="{Binding OverlayFontSize, Mode=TwoWay}"
                                       TickFrequency="2" 
                                       IsSnapToTickEnabled="True" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,60,0"/>
                                <TextBlock Text="{Binding OverlayFontSize, StringFormat='{}{0:F0}px'}"
                                          HorizontalAlignment="Right" 
                                          VerticalAlignment="Center"
                                          Foreground="{StaticResource TextMutedBrush}" 
                                          FontSize="12"/>
                            </Grid>

                            <TextBlock Text="Opacidade:" 
                                      Grid.Row="2" Grid.Column="0" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,16,12"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontSize="13"
                                      MinWidth="120"/>
                            <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                <Slider Minimum="0.3" 
                                       Maximum="1.0" 
                                       Value="{Binding OverlayOpacity, Mode=TwoWay}"
                                       TickFrequency="0.1" 
                                       IsSnapToTickEnabled="True" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,60,0"/>
                                <TextBlock Text="{Binding OverlayOpacity, StringFormat='{}{0:P0}'}"
                                          HorizontalAlignment="Right" 
                                          VerticalAlignment="Center"
                                          Foreground="{StaticResource TextMutedBrush}" 
                                          FontSize="12"/>
                            </Grid>

                            <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   Content="🧪 Testar Overlay" 
                                   Style="{StaticResource NeonSecondaryButtonStyle}"
                                   MinHeight="44" 
                                   Margin="0,8,0,0"
                                   Command="{Binding TestOverlayCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== INCIDENTES DETECTADOS ========== -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Style="{StaticResource SectionHeaderStyle}">
                            <Border Style="{StaticResource SectionIconStyle}">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource ErrorColor}" Opacity="0.2"/>
                                </Border.Background>
                                <TextBlock Text="⚠️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Incidentes Detectados" 
                                          FontSize="18" 
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Problemas de performance identificados durante o jogo"
                                          FontSize="12"
                                          Foreground="{StaticResource TextMutedBrush}"
                                          Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Background="{StaticResource DarkPanelAltBrush}"
                               BorderBrush="{StaticResource DarkBorderBrush}"
                               BorderThickness="1" 
                               CornerRadius="12" 
                               Padding="4"
                               MaxHeight="140">
                            <ListBox ItemsSource="{Binding Incidents}" 
                                    MinHeight="80" 
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    Style="{StaticResource ModernListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="12,8">
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" 
                                                      FontSize="11" 
                                                      Foreground="{StaticResource TextMutedBrush}"
                                                      Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Cause}" 
                                                      FontWeight="SemiBold" 
                                                      FontSize="13" 
                                                      Foreground="{StaticResource WarningBrush}"
                                                      Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding Summary}" 
                                                      FontSize="12" 
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ========== STATUS DO SISTEMA ========== -->
                <Border CornerRadius="16" Padding="24,20" Margin="0,0,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#12FF4B6B" Offset="0"/>
                            <GradientStop Color="#0A8B31FF" Offset="0.5"/>
                            <GradientStop Color="#0531A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#30FF4B6B" Offset="0"/>
                            <GradientStop Color="#208B31FF" Offset="0.5"/>
                            <GradientStop Color="#1531A8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" 
                               Width="44" 
                               Height="44" 
                               CornerRadius="12" 
                               Margin="0,0,16,0">
                            <Border.Background>
                                <SolidColorBrush Color="{StaticResource PrimaryColor}" Opacity="0.25"/>
                            </Border.Background>
                            <TextBlock Text="📌" 
                                      FontSize="20" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Status do Sistema" 
                                      FontWeight="SemiBold" 
                                      FontSize="15"
                                      Foreground="{StaticResource TextPrimaryBrush}" 
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StatusText}"
                                      Foreground="{StaticResource TextSecondaryBrush}" 
                                      FontSize="14"
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            
                <!-- Loading Overlay -->
                <Border Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                       Background="#80000000" 
                       CornerRadius="16" 
                       Padding="24" 
                       Margin="0,20,0,0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" 
                                   Width="240" 
                                   Height="6"
                                   Background="{StaticResource DarkBorderBrush}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Style="{StaticResource AnimatedProgressBarStyle}"/>
                        <TextBlock Text="{Binding BusyMessage}" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="14" 
                                  Margin="0,16,0,0" 
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
