<UserControl x:Class="VoltrisOptimizer.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Resources>
        <!-- Estilo moderno para cards de configuração -->
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DarkPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <!-- Estilo para título de seção dentro do card -->
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        
        <!-- Estilo para descrição da seção -->
        <Style x:Key="SettingsSectionDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <!-- Estilo para ícone de seção -->
        <Style x:Key="SettingsIconStyle" TargetType="Border">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-150,-150,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0">
            <Grid Margin="28,24,28,28"
                  MaxWidth="900"
                  HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header Centralizado -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <!-- Ícone moderno com gradiente -->
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6B7280" Offset="0"/>
                                <GradientStop Color="#4B5563" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#6B7280" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                              Fill="White"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Configurações"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Personalize o comportamento do Voltris Optimizer"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Cards de configuração -->
                <StackPanel Grid.Row="1">
                    
                    <!-- Seção de Idioma -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#1D4ED8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🌐" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding LanguageSectionTitle, FallbackValue='Idioma'}"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Selecione o idioma da interface"
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <RadioButton x:Name="RadioPortuguese"
                                                 Grid.Column="0"
                                                 Style="{StaticResource ModernRadioButtonStyle}"
                                                 Margin="0,0,8,0"
                                                 GroupName="Language"
                                                 Checked="RadioPortuguese_Checked"/>
                                    
                                    <RadioButton x:Name="RadioSpanish"
                                                 Grid.Column="1"
                                                 Style="{StaticResource ModernRadioButtonStyle}"
                                                 Margin="4,0"
                                                 GroupName="Language"
                                                 Checked="RadioSpanish_Checked"/>
                                    
                                    <RadioButton x:Name="RadioEnglish"
                                                 Grid.Column="2"
                                                 Style="{StaticResource ModernRadioButtonStyle}"
                                                 Margin="8,0,0,0"
                                                 GroupName="Language"
                                                 Checked="RadioEnglish_Checked"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Aparência -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8B5CF6" Offset="0"/>
                                        <GradientStop Color="#6D28D9" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🎨" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Aparência"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Escolha o tema visual do aplicativo"
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <ComboBox x:Name="ThemeCombo" 
                                          Width="200" 
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="ThemeCombo_SelectionChanged">
                                    <ComboBoxItem Content="🌙 Dark (Escuro)"/>
                                    <ComboBoxItem Content="☀️ Light (Claro)"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Inicialização -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🚀" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding StartupSectionTitle, FallbackValue='Inicialização'}"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Configure como o Voltris inicia com o sistema"
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <StackPanel>
                                    <CheckBox x:Name="CheckStartWithWindows"
                                              Content="{Binding StartWithWindowsText, FallbackValue='Iniciar com o Windows'}"
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Margin="0,0,0,10"
                                              Checked="CheckStartWithWindows_Checked"
                                              Unchecked="CheckStartWithWindows_Unchecked"/>
                                    
                                    <CheckBox x:Name="CheckStartMinimized"
                                              Content="{Binding StartMinimizedText, FallbackValue='Iniciar minimizado na bandeja'}"
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Checked="CheckStartMinimized_Checked"
                                              Unchecked="CheckStartMinimized_Unchecked"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Comportamento -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                        <GradientStop Color="#D97706" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="⚡" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding BehaviorSectionTitle, FallbackValue='Comportamento'}"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Ajuste como o aplicativo se comporta ao minimizar e fechar"
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <StackPanel>
                                    <CheckBox x:Name="CheckMinimizeToTray"
                                              Content="{Binding MinimizeToTrayText, FallbackValue='Minimizar para a bandeja do sistema'}"
                                              IsChecked="{Binding MinimizeToTrayChecked}"
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Margin="0,0,0,10"/>
                                    
                                    <CheckBox x:Name="CheckCloseToTray"
                                              Content="{Binding CloseToTrayText, FallbackValue='Fechar para a bandeja (manter em execução)'}"
                                              IsChecked="{Binding CloseToTrayChecked}"
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Margin="0,0,0,10"/>
                                    
                                    
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Segurança e Modo Extremo -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EF4444" Offset="0"/>
                                        <GradientStop Color="#DC2626" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🛡️" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Segurança e Modo Avançado"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Controle de Dry-Run e Watchdog de DPC. Use com cautela."
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <Border Background="{DynamicResource DarkPanelAltBrush}"
                                        CornerRadius="10"
                                        Padding="14"
                                        Margin="0,0,0,14">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Requer permissões elevadas para aplicar ajustes reais"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                                <StackPanel>
                                    <CheckBox x:Name="CheckDryRun"
                                              Content="Executar em modo Dry-Run (simular sem aplicar)"
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Margin="0,0,0,10"
                                              Checked="CheckDryRun_Checked"
                                              Unchecked="CheckDryRun_Unchecked"/>
                                    
                                    <CheckBox x:Name="CheckAllowWatchdog"
                                              Content="Permitir Watchdog de DPC em background"
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Checked="CheckAllowWatchdog_Checked"
                                              Unchecked="CheckAllowWatchdog_Unchecked"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção Otimizações Avançadas / DLS -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#4338CA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="⚙️" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Otimizações Avançadas" Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Estabilização dinâmica de carga para manter FPS e responsividade durante jogos" Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <CheckBox x:Name="CheckEnableDls"
                                          Content="Ativar Dynamic Load Stabilizer"
                                          Style="{StaticResource ModernCheckBoxStyle}"
                                          Margin="0,8,0,8"
                                          Checked="CheckEnableDls_Checked"
                                          Unchecked="CheckEnableDls_Unchecked"/>
                                
                                <Border Background="{DynamicResource DarkPanelAltBrush}" CornerRadius="10" Padding="14" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Processos otimizados em tempo real:" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <ListBox x:Name="DlsOptimizedList" MinHeight="80" Style="{StaticResource ModernListBoxStyle}"/>
                                        <TextBlock Text="Selecionar jogo principal:" Margin="0,12,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="DlsProcessCombo" Style="{StaticResource ModernComboBoxStyle}" MinWidth="240"/>
                                            <Button Grid.Column="1" x:Name="DlsSetGameButton" Content="Definir como jogo principal" Style="{StaticResource ModernButtonStyle}" Padding="16,0" Click="DlsSetGameButton_Click"/>
                                        </Grid>
                                        <TextBlock Text="Uso da CPU por núcleo:" Margin="0,12,0,6"/>
                                        <ItemsControl x:Name="DlsCoreUsage"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Ajuda e Tutorial -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EC4899" Offset="0"/>
                                        <GradientStop Color="#DB2777" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📚" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ajuda e Tutorial"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Revise o tutorial interativo para aprender todas as funcionalidades"
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <Button x:Name="ShowOnboardingButton"
                                        Content="📖 Ver Tutorial Novamente"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Height="44"
                                        HorizontalAlignment="Left"
                                        Padding="24,0"
                                        Click="ShowOnboardingButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Seção de Atualizações -->
                    <Border Style="{StaticResource SettingsCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Style="{StaticResource SettingsIconStyle}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8B31FF" Offset="0"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🚀" FontSize="20" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Atualizações"
                                           Style="{StaticResource SettingsSectionTitle}"/>
                                <TextBlock Text="Verifique se há novas versões do Voltris Optimizer"
                                           Style="{StaticResource SettingsSectionDesc}"/>
                                
                                <!-- Info de Versão -->
                                <Border Background="{DynamicResource DarkPanelAltBrush}"
                                        CornerRadius="10"
                                        Padding="14"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="📦" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="CurrentVersionText"
                                                       Text="Versão atual: Carregando..."
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✅" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="UpdateStatusText"
                                                       Text="Você está usando a versão mais recente"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource SuccessBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <WrapPanel>
                                    <Button x:Name="CheckUpdatesButton"
                                            Content="🔍 Verificar Atualizações"
                                            Style="{StaticResource NeonButtonStyle}"
                                            Height="44"
                                            Padding="20,0"
                                            Margin="0,0,10,10"
                                            Click="CheckUpdatesButton_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    
                    
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                     From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
