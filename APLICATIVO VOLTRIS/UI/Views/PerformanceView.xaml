<UserControl x:Class="VoltrisOptimizer.UI.Views.PerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <UserControl.DataContext>
        <Binding Source="{StaticResource Locator}" Path="PerformanceVM" />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="450" Height="450" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-100,-180,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="350" Height="350" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,24,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header Centralizado -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#059669" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#10B981" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="M13,2.05V5.08C16.39,5.57 19,8.47 19,12C19,12.9 18.82,13.75 18.5,14.54L21.12,16.07C21.68,14.83 22,13.45 22,12C22,6.82 18.05,2.55 13,2.05M12,19A7,7 0 0,1 5,12C5,8.47 7.61,5.57 11,5.08V2.05C5.94,2.55 2,6.81 2,12A10,10 0 0,0 12,22C15.3,22 18.23,20.39 20.05,17.91L17.45,16.38C16.17,18 14.21,19 12,19Z" 
                              Fill="White"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Desempenho Ultra"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Otimizações inteligentes baseadas no seu hardware"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- ============================================ -->
                <!-- CARD DE PERFIL DO SISTEMA -->
                <!-- ============================================ -->
                <Border Grid.Row="1" Margin="0,0,0,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#151520" Offset="0"/>
                            <GradientStop Color="#1A1A28" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4010B981" Offset="0"/>
                            <GradientStop Color="#3000D4FF" Offset="0.5"/>
                            <GradientStop Color="#208B31FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="16"/>
                            <Setter Property="Padding" Value="24,20"/>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#10B981" Opacity="0.15"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#00D4FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#10B981" Opacity="0.4"/>
                                    </Border.Effect>
                                    <TextBlock Text="🖥️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="PERFIL DO SISTEMA"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Detectado automaticamente"
                                              FontSize="11"
                                              Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Informações do Sistema -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding ProfileCpu}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="CPU" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding ProfileRam}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="RAM" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding ProfileStorage}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Disco" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="{Binding ProfileGpu}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="GPU" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Badge de Tipo de PC -->
                        <Border Grid.Column="1" VerticalAlignment="Center" Padding="16,10" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ProfileTypeIcon}" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ProfileType}" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- ============================================ -->
                <!-- AÇÕES RÁPIDAS -->
                <!-- ============================================ -->
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Botão Otimização Automática -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00D4FF" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="🚀" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Otimização Automática"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Aplica otimizações recomendadas"
                                              FontSize="11"
                                              Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" x:Name="AutoProgressPanel" Margin="0,0,0,12">
                                <TextBlock x:Name="AutoProgressText" Text="{Binding OptimizationStatus}" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,6"/>
                                <ProgressBar x:Name="AutoProgress" Height="4" Background="{DynamicResource DarkBorderBrush}" Foreground="{DynamicResource PrimaryBrush}" BorderThickness="0" Maximum="100" IsIndeterminate="True" Visibility="{Binding IsOptimizing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                            
                            <Button Grid.Row="2"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="44"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Command="{Binding AutoOptimizeCommand}"
                                    >
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" CornerRadius="10" Padding="16,12">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#00D4FF" Offset="0"/>
                                                                <GradientStop Color="#8B31FF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00D4FF" Opacity="0.3"/>
                                                        </Border.Effect>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#00D4FF" Opacity="0.5"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Otimizar Agora"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Botão Reverter -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#F59E0B" Opacity="0.2"/>
                                    </Border.Background>
                                    <TextBlock Text="↩️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Reverter Tudo"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Restaura configurações originais"
                                              FontSize="11"
                                              Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Button Grid.Row="1"
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="44"
                                    FontWeight="SemiBold"
                                    Command="{Binding RevertAllCommand}"
                                    >
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Reverter"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- ============================================ -->
                <!-- CATEGORIAS DE OTIMIZAÇÃO -->
                <!-- ============================================ -->
                <ItemsControl Grid.Row="3" ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource DarkPanelBrush}"
                                    BorderBrush="{DynamicResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="20"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <!-- Header da Categoria -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,12,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding CategoryColor}" Opacity="0.2"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Icon}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                          FontSize="14" 
                                                          FontWeight="SemiBold"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}" 
                                                          FontSize="11"
                                                          Foreground="{DynamicResource TextMutedBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding RecommendedCountText}" 
                                                      FontSize="11"
                                                      Foreground="{DynamicResource TextMutedBrush}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                            <CheckBox IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                     VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Lista de Otimizações -->
                                    <ItemsControl ItemsSource="{Binding Optimizations}" 
                                                  Visibility="{Binding ExpandedVisibility}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#08FFFFFF" 
                                                        CornerRadius="10" 
                                                        Padding="14,12" 
                                                        Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <CheckBox Grid.Column="0" 
                                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                 ToolTip="{Binding IncompatibilityReason}"
                                                                 Margin="0,0,12,0"
                                                                 VerticalAlignment="Center"/>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" 
                                                                      FontSize="12" 
                                                                      FontWeight="Medium"
                                                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Description}" 
                                                                      FontSize="10" 
                                                                      Foreground="{DynamicResource TextMutedBrush}"/>
                                                        </StackPanel>
                                                        
                                                        <!-- Impacto -->
                                                        <Border Grid.Column="2"
                                                               Background="{Binding ImpactColor}"
                                                               CornerRadius="6"
                                                               Padding="8,4"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ImpactText}" 
                                                                      FontSize="9" 
                                                                      FontWeight="Bold"
                                                                      Foreground="White"/>
                                                        </Border>
                                                        
                                                        <!-- Recomendado -->
                                                        <Border Grid.Column="3"
                                                               Visibility="{Binding RecommendedVisibility}"
                                                               Background="#1510B981"
                                                               CornerRadius="6"
                                                               Padding="8,4"
                                                               VerticalAlignment="Center">
                                                            <TextBlock Text="✓ REC" 
                                                                      FontSize="9" 
                                                                      FontWeight="Bold"
                                                                      Foreground="#10B981"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
