<UserControl x:Class="VoltrisOptimizer.UI.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource DarkBrush}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-120,-120,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300" Height="300" 
                     Fill="{DynamicResource PrimaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-80,0,0,-80">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,24,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header Centralizado -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center" Orientation="Horizontal">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>
                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-20" To="0" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                    
                    <!-- Ícone moderno com gradiente -->
                    <Border Width="44" Height="44" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F59E0B" Offset="0"/>
                                <GradientStop Color="#EF4444" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#F59E0B" Opacity="0.4"/>
                        </Border.Effect>
                        <Path Data="M19.36,2.72L20.78,4.14L15.06,9.85C16.13,11.39 16.28,13.24 15.38,14.44L9.06,8.12C10.26,7.22 12.11,7.37 13.65,8.44L19.36,2.72M5.93,17.57C3.92,15.56 2.69,13.16 2.35,10.92L7.23,8.83L14.67,16.27L12.58,21.15C10.34,20.81 7.94,19.58 5.93,17.57Z" 
                              Fill="White"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Limpeza Ultra"
                                  FontFamily="Segoe UI Variable Display, Segoe UI"
                                  FontSize="26"
                                  FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Limpeza profunda nível enterprise"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- ============================================ -->
                <!-- ULTRA CLEAN - CARD PRINCIPAL -->
                <!-- ============================================ -->
                <Border Grid.Row="1"
                        Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#151520" Offset="0"/>
                            <GradientStop Color="#1A1A28" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4031A8FF" Offset="0"/>
                            <GradientStop Color="#308B31FF" Offset="0.5"/>
                            <GradientStop Color="#20FF4B6B" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="16"/>
                            <Setter Property="Padding" Value="24"/>
                        </Style>
                    </Border.Style>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#8B31FF" Opacity="0.15"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal">
                                <Border Width="48" Height="48" CornerRadius="12" Margin="0,0,16,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00D4FF" Offset="0"/>
                                            <GradientStop Color="#8B31FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00D4FF" Opacity="0.5"/>
                                    </Border.Effect>
                                    <TextBlock Text="🚀" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="VOLTRIS ULTRA CLEANER"
                                              FontSize="18"
                                              FontWeight="Bold">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#00D4FF" Offset="0"/>
                                                <GradientStop Color="#8B31FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock Text="Limpeza profunda e 100% precisa"
                                              FontSize="12"
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Botões de ação -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="UltraAnalyzeButton"
                                       Content="🔍 Analisar"
                                       Click="UltraAnalyzeButton_Click"
                                       MinWidth="120"
                                       MinHeight="44"
                                       Margin="0,0,12,0"
                                       FontWeight="SemiBold"
                                       Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" CornerRadius="10" Padding="20,12">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                                                    <GradientStop Color="#8B31FF" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#00D4FF" Opacity="0.3"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="#00D4FF" Opacity="0.5"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <Button x:Name="UltraCleanButton"
                                       Content="🧹 Limpar"
                                       Click="UltraCleanButton_Click"
                                       MinWidth="120"
                                       MinHeight="44"
                                       IsEnabled="False"
                                       Style="{StaticResource NeonButtonStyle}"
                                       FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Progress -->
                        <StackPanel x:Name="UltraProgressPanel" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,16">
                            <TextBlock x:Name="UltraProgressText"
                                      Text="Analisando..."
                                      FontSize="13"
                                      Foreground="{DynamicResource PrimaryBrush}"
                                      Margin="0,0,0,8"/>
                            <ProgressBar x:Name="UltraProgress"
                                        Height="6"
                                        Background="{DynamicResource DarkBorderBrush}"
                                        Foreground="{DynamicResource VoltrisGradientHorizontalBrush}"
                                        BorderThickness="0"
                                        Maximum="100"
                                        Value="0"/>
                        </StackPanel>
                        
                        <!-- Summary Stats -->
                        <Border x:Name="UltraSummary" Grid.Row="2" Visibility="Collapsed"
                                Background="#10FFFFFF"
                                CornerRadius="12"
                                Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TotalCategoriesText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#00D4FF" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Categorias" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TotalItemsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#8B31FF" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Itens" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock x:Name="SelectedItemsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Selecionados" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TotalSizeText" Text="0 B" FontSize="28" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Recuperável" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- ============================================ -->
                <!-- CATEGORIAS DE LIMPEZA - UI MODERNA -->
                <!-- ============================================ -->
                <ItemsControl x:Name="CategoriesPanel" Grid.Row="2" Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource DarkPanelBrush}"
                                    BorderBrush="{DynamicResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="20"
                                    Margin="0,0,0,16">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#5031A8FF" Offset="0"/>
                                                            <GradientStop Color="#308B31FF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#31A8FF" Opacity="0.2"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <!-- Category Header Moderno -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Checkbox Moderno -->
                                        <CheckBox Grid.Column="0"
                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                 Margin="0,0,16,0"
                                                 VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Ícone moderno com gradiente animado -->
                                            <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#4031A8FF" Offset="0"/>
                                                        <GradientStop Color="#308B31FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#31A8FF" Opacity="0.3"/>
                                                </Border.Effect>
                                                <TextBlock Text="{Binding Icon}" 
                                                          FontSize="20" 
                                                          HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                          FontSize="15" 
                                                          FontWeight="Bold"
                                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding ItemsCountText}" 
                                                          FontSize="11"
                                                          Foreground="{DynamicResource TextMutedBrush}"
                                                          Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <!-- Tamanho com badge moderno -->
                                        <Border Grid.Column="3"
                                               Background="#1031A8FF"
                                               CornerRadius="8"
                                               Padding="12,8"
                                               VerticalAlignment="Center"
                                               BorderThickness="1"
                                               BorderBrush="#3031A8FF">
                                            <TextBlock Text="{Binding TotalSizeText}" 
                                                      FontSize="13"
                                                      FontWeight="Bold"
                                                      Foreground="#31A8FF"/>
                                        </Border>
                                    </Grid>
                                    
                                    <!-- Category Items -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0AFFFFFF" 
                                                        CornerRadius="10" 
                                                        Padding="16,12" 
                                                        Margin="0,0,0,8"
                                                        BorderThickness="1"
                                                        BorderBrush="#15FFFFFF">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#18FFFFFF"/>
                                                                    <Setter Property="BorderBrush" Value="#3531A8FF"/>
                                                                    <Setter Property="Effect">
                                                                        <Setter.Value>
                                                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#31A8FF" Opacity="0.2"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <CheckBox Grid.Column="0" 
                                                                 IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                 Margin="0,0,16,0"
                                                                 VerticalAlignment="Center"/>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" 
                                                                      FontSize="13" 
                                                                      FontWeight="SemiBold"
                                                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Description}" 
                                                                      FontSize="11" 
                                                                      Foreground="{DynamicResource TextMutedBrush}"
                                                                      Margin="0,4,0,0"
                                                                      TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        
                                                        <!-- Tamanho com badge moderno e gradiente -->
                                                        <Border Grid.Column="2"
                                                               Background="#1031A8FF"
                                                               CornerRadius="8"
                                                               Padding="14,8"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,12,0"
                                                               BorderThickness="1"
                                                               BorderBrush="#2531A8FF">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#31A8FF" Opacity="0.25"/>
                                                            </Border.Effect>
                                                            <TextBlock Text="{Binding SizeText}" 
                                                                      FontSize="12" 
                                                                      FontWeight="Bold"
                                                                      Foreground="#31A8FF"/>
                                                        </Border>
                                                        
                                                        <!-- Badge de segurança ultra moderno -->
                                                        <Border Grid.Column="3"
                                                               Background="{Binding SafetyColor}"
                                                               CornerRadius="8"
                                                               Padding="12,7"
                                                               VerticalAlignment="Center">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="{Binding SafetyColor.Color}" Opacity="0.4"/>
                                                            </Border.Effect>
                                                            <TextBlock Text="{Binding SafetyText}" 
                                                                      FontSize="10" 
                                                                      FontWeight="Bold"
                                                                      Foreground="White"
                                                                      TextAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- ============================================ -->
                <!-- QUICK ACTIONS -->
                <!-- ============================================ -->
                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Quick: Temp Files -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16"
                            Cursor="Hand"
                            MouseLeftButtonUp="QuickCleanTemp_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#3B82F6"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#3B82F6" Opacity="0.3"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#3B82F6" Opacity="0.2"/>
                                    </Border.Background>
                                    <TextBlock Text="🗑️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Temp Rápido"
                                              FontWeight="SemiBold"
                                              FontSize="13"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="TempSizeText"
                                              Text="Calculando..."
                                              FontSize="11"
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="Limpa arquivos temporários"
                                      FontSize="10"
                                      Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Quick: Browser Cache -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16"
                            Cursor="Hand"
                            MouseLeftButtonUp="QuickCleanBrowser_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#8B5CF6"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#8B5CF6" Opacity="0.3"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#8B5CF6" Opacity="0.2"/>
                                    </Border.Background>
                                    <TextBlock Text="🌐" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Navegadores"
                                              FontWeight="SemiBold"
                                              FontSize="13"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="BrowserSizeText"
                                              Text="Calculando..."
                                              FontSize="11"
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="Limpa cache de navegadores"
                                      FontSize="10"
                                      Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Quick: Game Cache -->
                    <Border Grid.Column="4"
                            Background="{DynamicResource DarkPanelBrush}"
                            BorderBrush="{DynamicResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16"
                            Cursor="Hand"
                            MouseLeftButtonUp="QuickCleanGames_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush">
                                            <Setter.Value>
                                                <SolidColorBrush Color="#10B981"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#10B981" Opacity="0.3"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#10B981" Opacity="0.2"/>
                                    </Border.Background>
                                    <TextBlock Text="🎮" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Shader Cache"
                                              FontWeight="SemiBold"
                                              FontSize="13"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="GameSizeText"
                                              Text="Calculando..."
                                              FontSize="11"
                                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="Limpa cache de jogos"
                                      FontSize="10"
                                      Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
