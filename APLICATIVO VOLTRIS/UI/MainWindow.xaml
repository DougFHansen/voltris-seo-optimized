    </Window.Resources>
    
    <!-- Container principal com bordas arredondadas perfeitas -->
    <Grid x:Name="RootContainer">
        <Grid.Clip>
            <RectangleGeometry x:Name="ClipGeometry" RadiusX="16" RadiusY="16"/>
        </Grid.Clip>
        
        <!-- Fundo sólido base - elimina qualquer transparência -->
        <Border Background="#0A0A0F" CornerRadius="16"/>
        
        <!-- Borda decorativa com sombra sutil -->
        <Border x:Name="MainBorder"
                BorderThickness="1" 
                BorderBrush="#1E1E2E"
                CornerRadius="16"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True"
                Background="#0A0A0F">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" 
                                  ShadowDepth="0" 
                                  Opacity="0.4" 
                                  Color="Black"/>
            </Border.Effect>
        </Border>
        
        <!-- Container de conteúdo com clipping perfeito -->
        <Border CornerRadius="16" ClipToBounds="True" Background="#0A0A0F">
        <Grid UseLayoutRounding="True" SnapsToDevicePixels="True" ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Efeitos de Blur Decorativos -->
            <Viewbox HorizontalAlignment="Left" 
                     VerticalAlignment="Top"
                     Margin="30,20,0,0"
                     Stretch="Uniform"
                     MaxWidth="350" MaxHeight="350"
                     Grid.RowSpan="2"
                     IsHitTestVisible="False">
                <Ellipse Width="350" Height="350" 
                         Fill="{StaticResource AccentBlurBrush}">
                    <Ellipse.Effect>
                        <BlurEffect Radius="120"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Viewbox>
            
            <Viewbox HorizontalAlignment="Right" 
                     VerticalAlignment="Bottom"
                     Margin="0,0,60,40"
                     Stretch="Uniform"
                     MaxWidth="300" MaxHeight="300"
                     Grid.RowSpan="2"
                     IsHitTestVisible="False">
                <Ellipse Width="300" Height="300" 
                         Fill="{StaticResource SecondaryBlurBrush}">
                    <Ellipse.Effect>
                        <BlurEffect Radius="120"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Viewbox>
            
            <Viewbox HorizontalAlignment="Center" 
                     VerticalAlignment="Center"
                     Stretch="Uniform"
                     MaxWidth="200" MaxHeight="200"
                     Grid.RowSpan="2"
                     IsHitTestVisible="False">
                <Ellipse Width="200" Height="200" 
                         Fill="{StaticResource PrimaryBlurBrush}">
                    <Ellipse.Effect>
                        <BlurEffect Radius="100"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Viewbox>
            
            <!-- Overlay para legibilidade -->
            <Border Opacity="0.92" CornerRadius="0" Grid.RowSpan="2" IsHitTestVisible="False">
                <Border.Background>
                    <SolidColorBrush Color="#0A0A0F"/>
                </Border.Background>
            </Border>
            
            <!-- ============================================ -->
            <!-- BARRA DE TÍTULO MODERNA -->
            <!-- ============================================ -->
            <Border Grid.Row="0"
                    VerticalAlignment="Top"
                    CornerRadius="15,15,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0D0D14" Offset="0"/>
                        <GradientStop Color="#0A0A0F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1E1E2E" Offset="0"/>
                        <GradientStop Color="#151520" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness>0,0,0,1</Thickness>
                </Border.BorderThickness>
                <Grid Height="48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Logo e Título -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="16,0,12,0">
                        <!-- Ícone da Logo -->
                        <Image Source="pack://siteoforigin:,,,/Images/favicon.ico"
                               Width="28" Height="28" 
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Voltris Optimizer"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock x:Name="VersionText"
                                       Text="v1.0.0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="10"
                                       Margin="0,1,0,0"
                                       TextWrapping="NoWrap"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Área arrastável -->
                    <Border Grid.Column="1" 
                            MouseDown="TitleBar_MouseDown"
                            Background="Transparent"
                            Cursor="SizeAll"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
                    
                    <!-- Botões da Barra de Título -->
                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch">
                        <!-- Botão Ativar Licença -->
                        <Button x:Name="ActivateLicenseHeaderButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="ActivateLicenseHeaderButton_Click"
                                MinWidth="46"
                                MinHeight="32"
                                ToolTip="Ativar Licença">
                            <TextBlock Text="🔑" 
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="SettingsButton_Click"
                                MinWidth="46"
                                MinHeight="32"
                                ToolTip="Configurações">
                            <Path Data="{StaticResource SettingsIcon}"
                                  Fill="{StaticResource TextSecondaryBrush}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="MinimizeButton_Click"
                                Width="46"
                                Height="32"
                                ToolTip="Minimizar">
                            <Path Data="M4,12 L20,12" 
                                  Stroke="{StaticResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"
                                  Width="12" Height="12"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="MaximizeButton"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="MaximizeButton_Click"
                                Width="46"
                                Height="32"
                                ToolTip="Maximizar/Restaurar">
                            <Path x:Name="MaximizeIcon"
                                  Data="M4,4 L20,4 L20,20 L4,20 Z" 
                                  Stroke="{StaticResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  Width="11" Height="11"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Button>
                        <Button x:Name="CloseButton"
                                Style="{StaticResource TitleBarCloseButtonStyle}"
                                Click="CloseButton_Click"
                                Width="46"
                                Height="32"
                                ToolTip="Fechar">
                            <Path Data="M4,4 L20,20 M20,4 L4,20" 
                                  Stroke="{StaticResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"
                                  Width="11" Height="11"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- ============================================ -->
            <!-- CONTEÚDO PRINCIPAL -->
            <!-- ============================================ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="200" MaxWidth="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- ============================================ -->
                <!-- SIDEBAR MODERNA COM TRANSPARÊNCIA PROFISSIONAL -->
                <!-- ============================================ -->
                <Border Grid.Column="0" 
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ClipToBounds="False"
                        Background="{DynamicResource DarkBrush}">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4031A8FF" Offset="0"/>
                            <GradientStop Color="#308B31FF" Offset="0.5"/>
                            <GradientStop Color="#20FF4B6B" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>0,0,1,0</Thickness>
                    </Border.BorderThickness>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#8B31FF" Opacity="0.15" Direction="90"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        
                        <!-- Logo e Branding -->
                        <Border Grid.Row="0"
                                Padding="20,18,20,16"
                                Background="{DynamicResource DarkPanelBrush}">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4031A8FF" Offset="0"/>
                                    <GradientStop Color="#308B31FF" Offset="0.5"/>
                                    <GradientStop Color="#20FF4B6B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>0,0,0,1</Thickness>
                            </Border.BorderThickness>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Logo Voltris -->
                                <Image Source="pack://siteoforigin:,,,/Images/logo.png"
                                       Width="200"
                                       Height="65"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Margin="0,0,0,6"/>
                                <TextBlock x:Name="SidebarVersionText"
                                           Text="v1.0.0.3"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           TextWrapping="NoWrap"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Menu de Navegação -->
                        <StackPanel Grid.Row="1" 
                                    Margin="0,2,0,2"
                                    VerticalAlignment="Top">
                                <!-- Dashboard -->
                                <Button x:Name="NavDashboard" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="Dashboard">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource HomeIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Limpeza -->
                                <Button x:Name="NavCleanup" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="Cleanup">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource CleanupIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Limpeza" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Desempenho -->
                                <Button x:Name="NavPerformance" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="Performance">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource PerformanceIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Desempenho" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Rede -->
                                <Button x:Name="NavNetwork" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="Network">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource NetworkIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Rede" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Sistema -->
                                <Button x:Name="NavSystem" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="System">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource SystemIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Sistema" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Gamer -->
                                <Button x:Name="NavGamer" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="Gamer">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource GamerIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Gamer" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Diagnóstico -->
                                <Button x:Name="NavDiagnostics" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="Diagnostics">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource DiagnosticsIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Diagnóstico" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Histórico -->
                                <Button x:Name="NavHistory" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="History">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource HistoryIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Histórico" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Agendamento -->
                                <Button x:Name="NavScheduler" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="Scheduler">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource SchedulerIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Agendamento" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                
                                <!-- Logs -->
                                <Button x:Name="NavLogs" 
                                        Style="{StaticResource PremiumNavButtonStyle}"
                                        Click="NavButton_Click"
                                        Tag="Logs">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource LogsIcon}" 
                                              Fill="{StaticResource TextSecondaryBrush}"
                                              Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Logs" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                        </StackPanel>
                        
                        <!-- Status Footer -->
                        <Border Grid.Row="2"
                                Padding="20,12,20,12"
                                Background="{DynamicResource DarkPanelBrush}">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4031A8FF" Offset="0"/>
                                    <GradientStop Color="#308B31FF" Offset="0.5"/>
                                    <GradientStop Color="#20FF4B6B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>0,1,0,0</Thickness>
                            </Border.BorderThickness>
                            <StackPanel>
                                    <TextBlock x:Name="StatusText"
                                               Text="Status: Pronto"
                                               FontSize="11"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="190"
                                               LineHeight="16"
                                               Margin="0,0,0,8"/>
                                    <Border x:Name="StatusIndicatorContainer"
                                            Height="3"
                                            Background="{StaticResource DarkBorderBrush}"
                                            CornerRadius="2"
                                            HorizontalAlignment="Stretch">
                                        <Border x:Name="StatusIndicator"
                                                HorizontalAlignment="Stretch"
                                                Background="{StaticResource VoltrisGradientHorizontalBrush}"
                                                CornerRadius="2">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                                            </Border.Effect>
                                        </Border>
                                    </Border>
                                </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- ============================================ -->
                <!-- ÁREA DE CONTEÚDO -->
                <!-- ============================================ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Frame de Conteúdo -->
                    <ContentControl x:Name="ContentFrame"
                                    Grid.Row="0"
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Top"
                                    Margin="0"
                                    Padding="0"
                                    RenderTransformOrigin="0.5,0.5">
                        <ContentControl.RenderTransform>
                            <TranslateTransform/>
                        </ContentControl.RenderTransform>
                    </ContentControl>
                    
                    <!-- Barra de Progresso Inferior -->
                    <Border Grid.Row="1"
                           Padding="24,14"
                           CornerRadius="0,0,15,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0A0A0F" Offset="0"/>
                                <GradientStop Color="#0D0D14" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#151520" Offset="0"/>
                                <GradientStop Color="#1E1E2E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                            <Thickness>0,1,0,0</Thickness>
                        </Border.BorderThickness>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Progress Bar com Glow -->
                            <Border Grid.Row="0"
                                    MinHeight="6"
                                    Height="6"
                                    Background="{StaticResource DarkBorderBrush}"
                                    CornerRadius="3"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center">
                                <Border x:Name="ProgressBarFill"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource VoltrisGradientHorizontalBrush}"
                                        CornerRadius="3"
                                        Width="0"
                                        VerticalAlignment="Stretch"
                                        Height="6">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                                    </Border.Effect>
                                </Border>
                            </Border>
                            
                            <TextBlock x:Name="StatusLabel"
                                       Grid.Row="1"
                                       Text="Pronto"
                                       FontSize="12"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       FontWeight="Medium"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
        </Border>
    </Grid>
</Window>
