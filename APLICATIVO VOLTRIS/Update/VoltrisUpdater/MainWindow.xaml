<Window x:Class="VoltrisUpdater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voltris Optimizer - Atualização"
        Width="700" Height="550"
        MinWidth="600" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    
    <Border Background="{StaticResource DarkBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" 
                            ShadowDepth="0" 
                            Opacity="0.5" 
                            Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Content -->
                <RowDefinition Height="*"/>
                <!-- Footer/Progress -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Efeitos de Fundo -->
            <Ellipse Width="300" Height="300" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top"
                    Margin="50,30,0,0"
                    Fill="{StaticResource AccentBlurBrush}">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <Ellipse Width="250" Height="250" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom"
                    Margin="0,0,80,50"
                    Fill="{StaticResource SecondaryBlurBrush}">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <Border Background="{StaticResource DarkBrush}" Opacity="0.7"/>
            
            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource DarkPanelBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    Padding="24,20">
                <Grid>
                    <StackPanel Orientation="Horizontal" 
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left">
                        <Image Source="pack://application:,,,/Images/voltris.png"
                               Width="52"
                               Height="52"
                               Stretch="Uniform"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Voltris Optimizer"
                                      FontFamily="Segoe UI"
                                      FontSize="20"
                                      FontWeight="Bold"
                                      VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4B6B" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="0.5"/>
                                        <GradientStop Color="#31A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="Atualização Automática"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      FontFamily="Segoe UI"
                                      FontSize="12"
                                      Margin="0,4,0,0"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Content Area -->
            <ScrollViewer Grid.Row="1"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Padding="32,24">
                <StackPanel x:Name="ContentPanel">
                    <!-- Conteúdo será inserido dinamicamente -->
                </StackPanel>
            </ScrollViewer>
            
            <!-- Footer com Progress Bar -->
            <Border Grid.Row="2"
                   Background="{StaticResource DarkPanelBrush}"
                   BorderBrush="{StaticResource DarkBorderBrush}"
                   BorderThickness="0,1,0,0"
                   CornerRadius="0,0,12,12"
                   Padding="24,20">
                <StackPanel>
                    <!-- Status Text -->
                    <TextBlock x:Name="StatusText"
                              Text="Preparando atualização..."
                              Foreground="{StaticResource TextSecondaryBrush}"
                              FontFamily="Segoe UI"
                              FontSize="13"
                              Margin="0,0,0,12"
                              TextAlignment="Center"/>
                    
                    <!-- Progress Bar -->
                    <ProgressBar x:Name="ProgressBar"
                               Height="6"
                               Margin="0,0,0,0"
                               Minimum="0"
                               Maximum="100"
                               Value="0"
                               Background="{StaticResource DarkBorderBrush}">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>


