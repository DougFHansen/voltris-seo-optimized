<UserControl x:Class="VoltrisOptimizer.Core.SystemIntelligenceProfiler.UI.Views.ProfilerQuestionnaireView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VoltrisOptimizer.Core.SystemIntelligenceProfiler.UI.ViewModels"
             mc:Ignorable="d"
             Background="{DynamicResource DarkBrush}">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <UserControl.DataContext>
        <vm:ProfilerQuestionnaireViewModel />
    </UserControl.DataContext>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="500" Height="500" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-200,-200,0,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-150,-150">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <!-- Container Principal - SEM SCROLL -->
        <Grid Margin="32,24" MaxWidth="1100" HorizontalAlignment="Center" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header Compacto -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="14" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B31FF" Offset="0"/>
                                <GradientStop Color="#FF4B6B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="⚙️" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Configuração de Perfil"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Personalize as otimizações para o seu uso"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            
            <!-- Conteúdo Principal - Layout Horizontal -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>
                
                <!-- Coluna Esquerda - Formulário Compacto -->
                <Border Grid.Column="0" 
                        Background="{DynamicResource DarkPanelBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24"
                        Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Preferências de Uso"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Grid de opções 2x2 com ScrollViewer -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Uso do PC -->
                            <Border Grid.Row="0" Grid.Column="0" 
                                    Background="{DynamicResource DarkPanelAltBrush}"
                                    BorderBrush="{DynamicResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,8,8"
                                    Cursor="Hand">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="#20FF4B6B" Margin="0,0,10,0">
                                            <TextBlock Text="💻" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Uso Principal"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="UseCaseCombo" 
                                              Style="{DynamicResource ModernComboBoxStyle}"
                                              SelectedValuePath="Content" 
                                              SelectedValue="{Binding UseCase}">
                                        <ComboBoxItem Content="Jogos competitivos"/>
                                        <ComboBoxItem Content="Jogos singleplayer"/>
                                        <ComboBoxItem Content="Trabalho produtivo"/>
                                        <ComboBoxItem Content="Edição de vídeo"/>
                                        <ComboBoxItem Content="Uso geral"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            
                            <!-- Prioridade -->
                            <Border Grid.Row="0" Grid.Column="1" 
                                    Background="{DynamicResource DarkPanelAltBrush}"
                                    BorderBrush="{DynamicResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="8,0,0,8"
                                    Cursor="Hand">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="#208B31FF" Margin="0,0,10,0">
                                            <TextBlock Text="⚡" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Prioridade"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="PriorityCombo" 
                                              Style="{DynamicResource ModernComboBoxStyle}"
                                              SelectedValuePath="Content" 
                                              SelectedValue="{Binding Priority}">
                                        <ComboBoxItem Content="Estabilidade"/>
                                        <ComboBoxItem Content="Performance Máxima"/>
                                        <ComboBoxItem Content="Equilibrado"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            
                            <!-- Opções Adicionais -->
                            <Border Grid.Row="1" Grid.ColumnSpan="2" 
                                    Background="{DynamicResource DarkPanelAltBrush}"
                                    BorderBrush="{DynamicResource DarkBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="20"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Width="32" Height="32" CornerRadius="8" Background="#2031A8FF" Margin="0,0,10,0">
                                            <TextBlock Text="🔧" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Opções Adicionais"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <StackPanel Margin="0,0,0,4">
                                        <CheckBox 
                                                  IsChecked="{Binding IsLaptop}" 
                                                  Style="{DynamicResource ModernCheckBoxStyle}"
                                                  Margin="0,0,0,12">
                                            <TextBlock Text="Notebook/Laptop" TextWrapping="Wrap"/>
                                        </CheckBox>
                                        <CheckBox 
                                                  IsChecked="{Binding AutoRestartServices}" 
                                                  Style="{DynamicResource ModernCheckBoxStyle}"
                                                  Margin="0,0,0,12">
                                            <TextBlock Text="Auto-restart serviços" TextWrapping="Wrap"/>
                                        </CheckBox>
                                        <CheckBox 
                                                  IsChecked="{Binding AllowRegistryChanges}" 
                                                  Style="{DynamicResource ModernCheckBoxStyle}"
                                                  Margin="0,0,0,4">
                                            <TextBlock Text="Permitir mudanças no registro" TextWrapping="Wrap"/>
                                        </CheckBox>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                        </ScrollViewer>
                        
                        <!-- Botão Confirmar -->
                        <Button Grid.Row="2" 
                                Content="✓ Confirmar e Continuar" 
                                Style="{DynamicResource ModernButtonStyle}" 
                                Height="48"
                                HorizontalAlignment="Stretch"
                                Margin="0,16,0,0"
                                Command="{Binding ConfirmCommand}"/>
                    </Grid>
                </Border>
                
                <!-- Coluna Direita - Preview Compacto -->
                <Border Grid.Column="1"
                        Background="{DynamicResource DarkPanelBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#31A8FF" Offset="0"/>
                                        <GradientStop Color="#8B31FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Resumo do Perfil"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Info Cards -->
                        <StackPanel Grid.Row="1">
                            <!-- Tipo de Uso -->
                            <Border Background="{DynamicResource DarkPanelAltBrush}"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="TIPO DE USO"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding UseCase, FallbackValue='Selecione...'}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Prioridade -->
                            <Border Background="{DynamicResource DarkPanelAltBrush}"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="PRIORIDADE"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Priority, FallbackValue='Selecione...'}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Tags -->
                            <TextBlock Text="CONFIGURAÇÕES ATIVAS"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Border Background="#20FF4B6B" CornerRadius="6" Padding="10,5" Margin="0,0,6,6"
                                        Visibility="{Binding IsLaptop, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="💻 Notebook" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Background="#208B31FF" CornerRadius="6" Padding="10,5" Margin="0,0,6,6"
                                        Visibility="{Binding AutoRestartServices, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="🔄 Auto-restart" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                                <Border Background="#2031A8FF" CornerRadius="6" Padding="10,5" Margin="0,0,6,6"
                                        Visibility="{Binding AllowRegistryChanges, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="📝 Registro" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        
                        <!-- Tip -->
                        <Border Grid.Row="2" 
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,12,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0" Opacity="0.15">
                                    <GradientStop Color="#8B31FF" Offset="0"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💡" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                <TextBlock Text="Você pode alterar estas configurações a qualquer momento nas Configurações do app."
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="16"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
