<UserControl x:Class="VoltrisOptimizer.Core.SystemIntelligenceProfiler.UI.Views.ProfilerSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource DarkBrush}">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Grid>
        <!-- Background decorativo -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="500" Height="500" 
                     Fill="{DynamicResource AccentBlurBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-200,0">
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="400" Height="400" 
                     Fill="{DynamicResource SecondaryBlurBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-150,0,0,-150">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        
        <!-- Container Principal -->
        <Grid Margin="28,20,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" CornerRadius="14" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🧠" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Resumo Inteligente"
                                   FontSize="24"
                                   FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Recomendações personalizadas para seu sistema"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Filtro -->
                <Border Grid.Column="1" 
                        Background="{DynamicResource DarkPanelBrush}"
                        CornerRadius="10"
                        Padding="4">
                    <ComboBox Width="160" 
                              SelectedValuePath="Content" 
                              SelectedValue="{Binding Filter}" 
                              Style="{DynamicResource ModernComboBoxStyle}">
                        <ComboBoxItem Content="All" IsSelected="True">
                            <ComboBoxItem.ContentTemplate>
                                <DataTemplate>
                                    <TextBlock Text="Todas" FontSize="12"/>
                                </DataTemplate>
                            </ComboBoxItem.ContentTemplate>
                        </ComboBoxItem>
                        <ComboBoxItem Content="SAFE">
                            <ComboBoxItem.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0"/>
                                        <TextBlock Text="Seguras" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBoxItem.ContentTemplate>
                        </ComboBoxItem>
                        <ComboBoxItem Content="COND">
                            <ComboBoxItem.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#F59E0B" Margin="0,0,8,0"/>
                                        <TextBlock Text="Condicionais" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBoxItem.ContentTemplate>
                        </ComboBoxItem>
                        <ComboBoxItem Content="UNSUPPORTED">
                            <ComboBoxItem.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#EF4444" Margin="0,0,8,0"/>
                                        <TextBlock Text="Não Suportadas" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBoxItem.ContentTemplate>
                        </ComboBoxItem>
                    </ComboBox>
                </Border>
            </Grid>
            
            <!-- Conteúdo Principal - Grid de Cards -->
            <Border Grid.Row="1" 
                    Background="{DynamicResource DarkPanelBrush}"
                    BorderBrush="{DynamicResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">
                <Grid>
                    <!-- Lista de recomendações em Grid 2x2 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl x:Name="RecommendationsList" 
                                      ItemsSource="{Binding RecommendationsView}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" Margin="-6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource DarkPanelAltBrush}"
                                            BorderBrush="{DynamicResource DarkBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="16"
                                            Margin="6"
                                            MinHeight="140">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Título -->
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding Name}" 
                                                       FontSize="14" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            
                                            <!-- Descrição -->
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Explanation}" 
                                                       FontSize="11" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}" 
                                                       TextWrapping="Wrap"
                                                       MaxHeight="48"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,6,0,0"/>
                                            
                                            <!-- Spacer -->
                                            <Border Grid.Row="2"/>
                                            
                                            <!-- Footer: Tags + Botões -->
                                            <Grid Grid.Row="3" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Tags -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border Background="#2010B981" CornerRadius="4" Padding="6,3" Margin="0,0,4,0">
                                                        <TextBlock Text="SAFE" FontSize="9" FontWeight="Bold" Foreground="#10B981">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Category}" Value="Safe">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Background="#20F59E0B" CornerRadius="4" Padding="6,3" Margin="0,0,4,0">
                                                        <TextBlock Text="COND" FontSize="9" FontWeight="Bold" Foreground="#F59E0B">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Category}" Value="Conditional">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Background="#20EF4444" CornerRadius="4" Padding="6,3">
                                                        <TextBlock Text="N/A" FontSize="9" FontWeight="Bold" Foreground="#EF4444">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Supported}" Value="False">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                                
                                                <!-- Botões -->
                                                <StackPanel Grid.Column="1" 
                                                            Orientation="Horizontal" 
                                                            HorizontalAlignment="Right">
                                                    <Button Content="Aplicar" 
                                                            Height="26" 
                                                            Padding="12,0"
                                                            FontSize="11"
                                                            Margin="0,0,6,0" 
                                                            Style="{DynamicResource ModernButtonStyle}"
                                                            Command="{Binding DataContext.ApplyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding Supported}"/>
                                                    <Button Content="Reverter" 
                                                            Height="26"
                                                            Padding="12,0"
                                                            FontSize="11"
                                                            Style="{DynamicResource SecondaryButtonStyle}"
                                                            Command="{Binding DataContext.RevertCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding Supported}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Loading State -->
                    <Border Visibility="{Binding IsBusyUi, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="{DynamicResource DarkPanelBrush}"
                            CornerRadius="12">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" 
                                         Width="200" 
                                         Height="4" 
                                         Margin="0,0,0,16">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar">
                                        <Setter Property="Background" Value="#2A2A3A"/>
                                        <Setter Property="Foreground">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>
                            <TextBlock Text="Analisando sistema..."
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Empty State -->
                    <Border Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="{DynamicResource DarkPanelBrush}"
                            CornerRadius="12">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="✅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="Nenhuma recomendação pendente!"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Seu sistema está otimizado."
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Footer com Ações -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Status Profissional -->
                <Border Background="{DynamicResource DarkPanelAltBrush}"
                        BorderBrush="{DynamicResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,10"
                        Margin="0,0,20,0"
                        VerticalAlignment="Center"
                        MaxWidth="400">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="8" Height="8" CornerRadius="4" 
                                Background="#10B981" 
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#10B981" Opacity="0.6"/>
                            </Border.Effect>
                        </Border>
                        <TextBlock Text="{Binding Status, FallbackValue='Sistema pronto'}" 
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                
                <!-- Botões -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ApplyAllButton"
                            Height="44" 
                            Padding="20,0"
                            Margin="0,0,12,0"
                            Style="{DynamicResource ModernButtonStyle}"
                            Click="ApplyAllButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚀" Margin="0,0,8,0"/>
                            <TextBlock Text="Aplicar Todas (SAFE)"/>
                        </StackPanel>
                    </Button>
                    <Button Height="44" 
                            Padding="20,0"
                            Command="{Binding ExportBackupCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#8B31FF" Offset="0"/>
                                            <GradientStop Color="#31A8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" Margin="0,0,8,0"/>
                            <TextBlock Text="Exportar Backup"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
        
        <!-- Overlay de Celebração -->
        <Border x:Name="CelebrationOverlay" 
                Background="#E0171313"
                Visibility="Collapsed"
                Opacity="0">
            <Grid>
                <!-- Efeitos de fundo -->
                <Grid IsHitTestVisible="False">
                    <Ellipse Width="600" Height="600" 
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#408B31FF" Offset="0"/>
                                <GradientStop Color="#00171313" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>
                
                <!-- Conteúdo -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Ícone de sucesso animado -->
                    <Border x:Name="SuccessIcon" 
                            Width="120" Height="120" 
                            CornerRadius="60"
                            Margin="0,0,0,32"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#059669" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#10B981" Opacity="0.5"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <TextBlock Text="✓" 
                                   FontSize="64" 
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Texto principal -->
                    <TextBlock Text="Configuração Concluída!"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#34D399" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    
                    <TextBlock Text="Seu sistema foi configurado e otimizado com sucesso!"
                               FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    
                    <TextBlock x:Name="OptimizationCountText"
                               Text="4 otimizações aplicadas"
                               FontSize="14"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>
                    
                    <!-- Barra de progresso de redirecionamento -->
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="RedirectText"
                                   Text="Redirecionando para o Dashboard em 3..."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <Border Width="200" Height="4" Background="#2A2A2E" CornerRadius="2">
                            <Border x:Name="RedirectProgress" 
                                    Width="0" 
                                    HorizontalAlignment="Left"
                                    CornerRadius="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#34D399" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Toast Notification -->
        <Border x:Name="ToastPanel" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Bottom" 
                Margin="0,0,0,80"
                CornerRadius="12" 
                Padding="20,12" 
                Visibility="Collapsed" 
                Opacity="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#8B31FF" Offset="0"/>
                    <GradientStop Color="#FF4B6B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#8B31FF"/>
            </Border.Effect>
            <TextBlock x:Name="ToastText" 
                       Foreground="White" 
                       FontWeight="SemiBold"
                       FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
