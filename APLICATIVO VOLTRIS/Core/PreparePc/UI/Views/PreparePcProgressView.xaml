<UserControl x:Class="VoltrisOptimizer.Core.PreparePc.UI.Views.PreparePcProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="750">
    
    <UserControl.Resources>
        <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#6C5CE7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" 
                                        Background="{TemplateBinding Foreground}" 
                                        CornerRadius="4"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4A1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#0D0D1A" CornerRadius="16" Padding="32">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="HeaderIcon" Text="⚙️" FontSize="28" VerticalAlignment="Center"/>
                    <TextBlock x:Name="HeaderText" 
                               Text="Preparando PC..." 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="SubHeaderText"
                           Text="Por favor, não desligue o computador durante este processo."
                           Foreground="#A0A0A0"
                           FontSize="13"
                           Margin="0,8,0,0"/>
            </StackPanel>
            
            <!-- Progress Overview -->
            <Border Grid.Row="1" Background="#1A1A2E" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Current step info -->
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                        <TextBlock x:Name="CurrentStepText" 
                                   Text="Step 1/9: Pré-verificações" 
                                   Foreground="White" 
                                   FontWeight="SemiBold"
                                   FontSize="15"/>
                        <TextBlock x:Name="CurrentActionText" 
                                   Text="Verificando privilégios..." 
                                   Foreground="#A0A0A0"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <!-- Progress bar -->
                    <ProgressBar x:Name="OverallProgress" 
                                 Grid.Row="1" 
                                 Grid.ColumnSpan="2"
                                 Style="{StaticResource ProgressBarStyle}"
                                 Value="0"
                                 Maximum="100"
                                 Margin="0,16,0,8"/>
                    
                    <!-- Time info -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBlock Text="⏱️" FontSize="12"/>
                        <TextBlock x:Name="ElapsedTimeText" 
                                   Text="Tempo: 00:00" 
                                   Foreground="#808080"
                                   FontSize="12"
                                   Margin="6,0,16,0"/>
                        <TextBlock Text="⏳" FontSize="12"/>
                        <TextBlock x:Name="RemainingTimeText" 
                                   Text="Restante: ~10 min" 
                                   Foreground="#808080"
                                   FontSize="12"
                                   Margin="6,0,0,0"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="PercentText" 
                               Grid.Row="2" 
                               Grid.Column="1"
                               Text="0%"
                               Foreground="#6C5CE7"
                               FontWeight="Bold"
                               FontSize="18"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>
            
            <!-- Steps status -->
            <Border Grid.Row="2" Background="#1A1A2E" CornerRadius="12" Padding="20" Margin="0,0,0,16" MaxHeight="150">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="StepsStatusPanel">
                        <!-- Steps serão adicionados dinamicamente -->
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- Logs -->
            <Border Grid.Row="3" Background="#0A0A14" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="📋 Logs" Foreground="#808080" FontWeight="SemiBold"/>
                        <Button x:Name="ExportLogsBtn" 
                                Content="Exportar"
                                Background="Transparent"
                                Foreground="#6C5CE7"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="16,0,0,0"
                                Click="ExportLogsBtn_Click"/>
                    </StackPanel>
                    
                    <Border Grid.Row="1" Background="#0D0D1A" CornerRadius="8" Padding="12">
                        <ScrollViewer x:Name="LogsScrollViewer" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LogsTextBlock"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="#A0A0A0"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Actions -->
            <Grid Grid.Row="4" Margin="0,16,0,0">
                <Button x:Name="CancelBtn" 
                        Content="❌ Cancelar"
                        Style="{StaticResource CancelButtonStyle}"
                        HorizontalAlignment="Left"
                        Click="CancelBtn_Click"/>
                
                <StackPanel x:Name="CompletedActions" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Visibility="Collapsed">
                    <Button x:Name="RollbackBtn" 
                            Content="↩️ Reverter Alterações"
                            Background="#4A3A1A"
                            Foreground="#FFC107"
                            BorderThickness="0"
                            Padding="20,10"
                            Margin="0,0,12,0"
                            Cursor="Hand"
                            Click="RollbackBtn_Click"/>
                    <Button x:Name="ViewReportBtn" 
                            Content="📊 Ver Relatório"
                            Background="#1A3A1A"
                            Foreground="#4CAF50"
                            BorderThickness="0"
                            Padding="20,10"
                            Margin="0,0,12,0"
                            Cursor="Hand"
                            Click="ViewReportBtn_Click"/>
                    <Button x:Name="ContinueBtn" 
                            Content="✅ Continuar"
                            Background="#6C5CE7"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="24,10"
                            Cursor="Hand"
                            Click="ContinueBtn_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>

