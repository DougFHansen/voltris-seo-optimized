<UserControl x:Class="VoltrisOptimizer.Core.PreparePc.UI.Views.ProfilerSuccessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">
    
    <UserControl.Resources>
        <!-- Estilo de tag de recurso seguindo paleta global -->
        <Style x:Key="FeatureTagStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DarkHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DarkBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
        </Style>
        <!-- Link dentro do tema -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="text" 
                                   Text="{TemplateBinding Content}" 
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="text" Property="Foreground" Value="{DynamicResource PrimaryLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Border Background="#0A0A0F" ClipToBounds="True">
        <!-- Background decorations - estilo do programa -->
        <Grid>
            <!-- Efeitos de Blur Decorativos -->
            <Viewbox HorizontalAlignment="Left" 
                     VerticalAlignment="Top"
                     Margin="30,20,0,0"
                     Stretch="Uniform"
                     MaxWidth="350" MaxHeight="350"
                     IsHitTestVisible="False">
                <Ellipse Width="350" Height="350" 
                         Fill="{StaticResource AccentBlurBrush}">
                    <Ellipse.Effect>
                        <BlurEffect Radius="120"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Viewbox>
            
            <Viewbox HorizontalAlignment="Right" 
                     VerticalAlignment="Bottom"
                     Margin="0,0,60,40"
                     Stretch="Uniform"
                     MaxWidth="300" MaxHeight="300"
                     IsHitTestVisible="False">
                <Ellipse Width="300" Height="300" 
                         Fill="{StaticResource SecondaryBlurBrush}">
                    <Ellipse.Effect>
                        <BlurEffect Radius="120"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Viewbox>
            
            <Viewbox HorizontalAlignment="Center" 
                     VerticalAlignment="Center"
                     Stretch="Uniform"
                     MaxWidth="200" MaxHeight="200"
                     IsHitTestVisible="False">
                <Ellipse Width="200" Height="200" 
                         Fill="{StaticResource PrimaryBlurBrush}">
                    <Ellipse.Effect>
                        <BlurEffect Radius="100"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Viewbox>
            
            <!-- Overlay para legibilidade -->
            <Border Opacity="0.92" CornerRadius="0" IsHitTestVisible="False">
                <Border.Background>
                    <SolidColorBrush Color="#0A0A0F"/>
                </Border.Background>
            </Border>
            
            <!-- Main content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,30">
                <Grid MaxWidth="800" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Success Icon with Animation -->
                    <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
                        <!-- Outer glow ring -->
                        <Ellipse Width="140" Height="140" StrokeThickness="2">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3000B894" Offset="0"/>
                                    <GradientStop Color="#1000B894" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                        </Ellipse>
                        
                        <!-- Middle ring -->
                        <Ellipse Width="120" Height="120" StrokeThickness="3">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#5000B894" Offset="0"/>
                                    <GradientStop Color="#2000B894" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                        </Ellipse>
                        
                        <!-- Inner circle with check -->
                        <Border Width="100" Height="100" CornerRadius="50" 
                                Background="{StaticResource SuccessGradientBrush}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#00FF88" Opacity="0.6"/>
                            </Border.Effect>
                            <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" 
                                  Fill="White"
                                  Width="48" Height="48" 
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    
                    <!-- Title Section -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,35">
                        <TextBlock Text="Otimizações Aplicadas com Sucesso!" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4B6B" Offset="0"/>
                                    <GradientStop Color="#8B31FF" Offset="0.5"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#8B31FF"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Seu sistema foi configurado de acordo com seu perfil de uso" 
                                   FontSize="15" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                    
                    <!-- Applied Optimizations Card -->
                    <Border Grid.Row="2"
                            Background="#0D0D14"
                            BorderBrush="#1E1E2E"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24"
                            Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#1A1A24" Margin="0,0,12,0">
                                    <Path Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,5V19H5V5H19Z" 
                                          Fill="{StaticResource PrimaryBrush}"
                                          Width="18" Height="18" 
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Resumo das Otimizações" 
                                               FontSize="16" 
                                               FontWeight="SemiBold" 
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Configurações aplicadas ao seu sistema" 
                                               FontSize="12" 
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               Foreground="{StaticResource TextMutedBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Background="#12121A" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel x:Name="AppliedSummary">
                                    <!-- Items serão adicionados dinamicamente -->
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Prepare PC Card - Hero Section -->
                    <Border Grid.Row="3" 
                            CornerRadius="20" 
                            Padding="2"
                            Margin="0,0,0,25">
                        <!-- Gradient border - estilo Voltris -->
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF4B6B" Offset="0"/>
                                <GradientStop Color="#8B31FF" Offset="0.5"/>
                                <GradientStop Color="#31A8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.4" Color="#8B31FF"/>
                        </Border.Effect>
                        
                        <Border Background="#0D0D14" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="18" Padding="28">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel>
                                    <!-- Header with badge -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0" Background="#1A1A24">
                                            <Path Data="M22.7,19L13.6,9.9C14.5,7.1 17.2,5 20.4,5C23.6,5 26.3,7.1 27.2,9.9L22.7,19M20.4,3C16.7,3 13.5,5.1 12,8.3L2,18.3L3.6,19.9L5.1,18.4L7.1,20.4L8.6,18.9L6.6,16.9L8.1,15.4L10.1,17.4L11.6,15.9L9.6,13.9L12,11.5C13.5,8.3 16.7,6.2 20.4,6.2C24.1,6.2 27.3,8.3 28.8,11.5L30.2,10.1L31.7,11.6L30.3,13C31.8,16.2 31.8,20 30.3,23.2L28.9,24.6L27.4,23.1L28.8,21.7C29.9,19.1 29.9,16.1 28.8,13.5L22.7,19.6C22.5,19.8 22.2,19.9 22,19.9C21.8,19.9 21.5,19.8 21.3,19.6L20.4,18.7L19.5,19.6C19.1,20 18.5,20 18.1,19.6C17.7,19.2 17.7,18.6 18.1,18.2L19,17.3L18.1,16.4C17.7,16 17.7,15.4 18.1,15C18.5,14.6 19.1,14.6 19.5,15L20.4,15.9L21.3,15C21.7,14.6 22.3,14.6 22.7,15C23.1,15.4 23.1,16 22.7,16.4L21.8,17.3L22.7,18.2C23.1,18.6 23.1,19.2 22.7,19.6M13.1,22.6L11.6,21.1L13.6,19.1L15.1,20.6L13.1,22.6Z" 
                                                  Fill="{StaticResource VoltrisGradientBrush}"
                                                  Width="22" Height="22" 
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Preparar PC" 
                                                       FontSize="20" 
                                                       FontWeight="Bold" 
                                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <Border Background="{StaticResource VoltrisGradientHorizontalBrush}" 
                                                    CornerRadius="6" 
                                                    Padding="10,4" 
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#8B31FF" Opacity="0.6"/>
                                                </Border.Effect>
                                                <TextBlock Text="RECOMENDADO" 
                                                           Foreground="White" 
                                                           FontSize="10" 
                                                           FontWeight="Bold"
                                                           FontFamily="Segoe UI Variable, Segoe UI"/>
                                            </Border>
                                            </StackPanel>
                                            <TextBlock Text="Verificações avançadas e otimizações do sistema" 
                                                       FontSize="13" 
                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Features grid -->
                                    <WrapPanel Margin="0,16,0,0">
                                        <Border Style="{StaticResource FeatureTagStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" 
                                                      Fill="{StaticResource PrimaryBrush}"
                                                      Width="14" Height="14" 
                                                      Stretch="Uniform"
                                                      Margin="0,0,8,0"/>
                                                <TextBlock Text="SFC Scan" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" FontFamily="Segoe UI Variable, Segoe UI"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <Border Style="{StaticResource FeatureTagStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" 
                                                      Fill="{StaticResource SecondaryBrush}"
                                                      Width="14" Height="14" 
                                                      Stretch="Uniform"
                                                      Margin="0,0,8,0"/>
                                                <TextBlock Text="DISM Repair" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" FontFamily="Segoe UI Variable, Segoe UI"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <Border Style="{StaticResource FeatureTagStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M19.36,2.72L20.78,4.14L15.06,9.85C16.13,11.39 16.28,13.24 15.38,14.44L9.06,8.12C10.26,7.22 12.11,7.37 13.65,8.44L19.36,2.72M5.93,17.57C3.92,15.56 2.69,13.16 2.35,10.92L7.23,8.83L14.67,16.27L12.58,21.15C10.34,20.81 7.94,19.58 5.93,17.57Z" 
                                                      Fill="{StaticResource AccentBrush}"
                                                      Width="14" Height="14" 
                                                      Stretch="Uniform"
                                                      Margin="0,0,8,0"/>
                                                <TextBlock Text="Limpeza Profunda" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" FontFamily="Segoe UI Variable, Segoe UI"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <Border Style="{StaticResource FeatureTagStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M12,21L15.6,16.2C14.6,15.45 13.35,15 12,15C10.65,15 9.4,15.45 8.4,16.2L12,21M12,3C7.95,3 4.21,4.34 1.2,6.6L3,9C5.5,7.12 8.62,6 12,6C15.38,6 18.5,7.12 21,9L22.8,6.6C19.79,4.34 16.05,3 12,3M12,9C9.3,9 6.81,9.89 4.8,11.4L6.6,13.8C8.1,12.67 9.97,12 12,12C14.03,12 15.9,12.67 17.4,13.8L19.2,11.4C17.19,9.89 14.7,9 12,9Z" 
                                                      Fill="{StaticResource PrimaryBrush}"
                                                      Width="14" Height="14" 
                                                      Stretch="Uniform"
                                                      Margin="0,0,8,0"/>
                                                <TextBlock Text="Reset de Rede" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" FontFamily="Segoe UI Variable, Segoe UI"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <Border Style="{StaticResource FeatureTagStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M11,21H10L11,14H7.5C7.16,14 7,13.76 7,13.5C7,13.35 7.04,13.23 7.12,13.13L13,3H14L13,10H16.5C16.82,10 17,10.25 17,10.5C17,10.66 16.95,10.78 16.88,10.88L11,21Z" 
                                                      Fill="{StaticResource AccentBrush}"
                                                      Width="14" Height="14" 
                                                      Stretch="Uniform"
                                                      Margin="0,0,8,0"/>
                                                <TextBlock Text="Power Plan" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" FontFamily="Segoe UI Variable, Segoe UI"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <Border Style="{StaticResource FeatureTagStyle}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M21,6H3A2,2 0 0,0 1,8V16A2,2 0 0,0 3,18H21A2,2 0 0,0 23,16V8A2,2 0 0,0 21,6M11,13H8V16H6V13H3V11H6V8H8V11H11V13M15.5,15A1.5,1.5 0 0,1 14,13.5A1.5,1.5 0 0,1 15.5,12A1.5,1.5 0 0,1 17,13.5A1.5,1.5 0 0,1 15.5,15M19.5,12A1.5,1.5 0 0,1 18,10.5A1.5,1.5 0 0,1 19.5,9A1.5,1.5 0 0,1 21,10.5A1.5,1.5 0 0,1 19.5,12Z" 
                                                      Fill="{StaticResource SecondaryBrush}"
                                                      Width="14" Height="14" 
                                                      Stretch="Uniform"
                                                      Margin="0,0,8,0"/>
                                                <TextBlock Text="Shader Cache" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" FontFamily="Segoe UI Variable, Segoe UI"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                    
                                    <!-- Time estimate -->
                                    <Border Background="#12121A" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,18,0,0" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                                                  Fill="{StaticResource PrimaryBrush}"
                                                  Width="14" Height="14" 
                                                  Stretch="Uniform"
                                                  Margin="0,0,10,0" 
                                                  VerticalAlignment="Center"/>
                                            <TextBlock Text="Tempo estimado: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center"/>
                                            <TextBlock Text="10-30 minutos" Foreground="{StaticResource PrimaryLightBrush}" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI Variable, Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                
                                <!-- CTA Button -->
                                <Button x:Name="PreparePcBtn" 
                                        Grid.Column="1"
                                        Style="{StaticResource NeonButtonStyle}"
                                        Padding="32,18"
                                        VerticalAlignment="Center"
                                        Margin="20,0,0,0"
                                        Click="PreparePcBtn_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Iniciar" FontSize="15" FontWeight="SemiBold" FontFamily="Segoe UI Variable, Segoe UI"/>
                                        <Path Data="M4,12 L20,12 M20,12 L14,6 M20,12 L14,18" 
                                              Stroke="White" 
                                              StrokeThickness="2" 
                                              Width="16" Height="16" 
                                              Stretch="Uniform"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center">
                                            <Path.StrokeStartLineCap>
                                                <PenLineCap>Round</PenLineCap>
                                            </Path.StrokeStartLineCap>
                                            <Path.StrokeEndLineCap>
                                                <PenLineCap>Round</PenLineCap>
                                            </Path.StrokeEndLineCap>
                                        </Path>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Border>
                    
                    <!-- Bottom Actions -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="SkipBtn" 
                                Style="{StaticResource LinkButtonStyle}"
                                Content="Pular e ir para o Dashboard →"
                                HorizontalAlignment="Left"
                                Click="SkipBtn_Click"/>
                        
                        <Button x:Name="ScheduleBtn" 
                                Grid.Column="1"
                                Style="{StaticResource NeonSecondaryButtonStyle}"
                                Padding="20,12"
                                Click="ScheduleBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z" 
                                      Fill="{StaticResource TextSecondaryBrush}"
                                      Width="14" Height="14" 
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"/>
                                <TextBlock Text="Agendar para depois" FontFamily="Segoe UI Variable, Segoe UI"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
