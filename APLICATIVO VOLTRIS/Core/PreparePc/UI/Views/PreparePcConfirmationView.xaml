<UserControl x:Class="VoltrisOptimizer.Core.PreparePc.UI.Views.PreparePcConfirmationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="700">
    
    <UserControl.Resources>
        <Style x:Key="ModeButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="#12121A" 
                                BorderBrush="#1E1E2E" 
                                BorderThickness="1" 
                                CornerRadius="12" 
                                Padding="20,16"
                                Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#252535"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#8B31FF" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#1A1A24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="StepCheckboxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource NeonButtonStyle}"/>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource NeonSecondaryButtonStyle}"/>
    </UserControl.Resources>
    
    <Border Background="#0A0A0F" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="16" Padding="32" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Path Data="M22.7,19L13.6,9.9C14.5,7.1 17.2,5 20.4,5C23.6,5 26.3,7.1 27.2,9.9L22.7,19M20.4,3C16.7,3 13.5,5.1 12,8.3L2,18.3L3.6,19.9L5.1,18.4L7.1,20.4L8.6,18.9L6.6,16.9L8.1,15.4L10.1,17.4L11.6,15.9L9.6,13.9L12,11.5C13.5,8.3 16.7,6.2 20.4,6.2C24.1,6.2 27.3,8.3 28.8,11.5L30.2,10.1L31.7,11.6L30.3,13C31.8,16.2 31.8,20 30.3,23.2L28.9,24.6L27.4,23.1L28.8,21.7C29.9,19.1 29.9,16.1 28.8,13.5L22.7,19.6C22.5,19.8 22.2,19.9 22,19.9C21.8,19.9 21.5,19.8 21.3,19.6L20.4,18.7L19.5,19.6C19.1,20 18.5,20 18.1,19.6C17.7,19.2 17.7,18.6 18.1,18.2L19,17.3L18.1,16.4C17.7,16 17.7,15.4 18.1,15C18.5,14.6 19.1,14.6 19.5,15L20.4,15.9L21.3,15C21.7,14.6 22.3,14.6 22.7,15C23.1,15.4 23.1,16 22.7,16.4L21.8,17.3L22.7,18.2C23.1,18.6 23.1,19.2 22.7,19.6M13.1,22.6L11.6,21.1L13.6,19.1L15.1,20.6L13.1,22.6Z" 
                      Fill="{StaticResource PrimaryBrush}"
                      Width="28" Height="28" 
                      Stretch="Uniform"
                      Margin="0,0,12,0"
                      VerticalAlignment="Center"/>
                    <TextBlock Text="Preparar PC" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="O Voltris pode preparar seu PC com verificações e otimizações seguras."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
            
            <!-- Pre-check warnings -->
            <Border x:Name="WarningsPanel" 
                    Grid.Row="1" 
                    Background="#2A1A1A" 
                    BorderBrush="#FF4466" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="16" 
                    Margin="0,0,0,16"
                    Visibility="Collapsed">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="M12,2L1,21H23M12,6L19.53,19H4.47M11,10V14M11,16V18" 
                              Fill="#FF4466"
                              Width="16" Height="16" 
                              Stretch="Uniform"
                              Margin="0,0,8,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Avisos" Foreground="#FF4466" FontWeight="SemiBold" FontFamily="Segoe UI Variable, Segoe UI"/>
                    </StackPanel>
                    <ItemsControl x:Name="WarningsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#E0A0A0" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            
            <!-- Mode selection -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Escolha do modo -->
                    <TextBlock Text="Escolha o modo de preparação:" 
                               Foreground="#E0E0E0" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,12"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <!-- Dry-Run -->
                        <RadioButton x:Name="DryRunMode" 
                                     GroupName="Mode" 
                                     Style="{StaticResource ModeButtonStyle}"
                                     Margin="0,0,12,0">
                            <StackPanel Width="180">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Path Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                                          Fill="{StaticResource PrimaryBrush}"
                                          Width="14" Height="14" 
                                          Stretch="Uniform"
                                          Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Simulação" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14" FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                                <TextBlock Text="Mostra o que seria feito sem executar nada" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           FontSize="11" 
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        
                        <!-- Recommended -->
                        <RadioButton x:Name="RecommendedMode" 
                                     GroupName="Mode" 
                                     Style="{StaticResource ModeButtonStyle}"
                                     IsChecked="True"
                                     Margin="0,0,12,0">
                            <StackPanel Width="180">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" 
                                          Fill="{StaticResource SuccessBrush}"
                                          Width="14" Height="14" 
                                          Stretch="Uniform"
                                          Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Recomendado" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" FontSize="14" FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                                <TextBlock Text="Executa apenas ações seguras, simula as condicionais" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           FontSize="11" 
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        
                        <!-- Full -->
                        <RadioButton x:Name="FullMode" 
                                     GroupName="Mode" 
                                     Style="{StaticResource ModeButtonStyle}">
                            <StackPanel Width="180">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Path Data="M11,21H10L11,14H7.5C7.16,14 7,13.76 7,13.5C7,13.35 7.04,13.23 7.12,13.13L13,3H14L13,10H16.5C16.82,10 17,10.25 17,10.5C17,10.66 16.95,10.78 16.88,10.88L11,21Z" 
                                          Fill="{StaticResource WarningBrush}"
                                          Width="14" Height="14" 
                                          Stretch="Uniform"
                                          Margin="0,0,6,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Completo" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" FontSize="14" FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                                <TextBlock Text="Executa todas as ações, pergunta para cada condicional" 
                                           Foreground="{StaticResource TextMutedBrush}" 
                                           FontSize="11" 
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                    
                    <!-- Steps que serão executados -->
                    <TextBlock Text="Ações que serão realizadas:" 
                               Foreground="#E0E0E0" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,12"/>
                    
                    <Border Background="#12121A" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel x:Name="StepsList">
                            <!-- Steps serão adicionados dinamicamente -->
                        </StackPanel>
                    </Border>
                    
                    <!-- Info adicional -->
                    <Border Background="#12121A" 
                            BorderBrush="#1E1E2E" 
                            BorderThickness="1" 
                            CornerRadius="12" 
                            Padding="16" 
                            Margin="0,16,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                                      Fill="{StaticResource PrimaryBrush}"
                                      Width="16" Height="16" 
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                                <TextBlock x:Name="EstimatedTimeText" 
                                           Text="Tempo estimado: 10-30 minutos" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           FontSize="13"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" 
                                      Fill="{StaticResource PrimaryBrush}"
                                      Width="16" Height="16" 
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                                <TextBlock x:Name="BackupPathText" 
                                           Text="Backups em: %AppData%\Voltris\Backups" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           FontSize="13"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- System Restore recommendation -->
                    <Border Background="#12121A" 
                            BorderBrush="#1E1E2E" 
                            BorderThickness="1" 
                            CornerRadius="12" 
                            Padding="16" 
                            Margin="0,16,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" 
                                      Fill="{StaticResource WarningBrush}"
                                      Width="16" Height="16" 
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                                <TextBlock Text="Recomendação" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" FontFamily="Segoe UI Variable, Segoe UI"/>
                            </StackPanel>
                            <TextBlock Text="Recomendamos criar um ponto de restauração do sistema antes de prosseguir. Isso permite reverter todas as alterações se necessário."
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,8"/>
                            <Button x:Name="CreateRestorePointBtn" 
                                    Style="{StaticResource NeonSecondaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Click="CreateRestorePointBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" 
                                          Fill="{StaticResource TextSecondaryBrush}"
                                          Width="14" Height="14" 
                                          Stretch="Uniform"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="Criar Ponto de Restauração" FontFamily="Segoe UI Variable, Segoe UI"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Confirmação extra para modo Full -->
            <Border x:Name="FullModeConfirmation" 
                    Grid.Row="3" 
                    Background="#2A1A2A" 
                    BorderBrush="#9C27B0" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="16" 
                    Margin="0,16,0,0"
                    Visibility="Collapsed">
                <StackPanel>
                    <CheckBox x:Name="FullModeConfirmCheck" 
                              Foreground="#E0E0E0"
                              Cursor="Hand">
                        <TextBlock TextWrapping="Wrap" Foreground="#E0E0E0">
                            <Run Text="Entendo que o modo Completo pode modificar configurações do sistema e aceito os riscos."/>
                            <Run Text=" Backups serão criados automaticamente." Foreground="#A0A0A0"/>
                        </TextBlock>
                    </CheckBox>
                </StackPanel>
            </Border>
            
            <!-- Botões de ação -->
            <Grid Grid.Row="4" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="SkipBtn" 
                        Content="Pular por agora" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Left"
                        Click="SkipBtn_Click"/>
                
                <Button x:Name="ScheduleBtn" 
                        Grid.Column="1"
                        Style="{StaticResource NeonSecondaryButtonStyle}"
                        Margin="0,0,12,0"
                        Click="ScheduleBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z" 
                              Fill="{StaticResource TextSecondaryBrush}"
                              Width="14" Height="14" 
                              Stretch="Uniform"
                              Margin="0,0,8,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Agendar" FontFamily="Segoe UI Variable, Segoe UI"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="StartBtn" 
                        Grid.Column="2"
                        Style="{StaticResource NeonButtonStyle}"
                        Click="StartBtn_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" 
                              Fill="White"
                              Width="14" Height="14" 
                              Stretch="Uniform"
                              Margin="0,0,8,0"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Iniciar Preparação" FontFamily="Segoe UI Variable, Segoe UI"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>

