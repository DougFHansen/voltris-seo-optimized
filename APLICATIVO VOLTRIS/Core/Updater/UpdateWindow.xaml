<Window x:Class="VoltrisOptimizer.Core.Updater.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nova Versão Disponível"
        Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True">
    
    <Window.Resources>
        <!-- Estilo do botão principal -->
        <Style x:Key="UpdateButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8B31FF" Offset="0"/>
                        <GradientStop Color="#31A8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="30,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#8B31FF" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#8B31FF" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Estilo do botão secundário -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B8BA0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- Container principal com borda arredondada -->
    <Border CornerRadius="16" Background="#0D0D14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.6"/>
        </Border.Effect>
        
        <Grid>
            <!-- Background decorativo -->
            <Canvas IsHitTestVisible="False" ClipToBounds="True">
                <Ellipse Width="300" Height="300" Canvas.Left="-100" Canvas.Top="-100">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#208B31FF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="200" Height="200" Canvas.Right="-50" Canvas.Bottom="-50">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#2031A8FF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>
            
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header com ícone -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
                    <TextBlock Text="🚀" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Nova Versão Disponível!" 
                               FontSize="24" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="VersionText"
                               Text="v3.0.0 → v3.1.0"
                               FontSize="14" Foreground="#8B8BA0"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- Changelog -->
                <Border Grid.Row="2" Background="#12121A" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="📝 O que há de novo:" 
                                   FontSize="14" FontWeight="SemiBold" 
                                   Foreground="White" Margin="0,0,0,12"/>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="120">
                            <TextBlock x:Name="ChangelogText"
                                       Text="• Correções importantes&#x0a;• Melhorias de performance&#x0a;• Novos recursos"
                                       FontSize="13" Foreground="#B4B4C0"
                                       TextWrapping="Wrap" LineHeight="22"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
                
                <!-- Barra de progresso (inicialmente oculta) -->
                <StackPanel x:Name="ProgressPanel" Grid.Row="3" Visibility="Collapsed" Margin="0,0,0,20">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ProgressStatusText" 
                                   Text="Baixando atualização..."
                                   FontSize="12" Foreground="#B4B4C0"/>
                        <TextBlock x:Name="ProgressPercentText" Grid.Column="1"
                                   Text="0%"
                                   FontSize="12" Foreground="#8B31FF" FontWeight="SemiBold"/>
                    </Grid>
                    
                    <Border Background="#1A1A2E" CornerRadius="4" Height="8">
                        <Border x:Name="ProgressBar" 
                                HorizontalAlignment="Left" 
                                Width="0"
                                CornerRadius="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#8B31FF" Offset="0"/>
                                    <GradientStop Color="#31A8FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#8B31FF" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                    </Border>
                </StackPanel>
                
                <!-- Botões -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="LaterButton"
                            Content="Depois"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="LaterButton_Click"
                            Margin="0,0,20,0"/>
                    
                    <Button x:Name="UpdateButton"
                            Content="⬇️ Atualizar Agora"
                            Style="{StaticResource UpdateButtonStyle}"
                            Click="UpdateButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
