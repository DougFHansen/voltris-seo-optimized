<Application x:Class="VoltrisOptimizer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VoltrisOptimizer.UI.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Aero2;component/themes/Aero2.NormalColor.xaml"/>
                <ResourceDictionary Source="/UI/Themes/Colors.xaml"/>
                <ResourceDictionary Source="/UI/Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="/UI/Themes/Styles.xaml"/>
                <ResourceDictionary Source="/UI/Themes/SidebarPremium.xaml"/>
                <ResourceDictionary Source="/UI/Themes/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <vm:ViewModelLocator x:Key="Locator" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
